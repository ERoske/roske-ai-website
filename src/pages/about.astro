---
import BaseLayout from '../layouts/BaseLayout.astro';

/**
 * About: the magazine-profile page. Permanent structure, weekly re-skin.
 * Every color and font below comes from the global theme variables
 * (--color-accent, --font-heading, etc.) so the page re-themes each
 * Saturday without a rewrite. Dark/light rules use the
 * :global([data-theme="..."]) pattern from SpeakerCTA.astro.
 */

const timeline = [
  { year: "2026", title: "Caribbean AI Summit", desc: "Co-chairing the largest AI conference Puerto Rico has ever seen. Puerto Rico Convention Center, October 9-10." },
  { year: "2025", title: "ODTUG Lifetime Achievement", desc: "Received the award at Kscope25. Fewer than 5 people have ever received it. Announced as my final Kscope." },
  { year: "2023", title: "Launched AI Ventures", desc: "Left Argano. Founded Roske.AI. Invested in Caprus. Started coding MCP servers." },
  { year: "2021", title: "MS Data Science, SMU", desc: "Perfect 4.0 GPA. Outstanding Graduate. Decided to get serious about the 'science' in 'Data Science.'" },
  { year: "2020", title: "Merged interRel into Argano", desc: "After 25 years, merged interRel to help form Argano, now a billion-dollar global consulting firm. Served as CEO of ArganoInterRel, then Chief Performance Officer." },
  { year: "2018", title: "Essbase Speaker of the Year", desc: "Kscope18. Also: first perfect score ever on the Essbase Certification exam." },
  { year: "2016", title: "BA from Shimer College", desc: "Finally finished the degree I started at 15. (College Calculus and Computer Science at 15. Full-time at Simon's Rock of Bard College at 16. Took a 20-year detour through entrepreneurship before finishing.)" },
  { year: "2008", title: "First 'Look Smarter' Book", desc: "Started co-authoring the 'Look Smarter Than You Are' series. 15 books total. All before generative AI existed. (Brag.)" },
  { year: "1997", title: "Founded interRel Consulting", desc: "Age 22. Built it into the longest-standing Oracle Platinum EPM Partner worldwide. Five-time Oracle Partner of the Year." },
  { year: "1995", title: "Started in Analytics", desc: "Senior Analytics Consultant at Technium/Pinnacle. Where the Essbase obsession began." },
];

const roles = [
  { role: "CEO", company: "Dawnward", period: "2023 - Present", desc: "Edward's investment firm. Portfolio across AI, technology, and strategic ventures." },
  { role: "Investor & Contributor", company: "Caprus", period: "2023 - Present", desc: "AI Software & Services firm helping finance teams leverage artificial intelligence for planning, analytics, and operations." },
  { role: "Co-founder & Stakeholder", company: "Argano", period: "2020 - Present", desc: "Billion-dollar global consulting firm. Formed through the merger of interRel Consulting (which Edward founded in 1997 and led for 25 years) with several other firms." },
  { role: "Co-chair", company: "Caribbean AI Summit", period: "2025 - Present", desc: "Co-chairing the Caribbean AI Summit (October 9-10, 2026, Puerto Rico Convention Center), the largest AI conference Puerto Rico has ever seen." },
  { role: "President", company: "Puerto Rico AI Community", period: "2024 - Present", desc: "Leading the island's AI community. 850+ attendees across bimonthly events." },
];

const education = [
  { degree: "Master of Science in Data Science", school: "SMU", period: "2019 - 2021", desc: "Perfect 4.0 GPA. Outstanding Graduate Award. Focus on machine learning, statistical modeling, and applied data science." },
  { degree: "Bachelor of Arts", school: "Shimer College", period: "2016", desc: "Great Books curriculum. Started college part-time at 15 (Calculus, Computer Science). Full-time at Simon's Rock of Bard College at 16. Finished after a 20-year detour through entrepreneurship." },
];

const expertise = [
  { area: "AI & Machine Learning", skills: "MCP Servers, AI Agents, LLMs, NLP, Computer Vision, Deep Learning, Prompt Engineering" },
  { area: "Enterprise Finance", skills: "Oracle EPM, Essbase, Planning, HFM, Financial Consolidation, Budgeting & Forecasting" },
  { area: "Data Science", skills: "Python, R, SQL, Statistical Modeling, Machine Learning, Data Visualization, ETL" },
  { area: "Leadership", skills: "Company Building, M&A, Strategic Planning, Public Speaking, Team Building, Board Governance" },
];

const awards = [
  { award: "ODTUG Lifetime Achievement Award", detail: "Fewer than 5 recipients ever", year: "2025" },
  { award: "Essbase Speaker of the Year", detail: "Kscope18, voted by attendees", year: "2018" },
  { award: "Oracle ACE Director", detail: "Held for 15+ years. Oracle's highest community recognition", year: "2008 - Present" },
  { award: "Five-Time Oracle Partner of the Year", detail: "Through interRel Consulting", year: "Multiple" },
  { award: "First Perfect Essbase Certification Score", detail: "First person to score perfectly on the exam", year: "Historic" },
  { award: "Kscope Conference Chair", detail: "ODTUG Board Member", year: "2011 - 2012" },
  { award: "Two US Patents", detail: "#5836617, #5848810, custom postage stamp technology", year: "1998" },
];
---

<BaseLayout title="About | Edward Roske" description="CEO, Speaker, Data Scientist, Dungeon Master. 25 years building companies, 80+ countries explored, 15 books written.">

  <!-- Person JSON-LD for author entity recognition -->
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Edward Roske",
    "url": "https://roske.ai/about/",
    "image": "https://roske.ai/images/Edward_Roske_Headshot.png",
    "jobTitle": "CEO",
    "description": "CEO, Speaker, Data Scientist, Dungeon Master. Expert in AI, Oracle EPM, and enterprise finance. Author of 15 books. Host of Asking Good Questions podcast.",
    "sameAs": [
      "https://www.linkedin.com/in/interrel/",
      "https://x.com/eroske",
      "https://www.youtube.com/@Roske-AI",
      "https://github.com/eroske",
      "https://www.amazon.com/stores/Edward-Roske/author/B00J237CUW",
      "https://podcasts.apple.com/podcast/id1783616142",
      "https://open.spotify.com/show/2MJqqgiNbQGysS6i0MAihh"
    ],
    "worksFor": [
      { "@type": "Organization", "name": "Dawnward", "url": "https://roske.ai" },
      { "@type": "Organization", "name": "Caprus", "url": "https://caprus.ai" }
    ],
    "alumniOf": [
      { "@type": "CollegeOrUniversity", "name": "Southern Methodist University", "department": "Data Science" },
      { "@type": "CollegeOrUniversity", "name": "Shimer College" },
      { "@type": "CollegeOrUniversity", "name": "Simon's Rock of Bard College" }
    ],
    "award": [
      "ODTUG Lifetime Achievement Award (2025)",
      "Essbase Speaker of the Year (2018)",
      "Oracle ACE Director (15+ years)",
      "Five-Time Oracle Partner of the Year",
      "First Perfect Score on Essbase Certification Exam",
      "SMU Outstanding Graduate Award"
    ],
    "knowsAbout": [
      "Artificial Intelligence", "Machine Learning", "MCP Servers", "Data Science",
      "Oracle EPM", "Oracle Essbase", "Financial Planning", "Enterprise Performance Management",
      "Public Speaking", "AI Agents", "Large Language Models"
    ],
    "knowsLanguage": ["English", "Spanish"],
    "nationality": "American",
    "homeLocation": {
      "@type": "Place",
      "name": "San Juan, Puerto Rico"
    },
    "hasCredential": [
      {
        "@type": "EducationalOccupationalCredential",
        "name": "Master of Science in Data Science",
        "credentialCategory": "degree",
        "educationalLevel": "Master's"
      }
    ]
  })} />

  <div class="ab">

    <!-- ============ OPENING SPREAD ============ -->
    <header class="ab-hero ab-b">
      <div class="ab-wrap">
        <p class="ab-kicker ab-rise">About</p>
        <h1 class="ab-h1 ab-ink ab-rise ab-rise-2">
          CEO. Speaker.<br />
          Data&nbsp;Scientist.<br />
          <em>Dungeon&nbsp;Master.</em>
        </h1>
        <div class="ab-hero-row">
          <div class="ab-hero-copy ab-rise ab-rise-3">
            <p class="ab-lede ab-muted">
              I started college at 15, founded my first company at 22, and spent the next 30 years building things and talking about them in 50+ countries across all 7 continents. Wrote 15 books. Convinced Oracle to send a shy introvert around the world for 15 years. Now I run AI companies from San Juan, Puerto Rico.
            </p>
            <p class="ab-meta ab-muted ab-b">San Juan, Puerto Rico &nbsp;|&nbsp; 80+ countries &nbsp;|&nbsp; 15 books &nbsp;|&nbsp; 1 fedora</p>
          </div>
          <figure class="ab-portrait ab-rise ab-rise-4">
            <img src="/images/hero-about.png"
              alt="Edward Roske at an impossibly cluttered desk with books, a D20 dice, globe, laptop, podcast mic, and a Dallas Cowboys pennant"
              class="ab-b"
              width="2752" height="1536"
              loading="eager"
              decoding="async" />
            <figcaption class="ab-muted">Every item on this desk is load-bearing.</figcaption>
          </figure>
        </div>
      </div>
    </header>

    <!-- ============ 01 / THE SHORT VERSION ============ -->
    <section class="ab-section">
      <div class="ab-wrap">
        <header class="ab-sechead animate-on-scroll">
          <span class="ab-num" aria-hidden="true">01</span>
          <div>
            <h2 class="ab-h2 ab-ink">The Short Version</h2>
            <p class="ab-sub ab-muted">For people who read executive summaries first.</p>
          </div>
        </header>
        <div class="ab-offset">
          <div class="ab-prose ab-muted animate-on-scroll">
            <p>
              I'm Edward Roske. I run <strong>Dawnward</strong> (my investment firm), invest in and contribute to <strong>Caprus</strong> (AI for finance teams), and still hold a stake in <strong>Argano</strong>, the billion-dollar consulting firm I helped create when I merged my 25-year-old company, interRel, in 2020.
            </p>
            <p>
              So what am I actually building? <strong>MCP servers</strong> that let AI models talk directly to enterprise financial systems (so your CFO can ask questions in English instead of writing calc scripts). I'm also co-chairing the <strong>Caribbean AI Summit</strong>, the largest AI conference Puerto Rico has ever seen. October 9-10, 2026. Puerto Rico Convention Center. You should come.
            </p>
            <p>
              Master of Data Science from SMU (4.0 GPA, Outstanding Graduate... yes, I mention this a lot). BA from <strong>Shimer College</strong>, a Great Books school taught entirely by Socratic Method, which is where "Asking Good Questions" comes from as a philosophy. Started at 15. Full-time at Simon's Rock of Bard College at 16. Took a 20-year detour through entrepreneurship before finishing.
            </p>
            <p>
              First person to score perfectly on the Essbase Certification exam. Oracle ACE Director for 15+ years. Fifteen books. The <strong>"Asking Good Questions"</strong> podcast. In 2025, I received ODTUG's Lifetime Achievement Award. Fewer than 5 people have ever been given it.
            </p>
            <p>
              Also, I'm a Dungeon Master. I recently ran Keith Baker (the creator of the Eberron campaign setting) through a homebrew adventure. He said I was the best-prepared DM he'd ever seen in Eberron. (I peaked.)
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 02 / CAREER TIMELINE ============ -->
    <section class="ab-section ab-alt ab-b">
      <div class="ab-wrap">
        <header class="ab-sechead animate-on-scroll">
          <span class="ab-num" aria-hidden="true">02</span>
          <div>
            <h2 class="ab-h2 ab-ink">Career Timeline</h2>
            <p class="ab-sub ab-muted">Thirty years of building things, condensed.</p>
          </div>
        </header>
        <div class="ab-offset">
          <div class="ab-timeline">
            {timeline.map((item) => (
              <div class="ab-tlrow ab-b animate-on-scroll">
                <span class="ab-tlyear">{item.year}</span>
                <div>
                  <h3 class="ab-ink">{item.title}</h3>
                  <p class="ab-muted">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 03 / THE RESUME ============ -->
    <section id="resume" class="ab-section">
      <div class="ab-wrap">
        <header class="ab-sechead animate-on-scroll">
          <span class="ab-num" aria-hidden="true">03</span>
          <div>
            <h2 class="ab-h2 ab-ink">The Resume</h2>
            <p class="ab-sub ab-muted">For the people who need the details.</p>
          </div>
        </header>
        <div class="ab-offset">
          <div class="ab-resume ab-b">

            <div class="animate-on-scroll">
              <details class="ab-details ab-b" open>
                <summary class="ab-summary ab-ink">Current Roles</summary>
                <div class="ab-details-body">
                  {roles.map((item) => (
                    <div class="ab-item ab-b">
                      <div class="ab-item-head">
                        <span class="ab-item-role ab-ink">{item.role}</span>
                        <span class="ab-item-co">{item.company}</span>
                        <span class="ab-item-period ab-muted">{item.period}</span>
                      </div>
                      <p class="ab-item-desc ab-muted">{item.desc}</p>
                    </div>
                  ))}
                </div>
              </details>
            </div>

            <div class="animate-on-scroll">
              <details class="ab-details ab-b">
                <summary class="ab-summary ab-ink">Education</summary>
                <div class="ab-details-body">
                  {education.map((item) => (
                    <div class="ab-item ab-b">
                      <div class="ab-item-head">
                        <span class="ab-item-role ab-ink">{item.degree}</span>
                        <span class="ab-item-co">{item.school}</span>
                        <span class="ab-item-period ab-muted">{item.period}</span>
                      </div>
                      <p class="ab-item-desc ab-muted">{item.desc}</p>
                    </div>
                  ))}
                </div>
              </details>
            </div>

            <div class="animate-on-scroll">
              <details class="ab-details ab-b">
                <summary class="ab-summary ab-ink">Expertise</summary>
                <div class="ab-details-body">
                  <div class="ab-skills">
                    {expertise.map((item) => (
                      <div class="ab-skill">
                        <h4>{item.area}</h4>
                        <p class="ab-muted">{item.skills}</p>
                      </div>
                    ))}
                  </div>
                </div>
              </details>
            </div>

            <div class="animate-on-scroll">
              <details class="ab-details ab-b">
                <summary class="ab-summary ab-ink">Awards &amp; Recognition</summary>
                <div class="ab-details-body">
                  {awards.map((item) => (
                    <div class="ab-award ab-b">
                      <span class="ab-award-year">{item.year}</span>
                      <div>
                        <span class="ab-award-name ab-ink">{item.award}</span>
                        <p class="ab-award-detail ab-muted">{item.detail}</p>
                      </div>
                    </div>
                  ))}
                </div>
              </details>
            </div>

          </div>
        </div>
      </div>
    </section>

    <!-- ============ 04 / BEYOND THE RESUME ============ -->
    <section class="ab-section ab-alt ab-b">
      <div class="ab-wrap">
        <header class="ab-sechead animate-on-scroll">
          <span class="ab-num" aria-hidden="true">04</span>
          <div>
            <h2 class="ab-h2 ab-ink">Beyond the Resume</h2>
            <p class="ab-sub ab-muted">The parts that don't fit on LinkedIn.</p>
          </div>
        </header>
        <div class="ab-facets">

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">World Traveler</h3>
                <span class="ab-facet-num" aria-hidden="true">01</span>
              </div>
              <p class="ab-muted">80+ countries across all 7 continents (yes, including Antarctica). Hiked through Son Doong, the largest cave on Earth, in 2025. Trekked to <a href="https://adventureconsultants.com/world-renowned/news-and-media/current-dispatches/luxury-evererest-base-camp-trek-1-2026" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">Everest Base Camp in April 2026</a> (day-by-day dispatches and photos at that link). Vegetarian food options at altitude: questionable.</p>
            </div>
          </div>

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">Dungeon Master</h3>
                <span class="ab-facet-num" aria-hidden="true">02</span>
              </div>
              <p class="ab-muted">5th Edition. Eberron setting. I once ran Keith Baker (Eberron's creator) through a vertical chase through Sharn. My ruling: I'll allow it. He loved falling. I loved being validated.</p>
            </div>
          </div>

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">Film Producer</h3>
                <span class="ab-facet-num" aria-hidden="true">03</span>
              </div>
              <p class="ab-muted">IMDB credit as Producer. Credits include BattleBots and How to Plan an Orgy in a Small Town. (One of these is a better conversation starter than the other.)</p>
            </div>
          </div>

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">Patent Holder</h3>
                <span class="ab-facet-num" aria-hidden="true">04</span>
              </div>
              <p class="ab-muted">Two US Patents for custom postage stamps (#5836617, #5848810). Before email killed the postal service. (You're welcome, stamp collectors.)</p>
            </div>
          </div>

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">Vegetarian</h3>
                <span class="ab-facet-num" aria-hidden="true">05</span>
              </div>
              <p class="ab-muted">For decades. Dawn (my wife) eats everything, which makes restaurant selection easier than you'd think. She's an oil painter and watercolor artist. We live in San Juan. My sons, Mycroft and Eliot, are in Miami.</p>
            </div>
          </div>

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">Escape Room Enthusiasts</h3>
                <span class="ab-facet-num" aria-hidden="true">06</span>
              </div>
              <p class="ab-muted">Dawn and I have played 300+ escape rooms each. We're annual nominators and voters for the TERPECA awards. (Yes, there are awards for escape rooms. Yes, we take it seriously.)</p>
            </div>
          </div>

          <div class="animate-on-scroll">
            <div class="ab-facet ab-b">
              <div class="ab-facet-head">
                <h3 class="ab-ink">Competitive by Nature</h3>
                <span class="ab-facet-num" aria-hidden="true">07</span>
              </div>
              <p class="ab-muted">Biggest Clifton StrengthsFinder result: Competition. I track phone unlocks (30+ daily), email volume (200+), and my Duolingo streak (1,000+ days). Introvert who built a career on public speaking. (The universe has a sense of humor.)</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ============ CLOSING / GET IN TOUCH ============ -->
    <section class="ab-close">
      <div class="ab-wrap">
        <div class="ab-close-grid animate-on-scroll">
          <div>
            <p class="ab-kicker">Next step</p>
            <h2 class="ab-h2 ab-ink">Get in Touch</h2>
            <p class="ab-close-copy ab-muted">
              Speaking engagements, consulting, partnerships, or advisory roles.
            </p>
          </div>
          <div class="ab-actions">
            <a href="/speaking/" class="ab-btn ab-btn-primary">Book Edward to speak</a>
            <a href="/contact/" class="ab-btn ab-btn-ghost ab-b">Get in Touch</a>
            <a href="https://www.linkedin.com/in/interrel/" target="_blank" rel="noopener noreferrer" class="ab-btn ab-btn-ghost ab-b">
              LinkedIn
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

  </div>

</BaseLayout>

<style>
  /* ==========================================================
     ABOUT: editorial profile system.
     Theme-variable driven: re-skins with the weekly theme.
     ========================================================== */

  .ab-wrap { max-width: 1140px; margin: 0 auto; padding: 0 1.5rem; }

  /* ---------- mode-scoped utility classes ---------- */
  :global([data-theme="dark"]) .ab-ink { color: var(--color-text); }
  :global([data-theme="light"]) .ab-ink { color: var(--color-primary); }
  :global([data-theme="dark"]) .ab-muted { color: var(--color-text-muted); }
  :global([data-theme="light"]) .ab-muted { color: var(--color-text-dark-muted); }
  :global([data-theme="dark"]) .ab-b { border-color: var(--color-border); }
  :global([data-theme="light"]) .ab-b { border-color: var(--color-border-light); }
  :global([data-theme="dark"]) .ab-alt { background: var(--color-surface); }
  :global([data-theme="light"]) .ab-alt { background: var(--color-surface-light); }

  /* ---------- type ---------- */
  .ab-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--color-accent); margin: 0 0 1.4rem;
  }
  .ab-h1 {
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: clamp(2.7rem, 6.5vw, 5rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    text-wrap: balance;
    margin: 0;
  }
  .ab-h1 em { font-style: italic; color: var(--color-accent); }
  .ab-h2 {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: clamp(1.9rem, 3.6vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.01em;
    text-wrap: balance;
    margin: 0;
  }
  .ab-sub { margin: 0.7rem 0 0; font-size: 1.02rem; line-height: 1.6; max-width: 55ch; }

  /* ---------- opening spread ---------- */
  .ab-hero { padding: 4.5rem 0 4.75rem; border-bottom: 1px solid; }
  .ab-hero-row {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.25fr);
    gap: 2.5rem 4.5rem;
    align-items: start;
    margin-top: 3rem;
  }
  .ab-lede {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.7;
    margin: 0;
  }
  .ab-meta {
    font-family: var(--font-mono);
    font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
    margin: 2rem 0 0; padding-top: 1.2rem;
    border-top: 1px solid;
  }
  .ab-portrait { margin: 0; position: relative; }
  .ab-portrait img {
    display: block; width: 100%; height: auto;
    border: 1px solid;
  }
  /* Offset hairline frame: designed, not decorated */
  .ab-portrait::before {
    content: ''; position: absolute; z-index: -1;
    inset: 0.9rem -0.9rem -0.9rem 0.9rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
  }
  .ab-portrait figcaption {
    font-family: var(--font-mono);
    font-size: 0.7rem; letter-spacing: 0.06em;
    margin-top: 0.8rem;
  }
  @media (max-width: 860px) {
    .ab-hero { padding-top: 3.25rem; }
    .ab-hero-row { grid-template-columns: 1fr; }
    .ab-portrait { max-width: 34rem; }
  }

  /* Entrance (hero only, CSS-driven, reduced-motion safe) */
  .ab-rise { opacity: 0; animation: abRise 0.7s ease-out forwards; }
  .ab-rise-2 { animation-delay: 0.1s; }
  .ab-rise-3 { animation-delay: 0.2s; }
  .ab-rise-4 { animation-delay: 0.3s; }
  @keyframes abRise {
    from { opacity: 0; transform: translateY(22px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ab-rise { opacity: 1; animation: none; }
  }

  /* ---------- section chassis ---------- */
  .ab-section { padding: 5.25rem 0 5.75rem; }
  .ab-alt { border-top: 1px solid; border-bottom: 1px solid; }
  .ab-sechead {
    position: relative;
    display: grid;
    grid-template-columns: 5.5rem minmax(0, 1fr);
    column-gap: 2.5rem;
    padding-top: 2.4rem;
