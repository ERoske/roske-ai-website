---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import Card from '../../components/Card.astro';

const benefits = [
  {
    title: "A real picture of what AI does today",
    body: "We look at AI that companies have actually deployed and measured, not the demo that wowed everyone at the conference. The version with an ROI attached (which is rarer than the demos would have you believe).",
  },
  {
    title: "The blind spots you can't see from inside",
    body: "Every industry has someone quietly building the thing that will make the incumbents nervous. We find yours before they announce it.",
  },
  {
    title: "Permission to think in multiples",
    body: "Incremental thinking gets incremental results. We spend real time on the 10x version of your business, then sort out which parts are actually doable by Tuesday.",
  },
  {
    title: "A leadership team pointed the same direction",
    body: "Most AI plans die because the leadership team never actually agreed on one direction. We fix that in the room, and you leave aligned (which, if you've ever run a leadership offsite, you know is the whole ballgame).",
  },
];

const tiers = [
  {
    format: "Half Day",
    name: "Imagine",
    builds: null,
    blurb: "The on-ramp: we open minds and set the table.",
    items: [
      "Welcome to the Future",
      "What's Really Possible Today",
      "What Is the Competition Doing?",
      "Our Path Forward",
    ],
  },
  {
    format: "Full Day",
    name: "Brainstorm",
    builds: "Imagine",
    blurb: "We stop watching AI happen to other companies and start building your ideas.",
    items: [
      "Surpass the Competition",
      "Disruption War Games",
      "Reimagine Workflows",
      "Define. Refine. Align.",
    ],
  },
  {
    format: "Two Days",
    name: "Plan",
    builds: "Brainstorm",
    blurb: "We turn the ideas into a roadmap with names and dates on it.",
    items: [
      "Why Do We Need to Change?",
      "How Will We Get There?",
      "Who Will Lead What?",
      "What Will We Prioritize?",
    ],
  },
];
---

<BaseLayout
  title="AI: Art of the Possible | Edward Roske"
  description="A one-to-two-day executive workshop with Edward Roske. See what AI actually does today, find your competitive blind spots, and leave with a plan your leadership team agrees on."
>

  <!-- Service JSON-LD -->
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Executive AI Strategy Workshop",
    "name": "AI: Art of the Possible",
    "description": "A one-to-two-day executive workshop led by Edward Roske. See what AI actually does today, find competitive blind spots, reimagine workflows, and leave with an aligned plan.",
    "provider": {
      "@type": "Person",
      "name": "Edward Roske",
      "url": "https://roske.ai/about/"
    },
    "areaServed": "Worldwide",
    "audience": {
      "@type": "Audience",
      "audienceType": "Executives and leadership teams"
    }
  })} />

  <!-- Hero -->
  <section class="relative py-20 md:py-28 px-6 overflow-hidden">
    <div class="absolute inset-0 dark:block hidden bg-gradient-to-b from-[var(--color-bg)] to-[var(--color-surface)]"></div>
    <div class="absolute inset-0 dark:hidden block bg-gradient-to-b from-[var(--color-bg-light)] to-gray-50"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 max-w-2xl text-center lg:text-left">
          <p class="text-sm font-[var(--font-mono)] tracking-widest uppercase mb-4 text-[var(--color-accent)]"
            style="animation: fadeInUp 0.6s ease-out forwards;">
            Workshop
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6 dark:text-white text-[var(--color-primary)]"
            style="animation: fadeInUp 0.6s ease-out 0.1s forwards; opacity: 0; font-family: var(--font-heading);">
            AI: Art of the Possible
          </h1>
          <p class="text-lg md:text-xl leading-relaxed dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-8"
            style="animation: fadeInUp 0.6s ease-out 0.2s forwards; opacity: 0;">
            Everyone agrees AI is a big deal. Far fewer have sat their leadership team in one room to decide what to actually do about it. This workshop is that room. Over a day or two, we look at what AI does in real companies today (the deployed-and-measured version, not the keynote fantasy), find where your competition is about to pull ahead, and walk out with a plan your leaders actually agree on.
          </p>
          <div class="flex flex-wrap gap-4 justify-center lg:justify-start"
            style="animation: fadeInUp 0.6s ease-out 0.3s forwards; opacity: 0;">
            <a href="/contact/"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/20">
              Bring this to your team
            </a>
            <a href="/question/" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-all duration-200 hover:-translate-y-0.5
                dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:border dark:border-white/10
                bg-black/5 text-[var(--color-primary)] hover:bg-black/10 border border-black/10">
              Book 13 Minutes
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        </div>
        <div class="flex-shrink-0" style="animation: fadeInUp 0.8s ease-out 0.3s forwards; opacity: 0;">
          <div class="relative">
            <div class="absolute -inset-4 rounded-2xl bg-[var(--color-accent)]/10 blur-2xl"></div>
            <img src="/images/hero-art-of-the-possible.png"
              alt="Edward Roske leading an AI: Art of the Possible workshop, wearing his signature blue fedora, gesturing at a whiteboard of AI ideas while executives watch"
              class="relative rounded-2xl w-full max-w-md lg:max-w-lg shadow-2xl ring-1 ring-white/10"
              loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hamel quote -->
  <Section dark>
    <div class="animate-on-scroll max-w-3xl mx-auto text-center">
      <blockquote class="text-2xl md:text-3xl font-bold leading-snug dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
        "Strategy is about inventing the future, not extrapolating the past."
      </blockquote>
      <p class="mt-4 text-sm font-[var(--font-mono)] uppercase tracking-widest text-[var(--color-accent)]">Gary Hamel</p>
    </div>
  </Section>

  <!-- Why this matters -->
  <Section title="What you'll walk out with" subtitle="A workshop to open your team's mind and prepare your company for an AI future that's already showing up.">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {benefits.map(b => (
        <div class="animate-on-scroll">
          <Card title={b.title}>
            <p>{b.body}</p>
          </Card>
        </div>
      ))}
    </div>
  </Section>

  <!-- Agenda -->
  <Section title="Three Ways to Run It" subtitle="Half a day is enough to get the conversation started. Give it two days and you walk out with a roadmap. We scale it to how far your team is ready to go." dark>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
      {tiers.map(tier => (
        <div class="animate-on-scroll h-full">
          <div class="h-full flex flex-col rounded-xl p-6 transition-all duration-300
            dark:bg-white/[0.03] dark:border dark:border-white/[0.06] dark:hover:border-[var(--color-accent)]/30
            bg-white border border-black/[0.06] hover:border-[var(--color-accent)]/30 hover:shadow-lg backdrop-blur-sm">
            <p class="text-xs font-[var(--font-mono)] uppercase tracking-widest text-[var(--color-accent)] mb-2">{tier.format}</p>
            <h3 class="text-2xl font-bold mb-1 dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">{tier.name}</h3>
            {tier.builds && (
              <p class="text-xs dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-3">
                Everything in <span class="font-semibold text-[var(--color-accent)]">{tier.builds}</span>, plus:
              </p>
            )}
            <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] text-sm leading-relaxed mb-5">{tier.blurb}</p>
            <ul class="space-y-3 mt-auto">
              {tier.items.map(item => (
                <li class="flex items-start gap-3 dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] text-sm">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="dark:text-white/90 text-[var(--color-primary)]/90">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
    <p class="animate-on-scroll mt-8 text-sm font-[var(--font-mono)] dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">
      Led by Edward Roske.
    </p>
  </Section>

  <!-- Led by Edward -->
  <Section>
    <div class="animate-on-scroll max-w-3xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-bold mb-6 dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">Who runs it</h2>
      <div class="space-y-5 dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] text-lg leading-relaxed">
        <p>
          I've spent 25+ years founding and running technology companies, written 15 books on enterprise software, and spoken in 50+ countries across all 7 continents. These days I build AI tools for enterprise finance, host the <strong class="dark:text-white text-[var(--color-primary)]">Asking Good Questions</strong> podcast, and run the largest AI community in Puerto Rico.
        </p>
        <p>
          I've advised Fortune 500 executives and three-person startups, sometimes in the same week. The workshop pulls from all of it. The real work is getting your leaders to ask better questions about your own business (which, conveniently, is the one thing I've spent a career practicing).
        </p>
      </div>
      <a href="/about/" class="inline-flex items-center gap-2 mt-6 text-[var(--color-accent)] hover:underline font-medium">
        More about Edward
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </Section>

  <!-- CTA -->
  <Section dark>
    <div class="animate-on-scroll text-center max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
        Ready when your team is
      </h2>
      <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-8 text-lg">
        If your leadership team is ready to stop reading about AI and start deciding what to do with it, let's talk. Tell me about your company and what you're trying to figure out, and we'll design the version that fits.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/contact/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/20">
          Start the conversation
        </a>
        <a href="/work/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-all duration-200 hover:-translate-y-0.5
            dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:border dark:border-white/10
            bg-black/5 text-[var(--color-primary)] hover:bg-black/10 border border-black/10">
          See more of Edward's work
        </a>
      </div>
    </div>
  </Section>

</BaseLayout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
