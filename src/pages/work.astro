---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Card from '../components/Card.astro';
---

<BaseLayout title="Work | Edward Roske" description="Speaking, companies, and the things I'm building. 50+ countries, 7 continents, 300+ presentations.">

  <!-- Hero -->
  <section class="relative py-20 md:py-28 px-6 overflow-hidden">
    <div class="absolute inset-0 dark:block hidden bg-gradient-to-b from-[var(--color-bg)] to-[var(--color-surface)]"></div>
    <div class="absolute inset-0 dark:hidden block bg-gradient-to-b from-[var(--color-bg-light)] to-gray-50"></div>
    <div class="relative max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="flex-1 max-w-2xl text-center lg:text-left">
          <p class="text-sm font-[var(--font-mono)] tracking-widest uppercase mb-4 text-[var(--color-accent)]"
            style="animation: fadeInUp 0.6s ease-out forwards;">
            Work
          </p>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tight leading-tight mb-6 dark:text-white text-[var(--color-primary)]"
            style="animation: fadeInUp 0.6s ease-out 0.1s forwards; opacity: 0; font-family: var(--font-heading);">
            50+ Countries. 7&nbsp;Continents. 300+&nbsp;Presentations.
          </h1>
          <p class="text-lg md:text-xl leading-relaxed dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]"
            style="animation: fadeInUp 0.6s ease-out 0.2s forwards; opacity: 0;">
            I've been speaking at conferences since the late '90s. I'm an introvert who happens to be good at standing in front of large rooms and explaining things. Oracle kept sending me places. I kept going.
          </p>
        </div>
        <div class="flex-shrink-0" style="animation: fadeInUp 0.8s ease-out 0.3s forwards; opacity: 0;">
          <div class="relative">
            <div class="absolute -inset-4 rounded-2xl bg-[var(--color-accent)]/10 blur-2xl"></div>
            <picture>
              <source srcset="/images/hero-speaking.webp" type="image/webp" />
              <img src="/images/hero-speaking.png"
                alt="Edward Roske giving a keynote on a TED Talk stage with AI + FINANCE displayed behind him"
                class="relative rounded-2xl w-full max-w-md lg:max-w-lg shadow-2xl ring-1 ring-white/10"
                loading="eager" />
            </picture>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Stats -->
  <Section dark>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {[
        { value: "50+", label: "Countries" },
        { value: "7", label: "Continents" },
        { value: "300+", label: "Presentations" },
        { value: "25+", label: "Years Speaking" },
      ].map(stat => (
        <div class="animate-on-scroll">
          <div class="text-4xl md:text-5xl font-black text-[var(--color-accent)] mb-2">{stat.value}</div>
          <div class="text-sm dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] font-medium">{stat.label}</div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Speaking pointer -->
  <Section>
    <a href="/speaking/" class="animate-on-scroll group block rounded-2xl p-8 md:p-10 transition-all duration-300 hover:-translate-y-1
      dark:bg-gradient-to-br dark:from-[var(--color-accent)]/[0.10] dark:to-white/[0.02] dark:border dark:border-[var(--color-accent)]/20 dark:hover:border-[var(--color-accent)]/40
      bg-gradient-to-br from-[var(--color-accent)]/[0.06] to-white border border-[var(--color-accent)]/20 hover:border-[var(--color-accent)]/40 hover:shadow-xl">
      <p class="text-xs font-[var(--font-mono)] uppercase tracking-widest text-[var(--color-accent)] mb-3">Speaking</p>
      <h3 class="text-2xl md:text-3xl font-bold mb-3 dark:text-white text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-heading);">
        I keynote events on AI, finance, and the Office of the CFO.
      </h3>
      <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-4 leading-relaxed max-w-3xl">
        Three signature talks, an executive podcast, and thirty days of amplification for the host event. Built for conference chairs and corporate program owners.
      </p>
      <span class="inline-flex items-center gap-2 text-[var(--color-accent)] font-medium">
        See speaking topics and book Edward
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </span>
    </a>
  </Section>

  <!-- Flagship Workshop -->
  <Section>
    <a href="/work/ai-art-of-the-possible/" class="animate-on-scroll group block rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1
      dark:bg-gradient-to-br dark:from-[var(--color-accent)]/[0.12] dark:to-white/[0.02] dark:border dark:border-[var(--color-accent)]/20 dark:hover:border-[var(--color-accent)]/40
      bg-gradient-to-br from-[var(--color-accent)]/[0.08] to-white border border-[var(--color-accent)]/20 hover:border-[var(--color-accent)]/40 hover:shadow-xl">
      <div class="flex flex-col md:flex-row">
        <div class="md:w-1/2 relative overflow-hidden">
          <img src="/images/hero-art-of-the-possible.png"
            alt="Edward Roske leading an AI: Art of the Possible workshop, gesturing at a whiteboard of AI ideas while executives watch"
            class="w-full h-full object-cover min-h-[240px]" loading="lazy" />
        </div>
        <div class="md:w-1/2 p-8 md:p-10 flex flex-col justify-center">
          <p class="text-xs font-[var(--font-mono)] uppercase tracking-widest text-[var(--color-accent)] mb-3">Flagship Workshop</p>
          <h3 class="text-2xl md:text-3xl font-bold mb-3 dark:text-white text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors" style="font-family: var(--font-heading);">AI: Art of the Possible</h3>
          <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-5 leading-relaxed">
            A one-to-two-day workshop that puts your leadership team in one room to decide what AI actually means for your business. We start with what AI does today, pressure-test it against your competition, and finish with a plan everyone signs off on.
          </p>
          <span class="inline-flex items-center gap-2 text-[var(--color-accent)] font-medium">
            See the workshop
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </span>
        </div>
      </div>
    </a>
  </Section>

  <!-- Side Projects -->
  <Section title="Also from the Workbench" subtitle="Not everything I build is enterprise software.">
    <div class="animate-on-scroll max-w-3xl">
      <Card title="Only Recipes" href="/only-recipes/">
        <p>My first Chrome extension. It strips recipe pages down to just the ingredients and steps, then lets you check things off, scale the servings, and switch units while you cook. Free, and it runs entirely on your own computer.</p>
        <p class="mt-3 text-xs dark:text-[var(--color-text-muted)]/50 text-[var(--color-text-dark-muted)]/50 font-[var(--font-mono)]">Chrome Extension · Free</p>
      </Card>
    </div>
  </Section>

  <!-- Companies -->
  <Section id="companies" title="Companies" subtitle="Leading at the intersection of AI and Finance." dark>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="animate-on-scroll">
        <Card title="Dawnward">
          <p>Edward's investment firm. Portfolio across AI, technology, and beyond.</p>
          <p class="mt-3 text-xs dark:text-[var(--color-text-muted)]/50 text-[var(--color-text-dark-muted)]/50 font-[var(--font-mono)]">Role: CEO</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="Caprus" href="https://caprus.ai" external>
          <p>AI Software & Services firm. Helping finance teams leverage artificial intelligence for smarter operations, planning, and analysis.</p>
          <p class="mt-3 text-xs dark:text-[var(--color-text-muted)]/50 text-[var(--color-text-dark-muted)]/50 font-[var(--font-mono)]">Role: Investor & Contributor</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="Argano" href="https://argano.com" external>
          <p>Billion-dollar worldwide consulting firm. Formed in 2020 when Edward merged interRel, the company he founded at age 22 and ran for 25 years.</p>
          <p class="mt-3 text-xs dark:text-[var(--color-text-muted)]/50 text-[var(--color-text-dark-muted)]/50 font-[var(--font-mono)]">Role: Co-founder & Stakeholder</p>
        </Card>
      </div>

    </div>
  </Section>

  <!-- Conference History -->
  <Section title="Conference History" subtitle="A partial list. The full one would need pagination.">
    <div class="max-w-3xl space-y-0">
      {[
        { event: "Caribbean AI Summit", detail: "Co-chair. October 9-10, 2026, Puerto Rico Convention Center. The largest AI conference Puerto Rico has ever seen.", year: "2026" },
        { event: "Puerto Rico AI Community", detail: "President and regular presenter. 850+ attendees across events. Bimonthly meetups in San Juan.", year: "2024-Present" },
        { event: "Kscope (ODTUG)", detail: "Speaker since 2008. Conference Chair 2011-2012. Essbase Speaker of the Year 2018. Lifetime Achievement Award 2025. Final Kscope appearance: 2025.", year: "2008-2025" },
        { event: "Oracle International Tours", detail: "Oracle ACE Director touring 50+ countries across all 7 continents. Training, keynotes, and workshops.", year: "2008-2023" },
        { event: "Oracle OpenWorld / CloudWorld", detail: "Regular speaker. San Francisco, Las Vegas, and international editions.", year: "2000s-2020s" },
        { event: "COLLABORATE (IOUG/OAUG)", detail: "One of the original Oracle user group super-speakers. National and international events.", year: "2000s-2010s" },
      ].map((item, i) => (
        <div class="animate-on-scroll flex gap-6 md:gap-8 group">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-[var(--color-accent)] group-hover:scale-125 transition-transform mt-2"></div>
            {i < 5 && <div class="w-px flex-1 dark:bg-[var(--color-border)] bg-[var(--color-border-light)] mt-2"></div>}
          </div>
          <div class="pb-10">
            <div class="text-sm font-[var(--font-mono)] text-[var(--color-accent)] mb-1">{item.year}</div>
            <h3 class="text-lg font-bold dark:text-white text-[var(--color-primary)] mb-1">{item.event}</h3>
            <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] text-sm leading-relaxed">{item.detail}</p>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Awards -->
  <Section title="Awards & Recognition" subtitle="The ones that fit on a slide." dark>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

      <div class="animate-on-scroll">
        <Card title="ODTUG Lifetime Achievement Award">
          <p>Kscope25. Fewer than 5 people have ever received this award for lifetime contributions to the Oracle community. I announced it would be my final Kscope.</p>
          <p class="mt-3 text-xs font-[var(--font-mono)] text-[var(--color-accent)]">2025</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="Essbase Speaker of the Year">
          <p>Kscope18. Voted by attendees. I peaked and immediately pivoted to Data Science.</p>
          <p class="mt-3 text-xs font-[var(--font-mono)] text-[var(--color-accent)]">2018</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="Oracle ACE Director">
          <p>Held for 15+ years. Oracle's highest-tier community recognition. They send you around the world and you pretend not to enjoy it.</p>
          <p class="mt-3 text-xs font-[var(--font-mono)] text-[var(--color-accent)]">2008-Present</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="Five-Time Oracle Partner of the Year">
          <p>Through interRel Consulting. Five separate years. Different categories. Same trophy shelf.</p>
          <p class="mt-3 text-xs font-[var(--font-mono)] text-[var(--color-accent)]">Multiple Years</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="First Perfect Essbase Certification Score">
          <p>First person to score perfectly on the Oracle Essbase Certification exam. I bring this up more than I should.</p>
          <p class="mt-3 text-xs font-[var(--font-mono)] text-[var(--color-accent)]">Historic</p>
        </Card>
      </div>

      <div class="animate-on-scroll">
        <Card title="Kscope Conference Chair">
          <p>Chaired the largest Oracle user group conference for 2011 and 2012. Board member. Community leader.</p>
          <p class="mt-3 text-xs font-[var(--font-mono)] text-[var(--color-accent)]">2011-2012</p>
        </Card>
      </div>

    </div>
  </Section>

  <!-- YouTube -->
  <Section>
    <div class="animate-on-scroll">
      <div class="rounded-2xl p-8 md:p-10
        dark:bg-white/[0.02] dark:border dark:border-white/[0.06]
        bg-white border border-black/[0.06] shadow-sm">
        <div class="flex flex-col md:flex-row gap-8 items-center">
          <div class="flex-shrink-0 w-20 h-20 rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center">
            <svg class="w-10 h-10 text-[var(--color-accent)]" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </div>
          <div class="flex-1 text-center md:text-left">
            <h3 class="text-xl font-bold dark:text-white text-[var(--color-primary)] mb-2">Monthly AI News Brief</h3>
            <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-4">
              Every month I record a video covering the biggest AI news that matters for business. No fluff. No 45-minute runtimes. Just the headlines you need, explained by someone who builds with this stuff.
            </p>
            <a href="https://www.youtube.com/@Roske-AI" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[var(--color-accent)] text-white text-sm font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200 hover:-translate-y-0.5">
              Watch on YouTube
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- Speaking Inquiry CTA -->
  <Section dark>
    <div class="animate-on-scroll text-center max-w-2xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold mb-4 dark:text-white text-[var(--color-primary)]">
        Book Edward to Speak
      </h2>
      <p class="dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] mb-8 text-lg">
        Keynotes, panels, workshops, webinars, and fireside chats. I travel anywhere. (I've spoken on every continent except Antarctica, and I'm open to penguins.)
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href="/speaking/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white font-medium hover:bg-[var(--color-accent-hover)] transition-all duration-200 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-[var(--color-accent)]/20">
          Speaking Inquiry
        </a>
        <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-medium transition-all duration-200 hover:-translate-y-0.5
            dark:bg-white/5 dark:text-white dark:hover:bg-white/10 dark:border dark:border-white/10
            bg-black/5 text-[var(--color-primary)] hover:bg-black/10 border border-black/10">
          Book 13 Minutes
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
      </div>
    </div>
  </Section>

</BaseLayout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
