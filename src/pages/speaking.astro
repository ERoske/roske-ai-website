---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/speaker.css';

// PERMANENT CONVERSION PAGE. This page is deliberately theme-independent:
// it defines its own editorial design tokens (--spk-*) and loads its own
// fonts so event planners see the same premium page in any week's theme.
// Weekly rebuilds must NOT restructure this page (see weekly-rebuild-prompt.md).
// One-pager PDF lives at public/downloads/edward-roske-speaker-onepager.pdf.
// Regenerate via: python scripts/build-speaker-onepager.py

const talks = [
  {
    num: '01',
    title: 'Your Day, Run by Ten Agents',
    audience: 'Executives and leadership teams',
    description:
      "Edward's life runs on ten or more AI agents at all times: calendar, inbox, research, writing, code, decisions. This talk walks through the actual stack, what each agent does, and how executives assemble the same force multiplier without an engineering degree. The website you booked him from is part of the talk (his agents redesign it every Saturday while he sleeps).",
    walkaway: [
      'A map of a working executive agent stack, tool by tool',
      'Which of their own recurring tasks an agent should take first',
      'A 90-day adoption path that survives contact with the IT department',
    ],
    tags: ['Keynote', 'Fireside', 'Most booked'],
  },
  {
    num: '02',
    title: "Answers to the Questions You've Been Quietly Asking Yourself About AI",
    audience: 'Senior leaders, cross-functional',
    description:
      'Drawn from a hundred-plus episodes of Asking Good Questions and a portfolio of live AI deployments. Frameworks for the questions executives are already wrestling with privately, from "which vendor is lying to me" to "what happens to my team." Works as a keynote, a fireside chat, or the opening session of a multi-day offsite.',
    walkaway: [
      'A working answer to the AI question they brought into the room',
      'A filter for separating deployed reality from vendor theater',
      'The three decisions worth making this quarter (and the ones that can wait)',
    ],
    tags: ['Keynote', 'Fireside', 'Offsite opener'],
  },
  {
    num: '03',
    title: 'The Computer-First Finance Department',
    audience: 'CFOs, finance and EPM leaders',
    description:
      "Planning, consolidation, and reporting are shifting from human-first to computer-first, and Edward is one of the people shipping that shift: MCP servers that let AI agents read and write live Oracle EPM data. Twenty-five years in the Office of the CFO, translated into what finance automates first, what it should never automate, and why knowing when a number is wrong still beats producing it fast.",
    walkaway: [
      'The finance processes AI takes first, in order, with evidence',
      'What a computer-first close actually looks like at companies doing it',
      'The judgment calls that stay human (and how to staff for them)',
    ],
    tags: ['Keynote', 'Workshop pairing', 'Finance events'],
  },
  {
    num: '04',
    title: 'Building a Company in the Era of AI',
    audience: 'Founders, operators, PE portfolios',
    description:
      "Edward founded interRel at twenty-two, ran it for twenty-five years, and merged it into a billion-dollar firm. Now he's building AI companies while AI rewrites the business model underneath them. It's a talk for founders and operating partners on what changes when your product, your staffing plan, and your competition are all being re-priced by the same technology.",
    walkaway: [
      'Which parts of the operating playbook AI actually re-prices',
      'How to evaluate AI claims inside a portfolio company in one meeting',
      'The hiring and org-design moves that age well',
    ],
    tags: ['Keynote', 'PE annual meetings', 'Board retreats'],
  },
];

const formats = [
  {
    name: 'Keynote',
    price: 'From $15,000',
    detail:
      'Up to 90 minutes plus Q&A, customized to your audience after a working call. Fireside and panel formats included at the same fee.',
  },
  {
    name: 'Executive Workshop',
    price: 'From $20,000',
    detail:
      'The full-day "AI: Art of the Possible" working session. Your leadership team leaves with a ranked pilot list they can act on Monday.',
    href: '/work/ai-art-of-the-possible/',
    linkText: 'See the workshop',
  },
  {
    name: 'Board Briefing',
    price: 'From $12,500',
    detail:
      'A private two-to-three hour AI oversight session for directors. What to ask management, what to greenlight, what to fear proportionately.',
  },
  {
    name: 'Virtual Keynote',
    price: 'From $7,500',
    detail:
      'Same talk, same customization, no airfare. Recording license and hybrid formats available.',
  },
];

const stages = [
  'Oracle OpenWorld', 'Oracle CloudWorld', 'Kscope / ODTUG', 'COLLABORATE',
  'Caribbean AI Summit', 'Puerto Rico AI Community', 'FENG', 'PACE',
  'Toronto EPM User Group', 'World Finance Forums',
];

const videos = [
  {
    id: 'qrMbUUvmAls',
    title: 'Masterclass: Ask Edward Roske about Strategic EPM',
    where: 'Kscope22 main stage',
  },
  {
    id: 'PZBIZxQGtBc',
    title: 'ODTUG Lifetime Achievement Award',
    where: 'Kscope25 (fewer than five people have ever received it)',
  },
  {
    id: 'SQ2Bltscmlc',
    title: 'AI in EPM: what gets automated first',
    where: 'Toronto EPM User Group, 2026',
  },
];

const history = [
  { event: 'Caribbean AI Summit', detail: 'Co-chair. October 9-10, 2026, Puerto Rico Convention Center. The largest AI conference Puerto Rico has ever seen.', year: '2026' },
  { event: 'Puerto Rico AI Community', detail: 'President and regular presenter. 850+ executives across the meetup series. Bimonthly in San Juan.', year: '2024-Present' },
  { event: 'Kscope (ODTUG)', detail: 'Speaker since 2008. Conference Chair 2011-2012. Essbase Speaker of the Year 2018. Lifetime Achievement Award 2025.', year: '2008-2025' },
  { event: 'Oracle International Speaking Tours', detail: 'Touring 50+ countries across all 7 continents. Training, keynotes, and workshops.', year: '2008-2023' },
  { event: 'Oracle OpenWorld / CloudWorld', detail: 'Regular speaker. San Francisco, Las Vegas, and international editions.', year: '2000s-2020s' },
  { event: 'COLLABORATE (IOUG/OAUG)', detail: 'One of the original Oracle user group super-speakers. National and international events.', year: '2000s-2010s' },
];

const faqs = [
  {
    q: 'What does it cost to book Edward for a keynote?',
    a: 'In-person keynotes start at $15,000. Full-day executive workshops start at $20,000, private board briefings at $12,500, and virtual keynotes at $7,500. Most engagements land between $15,000 and $25,000, which is also where most corporate keynote budgets land (not a coincidence). Terms are 50% deposit at signing, balance 30 days before the event.',
  },
  {
    q: 'How far in advance should we book?',
    a: 'Six to twelve months for a specific date, like most established speakers. Shorter windows sometimes work (Edward lives on planes anyway), so ask. January kickoffs book in the prior fall.',
  },
  {
    q: 'Does Edward travel? What about international events?',
    a: "He has spoken in 50+ countries on all 7 continents, including Antarctica. Domestic travel is a flat buyout instead of itemized receipts, because nobody enjoys expense reports. International is quoted per event.",
  },
  {
    q: 'Will the talk be customized for our audience?',
    a: "Always. Edward gets on a working call with you (and your program chair, if you have one) before writing a single slide. Finance conference, PE annual meeting, sales kickoff, and board retreat versions of the same talk are genuinely different talks.",
  },
  {
    q: 'What does Edward need on site?',
    a: 'A wireless lavalier or headset mic, HDMI or USB-C to your screens, and a confidence monitor if the room is large. He arrives early, does a tech check the day before when possible, and stays for the hallway conversations afterward. Full details are in the speaker kit.',
  },
  {
    q: 'Is Edward an AI futurist?',
    a: "Short answer: no. He ships AI products (MCP servers for Oracle EPM, in production), runs his own life on ten-plus AI agents, and spent twenty-five years in the Office of the CFO before AI was a keynote topic. If you want predictions about 2035, he'll politely decline (he's busy shipping 2026).",
  },
];

const testimonials = [
  {
    quote:
      'Edward has a gift for turning complex technical concepts into stories people understand and remember. He teaches with humor, energy, and genuine expertise, making every room he speaks to smarter and more engaged by the end.',
    name: 'Elizabeth Ferrell',
    role: 'Assistant Corporate Controller & Finance AI Leader, The Kroger Co.',
    tag: 'User Group President',
  },
  {
    quote:
      "If there was an award for winning the most speaker awards, Edward would win that too. He fills any room, he's funnier than a talk about financial software has any right to be, and I constantly hear attendees quoting him for the rest of the conference.",
    name: 'Monty Latiolais',
    role: 'Director of Business Development, Talan Oracle Technologies',
    tag: 'Past ODTUG President',
  },
  {
    quote:
      "I've seen Edward fill rooms with finance and systems people and then leave them laughing about consolidation. As a thought leader, he knows the material cold and he's honestly funny with it, which is unsurprisingly rare in our world.",
    name: 'Fred Mamadjanov',
    role: 'Cofounder, Canadian Oracle Technology User Group',
    tag: 'Oracle ACE Pro',
  },
  {
    quote:
      "Edward commands a stage like nobody else I've seen, and he's the only speaker I know who makes AI fun without dumbing it down.",
    name: 'JD Torres',
    role: 'Cofounder, Puerto Rico AI Community',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Keynote Speaking by Edward Roske',
  serviceType: 'Keynote speaking, executive AI workshops, board briefings',
  provider: {
    '@type': 'Person',
    name: 'Edward Roske',
    url: 'https://roske.ai',
    jobTitle: 'AI Keynote Speaker and CEO',
  },
  areaServed: 'Worldwide',
  offers: [
    { '@type': 'Offer', name: 'In-person keynote', price: '15000', priceCurrency: 'USD', description: 'Starting fee for in-person keynotes up to 90 minutes plus Q&A' },
    { '@type': 'Offer', name: 'Executive AI workshop (full day)', price: '20000', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Private board briefing', price: '12500', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Virtual keynote', price: '7500', priceCurrency: 'USD' },
  ],
  review: testimonials.map((t) => ({
    '@type': 'Review',
    reviewBody: t.quote,
    author: { '@type': 'Person', name: t.name, jobTitle: t.role },
  })),
};
---

<BaseLayout
  title="AI Keynote Speaker | Book Edward Roske"
  description="Book Edward Roske: the AI practitioner for finance leaders. Keynotes from $15,000. 15 books, 50+ countries, all 7 continents, 8 speaker awards. Ships MCP servers for enterprise finance. Inquiries answered within one business day."
  ogImage="/images/og-default.png">

  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..900;1,9..144,300..900&family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <div class="spk">

    <!-- ============ MASTHEAD ============ -->
    <header class="spk-masthead">
      <div class="spk-grain" aria-hidden="true"></div>
      <div class="spk-wrap">
        <p class="spk-kicker">Keynotes &middot; Executive Workshops &middot; Board Briefings</p>
        <h1 class="spk-h1">
          The AI practitioner<br />
          <em>for finance leaders.</em>
        </h1>
        <p class="spk-lede">
          Edward builds MCP servers that put AI agents inside Oracle EPM, runs his own day on
          ten-plus agents, and spent twenty-five years in the Office of the CFO before AI was a
          keynote topic. He's also, by most accounts, funny (the dry kind). Fifteen books,
          fifty-plus countries on all seven continents, and an overabundance of speaker awards
          to show the combination works.
        </p>
        <div class="spk-cta-row">
          <a class="spk-btn spk-btn-primary" href="#inquiry">Check availability</a>
          <a class="spk-btn spk-btn-ghost" href="#watch">Watch him speak</a>
        </div>
        <p class="spk-terms">
          Keynotes from $15,000 &middot; Inquiries answered within one business day
        </p>

        <dl class="spk-stats">
          <div><dt>50+</dt><dd>Countries spoken in</dd></div>
          <div><dt>7</dt><dd>Continents (yes, Antarctica)</dd></div>
          <div><dt>300+</dt><dd>Keynotes and sessions</dd></div>
          <div><dt>15</dt><dd>Books since 2007</dd></div>
          <div><dt>8</dt><dd>Speaker awards</dd></div>
        </dl>
      </div>
    </header>

    <!-- ============ PROOF BAR ============ -->
    <section class="spk-proof" aria-label="Awards and stages">
      <div class="spk-wrap">
        <div class="spk-awards">
          <p><strong>ODTUG Lifetime Achievement Award</strong> (2025, fewer than five people have ever received one)</p>
          <p><strong>Six Top Speaker awards. Two Best Overall Speaker awards.</strong> Across major industry conferences.</p>
          <p><strong>Essbase Speaker of the Year</strong> (Kscope18), plus the first perfect score ever on the Essbase certification exam.</p>
        </div>
        <div class="spk-stages">
          <span class="spk-stages-label">Stages</span>
          <ul>
            {stages.map((s) => <li>{s}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ WATCH ============ -->
    <section id="watch" class="spk-section">
      <div class="spk-wrap">
        <p class="spk-eyebrow">The footage</p>
        <h2 class="spk-h2">See him on a real stage.</h2>
        <p class="spk-deck">
          No sizzle-reel tricks, no stock crowd shots. Actual conference footage, the way an
          event planner would want to check it.
        </p>
        <div class="spk-videos">
          {videos.map((v, i) => (
            <figure class={`spk-video ${i === 0 ? 'spk-video-feature' : ''}`}>
              <button
                type="button"
                class="spk-video-facade"
                data-video-id={v.id}
                data-video-title={v.title}
                aria-label={`Play video: ${v.title}`}>
                <img
                  src={`https://i.ytimg.com/vi/${v.id}/hqdefault.jpg`}
                  alt={`Video thumbnail: ${v.title}`}
                  loading="lazy"
                  decoding="async" />
                <span class="spk-play" aria-hidden="true">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                </span>
              </button>
              <figcaption>
                <strong>{v.title}</strong>
                <span>{v.where}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ TALKS ============ -->
    <section class="spk-section spk-section-alt">
      <div class="spk-wrap">
        <p class="spk-eyebrow">Signature talks</p>
        <h2 class="spk-h2">Four talks. Zero recycled decks.</h2>
        <p class="spk-deck">
          Edward rebuilds every talk for your audience after a working call with you. Identical talks
          for different rooms is how speakers end up on the "never again" list, and Edward would
          rather stay off it.
        </p>
        <div class="spk-talks">
          {talks.map((t) => (
            <article class="spk-talk">
              <div class="spk-talk-head">
                <span class="spk-talk-num">{t.num}</span>
                <div class="spk-talk-tags">
                  {t.tags.map((tag) => <span>{tag}</span>)}
                </div>
              </div>
              <h3 class="spk-talk-title">{t.title}</h3>
              <p class="spk-talk-aud">{t.audience}</p>
              <p class="spk-talk-body">{t.description}</p>
              <div class="spk-talk-outcomes">
                <span class="spk-talk-outcomes-label">The room walks away with</span>
                <ul>
                  {t.walkaway.map((w) => <li>{w}</li>)}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ TESTIMONIALS ============ -->
    <section class="spk-section spk-quotes-section">
      <div class="spk-wrap">
        <p class="spk-eyebrow">From the room</p>
        <h2 class="spk-h2">The tough rooms, on the record.</h2>
        <p class="spk-deck">
          Oracle community leaders, a Fortune 500 finance executive, and the organizers who
          keep putting Edward on their stages (the kind of crowd that doesn't hand out
          compliments for fun).
        </p>
        <div class="spk-quotes">
          {testimonials.map((t) => (
            <figure class="spk-quote">
              <blockquote>{t.quote}</blockquote>
              <figcaption>
                <span class="spk-quote-name">{t.name}</span>
                <span class="spk-quote-role">{t.role}</span>
                {t.tag && <span class="spk-quote-tag">{t.tag}</span>}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FORMATS & FEES ============ -->
    <section class="spk-section">
      <div class="spk-wrap">
        <p class="spk-eyebrow">Formats and fees</p>
        <h2 class="spk-h2">Pick a format. The fee is right there.</h2>
        <p class="spk-deck">
          Published fees save both of us a discovery call about money. Terms: 50% deposit at
          signing, balance 30 days before the event. Domestic travel is a flat buyout
          (nobody enjoys receipts).
        </p>
        <div class="spk-formats">
          {formats.map((f) => (
            <article class="spk-format">
              <h3>{f.name}</h3>
              <p class="spk-format-price">{f.price}</p>
              <p class="spk-format-detail">{f.detail}</p>
              {f.href && <a class="spk-textlink" href={f.href}>{f.linkText}</a>}
            </article>
          ))}
        </div>
        <p class="spk-fineprint">
          Keynote plus workshop on the same trip bundles at $30,000. Exclusivity clauses,
          recording licenses, and hybrid formats are quoted per event.
        </p>
      </div>
    </section>

    <!-- ============ WHAT YOU GET ============ -->
    <section class="spk-section spk-section-alt">
      <div class="spk-wrap">
        <p class="spk-eyebrow">What you get</p>
        <h2 class="spk-h2">Booking Edward books an event campaign.</h2>
        <div class="spk-bundle">
          <article>
            <h3>The talk, customized</h3>
            <p>A working call with you before anything gets written. Tech check the day before, full rehearsal if you want one, Q&A or panel slot if it fits the format. Edward arrives early and stays for the hallway track.</p>
          </article>
          <article>
            <h3>A podcast appearance</h3>
            <p>An invited guest slot on Asking Good Questions, scheduled around your event. Your CEO, your keynote, or a key customer sits down with Edward for a conversation that lives on Apple, Spotify, Amazon, and YouTube.</p>
          </article>
          <article>
            <h3>Thirty days of amplification</h3>
            <p>If your event is public: a month of LinkedIn and X posts to a built-in audience of CFOs, CIOs, and AI operators, plus a month of mentions on Edward's YouTube channel and its 200,000+ subscribers.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ LIVE DEMO ============ -->
    <section class="spk-demo">
      <div class="spk-grain" aria-hidden="true"></div>
      <div class="spk-wrap">
        <p class="spk-eyebrow spk-eyebrow-invert">The live demo</p>
        <h2 class="spk-h2 spk-h2-invert">This website rebuilds itself every Saturday.</h2>
        <p class="spk-demo-body">
          Edward's AI agents redesign roske.ai every week: new theme, new imagery, new layout,
          researched, built, tested, and deployed while he sleeps. If someone's going to stand
          on your stage and talk about AI agents, he should probably be able to show you his.
          Edward's are running this website right now, which is either commitment or negligence,
          depending on the week's theme. It's the standing proof behind his most-booked talk,
          "Your Day, Run by Ten Agents."
        </p>
      </div>
    </section>

    <!-- ============ PLANNER KIT ============ -->
    <section class="spk-section">
      <div class="spk-wrap spk-kitrow">
        <div>
          <p class="spk-eyebrow">For your committee</p>
          <h2 class="spk-h2">Everything a program chair needs, one page.</h2>
          <p class="spk-deck">
            Bios in three lengths, downloadable headshots, a 75-word emcee intro, A/V needs, and
            the one-pager PDF. Built to be forwarded, since speaker decisions average two to five
            people (and at least one of them will only read the PDF).
          </p>
        </div>
        <div class="spk-kitlinks">
          <a class="spk-btn spk-btn-primary" href="/speaker-kit/">Open the speaker kit</a>
          <a class="spk-btn spk-btn-ghost" href="/downloads/edward-roske-speaker-onepager.pdf" target="_blank" rel="noopener">Download the one-pager (PDF)</a>
        </div>
      </div>
    </section>

    <!-- ============ INQUIRY ============ -->
    <section id="inquiry" class="spk-section spk-section-alt">
      <div class="spk-wrap">
        <div class="spk-inquiry-grid">
          <div>
            <p class="spk-eyebrow">Check availability</p>
            <h2 class="spk-h2">Tell Edward about the room.</h2>
            <p class="spk-deck">
              Date not locked yet? Send it anyway. Speaking inquiries are answered within one
              business day, usually faster (the inbox is run by agents, and they don't sleep either).
            </p>

            <form action="https://api.web3forms.com/submit" method="POST" class="spk-form"
              {...{"toolname": "speaking-inquiry-edward-roske", "tooldescription": "Submit a speaking engagement inquiry for Edward Roske. Use for keynote, fireside, workshop, board briefing, or panel requests at conferences, corporate offsites, and executive events."}}>
              <input type="hidden" name="access_key" value="927fd498-3a0f-470c-89af-80a8558e8530" />
              <input type="hidden" name="subject" value="New speaking inquiry from roske.ai/speaking" />
              <input type="hidden" name="from_name" value="Speaking Inquiry" />
              <input type="hidden" name="page" value="/speaking" />
              <input type="hidden" name="redirect" value="https://roske.ai/speaking/?inquiry=received" />

              <div class="spk-form-row">
                <label>Your name *
                  <input type="text" name="name" required autocomplete="name" />
                </label>
                <label>Email *
                  <input type="email" name="email" required autocomplete="email" />
                </label>
              </div>

              <div class="spk-form-row">
                <label>Organization *
                  <input type="text" name="organization" required autocomplete="organization" />
                </label>
                <label>What kind of session?
                  <select name="format">
                    <option value="">Select</option>
                    <option value="keynote">Keynote</option>
                    <option value="fireside">Fireside chat</option>
                    <option value="workshop">Executive workshop</option>
                    <option value="board-briefing">Board briefing</option>
                    <option value="panel">Panel</option>
                    <option value="virtual">Virtual session</option>
                    <option value="other">Other / not sure yet</option>
                  </select>
                </label>
              </div>

              <div class="spk-form-row">
                <label>Event name
                  <input type="text" name="event_name" />
                </label>
                <label>Event date (or best guess)
                  <input type="text" name="event_date" placeholder="March 2027, Q1, or an exact date" />
                </label>
              </div>

              <div class="spk-form-row">
                <label>Location
                  <input type="text" name="location" placeholder="City, country, or virtual" />
                </label>
                <label>Budget range
                  <select name="budget">
                    <option value="">Select</option>
                    <option value="under-15k">Under $15K</option>
                    <option value="15-25k">$15K to $25K</option>
                    <option value="25-40k">$25K to $40K</option>
                    <option value="40k+">$40K+</option>
                    <option value="discuss">Prefer to discuss</option>
                  </select>
                </label>
              </div>

              <label>The audience, and what you want them to walk away with
                <textarea name="notes" rows="4" placeholder="CFOs? Founders? A sales team that just got an AI mandate? Tell Edward about the room."></textarea>
              </label>

              <div class="spk-honeypot"><input type="text" name="botcheck" tabindex="-1" autocomplete="off" /></div>

              <button type="submit" class="spk-btn spk-btn-primary spk-btn-wide">Send inquiry</button>
              <p class="spk-form-sla">Answered within one business day.</p>
            </form>
          </div>

          <aside class="spk-inquiry-side">
            <div class="spk-sidecard spk-sidecard-hot">
              <h3>Or skip the form entirely</h3>
              <p>Thirty minutes with Edward. Walk through the event, the audience, the outcome you want. Leave with a recommended talk and a date hold.</p>
              <a class="spk-btn spk-btn-primary" href="/meet/" target="_blank" rel="noopener noreferrer">Book a screening call</a>
            </div>
            <div class="spk-sidecard">
              <h3>Direct email</h3>
              <p>If you'd rather just write, write.</p>
              <a class="spk-textlink" href="mailto:Edward@Roske.AI?subject=Speaking%20Inquiry">Edward@Roske.AI</a>
            </div>
            <div class="spk-sidecard">
              <h3>Working with a bureau?</h3>
              <p>Edward books non-exclusively and honors bureau relationships. Same fees either way.</p>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ HISTORY ============ -->
    <section class="spk-section">
      <div class="spk-wrap">
        <p class="spk-eyebrow">Selected history</p>
        <h2 class="spk-h2">A partial list.</h2>
        <p class="spk-deck">The full one would need pagination.</p>
        <div class="spk-history">
          {history.map((h) => (
            <div class="spk-history-row">
              <span class="spk-history-year">{h.year}</span>
              <div>
                <h3>{h.event}</h3>
                <p>{h.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="spk-section spk-section-alt">
      <div class="spk-wrap spk-faq-wrap">
        <p class="spk-eyebrow">Good questions</p>
        <h2 class="spk-h2">What planners ask before booking.</h2>
        <div class="spk-faq">
          {faqs.map((f) => (
            <details class="spk-faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ CLOSING ============ -->
    <section class="spk-closing">
      <div class="spk-grain" aria-hidden="true"></div>
      <div class="spk-wrap">
        <h2 class="spk-h2 spk-h2-invert">Your audience has AI questions.<br /><em>Book the person who ships answers.</em></h2>
        <div class="spk-cta-row spk-cta-center">
          <a class="spk-btn spk-btn-light" href="#inquiry">Check availability</a>
          <a class="spk-btn spk-btn-ghost-invert" href="/meet/" target="_blank" rel="noopener noreferrer">Screening call (30 min)</a>
        </div>
      </div>
    </section>

  </div>

  <script is:inline>
    // Click-to-load YouTube facades (perf: no iframe until requested)
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll('.spk-video-facade').forEach((btn) => {
        if (btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', () => {
          const id = btn.dataset.videoId;
          const title = btn.dataset.videoTitle || 'Video';
          const iframe = document.createElement('iframe');
          iframe.src = 'https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0';
          iframe.title = title;
          iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
          iframe.allowFullscreen = true;
          iframe.className = 'spk-video-player';
          btn.replaceWith(iframe);
        });
      });
    });
  </script>

</BaseLayout>
