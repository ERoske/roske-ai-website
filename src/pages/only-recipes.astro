---
// PERMANENT PAGE. Do not He-Man-ify or theme-rewrite during weekly rebuilds.
// It inherits the active weekly theme through the CSS custom properties
// (--color-*, --font-*) and should keep working as the theme changes.
// Companion page: /only-recipes-privacy/ (the privacy policy).
import BaseLayout from '../layouts/BaseLayout.astro';

const STORE_URL = 'https://chromewebstore.google.com/detail/only-recipes/jddinhkkkjbplpoefcilhdhaenphnjep';
const PRIVACY_URL = '/only-recipes-privacy/';

// Live demo recipe. Rendered server-side at the base state (US units, 4 servings)
// so the card is complete even without JavaScript. The inline script enhances it
// with the servings stepper, unit toggle, and check-off behavior.
const baseServings = 4;
const ingredients = [
  { name: 'Spaghetti', us: { qty: 12, unit: 'oz' }, metric: { qty: 340, unit: 'g' } },
  { name: 'Unsalted butter', us: { qty: 4, unit: 'tbsp' }, metric: { qty: 57, unit: 'g' } },
  { name: 'Garlic, sliced', us: { qty: 6, unit: 'cloves' }, metric: { qty: 6, unit: 'cloves' }, integer: true },
  { name: 'Parmesan, grated', us: { qty: 1, unit: 'cup' }, metric: { qty: 100, unit: 'g' } },
  { name: 'Black pepper', us: { qty: 1, unit: 'tsp' }, metric: { qty: 2, unit: 'g' } },
  { name: 'Salt', note: 'to taste' },
];
const steps = [
  'Boil the spaghetti in well-salted water until just shy of done. Save a mug of the pasta water before you drain it.',
  'Melt the butter over low heat. Add the garlic and cook until fragrant, not brown.',
  'Add the drained pasta, the pepper, and a splash of pasta water. Toss it hard for a full minute.',
  'Off the heat, fold in the parmesan until it turns glossy. Loosen with more pasta water if it tightens. Eat at once.',
];

const demoIngredients = ingredients.map((ing, i) => ({
  i,
  amount: ing.note ? '' : `${ing.us.qty} ${ing.us.unit}`,
  name: ing.note ? `${ing.name} (${ing.note})` : ing.name,
  usQty: ing.us?.qty ?? null,
  usUnit: ing.us?.unit ?? '',
  metricQty: ing.metric?.qty ?? null,
  metricUnit: ing.metric?.unit ?? '',
  integer: ing.integer ? '1' : '',
}));

const features = [
  {
    title: 'Just the recipe',
    body: 'Ingredients and steps, formatted to actually read. The memoir, the ads, the popups, and the auto-playing video are gone before you finish scrolling.',
  },
  {
    title: 'Check as you go',
    body: 'Tap an ingredient or a step and it crosses off. (Helpful for anyone who has added the butter twice because they lost their place.)',
  },
  {
    title: 'Scale the servings',
    body: 'Cooking for two or for twelve, the amounts do the arithmetic for you. (I have a Master’s in data science and I still did not want to do it by hand.)',
  },
  {
    title: 'US or metric',
    body: 'One toggle flips the whole recipe between cups and grams. For when the recipe is written in grams and your kitchen is not.',
  },
  {
    title: 'Save the keepers',
    body: 'A heart button saves a recipe to your own box, no account or sign-in required. It remembers the ones you liked.',
  },
  {
    title: 'Picks up where you left off',
    body: 'Close the tab in the middle of dinner, come back later, and your checkmarks and settings are waiting for you.',
  },
];

const faqs = [
  {
    q: 'Is it really free?',
    a: 'Yes. No paid tier, no upsell, no "Pro" version waiting behind a login. It is free, and it stays free.',
  },
  {
    q: 'Does it work on every recipe site?',
    a: 'It works on any page that publishes its recipe in the standard schema.org format, which covers most cooking sites and nearly every large one. If a page has a real recipe in it, Only Recipes finds it. If it does not, the extension stays quiet and out of your way.',
  },
  {
    q: 'What does it collect about me?',
    a: 'Nothing leaves your computer. No tracking, no analytics, no account. The privacy policy spells out every last detail, and it is a short read.',
  },
  {
    q: 'Will it work on my phone?',
    a: 'Not yet. It is a desktop Chrome extension, and phone browsers do not run extensions the same way. For now it lives on laptops and desktops.',
  },
  {
    q: 'Which browsers?',
    a: 'Chrome, and the browsers built on it: Edge, Brave, Arc, and Opera. If it runs Chrome extensions, it runs this one.',
  },
  {
    q: 'Who made it?',
    a: 'Edward Roske, the one in the fedora. It is my first browser extension, which I am told is a rite of passage I reached a little later than most.',
  },
];
---

<BaseLayout
  title="Only Recipes — The Chrome Extension That Strips Recipe Pages to Just the Recipe"
  description="Only Recipes is a free Chrome extension that deletes the memoir, ads, and popups from recipe pages and leaves only the ingredients and steps. Check things off, scale servings, switch units. Runs entirely on your device. Built by Edward Roske."
  ogImage="/images/only-recipes-edward.png"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Only Recipes",
      "applicationCategory": "BrowserApplication",
      "operatingSystem": "Chrome, Edge, Brave, Arc, Opera",
      "description": "A free Chrome extension that strips recipe pages down to ingredients and steps, with check-off, serving scaling, and unit conversion. Runs entirely on your device with no tracking.",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": "https://roske.ai/only-recipes/",
      "downloadUrl": STORE_URL,
      "author": { "@type": "Person", "name": "Edward Roske", "url": "https://roske.ai" }
    })} />
  </Fragment>

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="relative px-6 pt-16 pb-12 md:pt-24 md:pb-16 overflow-hidden">
    <div class="absolute inset-0 -z-10 opacity-[0.07]" style="background: var(--color-gradient, radial-gradient(circle at 50% 0%, var(--color-accent), transparent 60%));"></div>
    <div class="max-w-4xl mx-auto text-center">
      <p class="text-xs md:text-sm tracking-[0.2em] uppercase text-[var(--color-accent)] mb-5"
        style="font-family: var(--font-mono); animation: orUp 0.6s ease-out forwards;">
        Edward&rsquo;s first Chrome extension
      </p>
      <h1 class="text-5xl md:text-7xl font-black tracking-tight mb-6 dark:text-white text-[var(--color-primary)]"
        style="font-family: var(--font-heading); animation: orUp 0.6s ease-out 0.05s forwards; opacity: 0;">
        Only Recipes
      </h1>
      <p class="text-xl md:text-2xl leading-snug font-medium max-w-3xl mx-auto mb-5 dark:text-white text-[var(--color-text-dark)]"
        style="animation: orUp 0.6s ease-out 0.12s forwards; opacity: 0;">
        You came for a recipe and the website gave you a 2,000-word memoir, four ad breaks, a newsletter popup, and a video that follows you down the page. Only Recipes throws all of that out and keeps the recipe.
      </p>
      <p class="text-base md:text-lg leading-relaxed max-w-2xl mx-auto mb-9 dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]"
        style="animation: orUp 0.6s ease-out 0.2s forwards; opacity: 0;">
        It finds the recipe on almost any cooking site and shows you a clean card: ingredients and steps, nothing else. Check things off as you cook, scale the servings, and switch between US and metric without leaving the page. It all runs on your computer.
      </p>
      <div class="flex flex-wrap gap-4 justify-center items-center"
        style="animation: orUp 0.6s ease-out 0.28s forwards; opacity: 0;">
        <a href={STORE_URL} target="_blank" rel="noopener noreferrer" class="or-btn-primary">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-1.99.9-1.99 2v3.8H3.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7s2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z"/></svg>
          Add to Chrome (free)
        </a>
        <a href="#demo" class="or-btn-secondary">See it work</a>
      </div>
      <p class="mt-6 text-xs tracking-wide dark:text-[var(--color-text-muted)]/60 text-[var(--color-text-dark-muted)]/70"
        style="font-family: var(--font-mono); animation: orUp 0.6s ease-out 0.36s forwards; opacity: 0;">
        Free &middot; No account &middot; No tracking &middot; Chrome, Edge, Brave, Arc
      </p>
    </div>
  </section>

  <!-- ============================================================
       BEFORE / AFTER DEMO
       ============================================================ -->
  <section id="demo" class="px-6 py-16 md:py-24 scroll-mt-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold mb-3 dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
          One recipe page. Before and after.
        </h2>
        <p class="text-lg max-w-2xl mx-auto dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">
          This is the same recipe, before and after Only Recipes got to it. (Yes, the before page is a parody. No, it is not much of an exaggeration.)
        </p>
      </div>

      <!-- Real before/after, straight from the Chrome Web Store listing -->
      <div class="or-shots animate-on-scroll">
        <figure class="or-shot">
          <img src="/images/only-recipes-before.jpg" width="1280" height="800" loading="lazy"
            alt="A cluttered recipe page headlined 'The ONLY Pan-Seared Steak Recipe You'll Ever Need', stamped 47 min read, with a giant newsletter subscribe banner and the opening of a long personal memoir set in 1987." />
          <figcaption class="or-cap">Before. A real recipe page.</figcaption>
        </figure>

        <div class="or-arrow" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 6l6 6-6 6"/></svg>
        </div>

        <figure class="or-shot">
          <img src="/images/only-recipes-after.jpg" width="1280" height="800" loading="lazy"
            alt="The same recipe in Only Recipes: a clean 'Pan-Seared Steak with Rosemary Butter' card with check-off ingredients and a control bar for servings, units, saving, and auto-show." />
          <figcaption class="or-cap">After. The same page, in Only Recipes.</figcaption>
        </figure>
      </div>

      <!-- Interactive playground: the live version of the clean view -->
      <div class="or-try">
        <div class="or-try-head animate-on-scroll">
          <h3 class="or-try-title">Go ahead, change something</h3>
          <p class="or-try-deck">The clean view is not a static list. Scale the servings, flip between US and metric, and check things off as you cook. Here is that part, live.</p>
        </div>

        <div id="or-demo" class="or-after animate-on-scroll" data-system="us" data-servings={baseServings} data-base={baseServings}>
            <div class="or-after-top">
              <span class="or-badge"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l2.4 7.4H22l-6 4.4 2.3 7.4L12 16.8 5.7 21.2 8 13.8 2 9.4h7.6z"/></svg> Only Recipes</span>
              <button type="button" id="or-heart" class="or-heart" aria-pressed="false" aria-label="Save this recipe">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.6l-1-1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>
              </button>
            </div>

            <h3 class="or-recipe-title">Garlic Butter Spaghetti</h3>

            <div class="or-controls">
              <div class="or-control">
                <span class="or-control-label">Serves</span>
                <div class="or-stepper">
                  <button type="button" id="or-minus" aria-label="Fewer servings">&minus;</button>
                  <span id="or-servings" aria-live="polite">{baseServings}</span>
                  <button type="button" id="or-plus" aria-label="More servings">+</button>
                </div>
              </div>
              <div class="or-control">
                <span class="or-control-label">Units</span>
                <div class="or-unit" role="group" aria-label="Unit system">
                  <button type="button" class="or-unit-btn is-on" data-unit="us">US</button>
                  <button type="button" class="or-unit-btn" data-unit="metric">Metric</button>
                </div>
              </div>
            </div>

            <p class="or-sec-label">Ingredients</p>
            <ul class="or-list">
              {demoIngredients.map(d => (
                <li>
                  <button type="button" class="or-check or-ing" data-i={d.i}>
                    <span class="or-box" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
                    </span>
                    <span class="or-amt"
                      data-us-qty={d.usQty}
                      data-us-unit={d.usUnit}
                      data-metric-qty={d.metricQty}
                      data-metric-unit={d.metricUnit}
                      data-integer={d.integer}>{d.amount}</span>
                    <span class="or-name">{d.name}</span>
                  </button>
                </li>
              ))}
            </ul>

            <p class="or-sec-label">Steps</p>
            <ol class="or-list or-steps">
              {steps.map((s, i) => (
                <li>
                  <button type="button" class="or-check or-step">
                    <span class="or-num" aria-hidden="true">{i + 1}</span>
                    <span class="or-step-text">{s}</span>
                  </button>
                </li>
              ))}
            </ol>

            <p class="or-after-foot">Saved on your computer. Nothing left the kitchen.</p>
          </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FEATURES
       ============================================================ -->
  <section class="px-6 py-16 md:py-24 dark:bg-[var(--color-surface)] bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 md:mb-16 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
          It does one thing. It does it well.
        </h2>
        <p class="mt-4 text-lg max-w-2xl dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">
          That one thing happens to have a few useful corners.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map(f => (
          <div class="animate-on-scroll rounded-xl p-6 transition-all duration-300
            dark:bg-white/[0.03] dark:border dark:border-white/[0.06] dark:hover:border-[var(--color-accent)]/30 dark:hover:bg-white/[0.06]
            bg-white border border-black/[0.06] hover:border-[var(--color-accent)]/30 hover:shadow-lg hover:-translate-y-1">
            <h3 class="text-lg font-semibold mb-2 dark:text-white text-[var(--color-primary)]">{f.title}</h3>
            <p class="text-sm leading-relaxed dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       A CLOSER LOOK (real feature screenshots from the store listing)
       ============================================================ -->
  <section class="px-6 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 md:mb-16 animate-on-scroll">
        <h2 class="text-3xl md:text-4xl font-bold dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
          A closer look
        </h2>
        <p class="mt-4 text-lg max-w-2xl dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">
          More of the real thing, on that same over-written steak recipe.
        </p>
      </div>
      <div class="or-gallery">
        <figure class="or-shot animate-on-scroll">
          <a href="/images/only-recipes-instructions.jpg" target="_blank" rel="noopener noreferrer">
            <img src="/images/only-recipes-instructions.jpg" width="1280" height="800" loading="lazy"
              alt="Only Recipes showing the recipe method as clean numbered steps, with the floating control bar at the bottom." />
          </a>
          <figcaption class="or-cap">The steps, decluttered too</figcaption>
          <p class="or-gallery-note">The same treatment as the ingredients, now applied to the part where you actually cook.</p>
        </figure>

        <figure class="or-shot animate-on-scroll">
          <a href="/images/only-recipes-scaling.jpg" target="_blank" rel="noopener noreferrer">
            <img src="/images/only-recipes-scaling.jpg" width="1280" height="800" loading="lazy"
              alt="A close-up of the Only Recipes control bar: a minus and plus servings stepper, a units toggle set to Imperial, a save heart, an auto-show button, and Show original." />
          </a>
          <figcaption class="or-cap">One bar runs everything</figcaption>
          <p class="or-gallery-note">Servings, units, save, and a jump back to the original page, all from the strip that floats over the recipe.</p>
        </figure>

        <figure class="or-shot animate-on-scroll">
          <a href="/images/only-recipes-settings.jpg" target="_blank" rel="noopener noreferrer">
            <img src="/images/only-recipes-settings.jpg" width="1280" height="800" loading="lazy"
              alt="The Only Recipes panel showing a saved recipe with a thumbnail under Saved, and a Settings area with an auto-show checkbox and a default units selector." />
          </a>
          <figcaption class="or-cap">Saved recipes and settings</figcaption>
          <p class="or-gallery-note">Your keepers live in your own box, next to the handful of settings there are. (There are not many. That is on purpose.)</p>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================================
       PRIVACY
       ============================================================ -->
  <section class="px-6 py-16 md:py-24">
    <div class="max-w-3xl mx-auto animate-on-scroll">
      <p class="text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] mb-4" style="font-family: var(--font-mono);">The honest part</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-6 dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
        It is not quietly selling you.
      </h2>
      <div class="space-y-4 text-lg leading-relaxed dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">
        <p>
          Plenty of browser extensions are a quiet data-collection business wearing a friendly costume. Only Recipes is not one of them. It runs entirely on your device: no network calls of its own, no analytics, no ads, and no server to phone home to (there is no server).
        </p>
        <p>
          The only thing it stores lives on your computer: the recipes you saved and the boxes you checked. The full privacy policy is short, because there is very little to disclose.
        </p>
      </div>
      <a href={PRIVACY_URL} class="inline-flex items-center gap-2 mt-6 font-medium text-[var(--color-accent)] hover:gap-3 transition-all">
        Read the privacy policy
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>
  </section>

  <!-- ============================================================
       INSTALL
       ============================================================ -->
  <section class="px-6 py-16 md:py-24 dark:bg-[var(--color-surface)] bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="mb-12 animate-on-scroll text-center">
        <h2 class="text-3xl md:text-4xl font-bold dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
          Cooking with it in under a minute
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {[
          { n: '1', t: 'Add it to Chrome', b: 'It is free, from the Chrome Web Store, and installs in a couple of seconds.' },
          { n: '2', t: 'Open any recipe page', b: 'Cook a thing you found anywhere. Most recipe sites publish their recipe in a standard format, and that is what Only Recipes reads.' },
          { n: '3', t: 'Cook from the clean card', b: 'Click the icon when you want it, or turn on auto-show and it appears on its own every time.' },
        ].map(step => (
          <div class="animate-on-scroll text-center">
            <div class="or-step-num">{step.n}</div>
            <h3 class="text-lg font-semibold mb-2 dark:text-white text-[var(--color-primary)]">{step.t}</h3>
            <p class="text-sm leading-relaxed dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">{step.b}</p>
          </div>
        ))}
      </div>
      <div class="flex justify-center animate-on-scroll">
        <a href={STORE_URL} target="_blank" rel="noopener noreferrer" class="or-btn-primary">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-1.99.9-1.99 2v3.8H3.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7s2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z"/></svg>
          Add to Chrome (free)
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       ORIGIN
       ============================================================ -->
  <section class="px-6 py-16 md:py-24">
    <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14 items-center">
      <div class="animate-on-scroll order-2 md:order-1">
        <p class="text-xs tracking-[0.2em] uppercase text-[var(--color-accent)] mb-4" style="font-family: var(--font-mono);">Why a recipe extension</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-6 dark:text-white text-[var(--color-primary)]" style="font-family: var(--font-heading);">
          Of all the things to build first.
        </h2>
        <div class="space-y-4 text-lg leading-relaxed dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)]">
          <p>
            Short answer: I cook, and recipe websites had finally annoyed me into writing code.
          </p>
          <p>
            I am a vegetarian who actually makes dinner, so I spend real time on these sites, so I have developed real opinions about them. I have built MCP servers for enterprise finance, a podcast, and a couple of companies. I had never built a browser extension.
          </p>
          <p>
            So one irritated evening, I built one. It does exactly one thing and does it well, which is the kindest thing you can say about most software. This is my first extension, and the building of it was satisfying enough that it will not be the last.
          </p>
        </div>
      </div>
      <div class="animate-on-scroll order-1 md:order-2">
        <div class="relative">
          <div class="absolute -inset-4 rounded-2xl bg-[var(--color-accent)]/10 blur-2xl"></div>
          <img src="/images/only-recipes-edward.png"
            alt="Edward Roske in his signature blue fedora and a dark apron, holding a wooden spoon in a spotless modern kitchen, looking mildly unimpressed."
            class="relative rounded-2xl w-full shadow-2xl ring-1 ring-white/10"
            loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       FAQ
       ============================================================ -->
