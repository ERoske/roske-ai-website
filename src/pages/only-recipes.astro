<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const root = document.getElementById('or-demo');
    if (!root) return;

    const base = parseInt(root.dataset.base || '4', 10);
    const servingsEl = document.getElementById('or-servings');
    const minus = document.getElementById('or-minus');
    const plus = document.getElementById('or-plus');
    const heart = document.getElementById('or-heart');
    const unitBtns = root.querySelectorAll('.or-unit-btn');
    const ingRows = root.querySelectorAll('.or-ing');

    function fmt(n, integer, metric) {
      if (integer) return String(Math.max(1, Math.round(n)));
      if (metric) return String(Math.round(n));
      const r = Math.round(n * 100) / 100;
      return (r % 1 === 0) ? String(r) : String(parseFloat(r.toFixed(2)));
    }

    function recompute() {
      const servings = parseInt(root.dataset.servings || String(base), 10);
      const system = root.dataset.system || 'us';
      const metric = system === 'metric';
      ingRows.forEach((row) => {
        const amt = row.querySelector('.or-amt');
        if (!amt) return;
        const rawQty = metric ? amt.dataset.metricQty : amt.dataset.usQty;
        if (rawQty === undefined || rawQty === '' || rawQty === null) return;
        const qty = parseFloat(rawQty);
        if (isNaN(qty)) return;
        const unit = metric ? (amt.dataset.metricUnit || '') : (amt.dataset.usUnit || '');
        const integer = amt.dataset.integer === '1';
        const scaled = qty * servings / base;
        amt.textContent = (fmt(scaled, integer, metric) + ' ' + unit).trim();
      });
    }

    function setServings(n) {
      const clamped = Math.max(1, Math.min(40, n));
      root.dataset.servings = String(clamped);
      if (servingsEl) servingsEl.textContent = String(clamped);
      recompute();
    }

    if (minus) minus.addEventListener('click', () => setServings(parseInt(root.dataset.servings || String(base), 10) - 1));
    if (plus) plus.addEventListener('click', () => setServings(parseInt(root.dataset.servings || String(base), 10) + 1));

    unitBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        root.dataset.system = btn.dataset.unit || 'us';
        unitBtns.forEach((b) => b.classList.toggle('is-on', b === btn));
        recompute();
      });
    });

    if (heart) {
      heart.addEventListener('click', () => {
        const on = heart.classList.toggle('is-on');
        heart.setAttribute('aria-pressed', String(on));
      });
    }

    root.querySelectorAll('.or-check').forEach((row) => {
      row.addEventListener('click', () => row.classList.toggle('is-checked'));
    });

    recompute();
  });
</script>
