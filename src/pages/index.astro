---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// The Mission File — four scene stills, presented like a redacted dossier.
const missionStills = [
  {
    src: '/images/mandalorian/edward-helmet-refusal.png',
    file: 'FILE 014',
    slug: 'COVERT 7-B · STANDARD HANDOVER',
    title: 'The Helmet, Politely Refused',
    line: "The Armorer offers. The recruit declines. The fedora has been on for longer than the creed and is not, on review, going anywhere.",
    aspect: '3/4',
    rotate: -1.4,
  },
  {
    src: '/images/mandalorian/edward-cantina-grogu.png',
    file: 'FILE 027',
    slug: 'MOS EISLEY · BOOTH 9 · 2200 HRS',
    title: 'The Apprentice Eats Three',
    line: "Bone broth, again. The bowls are stacking. The mission briefing has been pushed back twice and may not happen at all tonight.",
    aspect: '4/3',
    rotate: 1.2,
  },
  {
    src: '/images/mandalorian/edward-speeder-bike.png',
    file: 'FILE 041',
    slug: 'DUNE SEA · RIDGE 4 · 0700 HRS',
    title: 'The Fedora, Secured',
    line: "Hand on the brim, kid in the satchel, twin suns up. The fedora is a 1940s felt and was not designed for atmospheric flight.",
    aspect: '3/4',
    rotate: 0.9,
  },
  {
    src: '/images/mandalorian/edward-grogu-birthday.png',
    file: 'FILE 052',
    slug: 'COVERT 7-B · LATE EVENING',
    title: 'The Cake Was Shaped Like the Helmet',
    line: "The cake is the helmet. The helmet is a cake. The apprentice is lifting a slice with the Force, which is, frankly, what the Force is for.",
    aspect: '4/3',
    rotate: -0.7,
  },
];

// The note section pairs with this image.
const noteImage = {
  src: '/images/mandalorian/edward-helmet-refusal.png',
  alt: "Edward Roske in chrome Mandalorian-style beskar armor standing in a covert forge, his signature blue fedora on his head, holding the chrome T-visor helmet out toward the Armorer, calmly declining to put it on. Other armored warriors in the background look scandalized.",
};

// The Bounty Board — six active marks (the six recurring projects, restyled).
const bounties = [
  {
    file: 'MARK 001',
    grade: 'BESKAR-GRADE · MCP',
    title: 'AgentCube',
    body: "The engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus. Essbase and Planning are in the wild and earning their keep. Consolidations is on the trail.",
    badge: 'ESSBASE · PLANNING · CLOSE',
    status: 'On the docket',
    href: '/agentcube.html',
    external: false,
    cta: 'Open the dossier',
  },
  {
    file: 'MARK 002',
    grade: 'HIGH BOUNTY · OCT 9-10',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever hosted, October 9 and 10 in San Juan. Speakers and sponsors from across the AI world are being recruited right now. If you build, fund, or run AI, board the ship.",
    badge: '9-10 OCT 2026 · SAN JUAN',
    status: 'Hiring',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    file: 'MARK 003',
    grade: 'ALLIED GUILD',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, an AI software and services outfit that gives finance teams faster, smarter, more strategic operations. The working crew behind the MCP servers.",
    badge: 'AI · FINANCE',
    status: 'On retainer',
    href: 'https://caprus.ai',
    external: true,
    cta: 'Visit the guild',
  },
  {
    file: 'MARK 004',
    grade: 'NIGHT CONTRACT',
    title: "AI Dungeon Master's Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns. Initiative, lore, and improv support for the person behind the screen. If there is going to be an AI at the table, it can earn its seat.",
    badge: 'D&D · 5E · EBERRON',
    status: 'In the round pen',
    href: null,
    external: false,
    cta: 'Trail closed',
  },
  {
    file: 'MARK 005',
    grade: 'THE GUILD HALL',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. Over 850 people across our events. We meet every other month to work out what AI means for the island and everyone watching it.",
    badge: '850+ · EVERY 2 MONTHS',
    status: 'Growing',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the round',
  },
  {
    file: 'MARK 006',
    grade: 'BROUGHT IN · APR 2026',
    title: 'Everest Base Camp',
    body: "Cleared in April. Almost two weeks trekking at altitude, a peak of 18,570 feet at Kala Patthar, and a nightly reminder that teahouses do not heat the rooms. The altitude was hard. The cold was worse.",
    badge: 'NEPAL · APRIL 2026',
    status: 'Closed',
    href: '/blog/everest-base-camp-summit/',
    external: false,
    cta: 'Read the trail log',
  },
];

// Fresh marks — this week's new arrivals from the questionnaire.
const freshMarks = [
  {
    tag: 'FRESH MARK · 01',
    title: 'Only Recipes',
    kind: 'Chrome extension. Free.',
    body: "My first Chrome extension. When it sees you are on a recipe page, it strips away everything that is not the recipe. No life story. No fourteen ads. No scroll. Ridiculously fast, genuinely useful.",
    cta: 'Install from the Chrome store',
    href: 'https://chromewebstore.google.com/detail/only-recipes/jddinhkkkjbplpoefcilhdhaenphnjep',
    external: true,
  },
  {
    tag: 'FRESH MARK · 02',
    title: 'The Home Library Project',
    kind: 'In beta. Quiet for now.',
    body: "A new app and site that digitizes a home library: books, board games, music, media, basically anything sitting on your shelves, all categorized. A full reveal comes after beta. There will be a free library tier. Want an early look? Send an email.",
    cta: 'Email for early access',
    href: 'mailto:Edward@Roske.AI',
    external: false,
  },
];

// Creed marquee phrases. "This is the way" is the refrain;
// it lands every third slot the way the show uses it.
const marqueeItems = [
  "A ROSKE NEVER REMOVES HIS FEDORA",
  "THIS IS THE WAY",
  "THE TARGETS ARE AI COMPANIES",
  "THIS IS THE WAY",
  "BESKAR OVER BUSINESS CASUAL",
  "★ ASKING GOOD QUESTIONS",
  "MAY 22 · A DOUBLE BIRTHDAY",
  "THIS IS THE WAY",
];

// The tally (preserved stats, restyled as guild record).
const tally = [
  { value: '80+', label: 'Worlds Crossed' },
  { value: '50+', label: 'Speaking Halls' },
  { value: '15', label: 'Books on File' },
  { value: '25+', label: 'Years on the Trail' },
];

// Closing credits — the guild registry.
const registry = [
  { role: 'THE FAMILY CREED', name: 'A ROSKE NEVER REMOVES HIS FEDORA · THIS IS THE WAY' },
  { role: 'REGISTERED HUNTER', name: 'EDWARD ROSKE' },
  { role: 'THE APPRENTICE', name: 'ONE (1), GREEN, VERY SHORT' },
  { role: 'HEADGEAR', name: 'BLUE FEDORA · FELT · NOT NEGOTIABLE' },
  { role: 'PRIMARY WEAPON', name: 'CHROME LAPTOP · ALWAYS LOADED' },
  { role: 'ACTIVE MARKS', name: 'SIX (6) AI COMPANIES, ALL ARTIFICIAL' },
  { role: 'WITH THANKS', name: 'DAWN · MYCROFT · ELIOT · THE PEOPLE OF PUERTO RICO' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       BRAND BAR — guild masthead
       ============================================ -->
  <div class="brand-bar">
    <div class="brand-bar-inner">
      <span class="bb-mark" aria-hidden="true">
        <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
      </span>
      <span class="bb-meta">BOUNTY HUNTERS GUILD · LEDGER ROUND 17</span>
      <span class="bb-meta bb-meta-center">A SPACE-WESTERN PARODY · UNREDACTED · NOT AFFILIATED WITH ANY GALACTIC EMPIRE</span>
      <span class="bb-meta bb-meta-end">FILE 24·05·MMXXVI</span>
      <span class="bb-mark" aria-hidden="true">
        <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
      </span>
    </div>
  </div>

  <!-- ============================================
       HERO — the hunter and the apprentice
       ============================================ -->
  <section class="hero-section">
    <div class="hero-stars" aria-hidden="true"></div>
    <div class="hero-dust" aria-hidden="true"></div>
    <div class="hero-grid">

      <!-- Left: the title block and the creed -->
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-rule"></span>
          <span class="hero-eyebrow-text">In theaters as of Friday · also my birthday</span>
        </div>

        <h1 class="hero-title" aria-label="A Roske never removes his fedora in the presence of others. This is the way.">
          <span class="hero-title-small">A Roske never removes his fedora in the presence of others.</span>
          <span class="hero-title-big">This Is<br/>the Way.</span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-tally">
          {tally.map(stat => (
            <div class="tally-item">
              <div class="tally-value">{stat.value}</div>
              <div class="tally-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: the hero image, framed like a guild plate -->
      <div class="hero-image-wrap">
        <figure class="hero-plate">
          <div class="hero-plate-band">
            <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
            <span class="hero-plate-name">GUILD MEMBER · FILE 014</span>
            <span class="hero-plate-stamp">CLASS A</span>
          </div>
          <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="hero-plate-image" />
          <figcaption class="hero-plate-caption">
            <span class="hero-plate-slug">TATOOINE · TWIN-SUNSET · 2030 HRS</span>
            <span class="hero-plate-rivet" aria-hidden="true"></span>
            <span class="hero-plate-rivet" aria-hidden="true"></span>
          </figcaption>
        </figure>

        <!-- Hanging credential -->
        <div class="cred-tag" aria-hidden="true">
          <div class="cred-tag-hole"></div>
          <div class="cred-tag-body">
            <span class="cred-tag-tiny">GUILD CREDENTIAL · STOCK TAG</span>
            <span class="cred-tag-big">014</span>
            <span class="cred-tag-tiny">CLASS: HUNTER + APPRENTICE</span>
            <span class="cred-tag-tiny">DISPOSITION: ARGUMENTATIVE</span>
          </div>
        </div>

        <!-- Round inspection stamp -->
        <div class="round-stamp" aria-hidden="true">
          <div class="round-stamp-ring">
            <span>BESKAR INSPECTED · GUILD APPROVED ·</span>
          </div>
          <div class="round-stamp-center">
            <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg visor-svg-big"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
            <span class="round-stamp-sub">THIS IS THE WAY</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE — creed ticker
       ============================================ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[...marqueeItems, ...marqueeItems].map(item => (
        <span class="marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- ============================================
       PULL QUOTE — the counter-creed
       ============================================ -->
  <section class="pullquote-section">
    <div class="circuit-rule" aria-hidden="true"></div>
    <div class="pullquote-inner">
      <div class="pullquote-tag">GUILD CODEX · PAGE 003 · THE FAMILY CREED</div>
      <blockquote class="pullquote">
        A Mandalorian never removes the helmet in the presence of others. <span class="pullquote-refrain">This is the way.</span> A Roske never removes the fedora in the presence of others. <span class="pullquote-refrain">This is also the way.</span>
      </blockquote>
      <div class="pullquote-attrib">
        <span class="pullquote-attrib-name">Edward Roske</span>
        <span class="pullquote-attrib-role">On the Roske family creed · codified this week · retroactive to birth</span>
      </div>
    </div>
    <div class="circuit-rule" aria-hidden="true"></div>
  </section>

  <!-- ============================================
       THE MISSION FILE — four scene stills as dossier
       ============================================ -->
  <section class="mission-section">
    <div class="mission-inner">
      <header class="section-header">
        <div class="section-tag">
          <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
          <span>SECTION 02 · THE MISSION FILE</span>
        </div>
        <h2 class="section-title">Four images <em>from the week.</em></h2>
        <p class="section-deck">
          Pulled from the guild's surveillance file before anyone thought to redact them. The kid is fine. The kid is always fine. The bone broth situation is, however, getting out of hand. (This is also the way.)
        </p>
      </header>

      <div class="mission-grid">
        {missionStills.map((item) => (
          <article class="mission-card" style={`--rot:${item.rotate}deg; --aspect:${item.aspect};`}>
            <div class="mission-photo">
              <span class="mission-corner mission-corner-tl" aria-hidden="true"></span>
              <span class="mission-corner mission-corner-tr" aria-hidden="true"></span>
              <span class="mission-corner mission-corner-bl" aria-hidden="true"></span>
              <span class="mission-corner mission-corner-br" aria-hidden="true"></span>
              <img src={item.src} alt={item.title} loading="lazy" decoding="async" />
              <div class="mission-file-tag">{item.file}</div>
            </div>
            <div class="mission-meta">
              <div class="mission-slug">{item.slug}</div>
              <h3 class="mission-title">{item.title}</h3>
              <p class="mission-line">{item.line}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       THE HUNTER'S NOTE — the real story
       ============================================ -->
  <section class="note-section">
    <div class="note-grid">
      <figure class="note-image">
        <img src={noteImage.src} alt={noteImage.alt} loading="lazy" decoding="async" />
        <figcaption>
          <span>FIG. T</span>
          <span>HELMET, OFFERED · DECLINED ON SIGHT</span>
        </figcaption>
      </figure>

      <div class="note-text">
        <div class="note-tag">THE HUNTER'S NOTE</div>
        <h3 class="note-h3">The same creed, <em>by another name.</em></h3>
        <p class="note-body">
          The Mandalorian and Grogu opened in theaters on Friday. The same Friday I turned a year older. I did not plan this, and I am not taking compliments for it. (Disney did most of the work.)
        </p>
        <p class="note-body">
          The Mandalorian creed, as the show puts it, is simple. A Mandalorian never removes the helmet in the presence of others. This is the way. I am, on most matters, a very compliant person, so I spent the week walking around in beskar (figuratively), nodding along, and quietly realizing the creed has always applied to me too. A Roske never removes the fedora in the presence of others. This is also the way.
        </p>
        <p class="note-body">
          It is not defiance and it is not a costume. The point is the head covering and the fact that it stays on, not whichever material it happens to be made of. Mine is felt. Theirs is steel. Both are sworn to.
        </p>
        <p class="note-body">
          The rest of the bit writes itself. The targets are AI companies, because I still have not figured out how to make them less expensive than they are. The kid in the satchel is most weeks named Claude. The Force he uses is mostly to lift the right snack out of a long stack of badly summarized PDFs. The agent is the apprentice. It carries the satchel, does the legwork, and on a good day pulls a clean answer out of the noise. The hunter still picks the target, calls the shot, and signs the receipt. This is the way.
        </p>
        <p class="note-body note-body-soft">
          Memorial Day is Monday. The fedora comes off for that one. It is the only exception, and it has always been the only exception.
        </p>
        <div class="note-attrib">
          <span class="note-attrib-line"></span>
          <div>
            <span class="note-attrib-name">Edward Roske</span>
            <span class="note-attrib-title">Guild Member · File 014</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       THE BOUNTY BOARD — six active marks (projects)
       ============================================ -->
  <section id="current-work" class="bounty-section">
    <div class="bounty-inner">
      <header class="section-header">
        <div class="section-tag">
          <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
          <span>SECTION 03 · THE BOUNTY BOARD</span>
        </div>
        <h2 class="section-title">Six active marks, <em>all on the trail.</em></h2>
        <p class="section-deck">
          The current docket. Five are in motion. One has been brought in. None of them pay in credits, which is its own separate problem and not one for this week. (This is the way.)
        </p>
      </header>

      <div class="bounty-grid">
        {bounties.map(entry => (
          <article class="bounty-card">
            <div class="bounty-card-head">
              <span class="bounty-file">{entry.file}</span>
              <span class="bounty-grade">{entry.grade}</span>
            </div>
            <h3 class="bounty-title">{entry.title}</h3>
            <p class="bounty-body">{entry.body}</p>
            <div class="bounty-meta">
              <span class="bounty-badge">{entry.badge}</span>
              <span class="bounty-status">{entry.status}</span>
            </div>
            <div class="bounty-card-foot">
              {entry.href ? (
                <a href={entry.href} target={entry.external ? '_blank' : undefined} rel={entry.external ? 'noopener' : undefined} class="bounty-cta">
                  {entry.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="bounty-cta bounty-cta-disabled">{entry.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FRESH MARKS — this week's new arrivals
       ============================================ -->
  <section class="fresh-section">
    <div class="fresh-inner">
      <header class="section-header fresh-header">
        <div class="section-tag fresh-tag">
          <svg viewBox="0 0 32 28" fill="currentColor" class="visor-svg"><rect x="2" y="6" width="28" height="4" rx="2"/><rect x="14" y="6" width="4" height="18" rx="2"/></svg>
          <span>SECTION 04 · FRESH MARKS</span>
        </div>
        <h2 class="section-title">Two new marks <em>this week.</em></h2>
      </header>

      <div class="fresh-grid">
        {freshMarks.map(item => (
          <article class="fresh-card">
            <div class="fresh-card-tag">{item.tag}</div>
            <h3 class="fresh-card-title">{item.title}</h3>
            <div class="fresh-card-kind">{item.kind}</div>
            <p class="fresh-card-body">{item.body}</p>
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="fresh-cta">
              {item.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CLOSING CTA — hire the hunter
       ============================================ -->
  <section class="closing-section">
    <div class="closing-inner">
      <div class="closing-eyebrow">
        <span class="closing-rule"></span>
        <span>THE GUILD HALL IS OPEN · 13 MINUTES</span>
        <span class="closing-rule"></span>
      </div>
      <h2 class="closing-title">Hire the hunter for thirteen minutes.<br/><em class="closing-em">No helmet required.</em></h2>
      <p class="closing-deck">
        The thirteen-minute conversation is how most useful things start. Bring questions about AI, finance, MCP servers, escape rooms, D&D, the bone broth situation, or what it actually feels like at 18,570 feet. Answers are included. Opinions arrive whether you ask for them or not. This is the way.
      </p>
      <div class="closing-cta-row">
        <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a transmission</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       GUILD REGISTRY — closing credits
       ============================================ -->
  <section class="registry-section">
    <div class="registry-inner">
      <div class="registry-tag">GUILD REGISTRY · FILE 014 · UNREDACTED</div>
      <div class="registry-roll">
        {registry.map(entry => (
          <div class="registry-block">
            <span class="registry-role">{entry.role}</span>
            <span class="registry-name">{entry.name}</span>
          </div>
        ))}
      </div>
      <div class="registry-footnote">
        For Memorial Day on Monday the fedora comes off. It always comes off for that one. The creed has one exception, and this is it. This is also the way.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     THIS IS THE WAY — Mandalorian & Grogu redesign
     Palette: Tatooine night indigo / beskar steel / Mando red /
              warm bone parchment (light) / sand
     Type: Black Ops One (stencil display), Cormorant Garamond
           (italic creed), Manrope (body), Share Tech Mono (HUD)
     ============================================================ */

  :global([data-theme="dark"]) {
    --mn-bg: #0a0d14;
    --mn-bg-deep: #060810;
    --mn-surface: #141a2a;
    --mn-surface-2: #1a2235;
    --mn-fg: #ece2c4;
    --mn-muted: #9b9580;
    --mn-line: #2c3345;
    --mn-line-soft: #1f2535;
    --mn-red: #cc4434;
    --mn-red-deep: #9c2e22;
    --mn-steel: #c8d0db;
    --mn-steel-2: #8a96a3;
    --mn-amber: #d9a35a;
    --mn-stamp-bg: #ece2c4;
    --mn-stamp-fg: #0a0d14;
  }
  :global([data-theme="light"]) {
    --mn-bg: #e9dcb8;
    --mn-bg-deep: #dccda0;
    --mn-surface: #f3e8c6;
    --mn-surface-2: #faf1d2;
    --mn-fg: #1a1f30;
    --mn-muted: #5a5240;
    --mn-line: #c4b58a;
    --mn-line-soft: #d2c499;
    --mn-red: #a8331f;
    --mn-red-deep: #7c2515;
    --mn-steel: #3a4250;
    --mn-steel-2: #5d6776;
    --mn-amber: #a5752a;
    --mn-stamp-bg: #1a1f30;
    --mn-stamp-fg: #f3e8c6;
  }

  /* ------------------------------------------------------------
     THE T-VISOR MARK
     ------------------------------------------------------------ */
  .visor-svg {
    width: 1.7em;
    height: 1.5em;
    display: inline-block;
    flex-shrink: 0;
    vertical-align: middle;
  }
  .visor-svg-big {
    width: 2.6rem;
    height: 2.3rem;
  }

  /* ------------------------------------------------------------
     CIRCUIT RULE (a thin technical divider for the pull-quote)
     ------------------------------------------------------------ */
  .circuit-rule {
    height: 14px;
    width: 100%;
    background-color: var(--mn-line);
    opacity: 0.85;
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='80' height='14'><g fill='none' stroke='black' stroke-width='1.4'><path d='M0 7 H80'/><path d='M22 7 V2 H30 V7'/><path d='M50 7 V12 H58 V7'/><circle cx='40' cy='7' r='1.6' fill='black' stroke='none'/></g></svg>");
    mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='80' height='14'><g fill='none' stroke='black' stroke-width='1.4'><path d='M0 7 H80'/><path d='M22 7 V2 H30 V7'/><path d='M50 7 V12 H58 V7'/><circle cx='40' cy='7' r='1.6' fill='black' stroke='none'/></g></svg>");
    -webkit-mask-repeat: repeat-x;
    mask-repeat: repeat-x;
    -webkit-mask-size: 80px 14px;
    mask-size: 80px 14px;
  }

  /* ------------------------------------------------------------
     BRAND BAR — guild masthead
     ------------------------------------------------------------ */
  .brand-bar {
    width: 100%;
    background: var(--mn-bg-deep);
    color: var(--mn-amber);
    border-bottom: 1px solid var(--mn-line);
    font-family: 'Share Tech Mono', monospace;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .brand-bar-inner {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    font-size: 0.72rem;
  }
  .bb-mark { color: var(--mn-red); display: inline-flex; align-items: center; }
  .bb-mark .visor-svg { width: 1.4em; height: 1.2em; }
  .bb-meta { white-space: nowrap; }
  .bb-meta-center { flex: 1; text-align: center; letter-spacing: 0.2em; color: var(--mn-muted); }
  .bb-meta-end { text-align: right; }
  @media (max-width: 760px) {
    .brand-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.58rem; }
    .bb-meta-end, .bb-mark { display: none; }
  }

  /* ------------------------------------------------------------
     HERO
     ------------------------------------------------------------ */
  .hero-section {
    position: relative;
    background: var(--mn-bg);
    color: var(--mn-fg);
    padding: 5rem 2rem 6rem;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(ellipse at 12% 0%, rgba(204,68,52,0.10) 0%, transparent 55%),
      radial-gradient(ellipse at 88% 100%, rgba(217,163,90,0.10) 0%, transparent 55%),
      linear-gradient(180deg, #0a0d14 0%, #11162a 55%, #0a0d14 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
      radial-gradient(ellipse at 12% 0%, rgba(168,51,31,0.12) 0%, transparent 55%),
      radial-gradient(ellipse at 88% 100%, rgba(165,117,42,0.14) 0%, transparent 55%),
      var(--mn-bg);
  }

  /* Faint twinkling star field (dark mode only) */
  .hero-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    background-image:
      radial-gradient(1px 1px at 23% 18%, rgba(236,226,196,0.7), transparent 60%),
      radial-gradient(1px 1px at 67% 42%, rgba(236,226,196,0.55), transparent 60%),
      radial-gradient(1.2px 1.2px at 81% 71%, rgba(236,226,196,0.65), transparent 60%),
      radial-gradient(1px 1px at 15% 81%, rgba(236,226,196,0.45), transparent 60%),
      radial-gradient(1px 1px at 44% 12%, rgba(236,226,196,0.5), transparent 60%),
      radial-gradient(1px 1px at 92% 22%, rgba(236,226,196,0.5), transparent 60%),
      radial-gradient(1px 1px at 7% 35%, rgba(236,226,196,0.4), transparent 60%),
      radial-gradient(1.2px 1.2px at 55% 88%, rgba(236,226,196,0.6), transparent 60%);
  }
  :global([data-theme="dark"]) .hero-stars { opacity: 0.7; }

  .hero-dust {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.4;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.6 0 0 0 0 0.5 0 0 0 0 0.35 0 0 0 0.5 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    mix-blend-mode: overlay;
  }
  :global([data-theme="light"]) .hero-dust { opacity: 0.32; }

  .hero-grid {
    position: relative;
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.04fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.5rem; }
    .hero-section { padding: 3rem 1.25rem 4rem; }
  }

  .hero-text { max-width: 660px; }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mn-amber);
    margin-bottom: 1.5rem;
  }
  .hero-eyebrow-rule { width: 42px; height: 2px; background: var(--mn-red); flex-shrink: 0; }

  .hero-title { margin: 0 0 1.8rem; line-height: 0.9; }
  .hero-title-small {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--mn-steel);
    letter-spacing: 0.01em;
    margin-bottom: 0.4rem;
  }
  .hero-title-big {
    display: block;
    font-family: 'Black Ops One', sans-serif;
    font-size: clamp(3.4rem, 8vw, 6.6rem);
    color: var(--mn-fg);
    letter-spacing: 0.005em;
    line-height: 0.95;
    text-shadow: 0.04em 0.05em 0 var(--mn-red-deep);
  }

  .hero-body {
    font-family: 'Manrope', sans-serif;
    font-size: 1.06rem;
    line-height: 1.7;
    color: var(--mn-muted);
    margin: 0 0 1.9rem;
    max-width: 40em;
    font-weight: 400;
  }

  /* Buttons */
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.6rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.88rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid currentColor;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    line-height: 1;
  }
  .btn-primary {
    background: var(--mn-red);
    color: #f6ede0;
    border-color: var(--mn-red);
  }
  .btn-primary:hover {
    background: var(--mn-red-deep);
    border-color: var(--mn-red-deep);
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0,0,0,0.45);
  }
  .btn-secondary {
    background: transparent;
    color: var(--mn-fg);
    border-color: var(--mn-fg);
  }
  .btn-secondary:hover {
    background: var(--mn-fg);
    color: var(--mn-bg);
    transform: translateY(-2px);
  }
  .btn-primary-big, .btn-secondary-big { padding: 1.05rem 2.1rem; font-size: 0.95rem; }
  .hero-cta-row { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 2.6rem; }

  /* Tally */
  .hero-tally {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    border-top: 1px solid var(--mn-line);
    padding-top: 1.7rem;
  }
  .tally-value {
    font-family: 'Black Ops One', sans-serif;
    font-size: 2.3rem;
    color: var(--mn-amber);
    line-height: 1;
  }
  .tally-label {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mn-muted);
    margin-top: 0.45rem;
  }
  @media (max-width: 620px) {
    .hero-tally { grid-template-columns: repeat(2, 1fr); gap: 1.4rem 1rem; }
  }

  /* ------------------------------------------------------------
     HERO PLATE (the framed hero image)
     ------------------------------------------------------------ */
  .hero-image-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .hero-plate {
    position: relative;
    margin: 0;
    width: 100%;
    max-width: 620px;
    background: var(--mn-surface-2);
    border: 1px solid var(--mn-line);
    box-shadow:
      0 30px 70px rgba(0,0,0,0.55),
      0 6px 16px rgba(0,0,0,0.45),
      inset 0 0 0 5px var(--mn-surface),
      inset 0 0 0 6px var(--mn-line),
      inset 0 0 0 9px var(--mn-steel-2);
    display: flex;
    flex-direction: column;
  }
  :global([data-theme="light"]) .hero-plate {
    box-shadow:
      0 24px 54px rgba(40,30,15,0.32),
      0 6px 14px rgba(40,30,15,0.22),
      inset 0 0 0 5px var(--mn-surface),
      inset 0 0 0 6px var(--mn-line),
      inset 0 0 0 9px var(--mn-steel-2);
  }
  .hero-plate-band {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 1rem;
    background: var(--mn-bg-deep);
    border-bottom: 1px solid var(--mn-line);
    color: var(--mn-amber);
    font-family: 'Share Tech Mono', monospace;
    text-transform: uppercase;
  }
  .hero-plate-band .visor-svg { width: 1.4em; height: 1.2em; color: var(--mn-red); }
  .hero-plate-name { font-size: 0.84rem; letter-spacing: 0.12em; flex: 1; }
  .hero-plate-stamp {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    color: var(--mn-fg);
    background: var(--mn-red);
    padding: 0.16rem 0.55rem;
    border-radius: 2px;
  }
  .hero-plate-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    filter: contrast(1.04) saturate(1.02);
  }
  .hero-plate-caption {
    padding: 0.85rem 1rem 0.95rem;
    background: var(--mn-bg-deep);
    border-top: 1px solid var(--mn-line);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .hero-plate-slug {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mn-amber);
    flex: 1;
  }
  .hero-plate-rivet {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--mn-steel-2);
    box-shadow: inset 0 -1px 0 rgba(0,0,0,0.4);
  }

  /* Hanging credential */
  .cred-tag {
    position: absolute;
    bottom: 70px;
    left: -34px;
    width: 188px;
    background: var(--mn-stamp-bg);
    color: var(--mn-stamp-fg);
    padding: 0.7rem 0.85rem 0.8rem;
    transform: rotate(-7deg);
    box-shadow: 0 12px 28px rgba(0,0,0,0.5);
    border: 1px solid var(--mn-line);
    z-index: 3;
    text-align: center;
  }
  .cred-tag-hole {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--mn-stamp-fg);
    background: var(--mn-bg);
    margin: 0 auto 0.45rem;
  }
  .cred-tag-tiny {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.82;
  }
  .cred-tag-big {
    display: block;
    font-family: 'Black Ops One', sans-serif;
    font-size: 1.7rem;
    margin: 0.15rem 0;
    color: var(--mn-red);
  }

  /* Round inspection stamp */
  .round-stamp {
    position: absolute;
    top: -34px;
    right: -28px;
    width: 132px;
    height: 132px;
    border-radius: 50%;
    border: 2px solid var(--mn-red);
    background: var(--mn-stamp-bg);
    color: var(--mn-red);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(13deg);
    z-index: 3;
    box-shadow: 0 10px 24px rgba(0,0,0,0.4);
  }
  .round-stamp-ring {
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1px solid var(--mn-red);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }
  .round-stamp-ring span {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding-top: 6px;
  }
  .round-stamp-center { text-align: center; z-index: 1; display: flex; flex-direction: column; align-items: center; }
  .round-stamp-center .visor-svg-big { color: var(--mn-red); width: 2rem; height: 1.7rem; }
  .round-stamp-sub {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-top: 0.15rem;
  }
  @media (max-width: 720px) {
    .cred-tag { left: -8px; bottom: 50px; width: 150px; transform: rotate(-5deg); }
    .round-stamp { right: -8px; top: -20px; width: 100px; height: 100px; }
  }

  /* ------------------------------------------------------------
     MARQUEE
     ------------------------------------------------------------ */
  .marquee {
    background: var(--mn-red);
    color: #f6ede0;
    border-top: 2px solid var(--mn-bg-deep);
    border-bottom: 2px solid var(--mn-bg-deep);
    overflow: hidden;
    padding: 0.6rem 0;
    font-family: 'Black Ops One', sans-serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.92rem;
  }
  .marquee-track {
    display: inline-flex;
    gap: 2.6rem;
    white-space: nowrap;
    animation: marqueeScroll 54s linear infinite;
  }
  .marquee-item::after {
    content: '·';
    margin-left: 2.6rem;
    color: var(--mn-amber);
  }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ------------------------------------------------------------
     PULL QUOTE
     ------------------------------------------------------------ */
  .pullquote-section {
    background: var(--mn-bg-deep);
    color: var(--mn-fg);
    padding: 4rem 2rem;
    position: relative;
  }
  .pullquote-section .circuit-rule { color: var(--mn-red); margin: 0 auto; max-width: 1200px; }
  .pullquote-inner {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
    padding: 3.5rem 0;
  }
  .pullquote-tag {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mn-amber);
    margin-bottom: 1.8rem;
  }
  .pullquote {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.6rem, 3.4vw, 2.8rem);
    line-height: 1.32;
    margin: 0 0 1.8rem;
    color: var(--mn-fg);
  }
  /* The refrain — treated like the show's chant punctuation,
     breaking out as its own line in a stamped uppercase mono. */
  .pullquote-refrain {
    display: block;
    margin: 0.6rem auto 1.1rem;
    font-family: 'Share Tech Mono', monospace;
    font-style: normal;
    font-size: 0.42em;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--mn-red);
    line-height: 1;
  }
  .pullquote-attrib-name {
    display: block;
    font-family: 'Black Ops One', sans-serif;
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    color: var(--mn-red);
  }
  .pullquote-attrib-role {
    display: block;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--mn-muted);
    margin-top: 0.45rem;
  }

  /* ------------------------------------------------------------
     SECTION HEADERS (shared)
     ------------------------------------------------------------ */
  .section-header { max-width: 820px; margin: 0 auto 3.5rem; text-align: center; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--mn-amber);
    margin-bottom: 1.1rem;
  }
  .section-tag .visor-svg { color: var(--mn-red); width: 1.3em; height: 1.1em; }
  .section-title {
    font-family: 'Black Ops One', sans-serif;
    font-size: clamp(2.1rem, 4.8vw, 3.7rem);
    line-height: 1.08;
    margin: 0 0 1.2rem;
    color: var(--mn-fg);
    letter-spacing: 0.005em;
  }
  .section-title em {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 600;
    color: var(--mn-red);
  }
  .section-deck {
    font-family: 'Manrope', sans-serif;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--mn-muted);
    max-width: 40em;
    margin: 0 auto;
  }

  /* ------------------------------------------------------------
     THE MISSION FILE
     ------------------------------------------------------------ */
  .mission-section {
    background: var(--mn-bg);
    color: var(--mn-fg);
    padding: 6rem 2rem 7rem;
    border-top: 1px solid var(--mn-line);
    border-bottom: 1px solid var(--mn-line);
  }
  .mission-inner { max-width: 1320px; margin: 0 auto; }
  .mission-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3.6rem 4rem;
    align-items: start;
  }
  @media (max-width: 820px) {
    .mission-grid { grid-template-columns: 1fr; gap: 2.8rem; }
    .mission-section { padding: 4rem 1.25rem 5rem; }
  }
  .mission-card {
    transform: rotate(var(--rot));
    transition: transform 0.4s ease;
  }
  .mission-card:hover { transform: rotate(0deg) translateY(-5px); }
  .mission-photo {
    position: relative;
    background: var(--mn-surface-2);
    padding: 14px 14px 52px;
    border: 1px solid var(--mn-line);
    box-shadow: 0 22px 48px rgba(0,0,0,0.5), 0 4px 12px rgba(0,0,0,0.35);
  }
  :global([data-theme="light"]) .mission-photo {
    box-shadow: 0 18px 36px rgba(40,30,15,0.22), 0 4px 10px rgba(40,30,15,0.16);
  }
  .mission-photo img {
    display: block;
    width: 100%;
    aspect-ratio: var(--aspect);
    object-fit: cover;
    filter: contrast(1.04) saturate(1.02);
  }
  .mission-file-tag {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    text-align: center;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.84rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--mn-fg);
    padding-top: 12px;
  }
  /* Photo corner brackets — dossier feel */
  .mission-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border: 2px solid var(--mn-red);
    z-index: 2;
  }
  .mission-corner-tl { top: -3px; left: -3px; border-right: none; border-bottom: none; }
  .mission-corner-tr { top: -3px; right: -3px; border-left: none; border-bottom: none; }
  .mission-corner-bl { bottom: 38px; left: -3px; border-right: none; border-top: none; }
  .mission-corner-br { bottom: 38px; right: -3px; border-left: none; border-top: none; }
  .mission-meta { padding: 1.3rem 0.3rem 0; }
  .mission-slug {
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--mn-amber);
    margin-bottom: 0.5rem;
  }
  .mission-title {
    font-family: 'Black Ops One', sans-serif;
    font-size: 1.6rem;
    color: var(--mn-fg);
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }
  .mission-line {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.12rem;
    line-height: 1.55;
    color: var(--mn-muted);
    margin: 0;
  }

  /* ------------------------------------------------------------
     THE HUNTER'S NOTE
     ------------------------------------------------------------ */
  .note-section {
    background: var(--mn-bg-deep);
    color: var(--mn-fg);
    padding: 7rem 2rem;
    border-bottom: 1px solid var(--mn-line);
  }
  .note-grid {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.92fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .note-grid { grid-template-columns: 1fr; gap: 2.6rem; }
    .note-section { padding: 4rem 1.25rem; }
