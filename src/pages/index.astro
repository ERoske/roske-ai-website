---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// The full Vought-style ensemble — four "Heroes of Roske International"
// pulled from this week's themed images.
const ensemble = [
  {
    src: '/images/the-boys/edward-butcher.png',
    codename: 'THE COUNSELOR',
    realName: 'Edward Roske',
    powers: 'Strategic Realism · Cigar Tolerance',
    blurb: "Found in the alley behind the keynote venue. Allegedly here to clean up the mess after the other Supes spreadsheet themselves into a corner.",
    aspect: '3/4',
    rotate: -1.2,
  },
  {
    src: '/images/the-boys/edward-starlight.png',
    codename: 'THE LIGHTBRINGER',
    realName: 'Edward Roske',
    powers: 'Photonic Q&A · Stagecraft Charisma',
    blurb: "Hand-picked by HR for the press tour. Conjures coherent answers to vague enterprise questions on demand. Surprisingly comfortable on stage.",
    aspect: '3/4',
    rotate: 1.4,
  },
  {
    src: '/images/the-boys/edward-speedster.png',
    codename: 'AGENT-1',
    realName: 'Edward Roske',
    powers: 'Iterative Velocity · Holding His Hat On',
    blurb: "Late to every standup, on time to every shipping deadline. Specializes in last-mile delivery, occasionally in the literal sense.",
    aspect: '4/3',
    rotate: -0.8,
  },
  {
    src: '/images/the-boys/edward-deep.png',
    codename: 'OCEANIC OUTREACH',
    realName: 'Edward Roske',
    powers: 'Aquatic Empathy · Plausible Deniability',
    blurb: "On a court-mandated PR rehab tour. Holds the goldfish, smiles at the cameras, and has not yet been allowed near the spreadsheets.",
    aspect: '3/4',
    rotate: 0.9,
  },
];

// Active Operations — the six recurring projects, restyled as Vought-style "active operations" briefs.
const operations = [
  {
    fileNo: 'OP-01',
    classification: 'PRIORITY · DEPLOYED',
    title: 'AgentCube',
    body: "The unified engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus.AI. Already shipping for Essbase and Planning. Consolidations in beta.",
    href: '/agentcube.html',
    external: false,
    cta: 'Open the file',
    badge: 'MCP · ENTERPRISE',
  },
  {
    fileNo: 'OP-02',
    classification: 'EVENT · OCT 9-10, 2026',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever seen. Speakers and attendees from around the globe. Submit a talk, sponsor a track, or grab a seat before the island fills up.",
    href: 'https://www.caribbeansummit.ai/',
    external: true,
    cta: 'See the agenda',
    badge: 'PR Convention Center',
  },
  {
    fileNo: 'OP-03',
    classification: 'INVESTMENT · ACTIVE',
    title: 'Caprus AI',
    body: "Investor and contributor at Caprus, an AI Software & Services firm empowering finance teams with AI solutions for smarter, faster, more strategic financial operations.",
    href: 'https://caprus.ai',
    external: true,
    cta: 'Visit Caprus',
    badge: 'AI · FINANCE',
  },
  {
    fileNo: 'OP-04',
    classification: 'R&D · IN PROGRESS',
    title: 'AI-Powered DM Screen',
    body: "Building a tool that helps Dungeon Masters run better D&D campaigns using AI. Because if you're going to have an artificial intelligence at your table, it should at least help with initiative tracking.",
    href: null,
    external: false,
    cta: 'Status: rolling',
    badge: 'D&D · AI',
  },
  {
    fileNo: 'OP-05',
    classification: 'COMMUNITY · 850+',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. Over 850 attendees across our events. We meet every other month to explore what AI means for the island and beyond.",
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next event',
    badge: 'BIMONTHLY · SAN JUAN',
  },
];

// Faux corporate Q&A — the "From the Desk of the CEO" section
const ceoQA = [
  {
    q: "Q: Roske International. Are you serious?",
    a: "It is a parody of a corporate-superhero firm. The Boys is wrapping up its final season, and Edward already volunteered (in writing) to play Butcher or Starlight. Nobody asked him. He volunteered. The website is the result.",
  },
  {
    q: "Q: Does Edward actually have superpowers?",
    a: "He has spoken in 50+ countries on all seven continents, written 15 books, and once climbed Everest Base Camp without complaining (much). He is not licensed by any state or federal agency to be called a Supe.",
  },
  {
    q: "Q: Is the AI as heroic as the marketing implies?",
    a: "Short answer: no. AI is a tool. The Caprus MCP servers are very good at their jobs. They will not fly. They will not save anyone from a burning building. They will close your books faster.",
  },
  {
    q: "Q: Where do I report misconduct?",
    a: "Send a tip to Edward@Roske.AI. He reads it. He answers it himself, in his own voice, in roughly the same number of paragraphs you sent.",
  },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       HERO — Roske International Propaganda Poster
       ============================================ -->
  <section class="hero-section">
    <div class="hero-stars" aria-hidden="true"></div>

    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-dot"></span>
          <span>FILE NO. 042 · WEEK OF {theme.week} · CLEARANCE: SEMI-PUBLIC</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">ROSKE</span>
          <span class="hero-title-line hero-title-accent">INTERNATIONAL</span>
        </h1>

        <p class="hero-deck">{theme.hero.subtitle}</p>

        <div class="hero-tagline">
          <span class="hero-tagline-rule"></span>
          <span>{theme.tagline}</span>
        </div>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            Book 13 Minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-stats">
          {[
            { value: '80+', label: 'Countries' },
            { value: '50+', label: 'Speaking' },
            { value: '15', label: 'Books' },
            { value: '25+', label: 'Years CEO' },
          ].map(stat => (
            <div class="hero-stat">
              <div class="hero-stat-value">{stat.value}</div>
              <div class="hero-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <div class="hero-image-frame">
          <div class="hero-corner hero-corner-tl"></div>
          <div class="hero-corner hero-corner-tr"></div>
          <div class="hero-corner hero-corner-bl"></div>
          <div class="hero-corner hero-corner-br"></div>
          <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="hero-image" />
          <div class="hero-image-meta">
            <span>EDITION 04·25·26</span>
            <span>R-STAR APPROVED</span>
          </div>
        </div>
        <div class="hero-stamp">
          <div class="hero-stamp-inner">
            <span class="hero-stamp-line">CERTIFIED</span>
            <span class="hero-stamp-big">PROBATIONARY</span>
            <span class="hero-stamp-line">SUPE · 2026</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE — Vought-style ticker
       ============================================ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-item">★ HEROES OF THE QUARTER</span>
      <span class="marquee-item">SAVING THE WORLD ONE MCP SERVER AT A TIME</span>
      <span class="marquee-item">★ Q3 ROSTER ANNOUNCED</span>
      <span class="marquee-item">CARIBBEAN AI SUMMIT · OCT 9-10</span>
      <span class="marquee-item">★ EVEREST BASE CAMP CLEARED</span>
      <span class="marquee-item">FEDORA: STILL BLUE</span>
      <span class="marquee-item">★ HEROES OF THE QUARTER</span>
      <span class="marquee-item">SAVING THE WORLD ONE MCP SERVER AT A TIME</span>
      <span class="marquee-item">★ Q3 ROSTER ANNOUNCED</span>
      <span class="marquee-item">CARIBBEAN AI SUMMIT · OCT 9-10</span>
      <span class="marquee-item">★ EVEREST BASE CAMP CLEARED</span>
      <span class="marquee-item">FEDORA: STILL BLUE</span>
    </div>
  </div>

  <!-- ============================================
       ENSEMBLE — Heroes of the Quarter
       ============================================ -->
  <section class="ensemble">
    <div class="ensemble-inner">
      <header class="section-header">
        <div class="section-tag">SECTION 02 · ROSTER</div>
        <h2 class="section-title">Heroes of the Quarter.</h2>
        <p class="section-deck">
          Four faces of Roske International. The same man, four different press cycles. (Casting call still open. Send headshots. Or don't.)
        </p>
      </header>

      <div class="ensemble-grid">
        {ensemble.map((hero, idx) => (
          <article class="ensemble-card" style={`--rot:${hero.rotate}deg; --aspect:${hero.aspect};`}>
            <div class="ensemble-photo">
              <img src={hero.src} alt={`Edward Roske as ${hero.codename}`} loading="lazy" decoding="async" />
              <div class="ensemble-stamp">{String(idx + 1).padStart(2, '0')}</div>
            </div>
            <div class="ensemble-meta">
              <div class="ensemble-codename">{hero.codename}</div>
              <div class="ensemble-realname">a/k/a {hero.realName}</div>
              <div class="ensemble-powers">{hero.powers}</div>
              <p class="ensemble-blurb">{hero.blurb}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CEO BOARDROOM — pull quote with image
       ============================================ -->
  <section class="ceo-section">
    <div class="ceo-grid">
      <figure class="ceo-image">
        <img src="/images/the-boys/edward-boardroom.png" alt="Edward Roske presenting 'AI: The New Heroes' in a corporate boardroom." loading="lazy" decoding="async" />
        <figcaption>
          <span>EX. A · QUARTERLY BRIEFING</span>
          <span>FLR 47 · MIDTOWN</span>
        </figcaption>
      </figure>

      <div class="ceo-text">
        <div class="ceo-tag">FROM THE DESK OF THE CEO</div>
        <blockquote class="ceo-quote">
          <span class="ceo-quote-mark" aria-hidden="true">"</span>
          The new heroes are not the ones in capes. They are the ones who can close your books in a week, run a coherent forecast on demand, and answer a follow-up question without sweating through their suit. We sell the spreadsheets. The capes are just for the press kit.
        </blockquote>
        <div class="ceo-attrib">
          <span class="ceo-attrib-name">Edward Roske</span>
          <span class="ceo-attrib-title">CEO, Roske International (parodically)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       ACTIVE OPERATIONS — Project briefs
       ============================================ -->
  <section id="current-work" class="ops-section">
    <div class="ops-inner">
      <header class="section-header">
        <div class="section-tag">SECTION 03 · ACTIVE OPERATIONS</div>
        <h2 class="section-title">What's actually shipping.</h2>
        <p class="section-deck">
          Six things Edward is building, running, or visibly bothering people about. The marketing is a parody. These are real.
        </p>
      </header>

      <div class="ops-grid">
        {operations.map(op => (
          <article class="op-card">
            <div class="op-card-header">
              <span class="op-fileno">{op.fileNo}</span>
              <span class="op-classification">{op.classification}</span>
            </div>
            <h3 class="op-title">{op.title}</h3>
            <p class="op-body">{op.body}</p>
            <div class="op-card-footer">
              <span class="op-badge">{op.badge}</span>
              {op.href ? (
                <a href={op.href} target={op.external ? '_blank' : undefined} rel={op.external ? 'noopener' : undefined} class="op-cta">
                  {op.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="op-cta op-cta-disabled">{op.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       Q&A — Faux corporate FAQ
       ============================================ -->
  <section class="qa-section">
    <div class="qa-inner">
      <header class="section-header">
        <div class="section-tag">SECTION 04 · STOCKHOLDER LETTER</div>
        <h2 class="section-title">Hard questions, on the record.</h2>
      </header>

      <div class="qa-list">
        {ceoQA.map((item, idx) => (
          <div class="qa-item">
            <div class="qa-num">{String(idx + 1).padStart(2, '0')}</div>
            <div class="qa-content">
              <div class="qa-q">{item.q}</div>
              <div class="qa-a">{item.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FINAL CTA — Submit a Briefing
       ============================================ -->
  <section class="final-cta">
    <div class="final-cta-inner">
      <div class="final-cta-stars" aria-hidden="true">
        <svg viewBox="0 0 800 120" preserveAspectRatio="none" width="100%" height="100%">
          {[...Array(28).keys()].map(i => {
            const x = 20 + (i * 28) + (i % 3) * 4;
            const y = 30 + ((i * 13) % 60);
            const size = 6 + (i % 4) * 2;
            return (
              <polygon
                points={`${x},${y - size} ${x + size * 0.3},${y - size * 0.4} ${x + size * 0.95},${y - size * 0.3} ${x + size * 0.5},${y + size * 0.15} ${x + size * 0.6},${y + size * 0.8} ${x},${y + size * 0.5} ${x - size * 0.6},${y + size * 0.8} ${x - size * 0.5},${y + size * 0.15} ${x - size * 0.95},${y - size * 0.3} ${x - size * 0.3},${y - size * 0.4}`}
                fill="currentColor"
                opacity={0.18 + (i % 5) * 0.04}
              />
            );
          })}
        </svg>
      </div>

      <div class="final-cta-content">
        <div class="section-tag">SECTION 05 · REPORTING</div>
        <h2 class="final-cta-title">
          Got a tip?<br/>
          <span class="final-cta-accent">Send it to the CEO.</span>
        </h2>
        <p class="final-cta-body">
          Edward reads every email. Answers most of them. Personally, in his own voice, in roughly the same number of paragraphs you sent. (No interns. No automated routing. No corporate Supe screening. The fedora is real and the inbox is open.)
        </p>
        <div class="final-cta-buttons">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary btn-primary-lg">
            Book a 13-Minute Briefing
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="/contact/" class="btn-secondary btn-secondary-lg">Submit Intel</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================
     ROSKE INTERNATIONAL — propaganda magazine
     ============================================ */

  :global(body) {
    font-family: var(--font-body);
  }

  /* CSS vars locally aliased for readability */
  section {
    position: relative;
  }

  .section-header {
    max-width: 56rem;
    margin: 0 auto 3rem;
    text-align: center;
    padding: 0 1.5rem;
  }
  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin: 0 0 1rem;
  }
  [data-theme="dark"] .section-title { color: var(--color-text); }
  [data-theme="light"] .section-title { color: var(--color-text-dark); }

  .section-deck {
    font-size: 1.1rem;
    line-height: 1.55;
    max-width: 44rem;
    margin: 0 auto;
  }
  [data-theme="dark"] .section-deck { color: var(--color-text-muted); }
  [data-theme="light"] .section-deck { color: var(--color-text-dark-muted); }

  /* ===================== HERO ===================== */
  .hero-section {
    position: relative;
    min-height: 92vh;
    overflow: hidden;
    isolation: isolate;
    display: flex;
    align-items: center;
    padding: 6rem 1.5rem 4rem;
  }
  [data-theme="dark"] .hero-section {
    background:
      radial-gradient(ellipse at 20% 30%, rgba(200, 16, 46, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 70%, rgba(27, 44, 95, 0.35) 0%, transparent 55%),
      linear-gradient(180deg, #0a0e1c 0%, #050811 100%);
  }
  [data-theme="light"] .hero-section {
    background:
      radial-gradient(ellipse at 20% 30%, rgba(200, 16, 46, 0.10) 0%, transparent 55%),
      radial-gradient(ellipse at 80% 70%, rgba(27, 44, 95, 0.10) 0%, transparent 55%),
      #f7f1e3;
  }

  .hero-stripes {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 28px,
      currentColor 28px,
      currentColor 29px
    );
    pointer-events: none;
    z-index: 0;
  }
  [data-theme="dark"] .hero-stripes { color: rgba(247, 241, 227, 0.025); }
  [data-theme="light"] .hero-stripes { color: rgba(10, 14, 28, 0.04); }

  .hero-stars {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background-image:
      radial-gradient(circle at 12% 18%, currentColor 1.2px, transparent 1.5px),
      radial-gradient(circle at 78% 12%, currentColor 1.4px, transparent 1.7px),
      radial-gradient(circle at 30% 70%, currentColor 1px, transparent 1.4px),
      radial-gradient(circle at 90% 60%, currentColor 1.4px, transparent 1.7px),
      radial-gradient(circle at 55% 88%, currentColor 1.1px, transparent 1.4px),
      radial-gradient(circle at 8% 52%, currentColor 1px, transparent 1.4px),
      radial-gradient(circle at 65% 28%, currentColor 1.3px, transparent 1.6px);
    background-size: 100% 100%;
  }
  [data-theme="dark"] .hero-stars { color: rgba(247, 241, 227, 0.45); }
  [data-theme="light"] .hero-stars { color: rgba(27, 44, 95, 0.45); }

  .hero-grid {
    position: relative;
    z-index: 2;
    max-width: 80rem;
    margin: 0 auto;
    width: 100%;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.05fr 1fr;
      gap: 4rem;
    }
  }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    padding: 0.55rem 0.9rem;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    margin-bottom: 1.6rem;
    font-weight: 600;
    background: rgba(200, 16, 46, 0.08);
  }
  .hero-eyebrow-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
    animation: heroPulse 2s ease-in-out infinite;
  }
  @keyframes heroPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.85); }
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(3.5rem, 11vw, 9rem);
    line-height: 0.85;
    letter-spacing: -0.005em;
    text-transform: uppercase;
    margin: 0 0 1.5rem;
    font-weight: 400;
  }
  .hero-title-line {
    display: block;
  }
  [data-theme="dark"] .hero-title-line { color: var(--color-text); }
  [data-theme="light"] .hero-title-line { color: var(--color-text-dark); }
  .hero-title-accent {
    color: var(--color-primary) !important;
    font-style: italic;
    transform: skewX(-5deg);
    transform-origin: left;
    text-shadow: 0.18rem 0.18rem 0 rgba(27, 44, 95, 0.25);
  }
  [data-theme="light"] .hero-title-accent {
    text-shadow: 0.18rem 0.18rem 0 rgba(27, 44, 95, 0.18);
  }

  .hero-deck {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(1.35rem, 2.4vw, 1.75rem);
    line-height: 1.35;
    margin: 0 0 1.2rem;
    max-width: 36rem;
  }
  [data-theme="dark"] .hero-deck { color: var(--color-text); }
  [data-theme="light"] .hero-deck { color: var(--color-text-dark); }

  .hero-tagline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1.6rem;
    font-weight: 500;
  }
  [data-theme="dark"] .hero-tagline { color: var(--color-text-muted); }
  [data-theme="light"] .hero-tagline { color: var(--color-text-dark-muted); }
  .hero-tagline-rule {
    width: 2.5rem;
    height: 2px;
    background: var(--color-accent);
  }

  .hero-body {
    font-size: 1.025rem;
    line-height: 1.65;
    margin: 0 0 2rem;
    max-width: 38rem;
  }
  [data-theme="dark"] .hero-body { color: var(--color-text-muted); }
  [data-theme="light"] .hero-body { color: var(--color-text-dark-muted); }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    max-width: 30rem;
    padding-top: 1.5rem;
    border-top: 1px solid;
  }
  [data-theme="dark"] .hero-stats { border-color: var(--color-border); }
  [data-theme="light"] .hero-stats { border-color: var(--color-border-light); }

  .hero-stat-value {
    font-family: var(--font-heading);
    font-size: 1.85rem;
    line-height: 1;
    color: var(--color-accent);
  }
