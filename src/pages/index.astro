---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// "The Spread": four framed ranch photographs.
const ranchStills = [
  {
    src: '/images/roske-ranch/edward-branding-iron.png',
    lot: 'No. 17',
    slug: 'THE BRANDING FIRE · DUSK',
    title: 'Registering the Brand',
    line: "He holds the iron up to the light and reads it like a quarterly report. It is, in fairness, both.",
    aspect: '4/3',
    rotate: -1.4,
  },
  {
    src: '/images/roske-ranch/edward-ranch-office.png',
    lot: 'No. 23',
    slug: 'THE RANCH HOUSE · NIGHT',
    title: 'Closing the Books',
    line: "Spurs on the desk, ledger open, laptop running. The job changed less than the wardrobe suggests.",
    aspect: '4/3',
    rotate: 1.2,
  },
  {
    src: '/images/roske-ranch/edward-drum-horse.png',
    lot: 'No. 31',
    slug: 'THE STABLE YARD · GOLDEN HOUR',
    title: 'A Proper Drum Horse',
    line: "We raised these in North Texas. Enormous, gentle, and entirely unbothered by how small they make a person feel.",
    aspect: '3/4',
    rotate: 0.9,
  },
  {
    src: '/images/roske-ranch/edward-on-horseback.png',
    lot: 'No. 08',
    slug: 'THE NORTH PASTURE · SUNSET',
    title: 'Riding the Line',
    line: "A man who genuinely knows how to ride, holding the reins like he is aware of the camera. Both things are true.",
    aspect: '3/4',
    rotate: -0.7,
  },
];

// Portrait used in "The Rancher's Note" section.
const noteImage = {
  src: '/images/roske-ranch/edward-barn-with-r.png',
  alt: "Edward Roske in his signature blue fedora standing in front of his ranch barn at golden hour, the Circle R brand painted prominently on the front of the barn.",
};

// "The Ledger" — six head of stock (the recurring projects, restyled as a livestock register).
const ledger = [
  {
    lot: 'LOT 001',
    brand: 'PRIME STOCK · MCP',
    title: 'AgentCube',
    body: "The engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus. Essbase and Planning are shipping. Consolidations is in beta.",
    badge: 'ESSBASE · PLANNING · CLOSE',
    head: 'Best in the herd',
    href: '/agentcube.html',
    external: false,
    cta: 'Read the brand book',
  },
  {
    lot: 'LOT 002',
    brand: 'THE BIG DRIVE',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever hosted, October 9-10 in San Juan. I am out rounding up speakers and sponsors from across the AI world. If you build, fund, or run AI, ride in.",
    badge: '9-10 OCT 2026 · SAN JUAN',
    head: 'Open range',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Send a speaker up',
  },
  {
    lot: 'LOT 003',
    brand: 'REGISTERED PARTNER',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, an AI software and services outfit that gives finance teams faster, smarter, more strategic operations. The working herd behind the MCP servers.",
    badge: 'AI · FINANCE',
    head: 'Working herd',
    href: 'https://caprus.ai',
    external: true,
    cta: 'Visit the outfit',
  },
  {
    lot: 'LOT 004',
    brand: 'NIGHT WORK',
    title: "AI Dungeon Master's Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns. Initiative, lore, and improv support for the person behind the screen. If there is going to be an AI at the table, it can earn its seat.",
    badge: 'D&D · 5E · EBERRON',
    head: 'Still being broke in',
    href: null,
    external: false,
    cta: 'In the round pen',
  },
  {
    lot: 'LOT 005',
    brand: 'THE COMMUNITY PEN',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. Over 850 people across our events. We meet every other month to work out what AI means for the island and everyone watching it.",
    badge: '850+ · EVERY 2 MONTHS',
    head: 'Growing herd',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the roundup',
  },
  {
    lot: 'LOT 006',
    brand: 'TRAIL LOGGED',
    title: 'Everest Base Camp',
    body: "Cleared in April. Almost two weeks trekking at altitude, a high point of 18,570 feet at Kala Pattar, and a nightly reminder that teahouses do not heat the rooms. The altitude was hard. The cold was worse.",
    badge: 'NEPAL · APRIL 2026',
    head: 'Cleared',
    href: '/blog/everest-base-camp-summit/',
    external: false,
    cta: 'Read the trail log',
  },
];

// "Fresh Off The Ranch" — this week's new stock, straight from the weekly questionnaire.
const freshStock = [
  {
    tag: 'NEW STOCK · 01',
    title: 'Only Recipes',
    kind: 'Chrome extension. Free.',
    body: "My first Chrome extension. When it sees you are on a recipe page, it strips away everything that is not the recipe. No life story, no fourteen ads, no scroll. Ridiculously fast, genuinely useful.",
    cta: 'Get it from the Chrome store',
    href: 'https://chromewebstore.google.com/detail/only-recipes/jddinhkkkjbplpoefcilhdhaenphnjep',
    external: true,
  },
  {
    tag: 'NEW STOCK · 02',
    title: 'The Home Library Project',
    kind: 'In beta. Quiet for now.',
    body: "A new app and site that digitizes a home library: books, board games, music, media, basically anything on your shelves, all categorized. A full reveal comes after beta. There will be a free library tier. Want an early look? Send an email.",
    cta: 'Email for early access',
    href: 'mailto:Edward@Roske.AI',
    external: false,
  },
];

// Ledger ticker phrases.
const marqueeItems = [
  "YOSEMITE: ROSKE RANCH",
  "EST. 1997",
  "SIX HEAD OF AI COMPANIES",
  "ONE FEDORA, NEVER A STETSON",
  "THE BRAND IS AN R",
  "BOOKS CLOSED BY SUNDOWN",
  "NORTH TEXAS, SPIRITUALLY",
  "★ ASKING GOOD QUESTIONS",
];

// The tally (preserved stats, restyled).
const tally = [
  { value: '80+', label: 'Countries Crossed' },
  { value: '50+', label: 'Speaking Stages' },
  { value: '15', label: 'Books Branded' },
  { value: '25+', label: 'Years On The Spread' },
];

// Brand registry (closing credits).
const brandRegistry = [
  { role: 'REGISTERED BRAND', name: 'THE R' },
  { role: 'THE RANCHER', name: 'EDWARD ROSKE' },
  { role: 'RANCH HAND', name: 'ONE (1) AI AGENT, UNPAID' },
  { role: 'LIVESTOCK', name: 'SIX HEAD, ALL ARTIFICIAL' },
  { role: 'HEADGEAR', name: 'BLUE FEDORA · PERSONAL PROPERTY · NOT A STETSON' },
  { role: 'WITH THANKS', name: 'DAWN · MYCROFT · ELIOT · THE PEOPLE OF PUERTO RICO' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       BRAND BAR — ranch ledger masthead
       ============================================ -->
  <div class="brand-bar">
    <div class="brand-bar-inner">
      <span class="bb-mark" aria-hidden="true"><span class="brand-r">R</span></span>
      <span class="bb-meta">YOSEMITE: ROSKE RANCH</span>
      <span class="bb-meta bb-meta-center">A YELLOWSTONE-UNIVERSE PARODY · UNAUTHORIZED · UNFENCED</span>
      <span class="bb-meta bb-meta-end">RANCH LEDGER · MMXXVI</span>
      <span class="bb-mark" aria-hidden="true"><span class="brand-r">R</span></span>
    </div>
  </div>

  <!-- ============================================
       HERO — the rancher and the horse
       ============================================ -->
  <section class="hero-section">
    <div class="hero-dust" aria-hidden="true"></div>
    <div class="hero-grid">

      <!-- Left: the title and the line he is delivering -->
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-rule"></span>
          <span class="hero-eyebrow-text">Premiered Friday on the back forty</span>
        </div>

        <h1 class="hero-title" aria-label="Yosemite: Roske Ranch">
          <span class="hero-title-small">Yosemite:</span>
          <span class="hero-title-big">Roske Ranch</span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-tally">
          {tally.map(stat => (
            <div class="tally-item">
              <div class="tally-value">{stat.value}</div>
              <div class="tally-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: the framed ranch photograph -->
      <div class="hero-image-wrap">
        <figure class="ranch-frame">
          <div class="ranch-frame-plank">
            <span class="brand-r" aria-hidden="true">R</span>
            <span class="ranch-frame-plank-name">YOSEMITE: ROSKE RANCH</span>
            <span class="ranch-frame-plank-est">EST. 1997</span>
          </div>
          <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="ranch-frame-image" />
          <figcaption class="ranch-frame-caption">
            <span class="ranch-frame-slug">THE PADDOCK · GOLDEN HOUR</span>
          </figcaption>
        </figure>

        <!-- Hanging livestock tag -->
        <div class="lot-tag" aria-hidden="true">
          <div class="lot-tag-hole"></div>
          <div class="lot-tag-body">
            <span class="lot-tag-tiny">ROSKE RANCH · STOCK TAG</span>
            <span class="lot-tag-big">LOT 01</span>
            <span class="lot-tag-tiny">HEAD: 1 RANCHER, 1 HORSE</span>
            <span class="lot-tag-tiny">DISPOSITION: TALKATIVE</span>
          </div>
        </div>

        <!-- Branded stamp -->
        <div class="brand-stamp" aria-hidden="true">
          <div class="brand-stamp-ring">
            <span>REGISTERED BRAND · NORTH TEXAS ·</span>
          </div>
          <div class="brand-stamp-center">
            <span class="brand-r brand-r-big">R</span>
            <span class="brand-stamp-sub">THE R BRAND</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE — ledger ticker
       ============================================ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[...marqueeItems, ...marqueeItems].map(item => (
        <span class="marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- ============================================
       PULL QUOTE — the rancher's thesis
       ============================================ -->
  <section class="pullquote-section">
    <div class="barbwire" aria-hidden="true"></div>
    <div class="pullquote-inner">
      <div class="pullquote-tag">RANCH LEDGER · PAGE 003 · A WORD FROM THE OWNER</div>
      <blockquote class="pullquote">
        Everyone wants to know whether AI replaces people. On a ranch the question is simpler. The AI is the ranch hand, not the rancher. It mends the fence. It does not get to decide where the fence goes.
      </blockquote>
      <div class="pullquote-attrib">
        <span class="pullquote-attrib-name">Edward Roske</span>
        <span class="pullquote-attrib-role">Owner, operator, and only human on the payroll</span>
      </div>
    </div>
    <div class="barbwire" aria-hidden="true"></div>
  </section>

  <!-- ============================================
       THE SPREAD — ranch photographs as a spread
       ============================================ -->
  <section class="spread-section">
    <div class="spread-inner">
      <header class="section-header">
        <div class="section-tag"><span class="brand-r" aria-hidden="true">R</span> SECTION 02 · THE SPREAD</div>
        <h2 class="section-title">Four photographs <em>off the property.</em></h2>
        <p class="section-deck">
          Pulled from the ranch records before anyone thought to file them properly. The ranch may be a metaphor. The horses, the ledger, and the cold nights at altitude were not.
        </p>
      </header>

      <div class="spread-grid">
        {ranchStills.map((item) => (
          <article class="still-card" style={`--rot:${item.rotate}deg; --aspect:${item.aspect};`}>
            <div class="still-photo">
              <span class="still-tape still-tape-tl" aria-hidden="true"></span>
              <span class="still-tape still-tape-br" aria-hidden="true"></span>
              <img src={item.src} alt={item.title} loading="lazy" decoding="async" />
              <div class="still-lot">{item.lot}</div>
            </div>
            <div class="still-meta">
              <div class="still-slug">{item.slug}</div>
              <h3 class="still-title">{item.title}</h3>
              <p class="still-line">{item.line}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       THE RANCHER'S NOTE — the real story
       ============================================ -->
  <section class="note-section">
    <div class="note-grid">
      <figure class="note-image">
        <img src={noteImage.src} alt={noteImage.alt} loading="lazy" decoding="async" />
        <figcaption>
          <span>FIG. R</span>
          <span>THE R · ON THE BARN</span>
        </figcaption>
      </figure>

      <div class="note-text">
        <div class="note-tag">THE RANCHER'S NOTE</div>
        <h3 class="note-h3">I did not reach far <em>for this one.</em></h3>
        <p class="note-body">
          I grew up riding horses and going to rodeos in the Pacific Northwest. Years later I owned a ranch in North Texas, where we raised drum horses, the enormous gentle ones with feathered feet that the British cavalry uses to carry kettle drums. My own horse, the one I actually rode, was a quarterhorse named Thomas Jefferson. Tommy, for short. (Naming a quarterhorse after a Founding Father is a decision that makes sense at the time and keeps making sense forever after.)
        </p>
        <p class="note-body">
          So when the newest Yellowstone show rode in this week, the ranch was not a costume. It was a Tuesday I had already lived. interRel, the firm I started in Arlington, Texas in 1997 and ran for 25 years, was the first spread. The herd is just AI companies now, the ranch hand is an AI agent, and the brand is still an R.
        </p>
        <p class="note-body">
          The work rhymes more than you would expect. You tend the stock, you mend the fences, you close the books by sundown, and you try not to lose anything to the weather.
        </p>
        <div class="note-attrib">
          <span class="note-attrib-line"></span>
          <div>
            <span class="note-attrib-name">Edward Roske</span>
            <span class="note-attrib-title">Owner, Yosemite: Roske Ranch</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       THE LEDGER — six head of stock (projects)
       ============================================ -->
  <section id="current-work" class="ledger-section">
    <div class="ledger-inner">
      <header class="section-header">
        <div class="section-tag"><span class="brand-r" aria-hidden="true">R</span> SECTION 03 · THE LEDGER</div>
        <h2 class="section-title">Six head of stock, <em>all accounted for.</em></h2>
        <p class="section-deck">
          The current livestock register. Five of these are working operations. One is a trail already ridden. None of them are cattle, but the accounting is the same.
        </p>
      </header>

      <div class="ledger-grid">
        {ledger.map(entry => (
          <article class="ledger-card">
            <div class="ledger-card-head">
              <span class="ledger-lot">{entry.lot}</span>
              <span class="ledger-brand">{entry.brand}</span>
            </div>
            <h3 class="ledger-title">{entry.title}</h3>
            <p class="ledger-body">{entry.body}</p>
            <div class="ledger-meta">
              <span class="ledger-badge">{entry.badge}</span>
              <span class="ledger-head">{entry.head}</span>
            </div>
            <div class="ledger-card-foot">
              {entry.href ? (
                <a href={entry.href} target={entry.external ? '_blank' : undefined} rel={entry.external ? 'noopener' : undefined} class="ledger-cta">
                  {entry.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="ledger-cta ledger-cta-disabled">{entry.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FRESH OFF THE RANCH — this week's new stock
       ============================================ -->
  <section class="fresh-section">
    <div class="fresh-inner">
      <header class="section-header fresh-header">
        <div class="section-tag fresh-tag"><span class="brand-r" aria-hidden="true">R</span> SECTION 04 · FRESH OFF THE RANCH</div>
        <h2 class="section-title">Two new arrivals <em>this week.</em></h2>
      </header>

      <div class="fresh-grid">
        {freshStock.map(item => (
          <article class="fresh-card">
            <div class="fresh-card-tag">{item.tag}</div>
            <h3 class="fresh-card-title">{item.title}</h3>
            <div class="fresh-card-kind">{item.kind}</div>
            <p class="fresh-card-body">{item.body}</p>
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="fresh-cta">
              {item.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CLOSING CTA — ride out to the ranch
       ============================================ -->
  <section class="closing-section">
    <div class="closing-inner">
      <div class="closing-eyebrow">
        <span class="closing-rule"></span>
        <span>THE GATE IS OPEN · 13 MINUTES</span>
        <span class="closing-rule"></span>
      </div>
      <h2 class="closing-title">Ride out to the ranch.<br/><em class="closing-em">Or just send an email.</em></h2>
      <p class="closing-deck">
        The thirteen-minute conversation is the front porch of this operation. No boots required, no horse to address. Bring questions about AI, finance, MCP servers, escape rooms, D&D, or what it actually feels like at 18,570 feet. The answers are free. (The opinions are included whether you ask or not.)
      </p>
      <div class="closing-cta-row">
        <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Write to the ranch</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       BRAND REGISTRY — closing credits
       ============================================ -->
  <section class="registry-section">
    <div class="registry-inner">
      <div class="registry-tag">RANCH LEDGER · BRAND REGISTRY</div>
      <div class="registry-roll">
        {brandRegistry.map(entry => (
          <div class="registry-block">
            <span class="registry-role">{entry.role}</span>
            <span class="registry-name">{entry.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     YOSEMITE: ROSKE RANCH — elevated modern Western
     Palette: oxblood brand-iron red / weathered denim blue /
              dusty sage / bone parchment / amber dusk / fence wood
     Type: Alfa Slab One (display), Zilla Slab (decked italics),
           Spectral (body), Special Elite (ledger mono)
     ============================================================ */

  :global([data-theme="dark"]) {
    --rr-bg: #17120d;
    --rr-bg-deep: #100c08;
    --rr-surface: #221a11;
    --rr-surface-2: #2b2014;
    --rr-fg: #ece3d1;
    --rr-muted: #a8957a;
    --rr-line: #3c2e1f;
    --rr-line-soft: #2c2117;
    --rr-oxblood: #cf5236;
    --rr-oxblood-deep: #9a3324;
    --rr-denim: #7ba6bc;
    --rr-sage: #9aae86;
    --rr-amber: #dca35a;
    --rr-stamp-bg: #ece3d1;
    --rr-stamp-fg: #17120d;
  }
  :global([data-theme="light"]) {
    --rr-bg: #e9dec6;
    --rr-bg-deep: #ddd0b2;
    --rr-surface: #f4ecd8;
    --rr-surface-2: #fbf5e6;
    --rr-fg: #2a2014;
    --rr-muted: #6a5942;
    --rr-line: #cabe9b;
    --rr-line-soft: #d7ccab;
    --rr-oxblood: #9a3324;
    --rr-oxblood-deep: #7d2a1e;
    --rr-denim: #3f5d70;
    --rr-sage: #5f7050;
    --rr-amber: #a5752a;
    --rr-stamp-bg: #2a2014;
    --rr-stamp-fg: #f4ecd8;
  }

  /* ------------------------------------------------------------
     THE CIRCLE R BRAND MARK
     ------------------------------------------------------------ */
  .brand-r {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.7em;
    height: 1.7em;
    border-radius: 50%;
    border: 0.14em solid currentColor;
    font-family: 'Alfa Slab One', serif;
    font-size: 0.7em;
    line-height: 1;
    padding-top: 0.06em;
    flex-shrink: 0;
  }
  .brand-r-big {
    font-size: 2.4rem;
    border-width: 4px;
  }

  /* ------------------------------------------------------------
     BARBED WIRE DIVIDER (theme-aware via mask)
     ------------------------------------------------------------ */
  .barbwire {
    height: 14px;
    width: 100%;
    background-color: var(--rr-line);
    opacity: 0.85;
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='60' height='14'><g fill='none' stroke='black' stroke-width='1.3'><path d='M0 7 H60'/><path d='M24 7 l5 -3.5 M24 7 l5 3.5 M36 7 l-5 -3.5 M36 7 l-5 3.5'/><path d='M27 2 L33 12 M33 2 L27 12'/></g></svg>");
    mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='60' height='14'><g fill='none' stroke='black' stroke-width='1.3'><path d='M0 7 H60'/><path d='M24 7 l5 -3.5 M24 7 l5 3.5 M36 7 l-5 -3.5 M36 7 l-5 3.5'/><path d='M27 2 L33 12 M33 2 L27 12'/></g></svg>");
    -webkit-mask-repeat: repeat-x;
    mask-repeat: repeat-x;
    -webkit-mask-size: 60px 14px;
    mask-size: 60px 14px;
  }

  /* ------------------------------------------------------------
     BRAND BAR — ranch ledger masthead
     ------------------------------------------------------------ */
  .brand-bar {
    width: 100%;
    background: var(--rr-bg-deep);
    color: var(--rr-amber);
    border-bottom: 1px solid var(--rr-line);
    font-family: 'Special Elite', monospace;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .brand-bar-inner {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    font-size: 0.68rem;
  }
  .bb-mark { color: var(--rr-oxblood); font-size: 0.78rem; }
  .bb-meta { white-space: nowrap; }
  .bb-meta-center { flex: 1; text-align: center; letter-spacing: 0.2em; color: var(--rr-muted); }
  .bb-meta-end { text-align: right; }
  @media (max-width: 760px) {
    .brand-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.56rem; }
    .bb-meta-end, .bb-mark { display: none; }
  }

  /* ------------------------------------------------------------
     HERO
     ------------------------------------------------------------ */
  .hero-section {
    position: relative;
    background: var(--rr-bg);
    color: var(--rr-fg);
    padding: 5rem 2rem 6rem;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(ellipse at 15% 0%, rgba(220,163,90,0.10) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 100%, rgba(207,82,54,0.08) 0%, transparent 55%),
      linear-gradient(180deg, #17120d 0%, #1f160e 55%, #17120d 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
      radial-gradient(ellipse at 15% 0%, rgba(165,117,42,0.16) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 100%, rgba(154,51,36,0.10) 0%, transparent 55%),
      var(--rr-bg);
  }
  .hero-dust {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.5;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.55 0 0 0 0 0.42 0 0 0 0 0.25 0 0 0 0.5 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    mix-blend-mode: overlay;
  }
  :global([data-theme="light"]) .hero-dust { opacity: 0.35; }

  .hero-grid {
    position: relative;
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.04fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.5rem; }
    .hero-section { padding: 3rem 1.25rem 4rem; }
  }

  .hero-text { max-width: 660px; }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-family: 'Special Elite', monospace;
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rr-amber);
    margin-bottom: 1.5rem;
  }
  .hero-eyebrow-rule { width: 42px; height: 2px; background: var(--rr-oxblood); flex-shrink: 0; }

  .hero-title { margin: 0 0 1.8rem; line-height: 0.9; }
  .hero-title-small {
    display: block;
    font-family: 'Zilla Slab', serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.4rem, 3vw, 2.1rem);
    color: var(--rr-denim);
    letter-spacing: 0.01em;
    margin-bottom: 0.1rem;
  }
  .hero-title-big {
    display: block;
    font-family: 'Alfa Slab One', serif;
    font-size: clamp(3.4rem, 8vw, 6.6rem);
    color: var(--rr-fg);
    letter-spacing: -0.01em;
    line-height: 0.95;
    text-shadow: 0.04em 0.05em 0 var(--rr-oxblood-deep);
  }

  .hero-body {
    font-family: 'Spectral', serif;
    font-size: 1.06rem;
    line-height: 1.7;
    color: var(--rr-muted);
    margin: 0 0 1.9rem;
    max-width: 40em;
  }

  /* Buttons */
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.6rem;
    font-family: 'Special Elite', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid currentColor;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    cursor: pointer;
    line-height: 1;
  }
  .btn-primary {
    background: var(--rr-oxblood);
    color: #f6ede0;
    border-color: var(--rr-oxblood);
  }
  .btn-primary:hover {
    background: var(--rr-oxblood-deep);
    border-color: var(--rr-oxblood-deep);
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0,0,0,0.35);
  }
  .btn-secondary {
    background: transparent;
    color: var(--rr-fg);
    border-color: var(--rr-fg);
  }
  .btn-secondary:hover {
    background: var(--rr-fg);
    color: var(--rr-bg);
    transform: translateY(-2px);
  }
  .btn-primary-big, .btn-secondary-big { padding: 1.05rem 2.1rem; font-size: 0.92rem; }
  .hero-cta-row { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 2.6rem; }

  /* Tally */
  .hero-tally {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    border-top: 1px solid var(--rr-line);
    padding-top: 1.7rem;
  }
  .tally-value {
    font-family: 'Alfa Slab One', serif;
    font-size: 2.3rem;
    color: var(--rr-amber);
    line-height: 1;
  }
  .tally-label {
    font-family: 'Special Elite', monospace;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rr-muted);
    margin-top: 0.45rem;
  }
  @media (max-width: 620px) {
    .hero-tally { grid-template-columns: repeat(2, 1fr); gap: 1.4rem 1rem; }
  }

  /* ------------------------------------------------------------
     RANCH FRAME (hero photograph)
     ------------------------------------------------------------ */
  .hero-image-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .ranch-frame {
    position: relative;
    margin: 0;
    width: 100%;
    max-width: 600px;
    background: var(--rr-surface-2);
    border: 1px solid var(--rr-line);
    box-shadow:
      0 30px 70px rgba(0,0,0,0.5),
      0 6px 16px rgba(0,0,0,0.4),
      inset 0 0 0 6px var(--rr-surface),
      inset 0 0 0 8px var(--rr-line);
    display: flex;
    flex-direction: column;
  }
  :global([data-theme="light"]) .ranch-frame {
    box-shadow:
      0 24px 54px rgba(60,40,20,0.32),
      0 6px 14px rgba(60,40,20,0.22),
      inset 0 0 0 6px var(--rr-surface),
      inset 0 0 0 8px var(--rr-line);
  }
  .ranch-frame-plank {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 1rem;
    background: var(--rr-bg-deep);
    border-bottom: 1px solid var(--rr-line);
    color: var(--rr-amber);
    font-family: 'Special Elite', monospace;
    text-transform: uppercase;
  }
  .ranch-frame-plank .brand-r { color: var(--rr-oxblood); font-size: 0.62rem; }
  .ranch-frame-plank-name { font-size: 0.8rem; letter-spacing: 0.12em; flex: 1; }
  .ranch-frame-plank-est { font-size: 0.66rem; letter-spacing: 0.1em; color: var(--rr-muted); }
  .ranch-frame-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    filter: contrast(1.04) saturate(1.02);
  }
  .ranch-frame-caption {
    padding: 0.85rem 1rem 0.95rem;
    background: var(--rr-bg-deep);
    border-top: 1px solid var(--rr-line);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .ranch-frame-slug {
    font-family: 'Special Elite', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rr-amber);
  }
  .ranch-frame-scene {
    font-family: 'Spectral', serif;
    font-style: italic;
    font-size: 0.92rem;
    color: var(--rr-muted);
  }

  /* Hanging livestock tag */
  .lot-tag {
    position: absolute;
    bottom: 66px;
    left: -34px;
    width: 188px;
    background: var(--rr-stamp-bg);
    color: var(--rr-stamp-fg);
    padding: 0.7rem 0.85rem 0.8rem;
    transform: rotate(-7deg);
    box-shadow: 0 12px 28px rgba(0,0,0,0.4);
    border: 1px solid var(--rr-line);
    z-index: 3;
    text-align: center;
  }
  .lot-tag-hole {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--rr-stamp-fg);
    background: var(--rr-bg);
    margin: 0 auto 0.45rem;
  }
  .lot-tag-tiny {
    display: block;
    font-family: 'Special Elite', monospace;
    font-size: 0.54rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.78;
  }
  .lot-tag-big {
    display: block;
    font-family: 'Alfa Slab One', serif;
    font-size: 1.5rem;
    margin: 0.15rem 0;
    color: var(--rr-oxblood);
  }

  /* Branded round stamp */
  .brand-stamp {
    position: absolute;
    top: -34px;
    right: -28px;
    width: 132px;
    height: 132px;
    border-radius: 50%;
    border: 2px solid var(--rr-oxblood);
    background: var(--rr-stamp-bg);
    color: var(--rr-oxblood);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(13deg);
    z-index: 3;
    box-shadow: 0 10px 24px rgba(0,0,0,0.35);
  }
  .brand-stamp-ring {
    position: absolute;
    inset: 5px;
    border-radius: 50%;
    border: 1px solid var(--rr-oxblood);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
  }
  .brand-stamp-ring span {
    font-family: 'Special Elite', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding-top: 6px;
  }
  .brand-stamp-center { text-align: center; z-index: 1; display: flex; flex-direction: column; align-items: center; }
  .brand-stamp-center .brand-r-big { color: var(--rr-oxblood); }
  .brand-stamp-sub {
    font-family: 'Special Elite', monospace;
    font-size: 0.5rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-top: 0.15rem;
  }
  @media (max-width: 720px) {
    .lot-tag { left: -8px; bottom: 48px; width: 150px; transform: rotate(-5deg); }
    .brand-stamp { right: -8px; top: -20px; width: 100px; height: 100px; }
  }

  /* ------------------------------------------------------------
     MARQUEE
     ------------------------------------------------------------ */
  .marquee {
    background: var(--rr-oxblood);
    color: #f6ede0;
    border-top: 2px solid var(--rr-bg-deep);
    border-bottom: 2px solid var(--rr-bg-deep);
    overflow: hidden;
    padding: 0.6rem 0;
    font-family: 'Alfa Slab One', serif;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: 0.82rem;
  }
  .marquee-track {
    display: inline-flex;
    gap: 2.6rem;
    white-space: nowrap;
    animation: marqueeScroll 48s linear infinite;
  }
  .marquee-item::after {
    content: '·';
    margin-left: 2.6rem;
    color: var(--rr-amber);
  }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ------------------------------------------------------------
     PULL QUOTE
     ------------------------------------------------------------ */
  .pullquote-section {
    background: var(--rr-bg-deep);
    color: var(--rr-fg);
    padding: 4rem 2rem;
    position: relative;
  }
  .pullquote-section .barbwire { color: var(--rr-oxblood); margin: 0 auto; max-width: 1200px; }
  .pullquote-inner {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
    padding: 3.5rem 0;
  }
  .pullquote-tag {
    font-family: 'Special Elite', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--rr-amber);
    margin-bottom: 1.8rem;
  }
  .pullquote {
    font-family: 'Zilla Slab', serif;
    font-style: italic;
    font-weight: 500;
    font-size: clamp(1.5rem, 3.3vw, 2.6rem);
    line-height: 1.32;
    margin: 0 0 1.8rem;
    color: var(--rr-fg);
  }
  .pullquote-attrib-name {
    display: block;
    font-family: 'Alfa Slab One', serif;
    font-size: 1.05rem;
    letter-spacing: 0.02em;
    color: var(--rr-oxblood);
  }
  .pullquote-attrib-role {
    display: block;
    font-family: 'Special Elite', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rr-muted);
    margin-top: 0.45rem;
  }

  /* ------------------------------------------------------------
     SECTION HEADERS (shared)
     ------------------------------------------------------------ */
  .section-header { max-width: 820px; margin: 0 auto 3.5rem; text-align: center; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: 'Special Elite', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--rr-amber);
    margin-bottom: 1.1rem;
  }
  .section-tag .brand-r { color: var(--rr-oxblood); font-size: 0.6rem; }
  .section-title {
    font-family: 'Alfa Slab One', serif;
    font-size: clamp(2.1rem, 4.8vw, 3.7rem);
    line-height: 1.05;
    margin: 0 0 1.2rem;
    color: var(--rr-fg);
    letter-spacing: -0.01em;
  }
  .section-title em {
    font-family: 'Zilla Slab', serif;
    font-style: italic;
    font-weight: 600;
    color: var(--rr-oxblood);
  }
  .section-deck {
    font-family: 'Spectral', serif;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--rr-muted);
    max-width: 40em;
    margin: 0 auto;
  }

  /* ------------------------------------------------------------
     THE SPREAD (ranch photographs)
     ------------------------------------------------------------ */
  .spread-section {
    background: var(--rr-bg);
    color: var(--rr-fg);
    padding: 6rem 2rem 7rem;
    border-top: 1px solid var(--rr-line);
    border-bottom: 1px solid var(--rr-line);
  }
  .spread-inner { max-width: 1320px; margin: 0 auto; }
  .spread-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3.6rem 4rem;
    align-items: start;
  }
  @media (max-width: 820px) {
    .spread-grid { grid-template-columns: 1fr; gap: 2.8rem; }
    .spread-section { padding: 4rem 1.25rem 5rem; }
  }
  .still-card {
    transform: rotate(var(--rot));
    transition: transform 0.4s ease;
  }
  .still-card:hover { transform: rotate(0deg) translateY(-5px); }
  .still-photo {
    position: relative;
    background: var(--rr-surface-2);
    padding: 14px 14px 52px;
    border: 1px solid var(--rr-line);
    box-shadow: 0 22px 48px rgba(0,0,0,0.42), 0 4px 12px rgba(0,0,0,0.3);
  }
  :global([data-theme="light"]) .still-photo {
    box-shadow: 0 18px 36px rgba(60,40,20,0.2), 0 4px 10px rgba(60,40,20,0.14);
  }
  .still-photo img {
    display: block;
    width: 100%;
    aspect-ratio: var(--aspect);
    object-fit: cover;
    filter: contrast(1.04) saturate(1.02) sepia(0.05);
  }
  .still-lot {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    text-align: center;
    font-family: 'Special Elite', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--rr-fg);
    padding-top: 12px;
  }
  .still-tape {
    position: absolute;
    width: 74px;
    height: 24px;
    background: rgba(207,82,54,0.28);
    border: 1px solid rgba(207,82,54,0.4);
    z-index: 2;
  }
  :global([data-theme="light"]) .still-tape {
    background: rgba(154,51,36,0.2);
    border-color: rgba(154,51,36,0.32);
  }
  .still-tape-tl { top: -9px; left: -11px; transform: rotate(-13deg); }
  .still-tape-br { bottom: 34px; right: -11px; transform: rotate(7deg); }
  .still-meta { padding: 1.3rem 0.3rem 0; }
  .still-slug {
    font-family: 'Special Elite', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rr-amber);
    margin-bottom: 0.5rem;
  }
  .still-title {
    font-family: 'Alfa Slab One', serif;
    font-size: 1.55rem;
    color: var(--rr-fg);
    margin: 0 0 0.6rem;
    line-height: 1.1;
  }
  .still-line {
    font-family: 'Spectral', serif;
    font-style: italic;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--rr-muted);
    margin: 0;
  }

  /* ------------------------------------------------------------
     THE RANCHER'S NOTE
     ------------------------------------------------------------ */
  .note-section {
    background: var(--rr-bg-deep);
    color: var(--rr-fg);
    padding: 7rem 2rem;
    border-bottom: 1px solid var(--rr-line);
  }
  .note-grid {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.92fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .note-grid { grid-template-columns: 1fr; gap: 2.6rem; }
    .note-section { padding: 4rem 1.25rem; }
  }
  .note-image {
    margin: 0;
    background: var(--rr-surface-2);
    padding: 12px 12px 12px;
    border: 1px solid var(--rr-line);
    box-shadow: 0 24px 50px rgba(0,0,0,0.45);
    transform: rotate(-1.4deg);
  }
  :global([data-theme="light"]) .note-image { box-shadow: 0 18px 36px rgba(60,40,20,0.2); }
  .note-image img {
    display: block;
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    filter: contrast(1.04) saturate(1.02) sepia(0.05);
  }
  .note-image figcaption {
    display: flex;
    justify-content: space-between;
    margin-top: 0.8rem;
    padding: 0 0.2rem;
    font-family: 'Special Elite', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rr-muted);
  }
  .note-tag {
    font-family: 'Special Elite', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--rr-amber);
    margin-bottom: 1.1rem;
  }
  .note-h3 {
    font-family: 'Alfa Slab One', serif;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.08;
    margin: 0 0 1.5rem;
    color: var(--rr-fg);
  }
  .note-h3 em {
    font-family: 'Zilla Slab', serif;
    font-style: italic;
    font-weight: 600;
    color: var(--rr-oxblood);
  }
  .note-body {
    font-family: 'Spectral', serif;
    font-size: 1.08rem;
    line-height: 1.75;
    color: var(--rr-fg);
    margin: 0 0 1.15rem;
  }
  :global([data-theme="dark"]) .note-body { color: #d8cdb8; }
  .note-attrib { display: flex; align-items: center; gap: 1rem; margin-top: 1.7rem; }
  .note-attrib-line { width: 52px; height: 2px; background: var(--rr-oxblood); }
  .note-attrib-name {
    display: block;
    font-family: 'Alfa Slab One', serif;
    font-size: 1.02rem;
    color: var(--rr-fg);
  }
  .note-attrib-title {
    display: block;
    font-family: 'Special Elite', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--rr-muted);
    margin-top: 0.25rem;
  }

  /* ------------------------------------------------------------
     THE LEDGER (project cards)
     ------------------------------------------------------------ */
  .ledger-section {
    background: var(--rr-bg);
    color: var(--rr-fg);
    padding: 7rem 2rem;
    border-bottom: 1px solid var(--rr-line);
  }
  .ledger-inner { max-width: 1320px; margin: 0 auto; }
  .ledger-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.8rem;
  }
  @media (max-width: 1080px) { .ledger-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 680px) {
    .ledger-grid { grid-template-columns: 1fr; }
    .ledger-section { padding: 4rem 1.25rem; }
  }
  .ledger-card {
    position: relative;
    background: var(--rr-surface);
    border: 1px solid var(--rr-line);
    border-left: 4px solid var(--rr-oxblood);
    padding: 1.8rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.95rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .ledger-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 18px 38px rgba(0,0,0,0.4);
    border-left-color: var(--rr-amber);
  }
  :global([data-theme="light"]) .ledger-card:hover { box-shadow: 0 14px 28px rgba(60,40,20,0.18); }
  .ledger-card-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.8rem;
    padding-bottom: 0.8rem;
    border-bottom: 1px dashed var(--rr-line);
  }
  .ledger-lot {
    font-family: 'Alfa Slab One', serif;
    font-size: 0.95rem;
    color: var(--rr-amber);
    letter-spacing: 0.04em;
  }
  .ledger-brand {
    font-family: 'Special Elite', monospace;
    font-size: 0.6rem;
