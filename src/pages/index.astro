---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import LatestContent from '../components/LatestContent.astro';
import SpeakerCTA from '../components/SpeakerCTA.astro';
import WhatsNew from '../components/WhatsNew.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// The ledger (stats), framed as a broadcast stat line. All real, plus one.
const ledger = [
  { value: '50+', label: 'COUNTRIES SPOKEN IN' },
  { value: '80+', label: 'COUNTRIES REACHED' },
  { value: '15', label: 'BOOKS WRITTEN' },
  { value: '25+', label: 'YEARS RUNNING COMPANIES' },
  { value: '1', label: 'FAVORITE BALL' },
];

// The fan cam: five plates from a month of supporting the wrong thing.
// Captions match each generated image exactly.
const fanCam = [
  {
    src: '/images/ai-ball/edward-charging-station.jpg',
    tag: 'CAM 01 . THE CHARGING DOCK',
    title: 'Battery Watch',
    caption: `Every ball gets charged between shifts, and a real person really does watch each battery on a screen. I offered to help, repeatedly. (Powerade, if you're reading this, I'm available.)`,
  },
  {
    src: '/images/ai-ball/edward-ball-costume-stands.jpg',
    tag: 'CAM 02 . SECTION 114',
    title: 'Come as the Ball',
    caption: `The fans around me couldn't place my allegiance, because it isn't to a country. The ball would have understood, if the ball understood anything, which is sort of the whole point.`,
  },
  {
    src: '/images/ai-ball/edward-ball-on-head.jpg',
    tag: 'CAM 03 . THE STATEMENT',
    title: 'Here for the Ball',
    caption: `The sign says exactly what I'm doing there, which is more honesty than most signs at a match manage.`,
  },
  {
    src: '/images/ai-ball/edward-ball-jersey.jpg',
    tag: 'CAM 04 . NUMBER ONE',
    title: 'No Surname Needed',
    caption: `Number 1, no last name, and it doesn't need one. You already know who THE BALL is.`,
  },
  {
    src: '/images/ai-ball/edward-both-jerseys.jpg',
    tag: 'CAM 05 . BOTH SIDES',
    title: 'Just to Be Safe',
    caption: `Before I understood my true loyalty, I hedged and wore both kits at once. Turns out I was on the ball's side the whole time. The jerseys make excellent pajamas.`,
  },
];

// The wire: dry facts about the ball, most of them real.
const wire = [
  'ADIDAS TRIONDA . OFFICIAL BALL OF THE 2026 WORLD CUP',
  '500Hz MOTION SENSOR INSIDE',
  'FEEDS THE AI OFFSIDE SYSTEM IN REAL TIME',
  'FOUR PANELS . FEWEST IN WORLD CUP HISTORY',
  'YES, IT HAS TO BE CHARGED',
  'A HUMAN WATCHES ITS BATTERY ON A SCREEN',
  'RUNS ON A NEURAL NET AND A USB-C',
  'TRIONDA MEANS THREE WAVES . THREE HOST NATIONS',
];

// The roster: the real work, framed as a team sheet. Six, all real.
const roster = [
  {
    num: '01',
    pos: 'THE REAL WORK',
    title: 'MCP Servers for Finance',
    body: `The connective tissue between AI agents and enterprise finance systems. The Oracle Essbase and EPM Planning servers ship today. Financial Close and Consolidations is in beta. Same idea as the ball, honestly: instrument the thing, report the truth, and let a human make the call.`,
    badge: 'ORACLE EPM . MCP',
    status: 'SHIPPING',
    href: 'https://caprus.ai/agentcube/',
    external: true,
    cta: 'See how it works',
  },
  {
    num: '02',
    pos: 'THE GATHERING',
    title: 'Caribbean AI Summit',
    body: `Co-chairing the largest AI conference Puerto Rico has hosted, October 9 and 10 in San Juan. The lineup is public and growing: Kay Firth-Butterfield, MIT's Fabio Duarte, EU AI advisor Idoia Salazar. (Co-chairing is ten percent stagecraft and ninety percent email.)`,
    badge: '9-10 OCT 2026 . SAN JUAN',
    status: 'CALL FOR SPEAKERS OPEN',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    num: '03',
    pos: 'THE SQUAD',
    title: 'Caprus',
    body: `Investor and contributor at Caprus, the AI software and services firm giving finance teams faster, smarter operations. They do the real work. I mostly show up and point at it, like a man in a ball jersey.`,
    badge: 'AI . FINANCE',
    status: 'RUNNING',
    href: 'https://caprus.ai',
    external: true,
    cta: 'Meet the team',
  },
  {
    num: '04',
    pos: 'THE ROAD GAME',
    title: 'Everest Base Camp',
    body: `This spring I walked to the foot of the tallest mountain on Earth. I brought a map, asked the guides everything, and kept my head down. The trail log is on the blog, altitude headaches and all.`,
    badge: 'NEPAL . 2026',
    status: 'TRAIL LOG LIVE',
    href: '/blog/everest-base-camp-summit/',
    external: false,
    cta: 'Read the trail log',
  },
  {
    num: '05',
    pos: 'AFTER HOURS',
    title: "AI Dungeon Master's Screen",
    body: `An AI-driven DM's screen for running better D&D 5e campaigns: initiative, lore, and improv help for the person behind the screen. If there's going to be an oracle at the table, it should earn its seat. (I still won't tell the party.)`,
    badge: 'D&D . 5E . EBERRON',
    status: 'IN PROTOTYPE',
    href: null,
    external: false,
    cta: 'Quiet build',
  },
  {
    num: '06',
    pos: 'THE MOVEMENT',
    title: 'Puerto Rico AI Community',
    body: `President of the Puerto Rico AI Community, more than 850 people across our events. We meet every other month to work out, in public, what AI means for the island. What happens here is usually a preview of what happens everywhere else.`,
    badge: '850+ . BI-MONTHLY',
    status: 'RUNNING',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next one',
  },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- BROADCAST BAR -->
  <div class="tv-bar">
    <div class="tv-bar-inner">
      <span class="tv-bar-brand">ROSKE.AI</span>
      <span class="tv-bar-meta tv-bar-center">THE BALL APPRECIATION SOCIETY . MEMBERSHIP: 1</span>
      <span class="tv-bar-live"><span class="tv-live-dot"></span>LIVE . CHARGE 97%</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-pip"></span>
          <span>FAN NO. 1 . THE ONLY PLAYER MADE OF SILICON</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">I'm just here</span>
          <span class="hero-title-line hero-title-em"><em>for the ball.</em></span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="/question/" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href={theme.hero.ctaLink} class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-ledger">
          {ledger.map(stat => (
            <div class="ledger-item">
              <div class="ledger-value">{stat.value}</div>
              <div class="ledger-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-monitor-wrap">
        <figure class="monitor">
          <div class="monitor-top">
            <span class="monitor-feed"><span class="monitor-rec"></span>FEED . PITCHSIDE CAM</span>
            <span class="monitor-num">4K . 500Hz</span>
          </div>
          <div class="monitor-window">
            <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1600" height="1067" loading="eager" decoding="async" class="monitor-image" />
            <div class="monitor-hud">
              <span class="hud-chip hud-chip-charge"><span class="hud-batt"><span class="hud-batt-fill"></span></span>BALL . 95% . CHARGING</span>
              <span class="hud-chip hud-chip-sensor">SENSOR: LOCKED</span>
            </div>
            <div class="monitor-lower3">
              <span class="lower3-kicker">MATCH IGNORED</span>
              <span class="lower3-text">Edward monitors the important player</span>
            </div>
          </div>
          <figcaption class="monitor-caption">The final is happening directly behind him. He is checking the battery.</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- WIRE / TICKER -->
  <div class="wire" aria-hidden="true">
    <div class="wire-track">
      {[...wire, ...wire].map(item => (
        <span class="wire-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- LATEST CONTENT (permanent) -->
  <LatestContent
    eyebrow="Post-match . Dispatches"
    heading={"Fresh <em>off the wire.</em>"}
    deck="The latest writing and video briefs, filed between charging cycles. New reports up top, no extra time required."
  />

  <!-- BOOK EDWARD (permanent) -->
  <SpeakerCTA eyebrow="The paid fixtures" />

  <!-- WHAT'S NEW (permanent) -->
  <WhatsNew
    eyebrow="The highlight reel"
    heading={"In the <em>news.</em>"}
    deck="Where Edward has turned up lately: interviews, press, awards, and the odd post worth keeping. (The reel runs whether or not anyone's watching.)"
  />

  <!-- FAN CAM GALLERY -->
  <section class="fancam">
    <div class="fancam-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>THE FAN CAM . FIVE PLATES . ONE MISPLACED LOYALTY</span>
        </div>
        <h2 class="section-title">A month of supporting <em>the wrong thing.</em></h2>
        <p class="section-deck">
          I showed up in earnest, dressed for it, and made a sign. At no point was I cheering for a country, which confused the people around me and, briefly, my wife.
        </p>
      </header>

      <div class="fancam-grid">
        {fanCam.map((f, i) => (
          <article class={`fc-card ${i === 0 ? 'fc-card-lead' : ''}`}>
            <div class="fc-frame">
              <img src={f.src} alt={f.caption} loading="lazy" decoding="async" class="fc-image" />
              <span class="fc-tag">{f.tag}</span>
            </div>
            <div class="fc-meta">
              <h3 class="fc-name">{f.title}</h3>
              <p class="fc-caption">{f.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- MANIFESTO / PULL QUOTE -->
  <section class="creed">
    <div class="creed-inner">
      <div class="creed-tag">WHY THE BALL . A STATEMENT OF SUPPORT</div>
      <blockquote class="creed-q">
        I build AI for finance teams, so I recognize one when I see it. The ball is the only honest AI at this tournament. It doesn't have opinions about the offside call. It reports where it was, 500 times a second, and lets a human make the decision. Then it goes to the sideline and charges, like the rest of us.
        <span class="creed-line">(My companies do the same thing, minus the shin pads.)</span>
      </blockquote>
      <div class="creed-attrib">
        <span class="creed-name">EDWARD ROSKE</span>
        <span class="creed-role">FAN NO. 1</span>
      </div>
    </div>
  </section>

  <!-- ROSTER / PROJECTS -->
  <section id="current-work" class="roster">
    <div class="roster-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>THE TEAM SHEET . SIX THINGS I ACTUALLY DO</span>
        </div>
        <h2 class="section-title">The real roster, <em>fully charged.</em></h2>
        <p class="section-deck">
          Between fixtures I run a few companies. Six things that are real, shipping or close to it, and considerably more useful than a foam finger.
        </p>
      </header>

      <div class="roster-grid">
        {roster.map(item => (
          <article class="rt-card">
            <div class="rt-head">
              <span class="rt-num">{item.num}</span>
              <span class="rt-pos">{item.pos}</span>
            </div>
            <h3 class="rt-title">{item.title}</h3>
            <p class="rt-body">{item.body}</p>
            <div class="rt-meta">
              <span class="rt-badge">{item.badge}</span>
              <span class={`rt-status rt-status-${item.status.toLowerCase().replace(/[^a-z]+/g, '-').replace(/^-|-$/g, '')}`}>{item.status}</span>
            </div>
            <div class="rt-foot">
              {item.href ? (
                <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="rt-cta">
                  {item.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="rt-cta rt-cta-disabled">{item.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- FAN PAGE TEASER -->
  <section class="fanpage">
    <div class="fanpage-inner">
      <div class="fanpage-copy">
        <div class="fanpage-tag">NOW WITH A DEDICATED FAN PAGE</div>
        <h2 class="fanpage-title">The ball gets its <em>own page.</em></h2>
        <p class="fanpage-deck">
          One player this good deserves more than a section. I gave it a permanent home: the specs, the sensor, the charging habit, and the full case for why a data scientist spent a World Cup rooting for hardware.
        </p>
        <a href="/ai-ball/" class="btn-primary btn-primary-big">
          Visit the fan page
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
      </div>
      <div class="fanpage-card" aria-hidden="true">
        <div class="fanpage-card-top">
          <span>MEMBER CARD</span>
          <span>NO. 0001</span>
        </div>
        <div class="fanpage-card-big">THE BALL</div>
        <div class="fanpage-card-row"><span>FAN</span><span>EDWARD ROSKE</span></div>
        <div class="fanpage-card-row"><span>STATUS</span><span class="fanpage-card-ok">FULLY CHARGED</span></div>
        <div class="fanpage-card-row"><span>SINCE</span><span>KICKOFF</span></div>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="signoff">
    <div class="signoff-inner">
      <div class="signoff-eyebrow">
        <span class="signoff-rule"></span>
        <span>FULL TIME . THE LINE IS OPEN . 13 MINUTES</span>
        <span class="signoff-rule"></span>
      </div>
      <h2 class="signoff-title">Ask a good question.<br/><em>I'll allow it.</em></h2>
      <p class="signoff-deck">
        Book thirteen minutes. Ask about AI in finance, MCP servers, the Caribbean AI Summit, whether the ball is technically a teammate, or how a grown man ends up dressed as sporting equipment in Section 114. Opinions arrive whether or not you asked for them.
      </p>
      <div class="signoff-cta-row">
        <a href="/question/" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a note</span>
        </a>
      </div>
    </div>
  </section>

  <!-- COLOPHON -->
  <section class="colo">
    <div class="colo-inner">
      <div class="colo-foot">
        Not affiliated with adidas, FIFA, Powerade, or the Adidas Trionda, which is a soccer ball and cannot consent to being a website's favorite. Ball facts are real: it carries a 500Hz sensor, feeds the AI offside system, and does need charging. The jerseys are real. The membership card is not. The fedora is real and stays on. Any resemblance to a data scientist who talks too long about AI is entirely accurate.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     I'M JUST HERE FOR THE BALL
     A sports-broadcast telemetry package crossed with a fan-zine.
     Palette: floodlit pitch-green + charging-cyan + trophy gold
     Type: Bricolage Grotesque (display), Hanken Grotesk (body),
           Space Mono (telemetry labels + jersey numbers)
     ============================================================ */

  :global([data-theme="dark"]) {
    --b-bg: #0a1712;
    --b-bg2: #06100c;
    --b-surf: #11231b;
    --b-surf2: #16301f;
    --b-fg: #eaf3ec;
    --b-muted: #a2c1af;
    --b-line: #244a38;
    --b-green: #37c98b;
    --b-cyan: #35d0e8;
    --b-gold: #e6b23c;
    --b-charge: #37d97f;
    --b-ink: #06100c;
  }
  :global([data-theme="light"]) {
    --b-bg: #eef4ee;
    --b-bg2: #e2ebe3;
    --b-surf: #ffffff;
    --b-surf2: #f2f8f2;
    --b-fg: #0f241a;
    --b-muted: #45604e;
    --b-line: #d0e2d5;
    --b-green: #0e7a53;
    --b-cyan: #0e7490;
    --b-gold: #8a6410;
    --b-charge: #12894e;
    --b-ink: #0f241a;
  }

  /* ---------- BROADCAST BAR ---------- */
  .tv-bar {
    width: 100%;
    background: var(--b-ink);
    color: var(--b-fg);
    border-bottom: 2px solid var(--color-accent);
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.12em; text-transform: uppercase;
  }
  :global([data-theme="light"]) .tv-bar { background: #0b1c14; color: #eaf3ec; }
  .tv-bar-inner {
    max-width: 1500px; margin: 0 auto; padding: 0.5rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; font-size: 0.64rem;
  }
  .tv-bar-brand {
    font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800;
    letter-spacing: 0.02em; font-size: 1.15rem; color: var(--b-gold);
  }
  :global([data-theme="light"]) .tv-bar-brand { color: #f0c04e; }
  .tv-bar-meta { white-space: nowrap; }
  .tv-bar-center { flex: 1; text-align: center; letter-spacing: 0.2em; opacity: 0.9; }
  .tv-bar-live { display: inline-flex; align-items: center; gap: 0.5rem; color: var(--b-cyan); text-align: right; }
  :global([data-theme="light"]) .tv-bar-live { color: #58e0f2; }
  .tv-live-dot { width: 8px; height: 8px; border-radius: 50%; background: #ff4d4d; box-shadow: 0 0 0 0 rgba(255,77,77,0.7); animation: livePulse 1.8s infinite; }
  @keyframes livePulse { 0% { box-shadow: 0 0 0 0 rgba(255,77,77,0.6); } 70% { box-shadow: 0 0 0 7px rgba(255,77,77,0); } 100% { box-shadow: 0 0 0 0 rgba(255,77,77,0); } }
  @media (prefers-reduced-motion: reduce) { .tv-live-dot { animation: none; } }
  @media (max-width: 820px) {
    .tv-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.5rem; }
    .tv-bar-center { display: none; }
  }

  /* ---------- HERO ---------- */
  .hero {
    position: relative; background: var(--b-bg); color: var(--b-fg);
    padding: 5rem 2rem 5.5rem; overflow: hidden;
  }
  :global([data-theme="dark"]) .hero {
    background:
      radial-gradient(circle at 84% 18%, rgba(53,208,232,0.16) 0%, transparent 46%),
      radial-gradient(circle at 10% 92%, rgba(15,122,83,0.28) 0%, transparent 52%),
      linear-gradient(168deg, #06100c 0%, #0a1712 54%, #0c2018 100%);
  }
  :global([data-theme="light"]) .hero {
    background:
      radial-gradient(circle at 86% 10%, rgba(14,116,144,0.10) 0%, transparent 44%),
      radial-gradient(circle at 12% 100%, rgba(14,122,83,0.12) 0%, transparent 50%),
      linear-gradient(180deg, #eef4ee 0%, #e4ede5 100%);
  }
  /* faint pitch stripes */
  .hero::before {
    content: ''; position: absolute; inset: 0; pointer-events: none; z-index: 1; opacity: 0.5;
    background-image: repeating-linear-gradient(90deg, transparent 0 78px, rgba(255,255,255,0.018) 78px 156px);
  }
  :global([data-theme="light"]) .hero::before { background-image: repeating-linear-gradient(90deg, transparent 0 78px, rgba(14,60,40,0.03) 78px 156px); }
  .hero-grid {
    position: relative; z-index: 2; max-width: 1500px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1.04fr; gap: 4rem; align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.2rem; }
    .hero { padding: 3.5rem 1.25rem 4.25rem; }
  }
  .hero-text { max-width: 660px; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.7rem;
    font-family: 'Space Mono', monospace; font-size: 0.64rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--b-cyan);
    margin-bottom: 1.5rem; padding: 0.4rem 0.85rem;
    border: 1px solid var(--b-line); background: rgba(14,116,144,0.08);
  }
  .hero-eyebrow-pip { width: 7px; height: 7px; background: var(--b-charge); border-radius: 50%; flex-shrink: 0; }
  .hero-title { margin: 0 0 1.6rem; line-height: 0.9; }
  .hero-title-line {
    display: block; font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 800; font-size: clamp(3rem, 8vw, 6.6rem);
    color: var(--b-fg); letter-spacing: -0.02em; line-height: 0.9;
  }
  .hero-title-em em { font-style: normal; color: var(--color-accent); }
  :global([data-theme="dark"]) .hero-title-em em { color: var(--b-cyan); }
  .hero-body {
    font-family: 'Hanken Grotesk', sans-serif; font-size: 1.08rem; line-height: 1.68;
    color: var(--b-muted); margin: 0 0 2rem; max-width: 40em; font-weight: 400;
  }

  /* Buttons */
  .btn-primary, .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.85rem 1.7rem; font-family: 'Space Mono', monospace;
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase; text-decoration: none;
    border: 1.5px solid transparent; border-radius: 3px;
    transition: transform 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    cursor: pointer; line-height: 1;
  }
  .btn-primary { background: var(--color-accent); color: #fff; box-shadow: 4px 4px 0 var(--b-gold); }
  .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--b-gold); background: var(--color-accent-hover); }
  .btn-secondary { background: transparent; color: var(--b-cyan); border-color: var(--b-cyan); box-shadow: 4px 4px 0 rgba(14,122,83,0.28); }
  :global([data-theme="dark"]) .btn-secondary { color: var(--b-cyan); border-color: #2a7d8f; }
