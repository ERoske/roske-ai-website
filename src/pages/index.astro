---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// The opposing roster — fictional fighters Edward "battles" each week.
// (Edward plays himself in every match. Casting was a formality.)
const roster = [
  {
    slot: '01',
    name: 'SCORPION',
    color: '#ffb800',
    move: 'GET OVER HERE',
    counter: 'NO, YOU GET OVER HERE',
    bio: "Throws a chained spear. Edward catches it, looks at the camera, says the line. Crowd loses its mind. (The chain is detachable.)",
  },
  {
    slot: '02',
    name: 'SUB-ZERO',
    color: '#4dd0ff',
    move: 'ICE BLAST',
    counter: 'CLOSE THE BOOKS COLD',
    bio: "Freezes the spreadsheet mid-forecast. Edward freezes the close. Whichever finishes Q4 first wins the round.",
  },
  {
    slot: '03',
    name: 'RAIDEN',
    color: '#b86dff',
    move: 'LIGHTNING STRIKE',
    counter: 'THE FEDORA CONDUCTS',
    bio: "Calls down lightning from the cloud. Edward routes it through Caprus, bills it back per hour, sends a clean invoice. Round won on procurement.",
  },
  {
    slot: '04',
    name: 'LIU KANG',
    color: '#ff5a3c',
    move: 'FLYING KICK',
    counter: 'COUNTERPOINT DECK',
    bio: "Comes in fast. Edward parries with a forty-slide deck, three of which are appendix, one of which is a Douglas Adams quote. Liu Kang reads it. Wakes up in round 2.",
  },
  {
    slot: '05',
    name: 'JOHNNY CAGE',
    color: '#3cff7a',
    move: 'NUTPUNCH',
    counter: 'THE RESUME OBJECTION',
    bio: "Edward responds with a quiet recitation of his actual credentials. Johnny tries to one-up. Edward mentions the Antarctica keynote. Match called.",
  },
  {
    slot: '06',
    name: 'KANO',
    color: '#ff2d6f',
    move: 'CYBER EYE LASER',
    counter: 'THE COMPLIANCE GLARE',
    bio: "Cybernetic eye versus a fedora and forty years of audit prep. The laser passes through the brim. The audit does not. Kano takes the L.",
  },
];

// "The Atelier" -> "The Roster" -- the six recurring projects, restyled
// as Mortal Kombat fighter cards.
const features = [
  {
    fileNo: 'P1.01',
    section: 'BOSS FIGHT',
    title: 'AgentCube',
    body: "The unified engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus.AI. Already shipping for Essbase and Planning. Consolidations is in beta and learning new fatalities.",
    href: '/agentcube.html',
    external: false,
    cta: 'Pick Fighter',
    badge: 'MCP · ENTERPRISE',
  },
  {
    fileNo: 'P1.02',
    section: 'TOURNAMENT',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever seen. Speakers and attendees from around the globe. Submit a talk, sponsor a track, or grab a seat before the island fills up.",
    href: 'https://www.caribbeansummit.ai/',
    external: true,
    cta: 'Enter the Tournament',
    badge: 'OCT 9-10 · SAN JUAN',
  },
  {
    fileNo: 'P1.03',
    section: 'TAG TEAM',
    title: 'Caprus AI',
    body: "Investor and contributor at Caprus, an AI Software & Services firm empowering finance teams with AI solutions for smarter, faster, more strategic financial operations.",
    href: 'https://caprus.ai',
    external: true,
    cta: 'Visit the Dojo',
    badge: 'AI · FINANCE',
  },
  {
    fileNo: 'P1.04',
    section: 'TRAINING MODE',
    title: 'AI-Powered DM Screen',
    body: "Building a tool that helps Dungeon Masters run better D&D campaigns using AI. Because if you're going to have an artificial intelligence at your table, it should at least help with initiative tracking.",
    href: null,
    external: false,
    cta: 'In Development',
    badge: 'D&D · AI',
  },
  {
    fileNo: 'P1.05',
    section: 'CO-OP',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. Over 850 attendees across our events. We meet every other month to explore what AI means for the island and beyond.",
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the Lobby',
    badge: 'BIMONTHLY · SAN JUAN',
  },
  {
    fileNo: 'P1.06',
    section: 'BONUS STAGE',
    title: 'Everest Base Camp · Cleared',
    body: "Hiked to Everest Base Camp in April with Dawn after acclimating in Santa Fe. Ten days, twelve thousand vertical feet, one fedora that survived the entire Khumbu Valley. The next summit is undecided.",
    href: '/blog',
    external: false,
    cta: 'Read the Dispatch',
    badge: 'NEPAL · APRIL 2026',
  },
];

// Fatality FAQ -- Edward's editor's notes, reframed as Kombat Kodes.
const kombatKodes = [
  {
    q: 'On the line.',
    a: "Edward did not write 'No, you get over here.' He just had a moment of inspiration during the spear toss and the editor kept it. The chain is rented. The fedora is his.",
  },
  {
    q: 'On playing every fighter.',
    a: 'Casting fell through twice. Edward volunteered for one role, then six. The director said yes because the wardrobe department had already ordered the fedora in seven colors.',
  },
  {
    q: 'On whether the spreadsheet survives Sub-Zero.',
    a: 'It freezes around row 412 and resumes thawing in March. The forecast is fine. Q4 is closed. The auditors were notified.',
  },
  {
    q: 'On corrections and complaints.',
    a: 'Send to Edward@Roske.AI. He reads them himself, in his own voice, in roughly the same number of paragraphs you sent. (Mail in BABALITY codes go straight to spam.)',
  },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       ARCADE TOP STRIP -- credit display
       ============================================ -->
  <div class="arcade-strip">
    <div class="arcade-strip-inner">
      <span class="arcade-meta arcade-meta-blink">INSERT COIN</span>
      <span class="arcade-meta">CREDITS: 99</span>
      <span class="arcade-meta">1P MODE · TOURNAMENT</span>
      <span class="arcade-meta arcade-meta-hide-mobile">HIGH SCORE: 9999990</span>
    </div>
  </div>

  <!-- ============================================
       HERO -- title screen with movie-still poster
       ============================================ -->
  <section class="hero-section">
    <div class="hero-scanlines" aria-hidden="true"></div>
    <div class="hero-crt-glow" aria-hidden="true"></div>

    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-block"></span>
          <span>SELECT YOUR FIGHTER · WEEK OF {theme.week}</span>
          <span class="hero-eyebrow-block"></span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line hero-title-edward">EDWARD</span>
          <span class="hero-title-line hero-title-kombat">KOMBAT</span>
          <span class="hero-title-line hero-title-ii">II</span>
        </h1>

        <p class="hero-deck">{theme.hero.subtitle}</p>

        <div class="hero-tagline">
          <span class="hero-tagline-rule"></span>
          <span>{theme.tagline}</span>
          <span class="hero-tagline-rule"></span>
        </div>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            <span class="btn-glyph">▶</span>
            Book 13 Minutes
          </a>
          <a href="#roster" class="btn-secondary">
            <span class="btn-glyph">◆</span>
            Choose Fighter
          </a>
        </div>

        <div class="hero-stats">
          {[
            { value: '80+', label: 'Countries' },
            { value: '50+', label: 'Speaking' },
            { value: '15', label: 'Books' },
            { value: '25+', label: 'Years CEO' },
          ].map(stat => (
            <div class="hero-stat">
              <div class="hero-stat-value">{stat.value}</div>
              <div class="hero-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <div class="hero-cab-tag">CABINET 09 · MK II PARODY</div>
        <div class="hero-image-frame">
          <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1600" height="900" loading="eager" decoding="async" class="hero-image" />
          <div class="hero-fight-banner">
            <span class="hero-fight-banner-text">ROUND 1 — FIGHT!</span>
          </div>
        </div>
        <div class="hero-vs-stamp">VS</div>
        <div class="hero-cab-feet">
          <span>PRESS START</span>
          <span class="hero-cab-feet-blink">_</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       ATTRACT-MODE MARQUEE
       ============================================ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span class="marquee-item">★ NOW PLAYING · EDWARD KOMBAT II</span>
      <span class="marquee-item">EXCLUSIVE · ALL SIX FIGHTERS PLAYED BY EDWARD</span>
      <span class="marquee-item">★ FATALITY · CLEAN BOOKS</span>
      <span class="marquee-item">CARIBBEAN AI SUMMIT · OCT 9-10</span>
      <span class="marquee-item">★ AGENTCUBE · NOW SHIPPING</span>
      <span class="marquee-item">FEDORA: STILL BLUE (UNLESS THEMED)</span>
      <span class="marquee-item">★ NOW PLAYING · EDWARD KOMBAT II</span>
      <span class="marquee-item">EXCLUSIVE · ALL SIX FIGHTERS PLAYED BY EDWARD</span>
      <span class="marquee-item">★ FATALITY · CLEAN BOOKS</span>
      <span class="marquee-item">CARIBBEAN AI SUMMIT · OCT 9-10</span>
      <span class="marquee-item">★ AGENTCUBE · NOW SHIPPING</span>
      <span class="marquee-item">FEDORA: STILL BLUE (UNLESS THEMED)</span>
    </div>
  </div>

  <!-- ============================================
       SCORPION SCENE -- the line, immortalized
       ============================================ -->
  <section class="scorpion-section">
    <div class="scorpion-inner">
      <div class="scorpion-image-wrap">
        <img src="/images/edward-kombat/scorpion-get-over-here.png" alt="Edward in his blue fedora yanks the chain back at Scorpion in a misty hellfire arena, mouth open mid-shout." loading="lazy" decoding="async" />
        <div class="scorpion-image-tag">EXHIBIT A · 0:43 INTO TRAILER</div>
      </div>
      <div class="scorpion-text">
        <div class="scorpion-tag">SIGNATURE LINE · EXCLUSIVE PARODY</div>
        <h2 class="scorpion-title">
          <span>"NO,</span>
          <span class="scorpion-title-emph">YOU</span>
          <span>GET OVER HERE!"</span>
        </h2>
        <p class="scorpion-deck">
          Scorpion throws his spear. Edward catches the chain, plants his fedora, and yanks. The line was unscripted. The fedora was prepared. The two facts are unrelated and also identical.
        </p>
        <ul class="scorpion-stats">
          <li><span class="scorpion-stat-key">Spear distance</span><span class="scorpion-stat-val">14 ft</span></li>
          <li><span class="scorpion-stat-key">Chain length</span><span class="scorpion-stat-val">22 ft</span></li>
          <li><span class="scorpion-stat-key">Crowd reaction</span><span class="scorpion-stat-val">★★★★★</span></li>
          <li><span class="scorpion-stat-key">Fedoras lost</span><span class="scorpion-stat-val">0</span></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ============================================
       ROSTER -- character select grid (the six fights)
       ============================================ -->
  <section id="roster" class="roster-section">
    <div class="roster-inner">
      <header class="section-header">
        <div class="section-tag">ROUND 02 · CHARACTER SELECT</div>
        <h2 class="section-title">CHOOSE<br/>YOUR<br/><span class="section-title-emph">OPPONENT.</span></h2>
        <p class="section-deck">
          Six fighters. One Edward. (Casting agreed to it on principle.) Each match-up below describes the move, the counter, and the round in three short sentences. Roster is final, the wardrobe department disagrees.
        </p>
      </header>

      <div class="roster-grid">
        {roster.map(r => (
          <article class="roster-card" style={`--rc:${r.color};`}>
            <div class="roster-slot">SLOT {r.slot}</div>
            <h3 class="roster-name">{r.name}</h3>
            <div class="roster-portrait">
              <span class="roster-portrait-corner roster-portrait-tl"></span>
              <span class="roster-portrait-corner roster-portrait-tr"></span>
              <span class="roster-portrait-corner roster-portrait-bl"></span>
              <span class="roster-portrait-corner roster-portrait-br"></span>
              <div class="roster-portrait-glyph"></div>
              <div class="roster-portrait-fedora">FEDORA</div>
            </div>
            <div class="roster-move-row">
              <span class="roster-move-label">MOVE</span>
              <span class="roster-move-text">{r.move}</span>
            </div>
            <div class="roster-move-row">
              <span class="roster-move-label">COUNTER</span>
              <span class="roster-move-text roster-move-counter">{r.counter}</span>
            </div>
            <p class="roster-bio">{r.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       PIXEL ARCADE CABINET -- 16-bit fight screen
       ============================================ -->
  <section class="cabinet-section">
    <div class="cabinet-inner">
      <header class="section-header cabinet-header">
        <div class="section-tag">ROUND 03 · ARCADE CABINET</div>
        <h2 class="section-title">FOR THE<br/><span class="section-title-emph">PURISTS.</span></h2>
        <p class="section-deck">
          The Genesis cartridge port. Same fight, fewer pixels, exactly as much fedora. (The pit stage rendered in 47 colors, none of which were licensed.)
        </p>
      </header>

      <div class="cabinet-screen-frame">
        <div class="cabinet-bezel-top">
          <span>1P  EDWARD</span>
          <span>CREDIT 99</span>
          <span>2P  SCORPION</span>
        </div>
        <img src="/images/edward-kombat/pixel-fight-screen.png" alt="16-bit pixel art fight screen: Edward in a blue pixel fedora faces Scorpion in The Pit stage, with health bars at the top and the word FIGHT in large yellow pixels." loading="lazy" decoding="async" class="cabinet-screen" />
        <div class="cabinet-bezel-bottom">
          <span>★ INSERT COIN ★</span>
          <span>HIGH SCORE 9999990</span>
        </div>
      </div>

      <div class="cabinet-grid">
        <figure class="cabinet-side-figure">
          <img src="/images/edward-kombat/character-select.png" alt="Pixel art character select grid showing Edward dressed as six different Mortal Kombat fighters, always wearing a small fedora." loading="lazy" decoding="async" />
          <figcaption>SELECT YOUR EDWARD · ALL SIX SLOTS PRE-CAST</figcaption>
        </figure>
        <div class="cabinet-side-text">
          <h3 class="cabinet-h3">Two Editions.<br/>One Fighter.</h3>
          <p>The cinematic cut hits theaters this weekend (we have notes). The arcade cabinet is in your basement, possibly. Both ship with Edward in every role and a difficulty setting labeled <em>Q4 CLOSE</em>.</p>
          <p>(There is no easy mode. There is, however, a tutorial. It is forty pages and shaped like a binder.)</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SUB-ZERO + RAIDEN STILLS -- secondary scenes
       ============================================ -->
  <section class="stills-section">
    <div class="stills-inner">
      <header class="section-header">
        <div class="section-tag">PRESS KIT · UNCROPPED</div>
        <h2 class="section-title">TWO MORE<br/><span class="section-title-emph">STILLS.</span></h2>
      </header>

      <div class="stills-grid">
        <figure class="still-card">
          <img src="/images/edward-kombat/sub-zero-spreadsheet.png" alt="Edward in his fedora freezing a glowing financial spreadsheet labeled Q4 FORECAST with ice powers." loading="lazy" decoding="async" />
          <figcaption>
            <span class="still-card-tag">EXHIBIT B</span>
            <h3>The Q4 Freeze.</h3>
            <p>Sub-Zero froze the spreadsheet. Edward froze the close. The spreadsheet thawed. Q4 did not.</p>
          </figcaption>
        </figure>
        <figure class="still-card">
          <img src="/images/edward-kombat/raiden-rooftop.png" alt="Edward in his fedora on a rooftop summoning lightning between his palms during a thunderstorm." loading="lazy" decoding="async" />
          <figcaption>
            <span class="still-card-tag">EXHIBIT C</span>
            <h3>The Lightning Routing.</h3>
            <p>Raiden brought the storm. Edward brought a service contract. The hourly rate is in the appendix.</p>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================
       FEATURE ROSTER -- six recurring projects
       ============================================ -->
  <section id="current-work" class="features-section">
    <div class="features-inner">
      <header class="section-header">
        <div class="section-tag">ROUND 04 · CURRENT KAMPAIGNS</div>
        <h2 class="section-title">SIX FIGHTS,<br/><span class="section-title-emph">CURRENTLY ACTIVE.</span></h2>
        <p class="section-deck">
          The actual roster, minus the wig. Each card below is a real project Edward is shipping, sitting on, or summiting. Pick one to read more.
        </p>
      </header>

      <div class="features-grid">
        {features.map(feat => (
          <article class="feat-card">
            <div class="feat-corner feat-corner-tl"></div>
            <div class="feat-corner feat-corner-tr"></div>
            <div class="feat-corner feat-corner-bl"></div>
            <div class="feat-corner feat-corner-br"></div>

            <div class="feat-card-header">
              <span class="feat-fileno">{feat.fileNo}</span>
              <span class="feat-section">{feat.section}</span>
            </div>
            <h3 class="feat-title">{feat.title}</h3>
            <p class="feat-body">{feat.body}</p>
            <div class="feat-card-footer">
              <span class="feat-badge">{feat.badge}</span>
              {feat.href ? (
                <a href={feat.href} target={feat.external ? '_blank' : undefined} rel={feat.external ? 'noopener' : undefined} class="feat-cta">
                  {feat.cta}
                  <span class="feat-cta-glyph">▶</span>
                </a>
              ) : (
                <span class="feat-cta feat-cta-disabled">{feat.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       KOMBAT KODES -- Q&A as cheat codes
       ============================================ -->
  <section class="kodes-section">
    <div class="kodes-inner">
      <header class="section-header">
        <div class="section-tag">ROUND 05 · KOMBAT KODES</div>
        <h2 class="section-title">A FEW NOTES,<br/><span class="section-title-emph">FROM THE BACK OF THE MANUAL.</span></h2>
      </header>

      <div class="kodes-list">
        {kombatKodes.map((item, idx) => (
          <div class="kode-item">
            <div class="kode-num">{String(idx + 1).padStart(2, '0')}</div>
            <div class="kode-content">
              <div class="kode-q">{item.q}</div>
              <div class="kode-a">{item.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FINAL CTA -- INSERT COIN TO CONTINUE
       ============================================ -->
  <section class="final-cta">
    <div class="final-cta-scanlines" aria-hidden="true"></div>
    <div class="final-cta-inner">
      <div class="final-cta-content">
        <div class="final-cta-tag">ROUND 06 · CONTINUE?</div>
        <h2 class="final-cta-title">
          INSERT COIN<br/>
          <span class="final-cta-accent">TO CONTINUE.</span>
        </h2>
        <p class="final-cta-body">
          Thirteen minutes on the calendar. No deck. No charge. The fedora is optional. (Edward will be wearing one.)
        </p>
        <div class="final-cta-buttons">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            <span class="btn-glyph">▶</span>
            Book 13 Minutes
          </a>
          <a href="mailto:Edward@Roske.AI" class="btn-secondary">
            <span class="btn-glyph">✉</span>
            Mail the Cabinet
          </a>
        </div>
        <div class="final-cta-countdown">
          <span class="final-cta-countdown-label">CONTINUE IN</span>
          <span class="final-cta-countdown-num">10</span>
          <span class="final-cta-countdown-blip">_</span>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ============================================================
     EDWARD KOMBAT II -- arcade fight game aesthetic
     Deep red, ice cyan, lightning gold. Press Start 2P for headers.
     ============================================================ */

  :global(:root) {
    color-scheme: dark light;
  }

  /* ARCADE TOP STRIP -------------------------------------------- */
  .arcade-strip {
    width: 100%;
    border-bottom: 2px solid var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0.6rem 1.5rem;
    position: relative;
    z-index: 10;
  }
  [data-theme="dark"] .arcade-strip {
    background: #0a0205;
    color: var(--color-accent);
  }
  [data-theme="light"] .arcade-strip {
    background: #170306;
    color: var(--color-accent);
  }
  .arcade-strip-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .arcade-meta {
    font-weight: 600;
  }
  .arcade-meta-blink {
    animation: arcade-blink 1.2s steps(1, end) infinite;
  }
  @keyframes arcade-blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0.15; }
  }
  @media (max-width: 768px) {
    .arcade-meta-hide-mobile { display: none; }
  }

  /* HERO --------------------------------------------------------- */
  .hero-section {
    position: relative;
    overflow: hidden;
    padding: 3.5rem 1.5rem 4.5rem;
    isolation: isolate;
  }
  @media (min-width: 768px) {
    .hero-section { padding: 5rem 2rem 6rem; }
  }
  [data-theme="dark"] .hero-section {
    background:
      radial-gradient(ellipse at 70% 30%, rgba(200, 16, 46, 0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 20% 80%, rgba(255, 184, 0, 0.08) 0%, transparent 55%),
      linear-gradient(180deg, #0a0205 0%, #160508 100%);
  }
  [data-theme="light"] .hero-section {
    background:
      radial-gradient(ellipse at 70% 30%, rgba(200, 16, 46, 0.12) 0%, transparent 55%),
      radial-gradient(ellipse at 20% 80%, rgba(255, 184, 0, 0.10) 0%, transparent 55%),
      #f4ece0;
  }

  .hero-scanlines {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background-image: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.18) 0px,
      rgba(0, 0, 0, 0.18) 1px,
      transparent 1px,
      transparent 4px
    );
    opacity: 0.5;
    mix-blend-mode: multiply;
  }
  [data-theme="light"] .hero-scanlines {
    background-image: repeating-linear-gradient(
      0deg,
      rgba(160, 0, 30, 0.07) 0px,
      rgba(160, 0, 30, 0.07) 1px,
      transparent 1px,
      transparent 4px
    );
    opacity: 0.7;
    mix-blend-mode: normal;
  }

  .hero-crt-glow {
    position: absolute;
    inset: -10%;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at center, transparent 50%, rgba(0, 0, 0, 0.5) 100%);
  }
  [data-theme="light"] .hero-crt-glow { display: none; }

  .hero-grid {
    position: relative;
    z-index: 3;
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1.1fr 1fr;
      gap: 4rem;
    }
  }

  .hero-text { position: relative; }

  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-bottom: 1.6rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .hero-eyebrow-block {
    width: 0.75rem;
    height: 0.75rem;
    background: var(--color-accent);
    box-shadow: 0 0 8px var(--color-accent);
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 6.5vw, 5rem);
    line-height: 1.1;
    letter-spacing: 0;
    margin: 0 0 2rem;
    text-transform: uppercase;
  }
  .hero-title-line {
    display: block;
  }
  [data-theme="dark"] .hero-title-edward {
    color: #fff4d9;
    text-shadow: 0.25rem 0.25rem 0 #c8102e;
  }
  [data-theme="dark"] .hero-title-kombat {
    color: var(--color-accent);
    text-shadow: 0.25rem 0.25rem 0 #c8102e;
  }
  [data-theme="dark"] .hero-title-ii {
    color: #c8102e;
    font-size: 1.4em;
    text-shadow: 0.3rem 0.3rem 0 #160508;
  }
  [data-theme="light"] .hero-title-edward {
    color: #170306;
    text-shadow: 0.2rem 0.2rem 0 #c8102e;
  }
  [data-theme="light"] .hero-title-kombat {
    color: #c8102e;
    text-shadow: 0.2rem 0.2rem 0 #170306;
  }
  [data-theme="light"] .hero-title-ii {
    color: #170306;
    font-size: 1.4em;
    text-shadow: 0.3rem 0.3rem 0 var(--color-accent);
  }

  .hero-deck {
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.8vw, 1.3rem);
    font-weight: 500;
    line-height: 1.45;
    margin: 0 0 1.6rem;
    max-width: 38rem;
  }
  [data-theme="dark"] .hero-deck { color: #fff4d9; }
  [data-theme="light"] .hero-deck { color: #170306; }

  .hero-tagline {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 1.6rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .hero-tagline-rule {
    flex: 1;
    height: 2px;
    background: var(--color-accent);
    max-width: 3rem;
  }

  .hero-body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.6;
    margin: 0 0 2rem;
    max-width: 38rem;
    font-weight: 400;
  }
  [data-theme="dark"] .hero-body { color: rgba(255, 244, 217, 0.8); }
  [data-theme="light"] .hero-body { color: #5a3a3a; }

  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.85rem 1.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    border: 2px solid var(--color-accent);
    transition: all 0.15s ease-out;
    cursor: pointer;
  }
  .btn-primary {
    background: var(--color-accent);
    color: #170306;
    box-shadow: 0.3rem 0.3rem 0 var(--color-secondary);
  }
  .btn-primary:hover {
    transform: translate(-0.15rem, -0.15rem);
    box-shadow: 0.45rem 0.45rem 0 var(--color-secondary);
  }
  .btn-primary:active {
    transform: translate(0.15rem, 0.15rem);
    box-shadow: 0.15rem 0.15rem 0 var(--color-secondary);
  }
  .btn-secondary {
    background: transparent;
    border-color: var(--color-secondary);
  }
  [data-theme="dark"] .btn-secondary { color: #fff4d9; }
  [data-theme="light"] .btn-secondary { color: #170306; }
  .btn-secondary:hover {
    background: var(--color-secondary);
    color: #fff4d9;
  }
  .btn-glyph {
    font-size: 0.9em;
    color: inherit;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .hero-stat {
    text-align: center;
    padding: 0.6rem 0.4rem;
    border: 2px solid var(--color-accent);
    background: rgba(10, 2, 5, 0.4);
  }
  [data-theme="light"] .hero-stat {
    background: rgba(255, 244, 217, 0.5);
    border-color: var(--color-secondary);
  }
  .hero-stat-value {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.3rem;
    color: var(--color-accent);
  }
  [data-theme="light"] .hero-stat-value { color: var(--color-secondary); }
  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 500;
  }
  [data-theme="dark"] .hero-stat-label { color: rgba(255, 244, 217, 0.65); }
  [data-theme="light"] .hero-stat-label { color: #5a3a3a; }

  .hero-image-wrap {
    position: relative;
    padding: 1rem;
  }
  .hero-cab-tag {
    position: absolute;
    top: -0.4rem;
    left: 1rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    font-weight: 600;
    text-transform: uppercase;
    background: var(--color-accent);
    color: #170306;
    padding: 0.35rem 0.65rem;
    z-index: 4;
    box-shadow: 0.2rem 0.2rem 0 var(--color-secondary);
  }

  .hero-image-frame {
    position: relative;
    border: 4px solid var(--color-accent);
    box-shadow: 0.5rem 0.5rem 0 var(--color-secondary);
    overflow: hidden;
    background: #000;
  }
  .hero-image {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: auto;
  }
  .hero-fight-banner {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-heading);
    font-size: clamp(0.85rem, 1.5vw, 1.3rem);
    background: var(--color-accent);
    color: #170306;
    padding: 0.5rem 1rem;
    letter-spacing: 0.05em;
    box-shadow: 0.2rem 0.2rem 0 var(--color-secondary);
    animation: arcade-blink 1.4s steps(1, end) infinite;
  }

  .hero-vs-stamp {
    position: absolute;
    top: -1rem;
    right: -1rem;
    width: 4.5rem;
    height: 4.5rem;
    background: var(--color-secondary);
    color: #fff4d9;
    border: 4px solid var(--color-accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 1.1rem;
    box-shadow: 0.3rem 0.3rem 0 var(--color-accent);
    transform: rotate(-8deg);
    z-index: 4;
  }

  .hero-cab-feet {
    margin-top: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
  }
  .hero-cab-feet-blink { animation: arcade-blink 0.7s steps(1, end) infinite; }

  /* MARQUEE ----------------------------------------------------- */
  .marquee {
    overflow: hidden;
    border-top: 2px solid var(--color-accent);
    border-bottom: 2px solid var(--color-accent);
    padding: 0.6rem 0;
    background: var(--color-secondary);
    color: #fff4d9;
  }
  .marquee-track {
    display: flex;
    gap: 2.5rem;
    white-space: nowrap;
    animation: marquee 38s linear infinite;
    will-change: transform;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  .marquee-item {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 600;
    flex-shrink: 0;
  }

  /* SCORPION SECTION -------------------------------------------- */
  .scorpion-section {
    padding: 4.5rem 1.5rem;
    position: relative;
  }
  [data-theme="dark"] .scorpion-section {
    background: linear-gradient(135deg, #160508 0%, #2a0510 100%);
    color: #fff4d9;
  }
  [data-theme="light"] .scorpion-section {
    background: linear-gradient(135deg, #f4ece0 0%, #f8e0d0 100%);
    color: #170306;
  }
  @media (min-width: 768px) {
    .scorpion-section { padding: 6rem 2rem; }
  }
  .scorpion-inner {
    max-width: 78rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .scorpion-inner { grid-template-columns: 1.1fr 1fr; gap: 4.5rem; }
  }

  .scorpion-image-wrap {
    position: relative;
  }
  .scorpion-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    border: 4px solid var(--color-accent);
    box-shadow: 0.6rem 0.6rem 0 var(--color-secondary);
  }
  .scorpion-image-tag {
    position: absolute;
    bottom: -0.6rem;
    left: 1rem;
    background: var(--color-secondary);
    color: #fff4d9;
    padding: 0.4rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.22em;
    font-weight: 600;
    text-transform: uppercase;
    box-shadow: 0.2rem 0.2rem 0 var(--color-accent);
  }

  .scorpion-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-bottom: 1.4rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .scorpion-title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 3rem);
    line-height: 1.1;
    margin: 0 0 1.6rem;
    text-transform: uppercase;
  }
  .scorpion-title span {
    display: block;
  }
  .scorpion-title-emph {
    color: var(--color-accent);
    font-size: 1.5em;
    text-shadow: 0.3rem 0.3rem 0 var(--color-secondary);
  }
  .scorpion-deck {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.55;
    margin: 0 0 2rem;
  }
  .scorpion-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.5rem;
    border: 2px solid var(--color-accent);
    padding: 1rem;
  }
  .scorpion-stats li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.4rem;
  }
  .scorpion-stat-key {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-weight: 500;
    opacity: 0.7;
  }
  .scorpion-stat-val {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  /* SECTION HEADER -- shared across sections -------------------- */
  .section-header {
    margin-bottom: 3rem;
    max-width: 50rem;
  }
  .section-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-weight: 600;
    color: var(--color-accent);
  }
  .section-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.05;
    margin: 0 0 1.6rem;
    text-transform: uppercase;
    letter-spacing: 0;
  }
  .section-title-emph {
    color: var(--color-accent);
    text-shadow: 0.2rem 0.2rem 0 var(--color-secondary);
  }
  [data-theme="light"] .section-title-emph {
    text-shadow: 0.2rem 0.2rem 0 var(--color-secondary);
  }
  .section-deck {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.55;
    max-width: 42rem;
    margin: 0;
  }
  [data-theme="dark"] .section-deck { color: rgba(255, 244, 217, 0.85); }
  [data-theme="light"] .section-deck { color: #5a3a3a; }

  /* ROSTER SECTION --------------------------------------------- */
  .roster-section {
    padding: 4.5rem 1.5rem;
  }
  [data-theme="dark"] .roster-section { background: #0a0205; color: #fff4d9; }
  [data-theme="light"] .roster-section { background: #f4ece0; color: #170306; }
  @media (min-width: 768px) {
    .roster-section { padding: 6rem 2rem; }
  }
  .roster-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .roster-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.4rem;
  }
  @media (min-width: 640px) {
    .roster-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .roster-grid { grid-template-columns: repeat(3, 1fr); gap: 1.8rem; }
  }

  .roster-card {
    --rc: var(--color-accent);
    border: 3px solid var(--rc);
    padding: 1.4rem;
    position: relative;
    box-shadow: 0.4rem 0.4rem 0 var(--color-secondary);
    transition: transform 0.15s ease-out, box-shadow 0.15s ease-out;
  }
  [data-theme="dark"] .roster-card { background: rgba(22, 5, 8, 0.7); }
  [data-theme="light"] .roster-card { background: #fff; }
  .roster-card:hover {
    transform: translate(-0.2rem, -0.2rem);
    box-shadow: 0.6rem 0.6rem 0 var(--color-secondary);
  }
  .roster-slot {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--rc);
    margin-bottom: 0.4rem;
    font-weight: 600;
  }
  .roster-name {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin: 0 0 1rem;
    color: var(--rc);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }
  .roster-portrait {
    aspect-ratio: 4 / 3;
    background:
      repeating-linear-gradient(0deg, transparent 0, transparent 6px, rgba(255,255,255,0.04) 6px, rgba(255,255,255,0.04) 7px),
      linear-gradient(135deg, color-mix(in srgb, var(--rc) 25%, transparent), color-mix(in srgb, var(--rc) 5%, transparent));
    position: relative;
    margin-bottom: 1rem;
    border: 2px solid var(--rc);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  [data-theme="light"] .roster-portrait {
    background:
      repeating-linear-gradient(0deg, transparent 0, transparent 6px, rgba(0,0,0,0.03) 6px, rgba(0,0,0,0.03) 7px),
      linear-gradient(135deg, color-mix(in srgb, var(--rc) 30%, white), white);
  }
  .roster-portrait-corner {
    position: absolute;
    width: 0.7rem;
    height: 0.7rem;
    border: 2px solid var(--rc);
  }
  .roster-portrait-tl { top: -0.15rem; left: -0.15rem; border-right: none; border-bottom: none; }
  .roster-portrait-tr { top: -0.15rem; right: -0.15rem; border-left: none; border-bottom: none; }
  .roster-portrait-bl { bottom: -0.15rem; left: -0.15rem; border-right: none; border-top: none; }
  .roster-portrait-br { bottom: -0.15rem; right: -0.15rem; border-left: none; border-top: none; }
  .roster-portrait-glyph {
    width: 3.5rem;
    height: 3.5rem;
    background: var(--rc);
    clip-path: polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%);
    box-shadow: 0 0 30px var(--rc);
  }
  .roster-portrait-fedora {
    position: absolute;
    bottom: 0.6rem;
    right: 0.6rem;
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    background: var(--rc);
    color: #170306;
    padding: 0.2rem 0.4rem;
    font-weight: 700;
  }

  .roster-move-row {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--rc);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .roster-move-label {
    flex-shrink: 0;
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.6;
    width: 4rem;
  }
  .roster-move-text {
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .roster-move-counter { color: var(--rc); }

  .roster-bio {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 1rem 0 0;
  }
  [data-theme="dark"] .roster-bio { color: rgba(255, 244, 217, 0.78); }
  [data-theme="light"] .roster-bio { color: #5a3a3a; }

  /* CABINET SECTION --------------------------------------------- */
  .cabinet-section {
    padding: 4.5rem 1.5rem;
    position: relative;
    overflow: hidden;
  }
  [data-theme="dark"] .cabinet-section {
    background:
      radial-gradient(ellipse at center, rgba(200, 16, 46, 0.15) 0%, transparent 60%),
      #160508;
    color: #fff4d9;
  }
  [data-theme="light"] .cabinet-section {
    background:
      radial-gradient(ellipse at center, rgba(200, 16, 46, 0.08) 0%, transparent 60%),
      #f4ece0;
    color: #170306;
  }
  @media (min-width: 768px) {
    .cabinet-section { padding: 6rem 2rem; }
  }
  .cabinet-inner { max-width: 80rem; margin: 0 auto; }
  .cabinet-header { text-align: center; margin-left: auto; margin-right: auto; }
  .cabinet-header .section-deck { margin-left: auto; margin-right: auto; }

  .cabinet-screen-frame {
    border: 6px solid var(--color-accent);
    background: #000;
    margin-bottom: 3rem;
    box-shadow: 0.6rem 0.6rem 0 var(--color-secondary);
    overflow: hidden;
  }
  .cabinet-bezel-top, .cabinet-bezel-bottom {
    background: var(--color-secondary);
    color: var(--color-accent);
    padding: 0.5rem 1rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    font-weight: 700;
    text-transform: uppercase;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .cabinet-bezel-top { border-bottom: 2px solid var(--color-accent); }
  .cabinet-bezel-bottom { border-top: 2px solid var(--color-accent); }
  .cabinet-screen {
    display: block;
    width: 100%;
    height: auto;
    image-rendering: pixelated;
  }

  .cabinet-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 1024px) {
    .cabinet-grid { grid-template-columns: 1fr 1fr; gap: 4rem; }
  }

  .cabinet-side-figure { margin: 0; }
  .cabinet-side-figure img {
    width: 100%;
    height: auto;
    border: 4px solid var(--color-accent);
    box-shadow: 0.4rem 0.4rem 0 var(--color-secondary);
    image-rendering: pixelated;
    display: block;
  }
  .cabinet-side-figure figcaption {
    text-align: center;
    margin-top: 0.85rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
  }
  .cabinet-h3 {
    font-family: var(--font-heading);
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    line-height: 1.1;
    margin: 0 0 1.4rem;
    text-transform: uppercase;
    color: var(--color-accent);
    text-shadow: 0.2rem 0.2rem 0 var(--color-secondary);
  }
  .cabinet-side-text p {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.55;
    margin: 0 0 1rem;
  }
  [data-theme="dark"] .cabinet-side-text p { color: rgba(255, 244, 217, 0.82); }
  [data-theme="light"] .cabinet-side-text p { color: #5a3a3a; }

  /* STILLS SECTION ---------------------------------------------- */
  .stills-section {
    padding: 4.5rem 1.5rem;
  }
  [data-theme="dark"] .stills-section { background: #0a0205; color: #fff4d9; }
  [data-theme="light"] .stills-section { background: #f4ece0; color: #170306; }
  @media (min-width: 768px) {
    .stills-section { padding: 6rem 2rem; }
