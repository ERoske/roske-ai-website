---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import LatestContent from '../components/LatestContent.astro';
import SpeakerCTA from '../components/SpeakerCTA.astro';
import WhatsNew from '../components/WhatsNew.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// Four attempts to help celebrate America's 250th. Three go badly. The fourth
// is the day job. Captions match each generated scene image.
const attempts = [
  {
    src: '/images/july4/usmnt-hamstring.jpg',
    kicker: 'EXHIBIT A',
    title: 'The Tryout',
    caption: "I made the World Cup squad, in my head, scored the winner, and pulled a hamstring in the celebration. The actual USMNT is alive heading into Monday's Belgium match, with or without me. (Without.)",
  },
  {
    src: '/images/july4/birthday-crash.jpg',
    kicker: 'EXHIBIT B',
    title: 'The Party',
    caption: "Crashed America's 250th birthday party to blow out the candles. Nobody invited me, which is a technicality I've never respected at a good party (and this is the best one in 250 years).",
  },
  {
    src: '/images/july4/declaration-late.jpg',
    kicker: 'EXHIBIT C',
    title: 'The Signing',
    caption: "Arrived to sign the Declaration of Independence exactly 250 years late, laptop in hand. The Founders were gracious about it. Adams less so. (He'd have had notes on the laptop, too.)",
  },
];

// The pivot: the one thing he's actually qualified for.
const pivot = {
  src: '/images/july4/longevity-report.jpg',
  kicker: 'THE DAY JOB',
  title: 'The Longevity Report',
  caption: "Then I did the one thing on this list I actually have credentials for: I ran the numbers on the longest-running startup in history. Two hundred fifty years of shipping updates is a retention curve nobody's beaten yet, and I could study it all day.",
};

// Patriotic broadside marquee: dry lines mixed with civic slogans.
const ticker = [
  "USA . USA . USA",
  "AMERICA: EST. 1776, STILL SHIPPING",
  "USMNT: ALIVE HEADING INTO MONDAY",
  "250 YEARS, ZERO GOALS SCORED BY EDWARD",
  "HAPPY SEMIQUINCENTENNIAL (SAY IT THREE TIMES FAST)",
  "THE FEDORA ABIDES",
  "ASK NOT WHAT AI CAN DO FOR YOU",
];

// The real-world work, framed as the contribution to the next 250 years.
const arsenal = [
  {
    code: 'No. 01',
    cat: 'IN PRODUCTION',
    title: 'AgentCube',
    body: "The engine that connects AI agents to enterprise finance systems: planning, close, consolidation. Built by Caprus. Shipped, and answering when you call it, which is more than I managed at the World Cup tryout.",
    badge: 'ENTERPRISE FINANCE',
    status: 'SHIPPED',
    href: 'https://caprus.ai/agentcube/',
    external: true,
    cta: 'Read the docs',
  },
  {
    code: 'No. 02',
    cat: 'THE GATHERING',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever hosted, October 9 and 10 in San Juan. The lineup is public: Kay Firth-Butterfield, MIT's Fabio Duarte, and EU AI advisor Idoia Salazar, with more every week. (Co-chairing is roughly ten percent stagecraft and ninety percent email.)",
    badge: '9-10 OCT 2026 . SAN JUAN',
    status: 'CALL FOR SPEAKERS OPEN',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    code: 'No. 03',
    cat: 'THE FIRM',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, the AI software and services firm giving finance teams faster, smarter operations. The crew behind the MCP servers, and the people who do the actual heroics while I take the cover photo.",
    badge: 'AI . FINANCE',
    status: 'RUNNING',
    href: 'https://caprus.ai',
    external: true,
    cta: 'See the team',
  },
  {
    code: 'No. 04',
    cat: 'AFTER HOURS',
    title: "AI Dungeon Master's Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns: initiative, lore, and improv help for the person behind the screen. If there's going to be an AI at the table, it should earn its seat. (The party still will not be told.)",
    badge: 'D&D . 5E . EBERRON',
    status: 'IN PROTOTYPE',
    href: null,
    external: false,
    cta: 'Quiet build',
  },
  {
    code: 'No. 05',
    cat: 'THE MOVEMENT',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community, more than 850 people across our events. We meet every other month to figure out, in public, what AI means for the island. What happens on the island is usually a preview of what happens everywhere else.",
    badge: '850+ . BI-MONTHLY',
    status: 'RUNNING',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next one',
  },
  {
    code: 'No. 06',
    cat: 'THE GADGET',
    title: 'Only Recipes',
    body: "My first Chrome extension. When it spots you on a recipe page, it strips out the author's childhood memoir, the fourteen ads, and the infinite scroll, and leaves you the recipe. It's small, free, and about as founding-era practical as software gets.",
    badge: 'CHROME EXTENSION . FREE',
    status: 'SHIPPED',
    href: '/only-recipes/',
    external: false,
    cta: 'See what it does',
  },
];

// Commemorative stat block.
const tally = [
  { value: '50+', label: 'COUNTRIES PRESENTED IN' },
  { value: '80+', label: 'COUNTRIES VISITED' },
  { value: '15', label: 'BOOKS IN PRINT' },
  { value: '2', label: 'U.S. PATENTS' },
  { value: '25+', label: 'YEARS RUNNING COMPANIES' },
];

// Commemorative-program colophon.
const indicia = [
  { role: 'EDITION', name: 'SEMIQUINCENTENNIAL . JULY 4, 2026' },
  { role: 'TITLE', name: 'AMERICA 250 VS. EDWARD ROSKE' },
  { role: 'STARRING', name: 'UNCLE SAM (EDWARD, UNCONVINCINGLY)' },
  { role: 'ATTEMPTS MADE', name: 'THREE . SUCCESSES: ZERO . USEFUL THINGS: ONE' },
  { role: 'WORLD CUP STATUS', name: 'ALIVE, HEADING INTO MONDAY VS. BELGIUM' },
  { role: 'HEADGEAR', name: 'ONE (1) STARS-AND-STRIPES FELT FEDORA' },
  { role: 'PRINTED IN', name: 'SAN JUAN, PUERTO RICO, USA' },
  { role: 'LETTERS PAGE', name: 'EDWARD@ROSKE.AI . NO FOUNDER FAN MAIL, PLEASE' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- MASTHEAD / BUNTING STRIP -->
  <div class="us-bar">
    <div class="us-bar-inner">
      <span class="us-bar-brand">ROSKE.AI</span>
      <span class="us-bar-meta us-bar-meta-center">AMERICA 250 . SEMIQUINCENTENNIAL . JULY 4, 2026</span>
      <span class="us-bar-meta us-bar-meta-end">EST. 1776</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero-section">
    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-pip"></span>
          <span>THE 250TH . A ROSKE.AI CIVIC EXPERIMENT</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">250 years.</span>
          <span class="hero-title-line"><em>Still shipping.</em></span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="/question/" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-tally">
          {tally.map(stat => (
            <div class="tally-item">
              <div class="tally-value">{stat.value}</div>
              <div class="tally-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <figure class="poster">
          <div class="poster-top">
            <span class="poster-logo">ROSKE COMMEMORATIVE</span>
            <span class="poster-price">250<br/>YRS</span>
          </div>
          <div class="poster-window">
            <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1600" height="900" loading="eager" decoding="async" class="poster-image" />
          </div>
          <div class="poster-bottom">
            <span>I WANT YOU</span>
            <span>TO ASK GOOD QUESTIONS</span>
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...ticker, ...ticker].map(item => (
        <span class="ticker-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- LATEST CONTENT (permanent) -->
  <LatestContent
    eyebrow="Section 02 . Hot off the press"
    heading={"New <em>this week.</em>"}
    deck="The latest writing and video briefs, in one place. Two hundred fifty years of the free press, and I'm using my share of it to talk about AI."
  />

  <!-- BOOK EDWARD (permanent) -->
  <SpeakerCTA eyebrow="Section 02.5 . The paying gig" />

  <!-- WHAT'S NEW (permanent) -->
  <WhatsNew
    eyebrow="Section 02.6 . The clippings file"
    heading={"In the <em>news.</em>"}
    deck="Where Edward keeps turning up: interviews, press, awards, and the odd post worth keeping. (Yes, the site tracks its own press. The agents insisted.)"
  />

  <!-- THE ATTEMPTS GALLERY -->
  <section class="attempts-section">
    <div class="attempts-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 03 . HOW I TRIED TO HELP . RESULTS MIXED</span>
        </div>
        <h2 class="section-title">Three attempts. <em>Zero successes.</em></h2>
        <p class="section-deck">
          America turns 250 and I wanted to contribute in person. I contributed a hamstring, a party foul, and a 250-year-late RSVP. (The fedora, at least, showed up on time.)
        </p>
      </header>

      <div class="attempts-grid">
        {attempts.map((a) => (
          <article class="panel-card">
            <div class="panel-frame">
              <img src={a.src} alt={a.caption} loading="lazy" decoding="async" class="panel-image" />
              <span class="panel-kicker">{a.kicker}</span>
            </div>
            <div class="panel-meta">
              <h3 class="panel-name">{a.title}</h3>
              <p class="panel-caption">{a.caption}</p>
            </div>
          </article>
        ))}

        <article class="panel-card panel-card-feature">
          <div class="panel-frame">
            <img src={pivot.src} alt={pivot.caption} loading="lazy" decoding="async" class="panel-image" />
            <span class="panel-kicker panel-kicker-gold">{pivot.kicker}</span>
          </div>
          <div class="panel-meta">
            <h3 class="panel-name panel-name-feature">{pivot.title}</h3>
            <p class="panel-caption">{pivot.caption}</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- NARRATION PULL-QUOTE -->
  <section class="statement-section">
    <div class="statement-inner">
      <div class="statement-tag">FROM THE NARRATION BOX</div>
      <blockquote class="statement-q">
        America is the only 250-year-old startup I know that still ships on Saturdays. I tried to help. Mostly I pulled a hamstring. <span class="statement-line">(I'll be here for the 251st. Someone has to run the numbers.)</span>
      </blockquote>
      <div class="statement-attrib">
        <span class="statement-attrib-name">EDWARD ROSKE</span>
        <span class="statement-attrib-role">ASPIRING FOUNDING FATHER . APPLICATIONS CLOSED 1787</span>
      </div>
    </div>
  </section>

  <!-- THE ARSENAL / PROJECTS -->
  <section id="current-work" class="arsenal-section">
    <div class="arsenal-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 04 . THE ACTUAL CONTRIBUTION . WHAT I'M QUALIFIED FOR</span>
        </div>
        <h2 class="section-title">Six things I can do <em>for the next 250.</em></h2>
        <p class="section-deck">
          I can't play for the USMNT and I missed the Declaration by a couple centuries. This is the part of the next quarter-millennium I'm actually equipped to work on: six things, all real, all shipping or close to it.
        </p>
      </header>

      <div class="arsenal-grid">
        {arsenal.map(item => (
          <article class="power-card">
            <div class="power-card-head">
              <span class="power-code">{item.code}</span>
              <span class="power-cat">{item.cat}</span>
            </div>
            <h3 class="power-title">{item.title}</h3>
            <p class="power-body">{item.body}</p>
            <div class="power-meta">
              <span class="power-badge">{item.badge}</span>
              <span class={`power-status power-status-${item.status.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{item.status}</span>
            </div>
            <div class="power-foot">
              {item.href ? (
                <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="power-cta">
                  {item.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="power-cta power-cta-disabled">{item.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG TEASER -->
  <section class="late-section">
    <div class="late-inner">
      <header class="section-header late-header">
        <div class="section-tag late-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 05 . THIS WEEK'S DISPATCH</span>
        </div>
        <h2 class="section-title">A birthday <em>question.</em></h2>
      </header>

      <div class="late-grid">
        <article class="late-card">
          <div class="late-card-tag">NEW ON THE BLOG . JULY 4, 2026</div>
          <h3 class="late-card-title">What Would the Founders Ask an AI?</h3>
          <div class="late-card-line">FRANKLIN . JEFFERSON . ADAMS . WASHINGTON</div>
          <p class="late-card-body">
            The Founders were the best question-askers ever assembled on this side of the Atlantic. Hand each of them a laptop running a modern AI, and I think they'd ask better questions than we do. Here's my honest guess at four of them, on the country's 250th birthday.
          </p>
          <a href="/blog/what-would-the-founders-ask-an-ai/" class="late-cta">
            Read the post
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="closing-section">
    <div class="closing-inner">
      <div class="closing-eyebrow">
        <span class="closing-rule"></span>
        <span>THE BOX OFFICE IS OPEN . 13 MINUTES</span>
        <span class="closing-rule"></span>
      </div>
      <h2 class="closing-title">Happy 250th.<br/><em>Now ask a good question.</em></h2>
      <p class="closing-deck">
        Book thirteen minutes. Ask about AI in finance, MCP servers, the Caribbean AI Summit, whether the USMNT can get past Belgium, or how a man pulls a hamstring at an imaginary World Cup. Independence is encouraged, and opinions arrive whether you asked for them or not.
      </p>
      <div class="closing-cta-row">
        <a href="/question/" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a note</span>
        </a>
      </div>
    </div>
  </section>

  <!-- COLOPHON / INDICIA -->
  <section class="indicia-section">
    <div class="indicia-inner">
      <div class="indicia-tag">COMMEMORATIVE PROGRAM . BACK COVER . 2026</div>
      <div class="indicia-roll">
        {indicia.map(entry => (
          <div class="indicia-block">
            <span class="indicia-role">{entry.role}</span>
            <span class="indicia-name">{entry.name}</span>
          </div>
        ))}
      </div>
      <div class="indicia-footnote">
        Not affiliated with the United States government, the National Archives, U.S. Soccer, the USMNT, FIFA, or the estate of any Founding Father. The Declaration of Independence remains unsigned by Edward Roske. The 250 years of mostly-good decisions belong to America. The hamstring, the party foul, and the fedora are all on Edward. No Founders were inconvenienced in the making of this website. One aspiring one very much was.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     AMERICA 250: STILL SHIPPING (a Semiquincentennial broadside)
     Palette: Old-Glory red / federal navy / brass gold /
              deep navy night (dark) / aged cream paper (light)
     Type: Big Shoulders Display (civic display), Bitter (slab body),
           Space Mono (labels + stats)
     ============================================================ */

  :global([data-theme="dark"]) {
    --us-bg: #0b1a33;
    --us-bg-deep: #071228;
    --us-surface: #12294d;
    --us-surface-2: #1a3560;
    --us-fg: #f4ecd8;
    --us-muted: #a7bad9;
    --us-line: #274873;
    --us-red: #d64550;
    --us-red-deep: #b22234;
    --us-navy: #24457e;
    --us-gold: #d8ab45;
    --us-cream: #f4ecd8;
    --us-ink: #071228;
    --us-dot: rgba(255,255,255,0.06);
  }
  :global([data-theme="light"]) {
    --us-bg: #f4ecd8;
    --us-bg-deep: #e9dcc0;
    --us-surface: #fbf6e9;
    --us-surface-2: #f0e6cf;
    --us-fg: #152a4d;
    --us-muted: #5c5340;
    --us-line: #d6c8a4;
    --us-red: #b22234;
    --us-red-deep: #9a1d2c;
    --us-navy: #1b3a6b;
    --us-gold: #9a6f1f;
    --us-cream: #fbf6e9;
    --us-ink: #152a4d;
    --us-dot: rgba(27,58,107,0.09);
  }

  /* ---------- MASTHEAD / BUNTING ---------- */
  .us-bar {
    width: 100%;
    background: var(--us-red-deep);
    color: #fff;
    border-bottom: 3px solid var(--us-gold);
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .us-bar-inner {
    max-width: 1500px; margin: 0 auto; padding: 0.5rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; font-size: 0.7rem;
  }
  .us-bar-brand {
    font-family: 'Big Shoulders Display', sans-serif; font-weight: 800;
    letter-spacing: 0.06em; font-size: 1.15rem; color: var(--us-gold);
  }
  .us-bar-meta { white-space: nowrap; }
  .us-bar-meta-center { flex: 1; text-align: center; letter-spacing: 0.16em; opacity: 0.95; }
  .us-bar-meta-end { text-align: right; font-weight: 700; }
  @media (max-width: 780px) {
    .us-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.54rem; }
    .us-bar-meta-end { display: none; }
    .us-bar-meta-center { font-size: 0.52rem; letter-spacing: 0.1em; }
  }

  /* ---------- HERO ---------- */
  .hero-section {
    position: relative; background: var(--us-bg); color: var(--us-fg);
    padding: 5rem 2rem 5.5rem; overflow: hidden;
  }
  .hero-section::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background-image: radial-gradient(var(--us-dot) 1.5px, transparent 1.6px);
    background-size: 17px 17px; opacity: 0.8;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(circle at 14% 16%, rgba(36,69,126,0.30) 0%, transparent 52%),
      radial-gradient(circle at 86% 84%, rgba(178,34,52,0.14) 0%, transparent 55%),
      linear-gradient(165deg, #071228 0%, #0b1a33 55%, #0e2246 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
      radial-gradient(circle at 50% -8%, #fbf6e9 0%, transparent 44%),
      linear-gradient(180deg, #efe6cd 0%, #f4ecd8 60%);
  }
  .hero-grid {
    position: relative; z-index: 2; max-width: 1500px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1.02fr; gap: 4rem; align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.5rem; }
    .hero-section { padding: 3.5rem 1.25rem 4.5rem; }
  }
  .hero-text { max-width: 660px; }
  .hero-eyebrow {
    display: inline-flex; align-items: center; gap: 0.7rem;
    font-family: 'Space Mono', monospace; font-size: 0.68rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--us-red);
    margin-bottom: 1.5rem; padding: 0.35rem 0.85rem;
    border: 2px solid var(--us-red); background: var(--us-surface);
  }
  :global([data-theme="light"]) .hero-eyebrow { background: #fff; }
  .hero-eyebrow-pip { width: 8px; height: 8px; background: var(--us-red); border-radius: 50%; flex-shrink: 0; }
  .hero-title { margin: 0 0 1.6rem; line-height: 0.9; }
  .hero-title-line {
    display: block; font-family: 'Big Shoulders Display', sans-serif;
    font-weight: 800; font-size: clamp(3rem, 7.6vw, 6.2rem);
    color: var(--us-fg); letter-spacing: 0.005em; line-height: 0.92;
    text-transform: uppercase;
  }
  .hero-title-line em { font-style: normal; color: var(--us-red); }
  .hero-body {
    font-family: 'Bitter', serif; font-size: 1.08rem; line-height: 1.7;
    color: var(--us-muted); margin: 0 0 2rem; max-width: 40em; font-weight: 400;
  }
  :global([data-theme="light"]) .hero-body { color: #4a4433; }

  /* Buttons */
  .btn-primary, .btn-secondary {
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.9rem 1.7rem; font-family: 'Big Shoulders Display', sans-serif;
    font-size: 1.05rem; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase; text-decoration: none;
    border: 2.5px solid var(--us-ink);
    transition: transform 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    cursor: pointer; line-height: 1;
  }
  :global([data-theme="dark"]) .btn-primary, :global([data-theme="dark"]) .btn-secondary { border-color: #071228; }
  .btn-primary { background: var(--us-red); color: #fff; box-shadow: 5px 5px 0 var(--us-gold); }
  .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 7px 7px 0 var(--us-gold); background: var(--us-red-deep); }
  .btn-secondary { background: var(--us-gold); color: #201500; box-shadow: 5px 5px 0 var(--us-navy); }
