---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import LatestContent from '../components/LatestContent.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// The Edward toy line. Five Pixar-style stills of Edward reimagined as a
// discontinued pull-string cowboy toy, each captioned to match the image.
const toyline = [
  {
    src: '/images/toy-story/clearance-aisle.png',
    kicker: 'PRODUCT No. 001',
    title: 'Edward: The Talking EPM Cowboy',
    caption: "Marked down, dusty, the last one on the peg. The sleek AI gadgets beside him sold out by nine. (He's choosing to read this as a supply-chain issue.)",
    feature: true,
  },
  {
    src: '/images/toy-story/now-with-ai.png',
    kicker: 'THE 2026 REFRESH',
    title: 'Now With A.I.',
    caption: "They bolted a cracked tablet to his chest, added some blinking lights, and called it a pivot. The pull string still works, though the tablet gave out on day two.",
    feature: false,
  },
  {
    src: '/images/toy-story/christmas-morning.png',
    kicker: 'ONE GOOD MORNING',
    title: 'Christmas, briefly',
    caption: "For one shining minute he had the kid's whole attention. The tablet on the floor was content to wait, the way a thing waits when it knows it's going to win.",
    feature: false,
  },
  {
    src: '/images/toy-story/bottom-of-the-box.png',
    kicker: 'THE DONATION BIN',
    title: 'Twenty-five cents, firm',
    caption: "Filed between two dead Game Boys and a flip phone. Honestly, good company. They all peaked around the same time.",
    feature: false,
  },
  {
    src: '/images/toy-story/keeps-talking.png',
    kicker: 'PULL STRING TO ACTIVATE',
    title: 'He will not stop',
    caption: "Pull it once and he explains agentic AI to a dinosaur, a robot, and a doll who did not ask. By now the string is decorative. He keeps going regardless.",
    feature: false,
  },
];

// Pull-string voice box. What the toy says, ranch-hand by way of the Office of
// the CFO. Hijacked marquee.
const pullStrings = [
  "THERE'S A ONESTREAM IN MY BOOT",
  "REACH FOR THE SKY, THEN RECONCILE IT",
  "SOMEBODY POISONED THE DATA LAKE",
  "YOU'RE MY FAVORITE DEPUTY (PENDING APPROVAL)",
  "ASK ME ABOUT AGENTIC AI. PLEASE. ANYONE.",
  "TO INFINITY, AND A REASONABLE Q3 FORECAST",
  "I'M A TOY, NOT A LARGE LANGUAGE MODEL",
  "PULL STRING FOR A 45-MINUTE ANSWER",
];

// The current product line. Same six real projects, framed as toys on a shelf.
const products = [
  {
    code: 'MODEL No. 01',
    cat: 'WORKS AS ADVERTISED (RARE)',
    title: 'AgentCube',
    body: "The engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus. Essbase and Planning shipped. Consolidations is in beta. (It's the toy that actually does what the box promised, which in this aisle makes it a collector's item.)",
    badge: 'ESSBASE · PLANNING · CLOSE',
    status: 'SHIPPED',
    href: 'https://caprus.ai/agentcube/',
    external: true,
    cta: 'Read the docs',
  },
  {
    code: 'MODEL No. 02',
    cat: 'COLLECT THE WHOLE ISLAND',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever hosted. October 9 and 10 in San Juan. Speakers and sponsors are being recruited right now. If you build, fund, or run AI, there's a slot on the stage with your name on it.",
    badge: '9-10 OCT 2026 · SAN JUAN',
    status: 'CALL FOR SPEAKERS OPEN',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    code: 'MODEL No. 03',
    cat: 'SOLD SEPARATELY',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, the AI software and services firm giving finance teams faster, smarter operations. The crew behind the MCP servers, and the people who do most of the actual building while I write the blog posts.",
    badge: 'AI · FINANCE',
    status: 'RUNNING',
    href: 'https://caprus.ai',
    external: true,
    cta: 'See the team',
  },
  {
    code: 'MODEL No. 04',
    cat: 'AGES: ETERNAL DM',
    title: "AI Dungeon Master's Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns. Initiative, lore, and improv help for the person behind the screen. If there's going to be an AI at the table, it should at least earn its seat. (The party will not be told.)",
    badge: 'D&D · 5E · EBERRON',
    status: 'IN PROTOTYPE',
    href: null,
    external: false,
    cta: 'Quiet build',
  },
  {
    code: 'MODEL No. 05',
    cat: 'SOME ASSEMBLY REQUIRED',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. More than 850 people across our events. We meet every other month to figure out, in public, what AI means for the island, which is also what it means for everyone watching the island.",
    badge: '850+ · BI-MONTHLY',
    status: 'RUNNING',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next one',
  },
  {
    code: 'MODEL No. 06',
    cat: 'WORKS RIGHT OUT OF THE BOX',
    title: 'Only Recipes',
    body: "My first Chrome extension. When it spots you on a recipe page, it strips out the author's childhood memoir, the fourteen ads, and the infinite scroll, and leaves you the recipe. It's ridiculously fast and genuinely useful, two phrases I don't often get to put next to each other.",
    badge: 'CHROME EXTENSION · FREE',
    status: 'SHIPPED',
    href: '/only-recipes/',
    external: false,
    cta: 'See what it does',
  },
];

// Late add to the catalog, still in beta.
const lateAdds = [
  {
    tag: 'IN BETA · NAME PENDING',
    title: 'The Home Library Project',
    line: 'BOOKS · GAMES · MEDIA · EVERY SHELF',
    body: "A new app and site that digitizes a home library: books, board games, music, media, anything sitting on a shelf at the house. All of it categorized. There'll be a free tier. I'll share the rest after beta. Want an early look? Send an email and you're on the list.",
    cta: 'Email for early access',
    href: 'mailto:Edward@Roske.AI',
    external: false,
  },
];

// Stat block, packaging-style.
const tally = [
  { value: '50+', label: 'COUNTRIES PRESENTED IN' },
  { value: '80+', label: 'COUNTRIES VISITED' },
  { value: '15', label: 'BOOKS IN PRINT' },
  { value: '2', label: 'U.S. PATENTS' },
  { value: '25+', label: 'YEARS RUNNING COMPANIES' },
];

// Toy-box back panel, in place of a colophon.
const backPanel = [
  { role: 'EDITION', name: 'WEEK 26 · TOY STORY 5 RELEASE WEEK · 2026' },
  { role: 'PRODUCT', name: 'EDWARD: THE TALKING EPM COWBOY' },
  { role: 'INCLUDES', name: 'ONE (1) COWBOY · ONE (1) PULL STRING · OPINIONS (UNLIMITED)' },
  { role: 'BATTERIES', name: 'NOT INCLUDED · NOT REQUIRED · RUNS ON SPITE AND CURIOSITY' },
  { role: 'HEADGEAR', name: 'ONE (1) ROYAL-BLUE FELT FEDORA · SURVIVES EVERY RECALL' },
  { role: 'WARNING', name: 'MAY DISCUSS AGENTIC AI FOR 45 MINUTES UNPROMPTED' },
  { role: 'MADE IN', name: 'SAN JUAN, PUERTO RICO' },
  { role: 'CARE', name: 'DO NOT EXPOSE TO SPREADSHEETS WITHOUT FREEZE PANES' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       PACKAGE STRIP — toy header card
       ============================================ -->
  <div class="toy-bar">
    <div class="toy-bar-inner">
      <span class="toy-bar-brand">EDWARD<span class="toy-bar-brand-x">:</span> THE TALKING EPM COWBOY</span>
      <span class="toy-bar-meta toy-bar-meta-center">PULL STRING FOR OPINIONS · BATTERIES NOT INCLUDED</span>
      <span class="toy-bar-meta toy-bar-meta-end">AGES 50 AND UP</span>
    </div>
  </div>

  <!-- ============================================
       HERO — split, text left, film still right
       ============================================ -->
  <section class="hero-section">
    <div class="hero-clouds" aria-hidden="true"></div>
    <div class="hero-grid">

      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-pip"></span>
          <span>NOW PLAYING · A ROSKE.AI PRODUCTION · JUNE 2026</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">The toy who wouldn't</span>
          <span class="hero-title-line"><em>update.</em></span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="/question/" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-tally">
          {tally.map(stat => (
            <div class="tally-item">
              <div class="tally-value">{stat.value}</div>
              <div class="tally-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <figure class="film-still">
          <div class="film-still-top">
            <span class="film-still-flag">FRAME 001 · THE TOY WHO WOULDN'T UPDATE</span>
            <span class="film-still-rate">RATED E</span>
          </div>
          <div class="film-still-window">
            <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="film-still-image" />
            <div class="film-still-tag" aria-hidden="true">
              <span class="film-still-tag-line">THE THREAT</span>
              <span class="film-still-tag-sub">ARRIVED WITH WI-FI</span>
            </div>
          </div>
          <div class="film-still-bottom">
            <span>DIR. EDWARD ROSKE</span>
            <span>PIXAR-ADJACENT · NO AFFILIATION</span>
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================
       PULL-STRING TICKER
       ============================================ -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...pullStrings, ...pullStrings].map(item => (
        <span class="ticker-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- ============================================
       LATEST CONTENT — permanent module
       ============================================ -->
  <LatestContent
    eyebrow="Section 02 · Fresh out of the box"
    heading={"New <em>this week.</em>"}
    deck="The latest writing and video briefs, in one place, so the good stuff isn't buried under a pile of older toys."
  />

  <!-- ============================================
       THE TOY LINE — scene gallery
       ============================================ -->
  <section class="line-section">
    <div class="line-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 03 · THE FULL PRODUCT LINE · NOW DISCONTINUED</span>
        </div>
        <h2 class="section-title">Every toy in the <em>line.</em></h2>
        <p class="section-deck">
          One man, several recalls. Each one a Pixar-grade study in what happens when the analog favorite meets a glowing rectangle with better marketing. (The fedora is in all of them. The fedora is non-negotiable.)
        </p>
      </header>

      <div class="line-grid">
        {toyline.map((toy) => (
          <article class={`toy-card ${toy.feature ? 'toy-card-feature' : ''}`}>
            <div class="toy-frame">
              <img src={toy.src} alt={toy.caption} loading="lazy" decoding="async" class="toy-image" />
              <span class="toy-kicker">{toy.kicker}</span>
            </div>
            <div class="toy-meta">
              <h3 class="toy-name">{toy.title}</h3>
              <p class="toy-caption">{toy.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       PULL-QUOTE — from the back of the box
       ============================================ -->
  <section class="statement-section">
    <div class="statement-inner">
      <div class="statement-tag">FROM THE BACK OF THE BOX</div>
      <blockquote class="statement-q">
        Every toy gets replaced eventually. I figure if I stay useful enough, they'll at least feel a little guilty about it. <span class="statement-line">(So far: mixed results.)</span>
      </blockquote>
      <div class="statement-attrib">
        <span class="statement-attrib-name">EDWARD ROSKE</span>
        <span class="statement-attrib-role">READING HIS OWN RECALL NOTICE</span>
      </div>
    </div>
  </section>

  <!-- ============================================
       CURRENT PRODUCT LINE — project cards
       ============================================ -->
  <section id="current-work" class="products-section">
    <div class="products-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 04 · WHAT HE'S ACTUALLY BUILDING</span>
        </div>
        <h2 class="section-title">Six things. <em>None require batteries.</em></h2>
        <p class="section-deck">
          The part of the toy box that still ships. Real projects, in beta or in production, all built on the theory that the old cowboy might be worth keeping around a little longer.
        </p>
      </header>

      <div class="products-grid">
        {products.map(product => (
          <article class="product-card">
            <div class="product-card-head">
              <span class="product-code">{product.code}</span>
              <span class="product-cat">{product.cat}</span>
            </div>
            <h3 class="product-title">{product.title}</h3>
            <p class="product-body">{product.body}</p>
            <div class="product-meta">
              <span class="product-badge">{product.badge}</span>
              <span class={`product-status product-status-${product.status.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{product.status}</span>
            </div>
            <div class="product-foot">
              {product.href ? (
                <a href={product.href} target={product.external ? '_blank' : undefined} rel={product.external ? 'noopener' : undefined} class="product-cta">
                  {product.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="product-cta product-cta-disabled">{product.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       LATE ADD
       ============================================ -->
  <section class="late-section">
    <div class="late-inner">
      <header class="section-header late-header">
        <div class="section-tag late-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 05 · NEW FOR THIS SEASON · STILL IN BETA</span>
        </div>
        <h2 class="section-title">One more <em>off the assembly line.</em></h2>
      </header>

      <div class="late-grid">
        {lateAdds.map(item => (
          <article class="late-card">
            <div class="late-card-tag">{item.tag}</div>
            <h3 class="late-card-title">{item.title}</h3>
            <div class="late-card-line">{item.line}</div>
            <p class="late-card-body">{item.body}</p>
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="late-cta">
              {item.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CLOSING CTA
       ============================================ -->
  <section class="closing-section">
    <div class="closing-clouds" aria-hidden="true"></div>
    <div class="closing-inner">
      <div class="closing-eyebrow">
        <span class="closing-rule"></span>
        <span>THE BOX OFFICE IS OPEN · 13 MINUTES</span>
        <span class="closing-rule"></span>
      </div>
      <h2 class="closing-title">Pull the string.<br/><em>Get a real answer.</em></h2>
      <p class="closing-deck">
        Book thirteen minutes. Ask about Oracle EPM, AI in finance, MCP servers, the Caribbean AI Summit, D&D, or what it's like to spend a career hyping the exact technology now eyeing your spot in the toy box. The pull string is free, and the opinions come with it whether you asked or not.
      </p>
      <div class="closing-cta-row">
        <a href="/question/" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a note</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       BACK PANEL
       ============================================ -->
  <section class="panel-section">
    <div class="panel-inner">
      <div class="panel-tag">TOY BOX · BACK PANEL · 2026</div>
      <div class="panel-roll">
        {backPanel.map(entry => (
          <div class="panel-block">
            <span class="panel-role">{entry.role}</span>
            <span class="panel-name">{entry.name}</span>
          </div>
        ))}
      </div>
      <div class="panel-footnote">
        Not affiliated with Pixar, Disney, or any toy currently in production. Toy Story and its characters are the property of their respective owners. The cowboy, the opinions, and the fedora are Edward's. No pull-string toys were replaced by AI in the making of this website, though several were made visibly nervous.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     TOY STORY 5 · THE TOY WHO WOULDN'T UPDATE
     Palette: Andy's-room sky blue / Woody red / toy-star gold /
              warm label cream / toy box at night
     Type: Fredoka (display), Nunito (body), Space Mono (tech
           warnings + labels), Rye (western pull-string flourish)
     ============================================================ */

  :global([data-theme="dark"]) {
    --ts-bg: #0f1b3d;
    --ts-bg-deep: #0a142e;
    --ts-surface: #1a2a55;
    --ts-surface-2: #21356a;
    --ts-fg: #f5f0e1;
    --ts-muted: #a9b8db;
    --ts-line: #2b407a;
    --ts-line-soft: #1c2c57;
    --ts-sky: #3b82e6;
    --ts-sky-deep: #1c5fc4;
    --ts-red: #e8462f;
    --ts-red-bright: #ff6a4d;
    --ts-gold: #f2b840;
    --ts-cream: #f5f0e1;
  }
  :global([data-theme="light"]) {
    --ts-bg: #e7f1fc;
    --ts-bg-deep: #d3e6fb;
    --ts-surface: #ffffff;
    --ts-surface-2: #f1f7ff;
    --ts-fg: #16335f;
    --ts-muted: #5a6f90;
    --ts-line: #c2d8f0;
    --ts-line-soft: #dcebfb;
    --ts-sky: #2f6fd0;
    --ts-sky-deep: #1c5fc4;
    --ts-red: #d83a22;
    --ts-red-bright: #e8462f;
    --ts-gold: #d39a26;
    --ts-cream: #ffffff;
  }

  /* Cloud-wallpaper texture used on the sky sections */
  .hero-clouds, .closing-clouds {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='150'%20height='110'%3E%3Cg%20fill='%23ffffff'%3E%3Cellipse%20cx='48'%20cy='56'%20rx='34'%20ry='17'/%3E%3Ccircle%20cx='34'%20cy='50'%20r='14'/%3E%3Ccircle%20cx='60'%20cy='44'%20r='18'/%3E%3Ccircle%20cx='84'%20cy='54'%20r='13'/%3E%3C/g%3E%3C/svg%3E");
    background-size: 200px 147px;
    opacity: 0.05;
  }
  :global([data-theme="light"]) .hero-clouds,
  :global([data-theme="light"]) .closing-clouds { opacity: 0.5; }

  /* ------------------------------------------------------------
     PACKAGE STRIP
     ------------------------------------------------------------ */
  .toy-bar {
    width: 100%;
    background: var(--ts-red);
    color: #fff;
    border-bottom: 4px solid var(--ts-gold);
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .toy-bar-inner {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    font-size: 0.7rem;
  }
  .toy-bar-brand {
    display: inline-flex;
    align-items: baseline;
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    letter-spacing: 0.01em;
    text-transform: none;
    font-size: 1.02rem;
    color: #fff;
  }
  .toy-bar-brand-x { color: var(--ts-gold); margin: 0 0.1em; }
  .toy-bar-meta { white-space: nowrap; }
  .toy-bar-meta-center { flex: 1; text-align: center; letter-spacing: 0.16em; opacity: 0.95; }
  .toy-bar-meta-end { text-align: right; color: #fff7e6; font-weight: 700; }
  @media (max-width: 780px) {
    .toy-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.56rem; }
    .toy-bar-meta-end { display: none; }
    .toy-bar-meta-center { font-size: 0.54rem; letter-spacing: 0.1em; }
  }

  /* ------------------------------------------------------------
     HERO
     ------------------------------------------------------------ */
  .hero-section {
    position: relative;
    background: var(--ts-bg);
    color: var(--ts-fg);
    padding: 5.5rem 2rem 6rem;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(circle at 14% 16%, rgba(59,130,230,0.22) 0%, transparent 52%),
      radial-gradient(circle at 86% 84%, rgba(232,70,47,0.12) 0%, transparent 55%),
      linear-gradient(165deg, #0a142e 0%, #0f1b3d 55%, #102350 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
      radial-gradient(circle at 50% -10%, #ffffff 0%, transparent 45%),
      linear-gradient(180deg, #cfe6fb 0%, #e7f1fc 60%);
  }
  .hero-grid {
    position: relative;
    z-index: 2;
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.5rem; }
    .hero-section { padding: 3.5rem 1.25rem 4.5rem; }
  }
  .hero-text { max-width: 660px; position: relative; z-index: 2; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ts-red);
    margin-bottom: 1.6rem;
    padding: 0.35rem 0.85rem;
    border: 2px solid var(--ts-red);
    border-radius: 999px;
  }
  :global([data-theme="light"]) .hero-eyebrow { background: #fff; }
  .hero-eyebrow-pip {
    width: 8px; height: 8px;
    background: var(--ts-red);
    border-radius: 50%;
    flex-shrink: 0;
  }
  .hero-title { margin: 0 0 1.8rem; line-height: 0.96; }
  .hero-title-line {
    display: block;
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(2.9rem, 7vw, 5.6rem);
    color: var(--ts-fg);
    letter-spacing: -0.01em;
    line-height: 1.0;
  }
  .hero-title-line em {
    font-style: normal;
    color: var(--ts-red);
  }
  .hero-body {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--ts-muted);
    margin: 0 0 2rem;
    max-width: 40em;
    font-weight: 500;
  }
  :global([data-theme="light"]) .hero-body { color: #3a4d6b; }

  /* Buttons */
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.95rem 1.7rem;
    font-family: 'Fredoka', sans-serif;
    font-size: 0.98rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    border: 2.5px solid currentColor;
    transition: transform 0.18s ease, box-shadow 0.18s ease, background 0.18s ease, color 0.18s ease;
    cursor: pointer;
    line-height: 1;
    border-radius: 999px;
  }
  .btn-primary {
    background: var(--ts-red);
    color: #fff;
    border-color: var(--ts-red);
    box-shadow: 4px 4px 0 var(--ts-sky-deep);
  }
  .btn-primary:hover {
    background: var(--ts-red-bright);
    border-color: var(--ts-red-bright);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--ts-sky-deep);
  }
  .btn-secondary {
    background: transparent;
    color: var(--ts-fg);
    border-color: var(--ts-fg);
    box-shadow: 4px 4px 0 var(--ts-gold);
  }
  .btn-secondary:hover {
    background: var(--ts-fg);
    color: var(--ts-bg);
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 var(--ts-gold);
  }
  .btn-primary-big, .btn-secondary-big { padding: 1.15rem 2.3rem; font-size: 1.05rem; }
  .hero-cta-row { display: flex; flex-wrap: wrap; gap: 1.3rem; margin-bottom: 2.8rem; }

  /* Tally */
  .hero-tally {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.2rem;
    border-top: 3px dotted var(--ts-sky);
    padding-top: 1.7rem;
  }
  .tally-value {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 2.4rem;
    color: var(--ts-red);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .tally-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ts-muted);
    margin-top: 0.4rem;
  }
  :global([data-theme="light"]) .tally-label { color: #5a6f90; }
  @media (max-width: 620px) {
    .hero-tally { grid-template-columns: repeat(2, 1fr); gap: 1.4rem 1rem; }
  }

  /* ------------------------------------------------------------
     FILM STILL (hero right)
     ------------------------------------------------------------ */
  .hero-image-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }
  .film-still {
    position: relative;
    margin: 0;
    width: 100%;
    max-width: 640px;
    background: var(--ts-surface);
    border: 5px solid var(--ts-gold);
    border-radius: 14px;
    box-shadow: 0 22px 60px rgba(0,0,0,0.5), inset 0 0 0 4px var(--ts-bg-deep);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  :global([data-theme="light"]) .film-still {
    box-shadow: 0 18px 44px rgba(28,95,196,0.22), inset 0 0 0 4px #ffffff;
  }
  .film-still-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 1rem;
    background: var(--ts-bg-deep);
    color: var(--ts-cream);
    border-bottom: 3px solid var(--ts-gold);
  }
  :global([data-theme="light"]) .film-still-top { background: var(--ts-sky-deep); color: #fff; }
  .film-still-flag {
    font-family: 'Space Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .film-still-rate {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 0.7rem;
    background: var(--ts-gold);
    color: #2a1a00;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }
  .film-still-window { position: relative; background: var(--ts-bg-deep); }
  .film-still-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .film-still-tag {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: var(--ts-red);
    color: #fff;
    padding: 0.45rem 0.7rem;
    border-radius: 6px;
    border: 2px solid #fff;
    transform: rotate(-3deg);
    box-shadow: 0 4px 0 rgba(0,0,0,0.25);
    font-family: 'Space Mono', monospace;
    line-height: 1.15;
  }
  .film-still-tag-line { display: block; font-weight: 700; font-size: 0.7rem; letter-spacing: 0.08em; }
  .film-still-tag-sub { display: block; font-size: 0.56rem; letter-spacing: 0.1em; opacity: 0.9; margin-top: 0.1rem; }
  .film-still-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.65rem 1rem;
    background: var(--ts-bg-deep);
    color: var(--ts-gold);
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-top: 3px solid var(--ts-gold);
    flex-wrap: wrap;
  }
  :global([data-theme="light"]) .film-still-bottom { background: var(--ts-sky-deep); color: #ffe6a8; }

  /* ------------------------------------------------------------
     PULL-STRING TICKER
     ------------------------------------------------------------ */
  .ticker {
    background: var(--ts-gold);
    color: #2a1a00;
    border-top: 4px solid var(--ts-red);
    border-bottom: 4px solid var(--ts-red);
    overflow: hidden;
    padding: 0.6rem 0;
    font-family: 'Rye', 'Fredoka', serif;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-size: 1.05rem;
  }
  .ticker-track {
    display: inline-flex;
    gap: 2.6rem;
    white-space: nowrap;
    animation: tickerScroll 64s linear infinite;
  }
  .ticker-item::after {
    content: '✦';
    margin-left: 2.6rem;
    color: var(--ts-red);
  }
  @keyframes tickerScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track { animation: none; }
  }

  /* ------------------------------------------------------------
     SECTION HEADERS
     ------------------------------------------------------------ */
  .section-header { max-width: 820px; margin: 0 auto 3.5rem; text-align: center; }
  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--ts-red);
    margin-bottom: 1.2rem;
  }
  .section-tag-dot { width: 10px; height: 10px; background: var(--ts-red); border-radius: 50%; flex-shrink: 0; }
  .section-title {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(2.1rem, 5vw, 3.8rem);
    line-height: 1.06;
    margin: 0 0 1.2rem;
    color: var(--ts-fg);
    letter-spacing: -0.015em;
  }
  .section-title em { font-style: normal; color: var(--ts-red); }
  .section-deck {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--ts-muted);
    max-width: 44em;
    margin: 0 auto;
    font-weight: 500;
  }
  :global([data-theme="light"]) .section-deck { color: #4a5f7e; }

  /* ------------------------------------------------------------
     THE TOY LINE (scene gallery)
     ------------------------------------------------------------ */
  .line-section {
    background: var(--ts-bg);
    color: var(--ts-fg);
    padding: 6.5rem 2rem 7rem;
    position: relative;
  }
  :global([data-theme="light"]) .line-section { background: var(--ts-surface-2); }
  .line-inner { max-width: 1320px; margin: 0 auto; position: relative; }
  .line-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
  }
  @media (max-width: 820px) {
    .line-grid { grid-template-columns: 1fr; gap: 2rem; }
    .line-section { padding: 4rem 1.25rem 5rem; }
  }
  .toy-card {
    display: flex;
    flex-direction: column;
    background: var(--ts-surface);
    border: 3px solid var(--ts-line);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    box-shadow: 0 12px 30px rgba(0,0,0,0.32);
  }
  :global([data-theme="light"]) .toy-card { box-shadow: 0 12px 26px rgba(28,95,196,0.1); }
  .toy-card:hover {
    transform: translateY(-5px);
    border-color: var(--ts-gold);
    box-shadow: 0 18px 42px rgba(0,0,0,0.42);
  }
  :global([data-theme="light"]) .toy-card:hover { box-shadow: 0 18px 38px rgba(28,95,196,0.18); }
  .toy-card-feature { grid-column: 1 / -1; display: grid; grid-template-columns: 1.4fr 1fr; align-items: stretch; }
  .toy-card-feature .toy-meta { display: flex; flex-direction: column; justify-content: center; }
  @media (max-width: 820px) {
    .toy-card-feature { grid-template-columns: 1fr; }
  }
  .toy-frame { position: relative; background: var(--ts-bg-deep); border-bottom: 3px solid var(--ts-gold); }
  .toy-card-feature .toy-frame { border-bottom: none; border-right: 3px solid var(--ts-gold); }
  @media (max-width: 820px) {
    .toy-card-feature .toy-frame { border-right: none; border-bottom: 3px solid var(--ts-gold); }
  }
  .toy-image { display: block; width: 100%; height: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .toy-card-feature .toy-image { aspect-ratio: 16/9; }
  .toy-kicker {
    position: absolute;
    top: 12px; left: 12px;
    background: var(--ts-red);
    color: #fff;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    border: 2px solid #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .toy-meta { padding: 1.5rem 1.6rem 1.8rem; }
  .toy-name {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.5rem;
    margin: 0 0 0.6rem;
    color: var(--ts-fg);
    line-height: 1.15;
  }
  .toy-card-feature .toy-name { font-size: 2rem; }
  .toy-caption {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--ts-muted);
    margin: 0;
    font-weight: 500;
  }
  :global([data-theme="light"]) .toy-caption { color: #4a5f7e; }

  /* ------------------------------------------------------------
     PULL-QUOTE
     ------------------------------------------------------------ */
  .statement-section {
    background: var(--ts-sky);
    color: #fff;
    padding: 5.5rem 2rem;
    position: relative;
    border-top: 5px solid var(--ts-gold);
    border-bottom: 5px solid var(--ts-gold);
  }
  :global([data-theme="dark"]) .statement-section { background: var(--ts-sky-deep); }
  .statement-inner { max-width: 980px; margin: 0 auto; text-align: center; position: relative; z-index: 1; }
  .statement-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff7e0;
    margin-bottom: 1.6rem;
  }
  .statement-q {
    font-family: 'Fredoka', sans-serif;
    font-weight: 500;
    font-size: clamp(1.5rem, 3.4vw, 2.5rem);
    line-height: 1.35;
    margin: 0 0 1.6rem;
    color: #fff;
  }
  .statement-line {
    display: block;
    margin-top: 0.8rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.62em;
    letter-spacing: 0.02em;
    color: #fff2cf;
  }
  .statement-attrib-name {
    display: block;
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: 0.02em;
    color: #fff;
  }
  .statement-attrib-role {
    display: block;
    font-family: 'Space Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffeec2;
    margin-top: 0.5rem;
  }

  /* ------------------------------------------------------------
     PRODUCTS (project cards)
     ------------------------------------------------------------ */
  .products-section {
    background: var(--ts-bg);
    color: var(--ts-fg);
    padding: 7rem 2rem;
    position: relative;
  }
  .products-inner { max-width: 1320px; margin: 0 auto; }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.8rem;
  }
  @media (max-width: 1080px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 680px) {
    .products-grid { grid-template-columns: 1fr; }
    .products-section { padding: 4rem 1.25rem; }
  }
  .product-card {
    position: relative;
    background: var(--ts-surface);
    border: 3px solid var(--ts-line);
    border-radius: 16px;
    padding: 1.7rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
  }
  :global([data-theme="light"]) .product-card { box-shadow: 0 10px 22px rgba(28,95,196,0.08); }
  .product-card:hover {
    transform: translateY(-5px);
    border-color: var(--ts-gold);
    box-shadow: 0 16px 38px rgba(0,0,0,0.4);
  }
  :global([data-theme="light"]) .product-card:hover { box-shadow: 0 16px 34px rgba(28,95,196,0.16); }
  .product-card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding-bottom: 0.7rem;
    border-bottom: 2px dotted var(--ts-line);
    flex-wrap: wrap;
  }
  .product-code {
    font-family: 'Space Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    color: var(--ts-red);
    text-transform: uppercase;
    font-weight: 700;
  }
  .product-cat {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    color: var(--ts-muted);
    text-transform: uppercase;
  }
  .product-title {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.45rem;
    margin: 0;
    color: var(--ts-fg);
    line-height: 1.15;
  }
  .product-body {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 0.98rem;
    line-height: 1.62;
    color: var(--ts-muted);
    margin: 0;
    flex-grow: 1;
    font-weight: 500;
  }
  :global([data-theme="light"]) .product-body { color: #4a5f7e; }
  .product-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem; }
  .product-badge {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ts-fg);
    background: var(--ts-surface-2);
    border: 1.5px solid var(--ts-line);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }
  .product-status {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    color: #2a1a00;
    background: var(--ts-gold);
  }
  .product-status-shipped { background: var(--ts-gold); }
  .product-status-running { background: #7fd07f; }
  .product-status-in-prototype { background: var(--ts-sky); color: #fff; }
  .product-status-call-for-speakers-open { background: var(--ts-red); color: #fff; }
  .product-foot { margin-top: 0.3rem; }
  .product-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--ts-red);
    text-decoration: none;
    transition: gap 0.2s ease, color 0.2s ease;
  }
  .product-cta:hover { gap: 0.75rem; color: var(--ts-red-bright); }
  .product-cta-disabled { color: var(--ts-muted); cursor: default; }
  .product-cta-disabled:hover { gap: 0.45rem; color: var(--ts-muted); }

  /* ------------------------------------------------------------
     LATE ADD
     ------------------------------------------------------------ */
  .late-section {
    background: var(--ts-surface-2);
    color: var(--ts-fg);
    padding: 6rem 2rem;
    position: relative;
  }
  :global([data-theme="dark"]) .late-section { background: var(--ts-bg-deep); }
  .late-inner { max-width: 900px; margin: 0 auto; }
  .late-grid { display: grid; grid-template-columns: 1fr; gap: 1.8rem; }
  .late-card {
    background: var(--ts-surface);
    border: 3px dashed var(--ts-gold);
    border-radius: 16px;
    padding: 2.2rem 2rem;
    text-align: center;
  }
  .late-card-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ts-red);
    margin-bottom: 0.8rem;
  }
  .late-card-title {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: 1.8rem;
    margin: 0 0 0.5rem;
    color: var(--ts-fg);
  }
  .late-card-line {
    font-family: 'Space Mono', monospace;
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ts-muted);
    margin-bottom: 1.1rem;
  }
  .late-card-body {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--ts-muted);
    margin: 0 auto 1.5rem;
    max-width: 40em;
    font-weight: 500;
  }
  :global([data-theme="light"]) .late-card-body { color: #4a5f7e; }
  .late-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Fredoka', sans-serif;
    font-weight: 600;
    font-size: 0.98rem;
    color: #fff;
    background: var(--ts-red);
    padding: 0.8rem 1.5rem;
    border-radius: 999px;
    text-decoration: none;
    box-shadow: 3px 3px 0 var(--ts-sky-deep);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .late-cta:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 var(--ts-sky-deep); }

  /* ------------------------------------------------------------
     CLOSING CTA
     ------------------------------------------------------------ */
  .closing-section {
    position: relative;
    background: var(--ts-bg);
    color: var(--ts-fg);
    padding: 6.5rem 2rem 7rem;
    overflow: hidden;
    text-align: center;
  }
  :global([data-theme="dark"]) .closing-section {
    background:
      radial-gradient(circle at 50% 0%, rgba(59,130,230,0.2) 0%, transparent 55%),
      linear-gradient(180deg, #0f1b3d 0%, #0a142e 100%);
  }
  :global([data-theme="light"]) .closing-section {
    background: linear-gradient(180deg, #e7f1fc 0%, #cfe6fb 100%);
  }
  .closing-inner { position: relative; z-index: 2; max-width: 820px; margin: 0 auto; }
  .closing-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ts-red);
    margin-bottom: 1.6rem;
  }
  .closing-rule { width: 40px; height: 2px; background: var(--ts-red); }
  .closing-title {
    font-family: 'Fredoka', sans-serif;
    font-weight: 700;
    font-size: clamp(2.2rem, 5.4vw, 4rem);
    line-height: 1.05;
    margin: 0 0 1.4rem;
    color: var(--ts-fg);
    letter-spacing: -0.015em;
  }
  .closing-title em { font-style: normal; color: var(--ts-red); }
  .closing-deck {
    font-family: 'Nunito', system-ui, sans-serif;
    font-size: 1.12rem;
    line-height: 1.7;
    color: var(--ts-muted);
    max-width: 46em;
    margin: 0 auto 2.4rem;
    font-weight: 500;
  }
  :global([data-theme="light"]) .closing-deck { color: #3a4d6b; }
  .closing-cta-row { display: flex; flex-wrap: wrap; gap: 1.3rem; justify-content: center; }

  /* ------------------------------------------------------------
     BACK PANEL
     ------------------------------------------------------------ */
  .panel-section {
    background: var(--ts-bg-deep);
    color: var(--ts-fg);
    padding: 4.5rem 2rem 5rem;
    border-top: 5px solid var(--ts-gold);
  }
  :global([data-theme="light"]) .panel-section { background: var(--ts-sky-deep); color: #fff; }
  .panel-inner { max-width: 1100px; margin: 0 auto; }
  .panel-tag {
