---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import LatestContent from '../components/LatestContent.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// Four disguise photographs the (fictional) Kscope26 photo desk filed during
// the week. Each one is captioned as if the conference program writer had no
// idea Edward was in the frame. The fedora is the giveaway in each shot.
const disguises = [
  {
    src: '/images/kscope/disguise-mustache.png',
    track: 'BREAKOUT · CONTINENTAL BALLROOM C',
    timestamp: 'TUE · 10:45 AM · MT',
    session: 'Oracle EPM Roadmap 2026',
    speaker: 'Matt Bradley, Oracle',
    caption: "Matt Bradley previews the Oracle EPM roadmap to a standing-room crowd. Edward, who has watched Matt present some version of that same slide deck every year since 2008, is sadly not anywhere to be seen.",
  },
  {
    src: '/images/kscope/disguise-dorothy.png',
    track: 'EXHIBIT HALL · ROCKIES HALL A',
    timestamp: 'WED · 12:18 PM · MT',
    session: 'Vendor Hall · Day Two',
    speaker: 'Oracle, Datavail, Donyati, Applied OLAP',
    caption: "Day-two exhibit hall, fully open for business. Edward, who once worked a Kscope booth for sixteen straight hours without sitting down, is by his own statement in Puerto Rico.",
  },
  {
    src: '/images/kscope/disguise-hotel-staff.png',
    track: 'HALLWAY · OUTSIDE LONGS PEAK 1',
    timestamp: 'THU · 02:30 PM · MT',
    session: 'AI in Enterprise EPM · Keynote',
    speaker: 'Featured Kscope26 Keynote',
    caption: "The AI-in-EPM keynote draws the largest crowd of the week. Edward, who delivered this exact slot in 2023, is at home in San Juan working through a quarterly.",
  },
  {
    src: '/images/kscope/disguise-tourist.png',
    track: 'LOBBY BALCONY · LEVEL 2',
    timestamp: 'FRI · 09:02 AM · MT',
    session: 'Closing Keynote · Press of the Mountains',
    speaker: 'ODTUG Board',
    caption: "Closing-day view from the balcony. The Rockies are doing what they do. Edward, who has spoken in fifty-plus countries on all seven continents, is for this one week choosing not to do the four-hour flight to Denver.",
  },
];

// Kscope greatest-hits clip reel. Real videos from Edward's catalog
// (src/data/external-videos.json), framed as a memorial program for the
// conference attendee who is, again, definitely not present this year.
const greatestHits = [
  {
    id: 'U8tLGHVBJIg',
    title: 'Edward Roske, Unnecessarily Censored',
    venue: 'REAL TIME BI · KSCOPE14 · 2014',
    note: "Sixty seconds from the Kscope14 livestream of Real Time BI with Kevin McGinley and Stewart Bryson. Edward's commentary is bleeped for effect. The censorship is, per the title, unnecessary. (Featured this week only, in honor of the week he isn't there.)",
  },
  {
    id: 'PZBIZxQGtBc',
    title: 'ODTUG Lifetime Achievement Award · Kscope25',
    venue: 'GAYLORD TEXAN · GRAPEVINE · 2025',
    note: "Fewer than five people in ODTUG's history have received this. Edward accepted it last June and announced, on stage, that Kscope25 would be his last as a regular. The board took him at his word. (The board, as it turns out, was the only group that did.)",
  },
  {
    id: '9Dx9tRPUXwM',
    title: 'Kscope or Bust: An Intergalactic Odyssey',
    venue: 'ANIMATED PROMO · ODTUG · 2025',
    note: "ODTUG's four-minute animated Kscope25 promo. A crew of alien tech enthusiasts intercepts a signal from Earth and sets course for the legendary Kscope conference. Edward voices an animated version of himself. The fedora made the cut.",
  },
  {
    id: 'tCmBz7mT51Y',
    title: 'Monty and Mike Interview Edward · Kscope15',
    venue: 'ODTUG · KSCOPE15 · HOLLYWOOD FL · 2015',
    note: "ODTUG board members Monty Latiolais and Mike Riley sit Edward down for the Kscope15 sponsor interview. Three men, three hats, one Titanium sponsor. (The hats were, for once, planned in advance.)",
  },
  {
    id: 'kscope11-survivor',
    externalUrl: 'https://timtows-hyperion-blog.blogspot.com/2011/07/kscope-11-opening-session-behind-scenes.html',
    thumbnail: '/images/kscope/survivor-poster.png',
    title: 'Survivor: Kscope11 · Voting for Kscope12 Location',
    venue: 'KSCOPE11 OPENING · LONG BEACH · 2011',
    note: "Edward's Survivor parody from the Kscope11 opening session in Long Beach. The ODTUG board got voted off one by one to reveal Kscope12's host city. (Edward, who wrote the screenplay as conference chair, was the first eliminated. By unanimous vote.) Hosted on Tim Tow's blog. Click through to watch.",
  },
  {
    id: 'AglCSOaGJqM',
    title: 'Edward Interviews Glenn Schwartzberg · Kscope23',
    venue: 'ODTUG PODCAST BOOTH · KSCOPE23',
    note: "Glenn Schwartzberg on twenty-plus years of Essbase contribution and the advice he gives newer practitioners. Recorded in 2023. (Glenn's hat game, for the record, is also strong.)",
  },
];

// Concurrent sessions Edward did NOT present at Kscope26, restyled from the
// usual project board. Same six current-work items, framed as the sessions
// he would have given if he were attending. Which he isn't.
const sessions = [
  {
    code: 'TRACK · EPM-101',
    room: 'WHAT HE IS BUILDING INSTEAD',
    title: 'AgentCube',
    body: "The engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus. Essbase and Planning shipped. Consolidations is in beta. (The session-room version of this talk would have been packed and standing in the back. The version where you click a link is also free.)",
    badge: 'ESSBASE · PLANNING · CLOSE',
    status: 'SHIPPED',
    href: 'https://caprus.ai/agentcube/',
    external: true,
    cta: 'Read the docs',
  },
  {
    code: 'TRACK · LDR-204',
    room: 'WHAT HE IS HOSTING INSTEAD',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever hosted. October 9 and 10 in San Juan. Speakers and sponsors are being recruited right now. If you build, fund, or run AI, the stage has a slot with your name on it.",
    badge: '9-10 OCT 2026 · SAN JUAN',
    status: 'CALL FOR SPEAKERS OPEN',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    code: 'TRACK · AI-305',
    room: 'WHAT HE IS INVESTING IN INSTEAD',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, the AI software and services firm giving finance teams faster, smarter operations. The working crew behind the MCP servers. The team that, for the record, does most of the actual building while Edward writes the blog posts.",
    badge: 'AI · FINANCE',
    status: 'RUNNING',
    href: 'https://caprus.ai',
    external: true,
    cta: 'See the team',
  },
  {
    code: 'TRACK · GAME-411',
    room: 'WHAT HE IS PROTOTYPING INSTEAD',
    title: "AI Dungeon Master's Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns. Initiative, lore, and improv help for the person behind the screen. If there's going to be an AI at the table, it should at least earn its seat. (The party will not be told.)",
    badge: 'D&D · 5E · EBERRON',
    status: 'IN PROTOTYPE',
    href: null,
    external: false,
    cta: 'Quiet build',
  },
  {
    code: 'TRACK · COMM-103',
    room: 'WHAT HE IS PRESIDING OVER INSTEAD',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. Over 850 people across our events. We meet every other month to figure out, in public, what AI means for the island, which is also what AI means for everyone else watching the island.",
    badge: '850+ · BI-MONTHLY',
    status: 'RUNNING',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next one',
  },
  {
    code: 'TRACK · TOOL-602',
    room: 'WHAT HE SHIPPED INSTEAD',
    title: 'Only Recipes',
    body: "Edward's first Chrome extension. When it spots you on a recipe page, it strips out everything that isn't the recipe. No author memoir. No fourteen ads. No infinite scroll. It's ridiculously fast and remarkably useful, which are two phrases I don't usually get to put next to each other.",
    badge: 'CHROME EXTENSION · FREE',
    status: 'SHIPPED',
    href: '/only-recipes/',
    external: false,
    cta: 'See what it does',
  },
];

// Late-breaking adds from the weekly questionnaire — fresh items shipping
// this week, slotted in as sessions added to the program after print.
const lateAdds = [
  {
    tag: 'IN BETA · NAME PENDING',
    title: 'The Home Library Project',
    line: 'BOOKS · GAMES · MEDIA · ALL SHELVES',
    body: "A new app and site that digitizes a home library: books, board games, music, media, anything sitting on a shelf at the house. All categorized. There'll be a free tier. The full reveal comes after beta. If you want an early look, send an email and you're on the list.",
    cta: 'Email for early access',
    href: 'mailto:Edward@Roske.AI',
    external: false,
  },
];

// Conference-program "stat block" sitting just under the hero.
const tally = [
  { value: '50+', label: 'COUNTRIES PRESENTED IN' },
  { value: '80+', label: 'COUNTRIES VISITED' },
  { value: '15', label: 'BOOKS IN PRINT' },
  { value: '~20', label: 'PRIOR KSCOPES' },
];

// Marquee ticker. The badge-line scroller from the conference app, gently
// hijacked into a faintly anxious public-address loop.
const tickerItems = [
  "ODTUG KSCOPE26 · JUNE 14 THRU 18 · AURORA CO",
  "GAYLORD ROCKIES RESORT · TECH AT NEW HEIGHTS",
  "EDWARD IS NOT ON THE SPEAKER LIST · WE CHECKED",
  "ATTENDEE BLUE-FEDORA SUPPLY IS RUNNING LOW",
  "★ ASKING GOOD QUESTIONS ★",
  "PLEASE REPORT UNAUTHORIZED FEDORAS TO REGISTRATION",
  "BACK ROW OF SESSIONS IS NOT FOR NETWORKING",
  "WIZARD-OF-OZ COSTUMES OUTSIDE EXHIBIT HALL ARE OPTIONAL",
];

// Program-guide colophon at the foot of the page.
const colophon = [
  { role: 'EDITION', name: 'KSCOPE26 · OFFICIAL PROGRAM · WEEK 25' },
  { role: 'CONFERENCE', name: 'ODTUG KSCOPE26 · JUNE 14-18 · AURORA, COLORADO' },
  { role: 'VENUE', name: 'GAYLORD ROCKIES RESORT AND CONVENTION CENTER' },
  { role: 'TAGLINE', name: 'TECH AT NEW HEIGHTS' },
  { role: 'HONOREE IN ABSENTIA', name: 'EDWARD ROSKE · LIFETIME ACHIEVEMENT, 2025' },
  { role: 'HEADGEAR (REQUIRED)', name: 'ONE (1) BLUE FELT FEDORA · BLACK BAND · NEVER NEGOTIATED' },
  { role: 'AT HOME (REPORTEDLY)', name: 'SAN JUAN, PUERTO RICO' },
  { role: 'WITH THANKS TO', name: 'EVERY ODTUG VOLUNTEER WHO HELD THE CONFERENCE TOGETHER FOR TWENTY-FIVE YEARS' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       BADGE STRIPE — conference-lanyard top bar
       ============================================ -->
  <div class="ks-bar">
    <div class="ks-bar-inner">
      <span class="ks-bar-logo" aria-hidden="true">
        <span class="ks-bar-logo-k">K</span><span class="ks-bar-logo-s">scope</span><span class="ks-bar-logo-yr">26</span>
      </span>
      <span class="ks-bar-meta ks-bar-meta-center">AURORA · COLORADO · GAYLORD ROCKIES · JUNE 14-18, 2026</span>
      <span class="ks-bar-meta ks-bar-meta-end">TECH AT NEW HEIGHTS</span>
    </div>
  </div>

  <!-- ============================================
       HERO — split layout, text left, fedora-room right
       ============================================ -->
  <section class="hero-section">
    <div class="hero-pattern" aria-hidden="true"></div>
    <div class="hero-grid">

      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-pip"></span>
          <span>OFFICIAL ATTENDEE NOTICE · ODTUG · 2026</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">Tech at <em>new heights.</em></span>
          <span class="hero-title-sub">Edward at sea level.</span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-tally">
          {tally.map(stat => (
            <div class="tally-item">
              <div class="tally-value">{stat.value}</div>
              <div class="tally-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <figure class="program-cover">
          <div class="program-cover-top">
            <span class="program-cover-flag">PROGRAM COVER · ROOM SHOT · DAY ONE</span>
          </div>
          <div class="program-cover-window">
            <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="program-cover-image" />
            <div class="program-cover-badge" aria-hidden="true">
              <span class="program-cover-badge-line">ATTENDEE</span>
              <span class="program-cover-badge-num">#000001</span>
              <span class="program-cover-badge-name">EDWARD ROSKE</span>
              <span class="program-cover-badge-tag">NOT IN ATTENDANCE</span>
            </div>
          </div>
          <div class="program-cover-bottom">
            <span>KSCOPE26 · DAY ONE · KEYNOTE HALL</span>
            <span>PHOTO STAFF · ODTUG · 6.14.26</span>
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================
       TICKER
       ============================================ -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...tickerItems, ...tickerItems].map(item => (
        <span class="ticker-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- ============================================
       PULL QUOTE — "official statement from ODTUG"
       ============================================ -->
  <section class="statement-section">
    <div class="statement-inner">
      <div class="statement-tag">OFFICIAL STATEMENT · ODTUG COMMUNICATIONS</div>
      <blockquote class="statement-q">
        Attendees showed up wearing his hat. Which is, frankly, more support than he was expecting. It's also, frankly, more support than is strictly necessary. <span class="statement-line">(Frankly, please stop.)</span>
      </blockquote>
      <div class="statement-attrib">
        <span class="statement-attrib-name">ODTUG BOARD</span>
        <span class="statement-attrib-role">REGISTRATION DESK · DAY ONE · MORNING</span>
      </div>
    </div>
  </section>

  <!-- ============================================
       LATEST CONTENT — permanent module
       ============================================ -->
  <LatestContent
    eyebrow="Section 02 · From the press box (in San Juan, not Aurora)"
    heading={"Fresh <em>off the wire.</em>"}
    deck="The newest writing and video briefs, in one place. Filed from wherever Edward happens to be this week, which is officially not Kscope. (Though he was reportedly spotted around the Gaylord Rockies? Probably just rumors.)"
  />

  <!-- ============================================
       THE SEARCH — disguise gallery
       ============================================ -->
  <section class="search-section">
    <div class="search-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 03 · WHERE'S THE FEDORA · DISGUISE GALLERY</span>
        </div>
        <h2 class="section-title">The search <em>continues.</em></h2>
        <p class="section-deck">
          Four photos from the ODTUG photo desk this week. Edward Roske is, per his own statement, in Puerto Rico. The fedora, however, has a way of turning up in the frame. (We make no claims about how it got there. We also make no claims about a Wizard of Oz costume seen in the Donyati booth.)
        </p>
      </header>

      <div class="search-grid">
        {disguises.map((item) => (
          <article class="disguise-card">
            <div class="disguise-frame">
              <img src={item.src} alt={item.caption} loading="lazy" decoding="async" class="disguise-image" />
            </div>
            <div class="disguise-meta">
              <div class="disguise-meta-row">
                <span class="disguise-track">{item.track}</span>
                <span class="disguise-time">{item.timestamp}</span>
              </div>
              <h3 class="disguise-session">{item.session}</h3>
              <div class="disguise-speaker">{item.speaker}</div>
              <p class="disguise-caption">{item.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       GREATEST HITS — video grid
       ============================================ -->
  <section class="memoriam-section">
    <div class="memoriam-inner">
      <header class="section-header memoriam-header">
        <div class="section-tag memoriam-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 04 · GREATEST HITS · ARCHIVE FOOTAGE</span>
        </div>
        <h2 class="section-title">In memoriam. <em>May he rest in peace at other conferences.</em></h2>
        <p class="section-deck">
          A program is just a list of things that already happened, eventually. Six clips from the archive: the Lifetime Achievement Award, the animated promo, the masterclass, the podcast booth, and a twenty-eight-second appearance from 2011 that, depending on your tolerance for tape hiss, holds up surprisingly well.
        </p>
      </header>

      <div class="memoriam-grid">
        {greatestHits.map((video) => {
          const href = video.externalUrl ?? `https://www.youtube.com/watch?v=${video.id}`;
          const thumb = video.thumbnail ?? `https://img.youtube.com/vi/${video.id}/hqdefault.jpg`;
          return (
            <article class="memoriam-card">
              <a href={href} target="_blank" rel="noopener" class="memoriam-thumb-link" aria-label={`Watch: ${video.title}`}>
                <div class="memoriam-thumb">
                  <img src={thumb} alt={video.title} loading="lazy" decoding="async" />
                  <div class="memoriam-play" aria-hidden="true">
                    <svg width="44" height="44" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                  <div class="memoriam-venue">{video.venue}</div>
                </div>
              </a>
              <h3 class="memoriam-title">
                <a href={href} target="_blank" rel="noopener">{video.title}</a>
              </h3>
              <p class="memoriam-note">{video.note}</p>
            </article>
          );
        })}
      </div>

      <div class="memoriam-foot">
        <a href="/content/" class="memoriam-more">
          More from the archive
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       CONCURRENT SESSIONS — project cards
       ============================================ -->
  <section id="current-work" class="sessions-section">
    <div class="sessions-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 05 · CONCURRENT SESSIONS · EDWARD DID NOT PRESENT</span>
        </div>
        <h2 class="section-title">Six sessions. <em>None of them at Kscope.</em></h2>
        <p class="section-deck">
          The current entries column, restyled from the program he would have submitted if he were going. Same six projects either way. (The room numbers are honest. The rooms aren't in Aurora.)
        </p>
      </header>

      <div class="sessions-grid">
        {sessions.map(session => (
          <article class="session-card">
            <div class="session-card-head">
              <span class="session-code">{session.code}</span>
              <span class="session-room">{session.room}</span>
            </div>
            <h3 class="session-title">{session.title}</h3>
            <p class="session-body">{session.body}</p>
            <div class="session-meta">
              <span class="session-badge">{session.badge}</span>
              <span class={`session-status session-status-${session.status.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{session.status}</span>
            </div>
            <div class="session-foot">
              {session.href ? (
                <a href={session.href} target={session.external ? '_blank' : undefined} rel={session.external ? 'noopener' : undefined} class="session-cta">
                  {session.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="session-cta session-cta-disabled">{session.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       LATE ADDS
       ============================================ -->
  <section class="late-section">
    <div class="late-inner">
      <header class="section-header late-header">
        <div class="section-tag late-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 06 · LATE ADDS · NEW SINCE PROGRAM PRINT</span>
        </div>
        <h2 class="section-title">One late <em>addition</em>, in beta.</h2>
      </header>

      <div class="late-grid">
        {lateAdds.map(item => (
          <article class="late-card">
            <div class="late-card-tag">{item.tag}</div>
            <h3 class="late-card-title">{item.title}</h3>
            <div class="late-card-line">{item.line}</div>
            <p class="late-card-body">{item.body}</p>
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="late-cta">
              {item.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CLOSING CTA
       ============================================ -->
  <section class="closing-section">
    <div class="closing-inner">
      <div class="closing-eyebrow">
        <span class="closing-rule"></span>
        <span>THE BOX OFFICE IS OPEN · 13 MINUTES</span>
        <span class="closing-rule"></span>
      </div>
      <h2 class="closing-title">Couldn't find him at Kscope?<br/><em>Of course not.</em></h2>
      <p class="closing-deck">
        Book a thirteen-minute call. Bring questions about Oracle EPM, AI in finance, MCP servers, Caribbean conferences, D&D, or what it feels like to skip your own conference for the first time in nineteen years. Answers included. Opinions arrive whether you ask for them or not, and at thirteen minutes a head, you can't really say they aren't a bargain.
      </p>
      <div class="closing-cta-row">
        <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a note</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       COLOPHON
       ============================================ -->
  <section class="colophon-section">
    <div class="colophon-inner">
      <div class="colophon-tag">PROGRAM COLOPHON · BACK COVER · 2026</div>
      <div class="colophon-roll">
        {colophon.map(entry => (
          <div class="colophon-block">
            <span class="colophon-role">{entry.role}</span>
            <span class="colophon-name">{entry.name}</span>
          </div>
        ))}
      </div>
      <div class="colophon-footnote">
        Not affiliated with ODTUG, Oracle, the Gaylord Rockies Resort, or any registered fedora. ODTUG, Kscope, Tech at New Heights, and the conference program are the property of their respective owners. The fedora is, and always has been, Edward's. (We checked.)
      </div>
    </div>
