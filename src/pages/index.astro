---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// "La Selection Officielle" — five scene images, treated as a film-still spread.
const filmStills = [
  {
    src: '/images/cannes/edward-director-chair.png',
    sceneNo: '23',
    slug: 'INT. PLATEAU 4. JOUR.',
    title: 'Le Realisateur',
    line: "Take 79. The director clicks the clapperboard a second too early, then a second too late, then claims it was on purpose.",
    aspect: '4/3',
    rotate: -1.2,
  },
  {
    src: '/images/cannes/edward-palais-steps.png',
    sceneNo: '41',
    slug: 'EXT. PALAIS DES FESTIVALS. CRÉPUSCULE.',
    title: "Le Tapis Rouge",
    line: "He bows. Nobody is here yet. Two security guards exchange a slow, professional glance.",
    aspect: '3/4',
    rotate: 1.4,
  },
  {
    src: '/images/cannes/edward-yacht-party.png',
    sceneNo: '57',
    slug: 'EXT. YACHT. NUIT.',
    title: "L'Apres-Premiere",
    line: "The financiers are smiling. The producer is on his fourth glass. Everyone agrees the third act is fine. It is not fine.",
    aspect: '4/3',
    rotate: -0.6,
  },
  {
    src: '/images/cannes/edward-press-conference.png',
    sceneNo: '63',
    slug: 'INT. SALLE DE PRESSE. JOUR.',
    title: "La Conference de Presse",
    line: "A journalist asks a question in French. The headphones are on top of the hat. He answers anyway. The press loves it.",
    aspect: '3/4',
    rotate: 0.8,
  },
];

// Closing portrait used in the "La Cloture" section
const closingStill = {
  src: '/images/cannes/edward-palme-victory.png',
  alt: "Edward Roske mock-emotional, hoisting a Palme d'Or trophy over his head at a Cannes photocall, eyes closed, blue fedora still firmly in place.",
};

// "Le Programme" — six festival entries (the recurring projects, restyled).
const programme = [
  {
    filmNo: 'No. 01',
    section: 'EN COMPETITION',
    title: 'AgentCube',
    body: "The unified engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus.AI. Already shipping for Essbase and Planning. Consolidations in beta.",
    href: '/agentcube.html',
    external: false,
    cta: 'Lire le synopsis',
    badge: 'LONG METRAGE · MCP',
    runtime: '∞ min',
  },
  {
    filmNo: 'No. 02',
    section: 'HORS COMPETITION',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever seen. Speakers and attendees from around the globe. Submit a talk, sponsor a track, or grab a seat before the island fills up.",
    href: 'https://www.caribbeansummit.ai/',
    external: true,
    cta: 'Acheter un billet',
    badge: '9-10 OCTOBRE · SAN JUAN',
    runtime: '48 hr',
  },
  {
    filmNo: 'No. 03',
    section: 'UN CERTAIN REGARD',
    title: 'Caprus AI',
    body: "Investor and contributor at Caprus, an AI Software & Services firm empowering finance teams with AI solutions for smarter, faster, more strategic financial operations.",
    href: 'https://caprus.ai',
    external: true,
    cta: 'Voir la maison',
    badge: 'AI · FINANCE',
    runtime: '24/7',
  },
  {
    filmNo: 'No. 04',
    section: 'SEANCE SPECIALE',
    title: 'AI Dungeon Master',
    body: "Building a tool that helps Dungeon Masters run better D&D campaigns using AI. Because if you're going to have an artificial intelligence at your table, it should at least help with initiative tracking.",
    href: null,
    external: false,
    cta: 'En post-production',
    badge: 'D&D · AI',
    runtime: '4 hr',
  },
  {
    filmNo: 'No. 05',
    section: 'QUINZAINE DES REALISATEURS',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. Over 850 attendees across our events. We meet every other month to explore what AI means for the island and beyond.",
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Reserver une place',
    badge: 'TOUS LES 2 MOIS',
    runtime: '3 hr',
  },
  {
    filmNo: 'No. 06',
    section: 'DOCUMENTAIRE',
    title: 'Everest Base Camp · Cleared',
    body: "Hiked to Everest Base Camp in April with Dawn after acclimating in Santa Fe. Ten days, twelve thousand vertical feet, one fedora that survived the entire Khumbu Valley. The next summit is undecided.",
    href: '/blog',
    external: false,
    cta: 'Lire le journal',
    badge: 'NEPAL · AVRIL 2026',
    runtime: '10 jours',
  },
];

// "L'Entretien" — Q&A formatted as a French film magazine interview.
const interview = [
  {
    q: "On having directed, written, and starred in the same film.",
    a: "Short answer: yes. Long answer: also yes, but it was unintentional, and at some point during principal photography I also started doing my own catering. The intern is, somehow, also me. (Edward is the only credit on the call sheet. The call sheet is one page long.)",
  },
  {
    q: "On the Palme d'Or in the hero image.",
    a: "It is a rental. Specifically, it is a prop that arrived in a wooden crate marked 'NE PAS OUVRIR · NE PAS POLIR' and I opened it and polished it anyway. The real one is in a vault in Paris guarded by people who would not return my emails. (I asked.)",
  },
  {
    q: "On the white dinner jacket.",
    a: "Strongly inadvisable on a yacht. Strongly inadvisable in a press tent. Strongly inadvisable anywhere within fifty feet of red wine, marinara, or any sauce whatsoever. I wore it anyway. The dry-cleaner in Mougins is now my closest friend in France.",
  },
  {
    q: "On the fedora at a black-tie event.",
    a: "The fedora is non-negotiable. I have spoken in fifty countries in this fedora. I summited a Himalayan pass in this fedora. The dress code at the Palais says 'noeud papillon obligatoire' and says nothing whatsoever about hats. I'll allow it.",
  },
];

// Festival marquee phrases
const marqueeItems = [
  "★ 79e FESTIVAL · SELECTION OFFICIELLE",
  "ROSKE · UN FILM DE EDWARD ROSKE",
  "★ AVEC EDWARD ROSKE",
  "AGENTCUBE · MAINTENANT EN SALLES",
  "★ CARIBBEAN AI SUMMIT · 9-10 OCTOBRE",
  "LE FEDORA EST TOUJOURS BLEU",
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       FESTIVAL MASTHEAD — fake Cannes header strip
       ============================================ -->
  <div class="festival-bar">
    <div class="festival-bar-inner">
      <span class="fb-laurel" aria-hidden="true">❦</span>
      <span class="fb-meta">79<sup>e</sup> FESTIVAL · SELECTION OFFICIELLE</span>
      <span class="fb-meta fb-meta-center">12 – 23 MAI · MMXXVI · CANNES</span>
      <span class="fb-meta fb-meta-end">DOSSIER DE PRESSE · No. 79</span>
      <span class="fb-laurel" aria-hidden="true">❦</span>
    </div>
  </div>

  <!-- ============================================
       HERO — French cinema poster
       ============================================ -->
  <section class="hero-section">
    <div class="hero-grain" aria-hidden="true"></div>
    <div class="hero-grid">

      <!-- Left: poster typography -->
      <div class="hero-text">

        <div class="hero-eyebrow">
          <span class="hero-eyebrow-rule"></span>
          <span class="hero-eyebrow-text">UN FILM DE EDWARD ROSKE</span>
        </div>

        <h1 class="hero-title" aria-label="Roske à Cannes">
          <span class="hero-title-line hero-title-tiny">presente</span>
          <span class="hero-title-line hero-title-big">ROSKE</span>
          <span class="hero-title-line hero-title-script"><em>à&nbsp;Cannes</em></span>
        </h1>

        <p class="hero-deck">{theme.hero.subtitle}</p>

        <!-- Poster billing block — vertically tight, all caps, narrow -->
        <div class="hero-billing" aria-hidden="true">
          <div class="bill-row bill-big">EDWARD ROSKE</div>
          <div class="bill-row bill-small">DANS LE ROLE DE EDWARD ROSKE</div>
          <div class="bill-row bill-tiny">AVEC EDWARD ROSKE &nbsp;·&nbsp; ET EDWARD ROSKE</div>
          <div class="bill-row bill-tiny">DIRECTEUR DE LA PHOTOGRAPHIE &nbsp; EDWARD ROSKE</div>
          <div class="bill-row bill-tiny">MUSIQUE ORIGINALE &nbsp; EDWARD ROSKE</div>
          <div class="bill-row bill-tiny">PRODUIT PAR &nbsp; EDWARD ROSKE</div>
          <div class="bill-row bill-tiny">ECRIT ET REALISE PAR &nbsp; EDWARD ROSKE</div>
        </div>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary">
            Reserver 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>Voir la selection</span>
          </a>
        </div>

        <div class="hero-stats">
          {[
            { value: '80+', label: 'Pays' },
            { value: '50+', label: 'Conferences' },
            { value: '15', label: 'Livres' },
            { value: '25+', label: 'Ans · PDG' },
          ].map(stat => (
            <div class="hero-stat">
              <div class="hero-stat-value">{stat.value}</div>
              <div class="hero-stat-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: the cover poster -->
      <div class="hero-image-wrap">
        <div class="poster-frame">
          <div class="poster-bar-top">
            <span>79<sup>e</sup></span>
            <span>FESTIVAL DE CANNES</span>
            <span>MMXXVI</span>
          </div>
          <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="poster-image" />
          <div class="poster-laurels" aria-hidden="true">
            <svg class="laurel laurel-left" viewBox="0 0 100 200" width="44" height="88" xmlns="http://www.w3.org/2000/svg">
              <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <path d="M70 10 C 40 50, 30 110, 50 195"/>
                <path d="M65 30 C 50 40, 40 50, 35 60"/>
                <path d="M60 55 C 45 65, 35 75, 30 85"/>
                <path d="M55 85 C 40 95, 30 105, 25 115"/>
                <path d="M52 115 C 38 125, 28 135, 23 145"/>
                <path d="M52 145 C 38 155, 30 165, 28 175"/>
              </g>
            </svg>
            <svg class="laurel laurel-right" viewBox="0 0 100 200" width="44" height="88" xmlns="http://www.w3.org/2000/svg">
              <g fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <path d="M30 10 C 60 50, 70 110, 50 195"/>
                <path d="M35 30 C 50 40, 60 50, 65 60"/>
                <path d="M40 55 C 55 65, 65 75, 70 85"/>
                <path d="M45 85 C 60 95, 70 105, 75 115"/>
                <path d="M48 115 C 62 125, 72 135, 77 145"/>
                <path d="M48 145 C 62 155, 70 165, 72 175"/>
              </g>
            </svg>
            <div class="poster-laurels-text">
              <span class="laurel-line">SELECTION</span>
              <span class="laurel-line laurel-line-big">OFFICIELLE</span>
              <span class="laurel-line">CANNES · 2026</span>
            </div>
          </div>
          <div class="poster-bar-bottom">
            <span class="poster-credit-blob">UN FILM DE</span>
            <span class="poster-credit-name">EDWARD ROSKE</span>
            <span class="poster-credit-blob">EN COMPETITION</span>
          </div>
        </div>

        <!-- Floating tickets -->
        <div class="ticket ticket-1" aria-hidden="true">
          <div class="ticket-edge"></div>
          <div class="ticket-body">
            <div class="ticket-line ticket-line-tiny">FESTIVAL · 2026</div>
            <div class="ticket-line ticket-line-big">ADMIT ONE</div>
            <div class="ticket-line ticket-line-tiny">PALAIS · ROW E · SEAT 23</div>
            <div class="ticket-line ticket-line-tiny">PRIX · GRATUIT</div>
          </div>
          <div class="ticket-stub">
            <span>79</span>
          </div>
        </div>

        <div class="poster-stamp" aria-hidden="true">
          <div class="stamp-ring">
            <span>OFFICIAL · SELECTION · OFFICIAL · SELECTION</span>
          </div>
          <div class="stamp-center">
            <span class="stamp-num">79</span>
            <span class="stamp-sub">EDITION</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       MARQUEE — Festival ticker
       ============================================ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      {[...marqueeItems, ...marqueeItems].map(item => (
        <span class="marquee-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- ============================================
       PULL QUOTE — auteur statement
       ============================================ -->
  <section class="pullquote-section">
    <div class="pullquote-inner">
      <div class="pullquote-tag">CAHIER · PAGE 003 · MOT D'AUTEUR</div>
      <blockquote class="pullquote">
        <span class="pullquote-mark">&laquo;</span>
        I directed, wrote, scored, and starred in the film. Then I went home and closed the books for a Fortune 500 client. The credits ran longer than the film.
        <span class="pullquote-mark pullquote-mark-close">&raquo;</span>
      </blockquote>
      <div class="pullquote-attrib">
        <span class="pullquote-attrib-name">Edward Roske</span>
        <span class="pullquote-attrib-role">Realisateur · Auteur · Probationary Auteur Anyway</span>
      </div>
    </div>
  </section>

  <!-- ============================================
       LA SELECTION — film stills as magazine spread
       ============================================ -->
  <section class="stills-section">
    <div class="stills-inner">
      <header class="section-header">
        <div class="section-tag">SECTION 02 · LA SELECTION</div>
        <h2 class="section-title">Quatre images <em>du film</em>,<br/>tirees au hasard.</h2>
        <p class="section-deck">
          Photos de plateau leaked to the press before the jury has finished its lunch. The film has not been screened. The film may not exist. We are committed either way.
        </p>
      </header>

      <div class="stills-grid">
        {filmStills.map((item) => (
          <article class="still-card" style={`--rot:${item.rotate}deg; --aspect:${item.aspect};`}>
            <div class="still-photo">
              <span class="still-tape still-tape-tl" aria-hidden="true"></span>
              <span class="still-tape still-tape-br" aria-hidden="true"></span>
              <img src={item.src} alt={item.title} loading="lazy" decoding="async" />
              <div class="still-pageno">SCENE {item.sceneNo}</div>
            </div>
            <div class="still-meta">
              <div class="still-slug">{item.slug}</div>
              <h3 class="still-title">{item.title}</h3>
              <p class="still-line">{item.line}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       MOT DU REALISATEUR — director's note with portrait
       ============================================ -->
  <section class="director-section">
    <div class="director-grid">
      <figure class="director-image">
        <img src={closingStill.src} alt={closingStill.alt} loading="lazy" decoding="async" />
        <figcaption>
          <span>FIG. C · 19:14</span>
          <span>PHOTOCALL · PALAIS</span>
        </figcaption>
      </figure>

      <div class="director-text">
        <div class="director-tag">MOT DU REALISATEUR</div>
        <h3 class="director-h3">A note from the director.<br/><em>(Also Edward.)</em></h3>
        <p class="director-body">
          The festival is a strange place. You stand on a red carpet that goes on for too long. You wave at people you do not know. You hold up an object you have not earned. Then you go back to your hotel, open your laptop, and the books still need to close.
        </p>
        <p class="director-body">
          The thesis of the film is simple: AI does not replace the auteur. It replaces the intern. The auteur is busy holding the Palme d'Or above his head and crying for the cameras. The intern is reconciling the GL. Both jobs are real. (One of them pays better.)
        </p>
        <div class="director-attrib">
          <span class="director-attrib-line"></span>
          <div>
            <span class="director-attrib-name">Edward Roske</span>
            <span class="director-attrib-title">Realisateur · Roske, ou, La Comptabilite des Reves</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       LE PROGRAMME — six selections
       ============================================ -->
  <section id="current-work" class="programme-section">
    <div class="programme-inner">
      <header class="section-header">
        <div class="section-tag">SECTION 03 · LE PROGRAMME</div>
        <h2 class="section-title">Six films <em>en selection.</em><br/>Tous projetes en ce moment.</h2>
        <p class="section-deck">
          The programme of the parallel festival running inside Edward's calendar. Some of these will absolutely happen. One of them is fictional. (We will not say which. The fictional one is also being scored as we speak.)
        </p>
      </header>

      <div class="programme-grid">
        {programme.map(film => (
          <article class="film-card">
            <div class="film-perfs film-perfs-top" aria-hidden="true">
              <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
            </div>

            <div class="film-card-header">
              <span class="film-no">{film.filmNo}</span>
              <span class="film-section">{film.section}</span>
            </div>

            <h3 class="film-title">{film.title}</h3>
            <p class="film-body">{film.body}</p>

            <div class="film-meta">
              <span class="film-badge">{film.badge}</span>
              <span class="film-runtime">DUREE · {film.runtime}</span>
            </div>

            <div class="film-card-footer">
              {film.href ? (
                <a href={film.href} target={film.external ? '_blank' : undefined} rel={film.external ? 'noopener' : undefined} class="film-cta">
                  {film.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="film-cta film-cta-disabled">{film.cta}</span>
              )}
            </div>

            <div class="film-perfs film-perfs-bot" aria-hidden="true">
              <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       L'ENTRETIEN — Q&A in French magazine style
       ============================================ -->
  <section class="entretien-section">
    <div class="entretien-inner">
      <header class="section-header entretien-header">
        <div class="section-tag">SECTION 04 · L'ENTRETIEN</div>
        <h2 class="section-title">A few things,<br/><em>on the record.</em></h2>
      </header>

      <div class="entretien-list">
        {interview.map((item, idx) => (
          <div class="entretien-item">
            <div class="entretien-num">{String(idx + 1).padStart(2, '0')}</div>
            <div class="entretien-content">
              <div class="entretien-q">— {item.q}</div>
              <div class="entretien-a">{item.a}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       FINAL CTA — "Achetez vos billets"
       ============================================ -->
  <section class="cloture-section">
    <div class="cloture-inner">
      <div class="cloture-eyebrow">
        <span class="cloture-rule"></span>
        <span>SEANCE DE CLOTURE · 13 MINUTES</span>
        <span class="cloture-rule"></span>
      </div>
      <h2 class="cloture-title">Achetez vos billets.<br/><em class="cloture-em">Or just send an email.</em></h2>
      <p class="cloture-deck">
        The closing screening is a thirteen-minute conversation with Edward. No black tie required. No headphones in French. No Palme d'Or. (Bring questions about AI, finance, podcasting, escape rooms, or the Khumbu Valley. He has opinions about all five.)
      </p>
      <div class="cloture-cta-row">
        <a href="https://calendar.app.google/udtTerQwcX9Z7QQt7" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Reserver 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Ecrire au directeur</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       CLOSING CREDITS — typewriter scroll
       ============================================ -->
  <section class="credits-section">
    <div class="credits-inner">
      <div class="credits-tag">FIN · GENERIQUE</div>
      <div class="credits-roll">
        <div class="credits-block">
          <span class="credits-role">REALISATEUR</span>
          <span class="credits-name">EDWARD ROSKE</span>
        </div>
        <div class="credits-block">
          <span class="credits-role">SCENARIO</span>
          <span class="credits-name">EDWARD ROSKE</span>
        </div>
        <div class="credits-block">
          <span class="credits-role">DANS LE ROLE PRINCIPAL</span>
          <span class="credits-name">EDWARD ROSKE</span>
        </div>
        <div class="credits-block">
          <span class="credits-role">ASSISTANT</span>
          <span class="credits-name">EDWARD ROSKE</span>
        </div>
        <div class="credits-block">
          <span class="credits-role">CHAPEAU</span>
          <span class="credits-name">FEDORA BLEU · CARRIER PERSONNEL</span>
        </div>
        <div class="credits-block">
          <span class="credits-role">REMERCIEMENTS</span>
          <span class="credits-name">DAWN ROSKE · MYCROFT · ELIOT · LE PEUPLE DE PUERTO RICO</span>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     ROSKE A CANNES — vintage French cinema poster aesthetic
     Color palette: ink black / programme cream / Palme gold / Cannes red
     Typography: Italiana (display), DM Serif Display (h3), EB Garamond (body), Special Elite (mono)
     ============================================================ */

  :global([data-theme="dark"]) {
    --hero-bg: #0a0907;
    --hero-fg: #f4ecdc;
    --hero-muted: #b5a78d;
    --gold: #c8a04a;
    --gold-soft: #8a6f30;
    --paper: #f4ecdc;
    --paper-soft: #ddcfa8;
    --red: #b8202a;
    --red-soft: #7d1820;
    --ink: #0a0907;
    --film: #15110d;
    --border-rule: #3a2f24;
  }
  :global([data-theme="light"]) {
    --hero-bg: #f4ecdc;
    --hero-fg: #15110d;
    --hero-muted: #5a4a36;
    --gold: #a07d24;
    --gold-soft: #c8a04a;
    --paper: #15110d;
    --paper-soft: #2a2014;
    --red: #a01820;
    --red-soft: #b8202a;
    --ink: #15110d;
    --film: #f4ecdc;
    --border-rule: #c8b48a;
  }

  /* ------------------------------------------------------------
     FESTIVAL MASTHEAD
     ------------------------------------------------------------ */
  .festival-bar {
    width: 100%;
    background: var(--ink);
    color: var(--gold);
    border-bottom: 1px solid var(--gold-soft);
    font-family: 'Italiana', serif;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  :global([data-theme="light"]) .festival-bar {
    background: var(--paper);
    color: var(--gold-soft);
  }

  .festival-bar-inner {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0.55rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    font-size: 0.72rem;
  }
  .fb-laurel {
    color: var(--gold);
    font-size: 1rem;
  }
  .fb-meta { white-space: nowrap; }
  .fb-meta-center {
    flex: 1;
    text-align: center;
    letter-spacing: 0.35em;
  }
  .fb-meta-end { text-align: right; }
  @media (max-width: 700px) {
    .festival-bar-inner { padding: 0.55rem 1rem; gap: 0.6rem; font-size: 0.6rem; }
    .fb-meta-end, .fb-laurel { display: none; }
  }

  /* ------------------------------------------------------------
     HERO POSTER
     ------------------------------------------------------------ */
  .hero-section {
    position: relative;
    background: var(--hero-bg);
    color: var(--hero-fg);
    padding: 5rem 2rem 6rem;
    overflow: hidden;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(ellipse at 20% 0%, rgba(200,160,74,0.07) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(184,32,42,0.06) 0%, transparent 60%),
      linear-gradient(180deg, #0a0907 0%, #161009 50%, #0a0907 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
      radial-gradient(ellipse at 20% 0%, rgba(200,160,74,0.12) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 100%, rgba(184,32,42,0.07) 0%, transparent 60%),
      var(--paper);
  }

  .hero-grain {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.10;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='2'/><feColorMatrix values='0 0 0 0 0.8 0 0 0 0 0.7 0 0 0 0 0.5 0 0 0 0.85 0'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
    mix-blend-mode: overlay;
  }
  :global([data-theme="light"]) .hero-grain { opacity: 0.06; }

  .hero-grid {
    position: relative;
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3rem; }
    .hero-section { padding: 3rem 1.25rem 4rem; }
  }

  /* Hero left column */
  .hero-text { max-width: 640px; }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-family: 'Special Elite', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.4rem;
  }
  .hero-eyebrow-rule {
    width: 38px;
    height: 1px;
    background: var(--gold);
    flex-shrink: 0;
  }

  .hero-title {
    margin: 0 0 1.6rem;
    line-height: 0.88;
    font-family: 'Italiana', serif;
    color: var(--hero-fg);
  }
  .hero-title-line { display: block; }
  .hero-title-tiny {
    font-family: 'EB Garamond', serif;
    font-style: italic;
    font-weight: 400;
    font-size: 1rem;
    letter-spacing: 0.04em;
    color: var(--hero-muted);
    margin-bottom: 0.5rem;
  }
  .hero-title-big {
    font-size: clamp(5.6rem, 13vw, 11rem);
    letter-spacing: -0.02em;
    color: var(--hero-fg);
    line-height: 0.84;
  }
  .hero-title-script {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.4rem, 5.5vw, 4.4rem);
    color: var(--red);
    margin-top: -0.15em;
    letter-spacing: -0.005em;
    line-height: 1;
  }

  .hero-deck {
    font-family: 'EB Garamond', serif;
    font-size: 1.18rem;
    line-height: 1.5;
    color: var(--hero-fg);
    margin: 0 0 1.4rem;
    max-width: 30em;
    font-style: italic;
    font-weight: 500;
  }

  /* Poster billing block — tight, centered, all caps */
  .hero-billing {
    border-top: 1px solid var(--gold-soft);
    border-bottom: 1px solid var(--gold-soft);
    padding: 1rem 0;
    margin: 1.8rem 0 1.5rem;
    text-align: center;
    color: var(--hero-fg);
    font-family: 'Italiana', serif;
    letter-spacing: 0.22em;
    line-height: 1.5;
  }
  .bill-row { display: block; text-transform: uppercase; }
  .bill-big { font-size: 1.18rem; letter-spacing: 0.32em; }
  .bill-small { font-size: 0.82rem; color: var(--hero-muted); margin-top: 0.15rem; letter-spacing: 0.28em; }
  .bill-tiny {
    font-family: 'Special Elite', monospace;
    font-size: 0.62rem;
    color: var(--hero-muted);
    margin-top: 0.25rem;
    letter-spacing: 0.14em;
  }

  .hero-body {
    font-family: 'EB Garamond', serif;
    font-size: 1.02rem;
    line-height: 1.65;
    color: var(--hero-muted);
    margin: 0 0 1.8rem;
    max-width: 38em;
  }

  /* CTAs */
  .btn-primary, .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.85rem 1.5rem;
    font-family: 'Italiana', serif;
    font-size: 0.85rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid currentColor;
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
    line-height: 1;
  }
  .btn-primary {
    background: var(--red);
    color: var(--paper);
    border-color: var(--red);
  }
  .btn-primary:hover {
    background: var(--ink);
    color: var(--gold);
    border-color: var(--gold);
    transform: translateY(-2px);
  }
  .btn-secondary {
    background: transparent;
    color: var(--hero-fg);
    border-color: var(--hero-fg);
  }
  .btn-secondary:hover {
    background: var(--hero-fg);
    color: var(--hero-bg);
    transform: translateY(-2px);
  }
  .btn-primary-big, .btn-secondary-big {
    padding: 1.1rem 2rem;
    font-size: 0.95rem;
  }
  .hero-cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-bottom: 2.6rem;
  }

  /* Stats */
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.2rem;
    border-top: 1px solid var(--border-rule);
    padding-top: 1.6rem;
  }
  .hero-stat-value {
    font-family: 'Italiana', serif;
    font-size: 2.2rem;
    color: var(--gold);
    line-height: 1;
  }
  .hero-stat-label {
    font-family: 'Special Elite', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--hero-muted);
    margin-top: 0.4rem;
  }
  @media (max-width: 640px) {
    .hero-stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* ------------------------------------------------------------
     POSTER FRAME (hero right column)
     ------------------------------------------------------------ */
  .hero-image-wrap {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .poster-frame {
    position: relative;
    width: 100%;
    max-width: 580px;
    background: var(--film);
    color: var(--paper);
    border: 1px solid var(--gold-soft);
    box-shadow:
      0 30px 70px rgba(0,0,0,0.55),
      0 6px 18px rgba(0,0,0,0.4),
      inset 0 0 0 4px var(--film),
      inset 0 0 0 5px var(--gold-soft);
    display: flex;
    flex-direction: column;
  }
  :global([data-theme="light"]) .poster-frame {
    background: #1a1410;
    color: var(--paper);
    box-shadow:
      0 24px 60px rgba(40,28,12,0.35),
      0 6px 14px rgba(40,28,12,0.25),
      inset 0 0 0 4px #1a1410,
      inset 0 0 0 5px var(--gold);
  }

  .poster-bar-top, .poster-bar-bottom {
    padding: 0.7rem 1.2rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    font-family: 'Italiana', serif;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: 0.78rem;
    color: var(--gold);
    background: rgba(0,0,0,0.4);
    border-bottom: 1px solid var(--gold-soft);
  }
  .poster-bar-bottom {
    border-bottom: none;
    border-top: 1px solid var(--gold-soft);
    font-size: 0.65rem;
    color: var(--paper);
  }
  .poster-credit-name {
    font-size: 0.95rem;
    color: var(--gold);
    letter-spacing: 0.28em;
  }
  .poster-credit-blob {
    color: var(--paper-soft);
    font-family: 'Special Elite', monospace;
    font-size: 0.6rem;
    letter-spacing: 0.12em;
  }

  .poster-image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16/9;
    object-fit: cover;
    filter: contrast(1.05) saturate(0.95);
  }

  .poster-laurels {
    position: relative;
    padding: 1.5rem 1.2rem 1.3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    color: var(--gold);
    background: rgba(0,0,0,0.3);
    border-top: 1px solid var(--gold-soft);
  }
  .laurel { color: var(--gold); flex-shrink: 0; }
  .poster-laurels-text {
    text-align: center;
    font-family: 'Italiana', serif;
    text-transform: uppercase;
    color: var(--paper);
    letter-spacing: 0.18em;
    line-height: 1.3;
  }
  .laurel-line { display: block; font-size: 0.72rem; }
  .laurel-line-big {
    font-size: 1.2rem;
    color: var(--gold);
    letter-spacing: 0.28em;
    margin: 0.15rem 0;
  }

  /* Floating ticket */
  .ticket {
    position: absolute;
    bottom: -34px;
    left: -34px;
    width: 220px;
    background: var(--paper);
    color: var(--ink);
    display: flex;
    transform: rotate(-7deg);
    box-shadow: 0 10px 30px rgba(0,0,0,0.45);
    font-family: 'Special Elite', monospace;
    border: 1px solid var(--gold-soft);
    z-index: 3;
  }
  :global([data-theme="light"]) .ticket {
    background: #fdf7e7;
    color: var(--ink);
    box-shadow: 0 14px 26px rgba(40,28,12,0.25);
  }
  .ticket-edge {
    width: 6px;
    background-image: radial-gradient(circle, var(--hero-bg) 2px, transparent 2.5px);
    background-size: 6px 8px;
    background-repeat: repeat-y;
    background-position: center;
  }
  .ticket-body {
    flex: 1;
    padding: 0.7rem 0.9rem;
    text-align: center;
  }
  .ticket-line { display: block; }
  .ticket-line-tiny {
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    opacity: 0.7;
  }
  .ticket-line-big {
    font-family: 'Italiana', serif;
    font-size: 1.4rem;
    letter-spacing: 0.18em;
    margin: 0.2rem 0;
    color: var(--red);
  }
  .ticket-stub {
    width: 56px;
    border-left: 1px dashed var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Italiana', serif;
    font-size: 1.8rem;
    color: var(--red);
  }

  /* Round official-selection stamp */
  .poster-stamp {
    position: absolute;
    top: -32px;
    right: -32px;
    width: 130px;
    height: 130px;
    border-radius: 50%;
    border: 2px solid var(--red);
    background: rgba(255, 250, 230, 0.92);
    color: var(--red);
    display: flex;
    align-items: center;
    justify-content: center;
    transform: rotate(15deg);
    z-index: 3;
    box-shadow: 0 8px 22px rgba(0,0,0,0.35);
    opacity: 0.92;
  }
  :global([data-theme="light"]) .poster-stamp {
    background: rgba(255, 244, 220, 0.98);
    box-shadow: 0 10px 18px rgba(80,40,20,0.18);
  }
  .stamp-ring {
    position: absolute;
    inset: 4px;
    border-radius: 50%;
    border: 1px solid var(--red);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .stamp-ring span {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    font-family: 'Italiana', serif;
    font-size: 0.55rem;
    letter-spacing: 0.32em;
    color: var(--red);
    text-transform: uppercase;
    padding-top: 4px;
    /* Bend text around top of stamp visually via wide letter-spacing */
  }
  .stamp-center {
    text-align: center;
    z-index: 1;
  }
  .stamp-num {
    display: block;
    font-family: 'Italiana', serif;
    font-size: 2.4rem;
    line-height: 1;
    color: var(--red);
  }
  .stamp-sub {
    display: block;
    font-family: 'Special Elite', monospace;
    font-size: 0.55rem;
    letter-spacing: 0.22em;
    color: var(--red);
  }

  @media (max-width: 700px) {
    .ticket { left: -10px; bottom: -22px; width: 170px; transform: rotate(-5deg); }
    .poster-stamp { right: -12px; top: -18px; width: 96px; height: 96px; }
    .stamp-num { font-size: 1.8rem; }
  }

  /* ------------------------------------------------------------
     MARQUEE
     ------------------------------------------------------------ */
  .marquee {
    background: var(--red);
    color: var(--paper);
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    overflow: hidden;
    padding: 0.55rem 0;
    font-family: 'Italiana', serif;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    font-size: 0.78rem;
  }
  :global([data-theme="light"]) .marquee {
    background: var(--ink);
    color: var(--paper);
  }
  .marquee-track {
    display: inline-flex;
    gap: 3rem;
    white-space: nowrap;
    animation: marqueeScroll 60s linear infinite;
  }
  .marquee-item::after {
    content: '·';
    margin-left: 3rem;
    color: var(--gold);
  }
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ------------------------------------------------------------
     PULL QUOTE
     ------------------------------------------------------------ */
  .pullquote-section {
    background: var(--hero-bg);
    color: var(--hero-fg);
    padding: 7rem 2rem;
    border-bottom: 1px solid var(--border-rule);
    position: relative;
  }
  .pullquote-section::before, .pullquote-section::after {
    content: '';
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 1px;
    background: var(--gold);
  }
  .pullquote-section::before { top: 3rem; }
  .pullquote-section::after { bottom: 3rem; }

  .pullquote-inner {
    max-width: 980px;
    margin: 0 auto;
    text-align: center;
  }
  .pullquote-tag {
    font-family: 'Special Elite', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 2rem;
  }
  .pullquote {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    font-size: clamp(1.6rem, 3.6vw, 2.9rem);
    line-height: 1.28;
    margin: 0 0 2rem;
    color: var(--hero-fg);
    position: relative;
    font-weight: 400;
  }
  .pullquote-mark {
    color: var(--red);
    font-family: 'Italiana', serif;
    font-size: 1.4em;
    line-height: 0;
    vertical-align: -0.18em;
    padding: 0 0.15em;
    font-style: normal;
  }
  .pullquote-attrib-name {
    display: block;
    font-family: 'Italiana', serif;
    font-size: 1.05rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .pullquote-attrib-role {
    display: block;
    font-family: 'Special Elite', monospace;
    font-size: 0.74rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--hero-muted);
    margin-top: 0.35rem;
  }

  /* ------------------------------------------------------------
     SECTION HEADERS (shared)
     ------------------------------------------------------------ */
  .section-header {
    max-width: 820px;
    margin: 0 auto 3.5rem;
    text-align: center;
  }
  .section-tag {
    font-family: 'Special Elite', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.2rem;
  }
  .section-title {
    font-family: 'Italiana', serif;
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    line-height: 1;
    margin: 0 0 1.2rem;
    color: var(--hero-fg);
    letter-spacing: -0.01em;
  }
  .section-title em {
    font-family: 'DM Serif Display', serif;
    font-style: italic;
    color: var(--red);
    font-weight: 400;
  }
  .section-deck {
    font-family: 'EB Garamond', serif;
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--hero-muted);
    max-width: 38em;
    margin: 0 auto;
    font-style: italic;
  }

  /* ------------------------------------------------------------
     LA SELECTION (film stills grid)
     ------------------------------------------------------------ */
  .stills-section {
    background: var(--hero-bg);
    color: var(--hero-fg);
    padding: 6rem 2rem 7rem;
    border-bottom: 1px solid var(--border-rule);
    position: relative;
  }
  :global([data-theme="dark"]) .stills-section {
    background: #08070a;
    background-image:
      linear-gradient(180deg, transparent 0%, rgba(200,160,74,0.04) 50%, transparent 100%);
  }
  :global([data-theme="light"]) .stills-section {
    background: #efe4c8;
  }

  .stills-inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  .stills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3.5rem 4rem;
    align-items: start;
  }
  @media (max-width: 800px) {
    .stills-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .stills-section { padding: 4rem 1.25rem 5rem; }
  }

  .still-card {
    transform: rotate(var(--rot));
    transition: transform 0.4s ease;
  }
  .still-card:hover {
    transform: rotate(0deg) translateY(-4px);
  }
  .still-photo {
    position: relative;
    background: var(--paper);
    padding: 14px 14px 56px;
    box-shadow:
      0 22px 50px rgba(0,0,0,0.45),
      0 4px 12px rgba(0,0,0,0.3);
    border: 1px solid var(--gold-soft);
  }
  :global([data-theme="light"]) .still-photo {
    background: #fdf7e7;
    box-shadow:
      0 18px 38px rgba(40,28,12,0.2),
      0 4px 10px rgba(40,28,12,0.15);
  }
  .still-photo img {
    display: block;
    width: 100%;
    aspect-ratio: var(--aspect);
    object-fit: cover;
    filter: contrast(1.05) saturate(0.95) sepia(0.04);
  }
  .still-pageno {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    text-align: center;
    font-family: 'Special Elite', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--ink);
    padding-top: 12px;
  }
  .still-tape {
    position: absolute;
    width: 70px;
    height: 22px;
    background: rgba(200, 160, 74, 0.35);
    border: 1px solid rgba(200, 160, 74, 0.5);
  }
  .still-tape-tl { top: -8px; left: -10px; transform: rotate(-12deg); }
  .still-tape-br { bottom: 36px; right: -10px; transform: rotate(8deg); }

  .still-meta {
    padding: 1.2rem 0.3rem 0;
  }
  .still-slug {
    font-family: 'Special Elite', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.5rem;
  }
  .still-title {
    font-family: 'Italiana', serif;
    font-size: 1.7rem;
    color: var(--hero-fg);
    margin: 0 0 0.6rem;
    letter-spacing: 0.02em;
  }
  .still-line {
    font-family: 'EB Garamond', serif;
    font-size: 1rem;
    line-height: 1.55;
    color: var(--hero-muted);
    font-style: italic;
    margin: 0;
  }

  /* ------------------------------------------------------------
     MOT DU REALISATEUR (director note)
     ------------------------------------------------------------ */
  .director-section {
    background: var(--hero-bg);
    color: var(--hero-fg);
    padding: 7rem 2rem;
    border-bottom: 1px solid var(--border-rule);
  }
  :global([data-theme="dark"]) .director-section {
    background:
      linear-gradient(180deg, rgba(200,160,74,0.03) 0%, transparent 100%),
      var(--hero-bg);
  }
  :global([data-theme="light"]) .director-section {
    background: var(--hero-bg);
  }

  .director-grid {
    max-width: 1300px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 0.85fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 900px) {
    .director-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .director-section { padding: 4rem 1.25rem; }
  }

  .director-image {
    margin: 0;
    background: var(--paper);
