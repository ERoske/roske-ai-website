---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import LatestContent from '../components/LatestContent.astro';
import SpeakerCTA from '../components/SpeakerCTA.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// The rogues' gallery. Five comic-book stills of Edward trying to become each
// Superman villain this week, with Supergirl foiling every attempt. Captions match each image.
const rogues = [
  {
    src: '/images/supergirl/hall-of-defeat.png',
    kicker: 'THE WHOLE WEEK',
    title: 'Five tries, five losses',
    caption: "Five days, five supervillains, and I lost every round. The experiment was simple: does crime pay? It doesn't. (I'm telling people I let her win, which is going about as well as you'd expect.)",
    feature: true,
  },
  {
    src: '/images/supergirl/lex-luthor.png',
    kicker: 'EXHIBIT A',
    title: 'Lex Luthor',
    caption: "Tried the Lex Luthor play: outspend the problem. I sank the GDP of a small nation into a kryptonite death-ray. She folded it into a pretzel without looking. I'm filing the receipt under research and development.",
    feature: false,
  },
  {
    src: '/images/supergirl/brainiac.png',
    kicker: 'EXHIBIT B',
    title: 'Brainiac',
    caption: "Went the Brainiac route next: a twelfth-level intellect and collector of worlds, undone by an unhandled exception about ninety seconds in. The console flashes ERROR, which is the most honest thing it's said all day.",
    feature: false,
  },
  {
    src: '/images/supergirl/bizarro.png',
    kicker: 'EXHIBIT C',
    title: 'Bizarro',
    caption: "Day three, I tried becoming Bizarro: an off-brand clone of myself, assembled from spare parts and unearned confidence. He'll tell you he won. (He didn't, though Bizarro logic is genuinely hard to argue with.)",
    feature: false,
  },
  {
    src: '/images/supergirl/general-zod.png',
    kicker: 'EXHIBIT D',
    title: 'General Zod',
    caption: "Closed the week as General Zod and demanded that everyone kneel. Got flicked across three city blocks by a single finger. The cape looked tremendous on the way down, which counts for something.",
    feature: false,
  },
];

// Comic SFX marquee, dry one-liners mixed with onomatopoeia.
const sfx = [
  "POW",
  "ERROR: VICTORY NOT FOUND",
  "KA-BLAM",
  "ONE (1) FINGER, ZERO (0) SURVIVORS",
  "KRYPTONITE, NOW PRETZEL-SHAPED",
  "BONK",
  "CRIME DOES NOT PAY (I RAN THE NUMBERS)",
  "NET VILLAIN PROFIT: $0.00",
];

// The real-world arsenal. Same six projects, framed as comic-book powers.
const arsenal = [
  {
    code: 'ISSUE No. 01',
    cat: 'ACTUALLY WORKS',
    title: 'AgentCube',
    body: "The engine that lets AI agents talk to Oracle Essbase, EPM Planning, and Financial Close. Built by Caprus. Essbase and Planning shipped. Consolidations is in beta. (Enterprise finance that finally answers when you call it. The cape was extra.)",
    badge: 'ESSBASE · PLANNING · CLOSE',
    status: 'SHIPPED',
    href: 'https://caprus.ai/agentcube/',
    external: true,
    cta: 'Read the docs',
  },
  {
    code: 'ISSUE No. 02',
    cat: 'TEAM-UP EVENT',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has ever hosted. October 9 and 10 in San Juan. Speakers and sponsors are being recruited right now. If you build, fund, or run AI, there's a slot on the stage with your name on it.",
    badge: '9-10 OCT 2026 · SAN JUAN',
    status: 'CALL FOR SPEAKERS OPEN',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    code: 'ISSUE No. 03',
    cat: 'THE REAL HEROES',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, the AI software and services firm giving finance teams faster, smarter operations. The crew behind the MCP servers, and the people who do most of the actual heroics while I take the cover photo.",
    badge: 'AI · FINANCE',
    status: 'RUNNING',
    href: 'https://caprus.ai',
    external: true,
    cta: 'See the team',
  },
  {
    code: 'ISSUE No. 04',
    cat: 'AFTER HOURS',
    title: "AI Dungeon Master's Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns. Initiative, lore, and improv help for the person behind the screen. If there's going to be an AI at the table, it should at least earn its seat. (The party still will not be told.)",
    badge: 'D&D · 5E · EBERRON',
    status: 'IN PROTOTYPE',
    href: null,
    external: false,
    cta: 'Quiet build',
  },
  {
    code: 'ISSUE No. 05',
    cat: 'SECRET SOCIETY',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community. More than 850 people across our events. We meet every other month to figure out, in public, what AI means for the island, which is also what it means for everyone watching the island.",
    badge: '850+ · BI-MONTHLY',
    status: 'RUNNING',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next one',
  },
  {
    code: 'ISSUE No. 06',
    cat: 'THE GADGET',
    title: 'Only Recipes',
    body: "My first Chrome extension. When it spots you on a recipe page, it strips out the author's childhood memoir, the fourteen ads, and the infinite scroll, and leaves you the recipe. Fast and genuinely useful, which for a free browser gadget is practically a superpower.",
    badge: 'CHROME EXTENSION · FREE',
    status: 'SHIPPED',
    href: '/only-recipes/',
    external: false,
    cta: 'See what it does',
  },
];

// Late add to the catalog, still in beta.
const lateAdds = [
  {
    tag: 'IN BETA · NAME PENDING',
    title: 'The Home Library Project',
    line: 'BOOKS · GAMES · MEDIA · EVERY SHELF',
    body: "A new app and site that digitizes a home library: books, board games, music, media, anything sitting on a shelf at the house. All of it categorized. There'll be a free tier. I'll share the rest after beta. Want an early look? Send an email and you're on the list.",
    cta: 'Email for early access',
    href: 'mailto:Edward@Roske.AI',
    external: false,
  },
];

// Stat block, comic-style.
const tally = [
  { value: '50+', label: 'COUNTRIES PRESENTED IN' },
  { value: '80+', label: 'COUNTRIES VISITED' },
  { value: '15', label: 'BOOKS IN PRINT' },
  { value: '2', label: 'U.S. PATENTS' },
  { value: '25+', label: 'YEARS RUNNING COMPANIES' },
];

// Comic-book indicia, in place of a colophon.
const indicia = [
  { role: 'EDITION', name: 'ISSUE No. 27 · SUPERGIRL OPENING WEEKEND · JUNE 2026' },
  { role: 'TITLE', name: 'SUPERGIRL VS. EDWARD ROSKE' },
  { role: 'STARRING', name: 'SUPERGIRL (WINNING) · EDWARD ROSKE (NOT)' },
  { role: 'VILLAINS ATTEMPTED', name: 'LOBO · LEX LUTHOR · BRAINIAC · BIZARRO · GENERAL ZOD' },
  { role: 'HEADGEAR', name: 'ONE (1) ROYAL-BLUE FELT FEDORA · SURVIVES EVERY COSTUME' },
  { role: 'NET PROFIT', name: 'ZERO DOLLARS · ZERO CENTS · CRIME DOES NOT PAY' },
  { role: 'PRINTED IN', name: 'SAN JUAN, PUERTO RICO' },
  { role: 'LETTERS PAGE', name: 'EDWARD@ROSKE.AI · NO VILLAIN FAN MAIL, PLEASE' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- ============================================
       COMIC MASTHEAD STRIP
       ============================================ -->
  <div class="cb-bar">
    <div class="cb-bar-inner">
      <span class="cb-bar-brand">ROSKE COMICS</span>
      <span class="cb-bar-meta cb-bar-meta-center">SUPERGIRL VS. EDWARD ROSKE · IN THEATERS NOW</span>
      <span class="cb-bar-meta cb-bar-meta-end">ISSUE No. 27</span>
    </div>
  </div>

  <!-- ============================================
       HERO: split, text left, comic cover right
       ============================================ -->
  <section class="hero-section">
    <div class="hero-grid">

      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-pip"></span>
          <span>IN THEATERS THIS WEEK · A ROSKE.AI CAREER EXPERIMENT</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">Crime doesn't</span>
          <span class="hero-title-line"><em>pay.</em></span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="/question/" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-tally">
          {tally.map(stat => (
            <div class="tally-item">
              <div class="tally-value">{stat.value}</div>
              <div class="tally-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <figure class="cover">
          <div class="cover-top">
            <span class="cover-logo">ROSKE COMICS</span>
            <span class="cover-price">No. 27<br/>60&cent;</span>
          </div>
          <div class="cover-window">
            <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1200" height="675" loading="eager" decoding="async" class="cover-image" />
            <span class="cover-burst" aria-hidden="true">VROOM!</span>
          </div>
          <div class="cover-bottom">
            <span>SUPERGIRL VS. EDWARD</span>
            <span>THE SPACEHOG ISSUE</span>
          </div>
        </figure>
      </div>
    </div>
  </section>

  <!-- ============================================
       SFX TICKER
       ============================================ -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...sfx, ...sfx].map(item => (
        <span class="ticker-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- ============================================
       LATEST CONTENT: permanent module
       ============================================ -->
  <LatestContent
    eyebrow="Section 02 · Hot off the presses"
    heading={"New <em>this week.</em>"}
    deck="The latest writing and video briefs, in one place, so the good stuff isn't buried under a stack of back issues."
  />

  <!-- ============================================
       BOOK EDWARD: permanent module (never remove)
       ============================================ -->
  <SpeakerCTA eyebrow="Section 02.5 · The paying gig" />

  <!-- ============================================
       THE ROGUES' GALLERY: scene gallery
       ============================================ -->
  <section class="rogues-section">
    <div class="rogues-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 03 · THE WEEK IN REVIEW · ALL DEFEATED</span>
        </div>
        <h2 class="section-title">Five villains. <em>Five losses.</em></h2>
        <p class="section-deck">
          I gave each one an honest try. Every attempt ran the same plot: pick a fight with Supergirl, lose it badly, often before the costume was fully on. (The fedora is in every frame, and unlike me, it never loses.)
        </p>
      </header>

      <div class="rogues-grid">
        {rogues.map((r) => (
          <article class={`panel-card ${r.feature ? 'panel-card-feature' : ''}`}>
            <div class="panel-frame">
              <img src={r.src} alt={r.caption} loading="lazy" decoding="async" class="panel-image" />
              <span class="panel-kicker">{r.kicker}</span>
            </div>
            <div class="panel-meta">
              <h3 class="panel-name">{r.title}</h3>
              <p class="panel-caption">{r.caption}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CAPTION-BOX PULL QUOTE
       ============================================ -->
  <section class="statement-section">
    <div class="statement-inner">
      <div class="statement-tag">MEANWHILE, IN THE NARRATION BOX</div>
      <blockquote class="statement-q">
        Every villain I tried to become was sure he was about to get rich. Supergirl turned up to correct the record, repeatedly. <span class="statement-line">(I respect the consistency.)</span>
      </blockquote>
      <div class="statement-attrib">
        <span class="statement-attrib-name">EDWARD ROSKE</span>
        <span class="statement-attrib-role">ASPIRING SUPERVILLAIN · RETIRED FRIDAY</span>
      </div>
    </div>
  </section>

  <!-- ============================================
       THE ARSENAL: project cards
       ============================================ -->
  <section id="current-work" class="arsenal-section">
    <div class="arsenal-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 04 · THE DAY JOB · WHERE THE MONEY ACTUALLY IS</span>
        </div>
        <h2 class="section-title">Six powers. <em>All non-fictional.</em></h2>
        <p class="section-deck">
          Crime didn't pay, so here's the part of the week that does. Real projects, in beta or in production, built on the boring idea that software should be useful instead of scary. (Villainy no longer offered.)
        </p>
      </header>

      <div class="arsenal-grid">
        {arsenal.map(item => (
          <article class="power-card">
            <div class="power-card-head">
              <span class="power-code">{item.code}</span>
              <span class="power-cat">{item.cat}</span>
            </div>
            <h3 class="power-title">{item.title}</h3>
            <p class="power-body">{item.body}</p>
            <div class="power-meta">
              <span class="power-badge">{item.badge}</span>
              <span class={`power-status power-status-${item.status.toLowerCase().replace(/[^a-z]+/g, '-')}`}>{item.status}</span>
            </div>
            <div class="power-foot">
              {item.href ? (
                <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="power-cta">
                  {item.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="power-cta power-cta-disabled">{item.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       LATE ADD
       ============================================ -->
  <section class="late-section">
    <div class="late-inner">
      <header class="section-header late-header">
        <div class="section-tag late-tag">
          <span class="section-tag-dot"></span>
          <span>SECTION 05 · NEXT ISSUE · STILL IN BETA</span>
        </div>
        <h2 class="section-title">One more <em>off the presses.</em></h2>
      </header>

      <div class="late-grid">
        {lateAdds.map(item => (
          <article class="late-card">
            <div class="late-card-tag">{item.tag}</div>
            <h3 class="late-card-title">{item.title}</h3>
            <div class="late-card-line">{item.line}</div>
            <p class="late-card-body">{item.body}</p>
            <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="late-cta">
              {item.cta}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================
       CLOSING CTA
       ============================================ -->
  <section class="closing-section">
    <div class="closing-inner">
      <div class="closing-eyebrow">
        <span class="closing-rule"></span>
        <span>THE BOX OFFICE IS OPEN · 13 MINUTES</span>
        <span class="closing-rule"></span>
      </div>
      <h2 class="closing-title">Retired from crime.<br/><em>Open for questions.</em></h2>
      <p class="closing-deck">
        Book thirteen minutes. Ask about Oracle EPM, AI in finance, MCP servers, the Caribbean AI Summit, D&D, or how a week of attempted supervillainy nets exactly zero dollars. No kryptonite required. Opinions arrive whether you asked for them or not.
      </p>
      <div class="closing-cta-row">
        <a href="/question/" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a note</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================
       INDICIA / BACK PANEL
       ============================================ -->
  <section class="indicia-section">
    <div class="indicia-inner">
      <div class="indicia-tag">COMIC-BOOK INDICIA · BACK COVER · 2026</div>
      <div class="indicia-roll">
        {indicia.map(entry => (
          <div class="indicia-block">
            <span class="indicia-role">{entry.role}</span>
            <span class="indicia-name">{entry.name}</span>
          </div>
        ))}
      </div>
      <div class="indicia-footnote">
        Not affiliated with DC Comics, Warner Bros., or anyone who actually owns Supergirl, Superman, or a single one of these villains. All characters are the property of their respective owners. The fedora, the cigar, and the poor career decisions are Edward's. No teenagers from Krypton were inconvenienced in the making of this website. One aspiring supervillain very much was.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     SUPERGIRL · CRIME DOESN'T PAY (A WEEK OF ATTEMPTED SUPERVILLAINY)
     Palette: hero blue / Supergirl red / S-shield gold /
              cosmic night (dark) / newsprint sky (light)
     Type: Anton (impact display), Barlow (body), Space Mono
           (tech + labels), Bangers (comic SFX bursts)
     ============================================================ */

  :global([data-theme="dark"]) {
    --sg-bg: #0a1230;
    --sg-bg-deep: #060b22;
    --sg-surface: #131d44;
    --sg-surface-2: #1b2a5e;
    --sg-fg: #f3f6ff;
    --sg-muted: #9fb0d8;
    --sg-line: #2a3a72;
    --sg-edge: #f5c518;
    --sg-blue: #3a78ff;
    --sg-blue-deep: #0b3bb0;
    --sg-red: #ff2f3c;
    --sg-red-bright: #ff5a64;
    --sg-gold: #f5c518;
    --sg-cream: #f3f6ff;
    --sg-ink: #060b22;
    --sg-dot: rgba(255,255,255,0.10);
  }
  :global([data-theme="light"]) {
    --sg-bg: #e9f1ff;
    --sg-bg-deep: #d4e4ff;
    --sg-surface: #ffffff;
    --sg-surface-2: #eef4ff;
    --sg-fg: #0e1a3d;
    --sg-muted: #4a5b80;
    --sg-line: #b9ccec;
    --sg-edge: #0e1a3d;
    --sg-blue: #1452c9;
    --sg-blue-deep: #0b3bb0;
    --sg-red: #d61420;
    --sg-red-bright: #ec1c2b;
    --sg-gold: #d99a06;
    --sg-cream: #ffffff;
    --sg-ink: #0e1a3d;
    --sg-dot: rgba(11,40,120,0.12);
  }

  /* ------------------------------------------------------------
     COMIC MASTHEAD STRIP
     ------------------------------------------------------------ */
  .cb-bar {
    width: 100%;
    background: var(--sg-red);
    color: #fff;
    border-bottom: 4px solid var(--sg-gold);
    font-family: 'Space Mono', monospace;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .cb-bar-inner {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0.5rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    font-size: 0.72rem;
  }
  .cb-bar-brand {
    font-family: 'Bangers', 'Anton', cursive;
    letter-spacing: 0.08em;
    font-size: 1.2rem;
    color: var(--sg-gold);
    -webkit-text-stroke: 0.6px #2a0a0a;
  }
  .cb-bar-meta { white-space: nowrap; }
  .cb-bar-meta-center { flex: 1; text-align: center; letter-spacing: 0.16em; opacity: 0.95; }
  .cb-bar-meta-end { text-align: right; font-weight: 700; }
  @media (max-width: 780px) {
    .cb-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.56rem; }
    .cb-bar-meta-end { display: none; }
    .cb-bar-meta-center { font-size: 0.54rem; letter-spacing: 0.1em; }
  }

  /* ------------------------------------------------------------
     HERO
     ------------------------------------------------------------ */
  .hero-section {
    position: relative;
    background: var(--sg-bg);
    color: var(--sg-fg);
    padding: 5.5rem 2rem 6rem;
    overflow: hidden;
  }
  .hero-section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: radial-gradient(var(--sg-dot) 1.5px, transparent 1.6px);
    background-size: 16px 16px;
    opacity: 0.7;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(circle at 16% 18%, rgba(58,120,255,0.22) 0%, transparent 52%),
      radial-gradient(circle at 84% 82%, rgba(255,47,60,0.14) 0%, transparent 55%),
      linear-gradient(165deg, #060b22 0%, #0a1230 55%, #0e1640 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
      radial-gradient(circle at 50% -8%, #ffffff 0%, transparent 42%),
      linear-gradient(180deg, #d4e4ff 0%, #e9f1ff 60%);
  }
  .hero-grid {
    position: relative;
    z-index: 2;
    max-width: 1500px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.05fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 1024px) {
    .hero-grid { grid-template-columns: 1fr; gap: 3.5rem; }
    .hero-section { padding: 3.5rem 1.25rem 4.5rem; }
  }
  .hero-text { max-width: 660px; position: relative; z-index: 2; }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sg-red);
    margin-bottom: 1.5rem;
    padding: 0.35rem 0.85rem;
    border: 2px solid var(--sg-red);
    background: var(--sg-surface);
  }
  :global([data-theme="light"]) .hero-eyebrow { background: #fff; }
  .hero-eyebrow-pip { width: 8px; height: 8px; background: var(--sg-red); border-radius: 50%; flex-shrink: 0; }
  .hero-title { margin: 0 0 1.6rem; line-height: 0.92; }
  .hero-title-line {
    display: block;
    font-family: 'Anton', sans-serif;
    font-weight: 400;
    font-size: clamp(3rem, 7.5vw, 6rem);
    color: var(--sg-fg);
    letter-spacing: 0.005em;
    line-height: 0.94;
    text-transform: uppercase;
  }
  .hero-title-line em {
    font-style: normal;
    color: var(--sg-red);
    -webkit-text-stroke: 1px var(--sg-ink);
  }
  :global([data-theme="dark"]) .hero-title-line em { -webkit-text-stroke: 1px #2a0a0a; }
  .hero-body {
