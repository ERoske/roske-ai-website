---
import BaseLayout from '../layouts/BaseLayout.astro';
import WeeklyAnimation from '../components/WeeklyAnimation.astro';
import LatestContent from '../components/LatestContent.astro';
import SpeakerCTA from '../components/SpeakerCTA.astro';
import WhatsNew from '../components/WhatsNew.astro';
import { currentTheme } from '../themes/theme-config';

const theme = currentTheme;

// Four trials of the crossing. Three failed for want of a good question; the
// fourth is the homecoming, where he finally used his head. Captions match
// each generated film plate exactly (the Cyclops card really does read
// "ODYSSEUS, CONSULTANT"; the Sirens plate shows him taking notes; Circe's
// wall really is a year of tally marks; the homecoming plate shows the bow
// and the dog).
const trials = [
  {
    src: '/images/the-odyssey/cyclops.jpg',
    plate: 'TRIAL I . THE CYCLOPS',
    title: 'The Sales Pitch',
    caption: "Trapped in the cave of a one-eyed giant, I did the natural thing and handed him my card. It says 'Odysseus, Consultant.' The good question was how to leave quietly. Instead I shouted my real name on the way out, which is how you turn one bad afternoon into a ten-year problem with the god of the sea.",
  },
  {
    src: '/images/the-odyssey/sirens.jpg',
    plate: 'TRIAL II . THE SIRENS',
    title: 'The Note-Taker',
    caption: "The Sirens sing the one song that kills you, so the crew plugged their ears with wax and had me lashed to the mast. Sensible. Then I spent the whole pass taking notes, like it was a keynote I'd flown in for. Some of us can't behave at a good session.",
  },
  {
    src: '/images/the-odyssey/circe.jpg',
    plate: 'TRIAL III . CIRCE’S HALL',
    title: 'The Long Weekend',
    caption: "Circe turned my crew into pigs, then set a genuinely excellent table. I meant to stay one night. Those tally marks behind me are days. The right question was when to leave, and I got to it about a year late, which for me counts as early.",
  },
];

// The homecoming: the pivot, where asking (and listening) finally worked.
const homecoming = {
  src: '/images/the-odyssey/homecoming.jpg',
  plate: 'BOOK XXIV . ITHACA',
  title: 'The Homecoming',
  caption: "Then I got home the way I should have run the entire trip: quietly, patiently, and by finally using my head instead of my mouth. I strung the one bow nobody else could bend, and the old dog still knew me. Ten years late. I'd argue the destination held up.",
};

// The rhapsode's ticker: dry epigraphs from the crossing.
const epigraphs = [
  "TEN YEARS FOR A TWO-WEEK SAIL",
  "HE TAUNTED THE CYCLOPS, THEN LEFT A FORWARDING ADDRESS",
  "THE CREW OPENED THE BAG OF WINDS WITHIN SIGHT OF HOME",
  "A PROPHET TOLD HIM EXACTLY WHAT WOULD HAPPEN",
  "HE STILL DID NOT ASK",
  "SING, MUSE, OF THE MAN WHO WOULDN’T READ THE MAP",
  "NOW A NOLAN PICTURE . THIS SATURDAY, A ROSKE ONE",
];

// The cargo worth carrying home: the real work, framed as the manifest. Six
// projects. All real, all shipping or close to it.
const cargo = [
  {
    code: 'No. I',
    cat: 'THE REAL WORK',
    title: 'MCP Servers for Finance',
    body: "The connective tissue between AI agents and enterprise finance systems. The Oracle Essbase and EPM Planning servers ship today. Financial Close and Consolidations is in beta. This is the part of the voyage I'm actually good at: getting a model to answer honestly about your close.",
    badge: 'ORACLE EPM . MCP',
    status: 'SHIPPING',
    href: 'https://caprus.ai/agentcube/',
    external: true,
    cta: 'See how it works',
  },
  {
    code: 'No. II',
    cat: 'THE GATHERING',
    title: 'Caribbean AI Summit',
    body: "Co-chairing the largest AI conference Puerto Rico has hosted, October 9 and 10 in San Juan. The lineup is public: Kay Firth-Butterfield, MIT's Fabio Duarte, and EU AI advisor Idoia Salazar, with more every week. (Co-chairing is ten percent stagecraft and ninety percent email, which Homer left out.)",
    badge: '9-10 OCT 2026 . SAN JUAN',
    status: 'CALL FOR SPEAKERS OPEN',
    href: 'https://www.caribbeansummit.ai/en/speakers/submit',
    external: true,
    cta: 'Submit a speaker',
  },
  {
    code: 'No. III',
    cat: 'THE CREW',
    title: 'Caprus',
    body: "Investor and contributor at Caprus, the AI software and services firm giving finance teams faster, smarter operations. The crew who do the actual rowing while I take the cover photo and imply the whole epic was my idea.",
    badge: 'AI . FINANCE',
    status: 'RUNNING',
    href: 'https://caprus.ai',
    external: true,
    cta: 'Meet the crew',
  },
  {
    code: 'No. IV',
    cat: 'THE OTHER ODYSSEY',
    title: 'Everest Base Camp',
    body: "This spring I walked to the foot of the tallest mountain on Earth, the closest I've come to an actual odyssey. Unlike Odysseus, I brought a map and asked the Sherpas everything. The trail log is on the blog, altitude headaches and all.",
    badge: 'NEPAL . 2026',
    status: 'THE APPROACH, DONE',
    href: '/blog/everest-base-camp-summit/',
    external: false,
    cta: 'Read the trail log',
  },
  {
    code: 'No. V',
    cat: 'AFTER HOURS',
    title: "AI Dungeon Master’s Screen",
    body: "An AI-driven DM's screen for running better D&D 5e campaigns: initiative, lore, and improv help for the person behind the screen. If there's going to be an oracle at the table, it should earn its seat. (I still won't tell the party.)",
    badge: 'D&D . 5E . EBERRON',
    status: 'IN PROTOTYPE',
    href: null,
    external: false,
    cta: 'Quiet build',
  },
  {
    code: 'No. VI',
    cat: 'THE MOVEMENT',
    title: 'Puerto Rico AI Community',
    body: "President of the Puerto Rico AI Community, more than 850 people across our events. We meet every other month to work out, in public, what AI means for the island. What happens here is usually a preview of what happens everywhere else.",
    badge: '850+ . BI-MONTHLY',
    status: 'RUNNING',
    href: 'https://praicommunity.org/',
    external: true,
    cta: 'Join the next one',
  },
];

// The ledger (stats), framed as the ship's manifest.
const ledger = [
  { value: '50+', label: 'COUNTRIES SPOKEN IN' },
  { value: '80+', label: 'COUNTRIES REACHED' },
  { value: '15', label: 'BOOKS WRITTEN' },
  { value: '2', label: 'U.S. PATENTS' },
  { value: '25+', label: 'YEARS RUNNING COMPANIES' },
];

// Back-plate colophon, in the manner of a fine-press edition.
const colophon = [
  { role: 'EDITION', name: 'THE ROSKE ODYSSEY . JULY 11, 2026' },
  { role: 'AFTER', name: 'HOMER (c. 800 BC) & CHRISTOPHER NOLAN (JULY 17, 2026)' },
  { role: 'STARRING', name: 'EDWARD ROSKE AS ODYSSEUS (TYPECAST)' },
  { role: 'TRIALS FACED', name: 'FOUR . PASSED CLEANLY: ZERO . EVENTUALLY: ALL' },
  { role: 'VOYAGE LENGTH', name: 'TEN YEARS . BILLABLE HOURS: NONE' },
  { role: 'NAVIGATION', name: 'BY STARS, BY OMENS, BY NOT ASKING' },
  { role: 'HEADGEAR', name: 'ONE (1) BLUE FELT FEDORA, SALT-STAINED' },
  { role: 'CORRESPONDENCE', name: 'EDWARD@ROSKE.AI . CARRIER PIGEON DISCOURAGED' },
];
---

<BaseLayout>
  <WeeklyAnimation />

  <!-- MASTHEAD STRIP -->
  <div class="od-bar">
    <div class="od-bar-inner">
      <span class="od-bar-brand">ROSKE.AI</span>
      <span class="od-bar-meta od-bar-center">THE ROSKE ODYSSEY . AN EPIC IN SIX BOOKS</span>
      <span class="od-bar-meta od-bar-end">SUNG SINCE c. 800 BC</span>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero-section">
    <div class="fret hero-fret" aria-hidden="true"></div>
    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">
          <span class="hero-eyebrow-pip"></span>
          <span>BOOK I . THE MAN OF TWISTS AND TURNS</span>
        </div>

        <h1 class="hero-title">
          <span class="hero-title-line">Ten years.</span>
          <span class="hero-title-line hero-title-em"><em>For a two-week sail.</em></span>
        </h1>

        <p class="hero-body">{theme.hero.description}</p>

        <div class="hero-cta-row">
          <a href="/question/" target="_blank" rel="noopener" class="btn-primary">
            Book 13 minutes
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
          <a href="#current-work" class="btn-secondary">
            <span>{theme.hero.ctaText}</span>
          </a>
        </div>

        <div class="hero-ledger">
          {ledger.map(stat => (
            <div class="ledger-item">
              <div class="ledger-value">{stat.value}</div>
              <div class="ledger-label">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-image-wrap">
        <figure class="plate hero-plate">
          <div class="plate-top">
            <span class="plate-logo">THE ROSKE ODYSSEY</span>
            <span class="plate-num">PLATE I</span>
          </div>
          <div class="plate-window">
            <img src={`/images/${theme.hero.heroImage}`} alt={theme.hero.imageAlt} width="1600" height="900" loading="eager" decoding="async" class="plate-image" />
          </div>
          <div class="plate-caption">Odysseus at the helm, steering with total confidence in the wrong direction.</div>
        </figure>
      </div>
    </div>
  </section>

  <!-- TICKER / RHAPSODE'S SCROLL -->
  <div class="ticker" aria-hidden="true">
    <div class="ticker-track">
      {[...epigraphs, ...epigraphs].map(item => (
        <span class="ticker-item">{item}</span>
      ))}
    </div>
  </div>

  <!-- LATEST CONTENT (permanent) -->
  <LatestContent
    eyebrow="Book II . Dispatches from the crossing"
    heading={"New <em>this week.</em>"}
    deck="The latest writing and video briefs, sent back from the voyage. Fresh reports, and no ten-year delay this time."
  />

  <!-- BOOK EDWARD (permanent) -->
  <SpeakerCTA eyebrow="Book II·V . The paying voyage" />

  <!-- WHAT'S NEW (permanent) -->
  <WhatsNew
    eyebrow="Book III . The ship’s log"
    heading={"In the <em>news.</em>"}
    deck="Where Edward has been sighted lately: interviews, press, awards, and the odd post worth keeping. (The log gets kept whether or not anyone reads it.)"
  />

  <!-- THE TRIALS GALLERY -->
  <section class="trials-section">
    <div class="fret" aria-hidden="true"></div>
    <div class="trials-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>BOOK IV . FOUR TRIALS . THREE FAILED FOR WANT OF A QUESTION</span>
        </div>
        <h2 class="section-title">Every trial had a good question. <em>I asked it last.</em></h2>
        <p class="section-deck">
          The Odyssey is usually sold as an adventure. Read it as a data scientist and it's a decade-long case study in a clever man ignoring the obvious question in front of him. I played all four scenes this week. Typecasting, honestly.
        </p>
      </header>

      <div class="trials-grid">
        {trials.map((t) => (
          <article class="plate-card">
            <div class="plate-card-frame">
              <img src={t.src} alt={t.caption} loading="lazy" decoding="async" class="plate-card-image" />
              <span class="plate-card-tag">{t.plate}</span>
            </div>
            <div class="plate-card-meta">
              <h3 class="plate-card-name">{t.title}</h3>
              <p class="plate-card-caption">{t.caption}</p>
            </div>
          </article>
        ))}

        <article class="plate-card plate-card-feature">
          <div class="plate-card-frame">
            <img src={homecoming.src} alt={homecoming.caption} loading="lazy" decoding="async" class="plate-card-image" />
            <span class="plate-card-tag plate-card-tag-gold">{homecoming.plate}</span>
          </div>
          <div class="plate-card-meta">
            <h3 class="plate-card-name plate-card-name-feature">{homecoming.title}</h3>
            <p class="plate-card-caption">{homecoming.caption}</p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- THE INVOCATION / PULL QUOTE -->
  <section class="invocation-section">
    <div class="invocation-inner">
      <div class="invocation-tag">BOOK V . FROM THE INVOCATION</div>
      <blockquote class="invocation-q">
        Sing to me of the man of twists and turns, who wandered ten full years because he trusted his own cleverness over one simple question. I've read it as a warning ever since. The tools were always there. A prophet told him precisely what would happen. He just didn't ask, and then didn't listen.
        <span class="invocation-line">(I run AI companies for a living. You can see why the story keeps me up.)</span>
      </blockquote>
      <div class="invocation-attrib">
        <span class="invocation-name">EDWARD ROSKE</span>
        <span class="invocation-role">ITHACA, EVENTUALLY</span>
      </div>
    </div>
  </section>

  <!-- THE CARGO / PROJECTS -->
  <section id="current-work" class="cargo-section">
    <div class="cargo-inner">
      <header class="section-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>BOOK VI . THE CARGO WORTH CARRYING HOME</span>
        </div>
        <h2 class="section-title">Six things I actually <em>brought home.</em></h2>
        <p class="section-deck">
          Odysseus came back with a good story and not much else. My haul is more practical: six things that are real, shipping or close to it, and considerably more useful than a bag of winds.
        </p>
      </header>

      <div class="cargo-grid">
        {cargo.map(item => (
          <article class="cargo-card">
            <div class="cargo-card-head">
              <span class="cargo-code">{item.code}</span>
              <span class="cargo-cat">{item.cat}</span>
            </div>
            <h3 class="cargo-title">{item.title}</h3>
            <p class="cargo-body">{item.body}</p>
            <div class="cargo-meta">
              <span class="cargo-badge">{item.badge}</span>
              <span class={`cargo-status cargo-status-${item.status.toLowerCase().replace(/[^a-z]+/g, '-').replace(/^-|-$/g, '')}`}>{item.status}</span>
            </div>
            <div class="cargo-foot">
              {item.href ? (
                <a href={item.href} target={item.external ? '_blank' : undefined} rel={item.external ? 'noopener' : undefined} class="cargo-cta">
                  {item.cta}
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
                </a>
              ) : (
                <span class="cargo-cta cargo-cta-disabled">{item.cta}</span>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- BLOG TEASER -->
  <section class="dispatch-section">
    <div class="dispatch-inner">
      <header class="section-header dispatch-header">
        <div class="section-tag">
          <span class="section-tag-dot"></span>
          <span>BOOK VII . THIS WEEK’S DISPATCH</span>
        </div>
        <h2 class="section-title">A question for <em>the crossing.</em></h2>
      </header>

      <div class="dispatch-grid">
        <article class="dispatch-card">
          <div class="dispatch-card-tag">NEW ON THE BLOG . JULY 11, 2026</div>
          <h3 class="dispatch-card-title">Would Odysseus Have Made It Home Sooner With an AI?</h3>
          <div class="dispatch-card-line">HOMER . TIRESIAS . THE ORACLE ON YOUR DESK</div>
          <p class="dispatch-card-body">
            Short answer: probably not, and the reason is the whole point. Odysseus already had the best oracle in the ancient world. He had prophecy on tap and still sailed in circles. An AI hands you Tiresias-grade answers on demand, but it can't make you ask, and it certainly can't stop you taunting the Cyclops.
          </p>
          <a href="/blog/would-odysseus-have-made-it-home-sooner-with-an-ai/" class="dispatch-cta">
            Read the post
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </article>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="harbor-section">
    <div class="fret" aria-hidden="true"></div>
    <div class="harbor-inner">
      <div class="harbor-eyebrow">
        <span class="harbor-rule"></span>
        <span>BOOK VIII . THE HARBOR IS OPEN . 13 MINUTES</span>
        <span class="harbor-rule"></span>
      </div>
      <h2 class="harbor-title">Come home.<br/><em>Ask a good question.</em></h2>
      <p class="harbor-deck">
        Book thirteen minutes. Ask about AI in finance, MCP servers, the Caribbean AI Summit, what Nolan gets right about the Odyssey, or how a grown man ends up taking conference notes at the Sirens. No wax required. Opinions arrive whether or not you asked for them.
      </p>
      <div class="harbor-cta-row">
        <a href="/question/" target="_blank" rel="noopener" class="btn-primary btn-primary-big">
          Book 13 minutes
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <a href="/contact" class="btn-secondary btn-secondary-big">
          <span>Send a note</span>
        </a>
      </div>
    </div>
  </section>

  <!-- COLOPHON -->
  <section class="colophon-section">
    <div class="colophon-inner">
      <div class="colophon-tag">COLOPHON . THE BACK PLATE . 2026</div>
      <div class="colophon-roll">
        {colophon.map(entry => (
          <div class="colophon-block">
            <span class="colophon-role">{entry.role}</span>
            <span class="colophon-name">{entry.name}</span>
          </div>
        ))}
      </div>
      <div class="colophon-footnote">
        Not affiliated with Universal Pictures, Christopher Nolan, the estate of Homer, or the Greek Ministry of Culture. No Cyclopes were pitched to in the making of this website (one was, actually). The Sirens' notes have been lost. Odysseus is a literary character, the bad decisions are dramatized, and the fedora is real and stays on. Any resemblance to a data scientist who talks too long about AI is entirely accurate.
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     THE ROSKE ODYSSEY (a fine-press illustrated edition,
     crossed with Nolan IMAX film grain)
     Palette: sea teal / oxidized bronze / amphora terracotta on
              wine-dark sea night (dark) or aged papyrus (light)
     Type: Cormorant Garamond (display), Spectral (body),
           JetBrains Mono (ship's-log labels)
     ============================================================ */

  :global([data-theme="dark"]) {
    --od-bg: #0b1a24;
    --od-bg-deep: #06121a;
    --od-surface: #122b38;
    --od-surface-2: #163545;
    --od-fg: #f1e7d2;
    --od-muted: #a6bcc1;
    --od-line: #284c5a;
    --od-teal: #3f8ba0;
    --od-bronze: #cba653;
    --od-terra: #d5563a;
    --od-terra-deep: #b23e24;
    --od-ink: #06121a;
    --od-wine: #7d2b3a;
    --od-fret: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='34'%20height='28'%20viewBox='0%200%2034%2028'%3E%3Cpath%20d='M4%2024V6H24V20H12V12H18'%20fill='none'%20stroke='%23cba653'%20stroke-width='2.4'/%3E%3C/svg%3E");
    --od-grain: 0.06;
  }
  :global([data-theme="light"]) {
    --od-bg: #efe4cd;
    --od-bg-deep: #e5d7ba;
    --od-surface: #f7eeda;
    --od-surface-2: #f0e4c8;
    --od-fg: #17303b;
    --od-muted: #5a4d34;
    --od-line: #d7c7a2;
    --od-teal: #1f5568;
    --od-bronze: #7a5818;
    --od-terra: #b23e24;
    --od-terra-deep: #97331c;
    --od-ink: #17303b;
    --od-wine: #7d2b3a;
    --od-fret: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='34'%20height='28'%20viewBox='0%200%2034%2028'%3E%3Cpath%20d='M4%2024V6H24V20H12V12H18'%20fill='none'%20stroke='%237a5818'%20stroke-width='2.4'/%3E%3C/svg%3E");
    --od-grain: 0.05;
  }

  /* Shared film grain (the IMAX texture) */
  .hero-section::after,
  .invocation-section::after,
  .harbor-section::after {
    content: '';
    position: absolute; inset: 0; pointer-events: none; z-index: 1;
    background-image: url("data:image/svg+xml,%3Csvg%20xmlns='http://www.w3.org/2000/svg'%20width='140'%20height='140'%3E%3Cfilter%20id='n'%3E%3CfeTurbulence%20type='fractalNoise'%20baseFrequency='0.82'%20numOctaves='2'%20stitchTiles='stitch'/%3E%3C/filter%3E%3Crect%20width='140'%20height='140'%20filter='url(%23n)'%20opacity='0.55'/%3E%3C/svg%3E");
    opacity: var(--od-grain); mix-blend-mode: soft-light;
  }

  /* Greek-key meander frieze divider */
  .fret {
    height: 28px; width: 100%;
    background-image: var(--od-fret);
    background-repeat: repeat-x; background-position: center;
    opacity: 0.85;
  }
  .hero-fret { position: absolute; bottom: 0; left: 0; z-index: 3; opacity: 0.55; }

  /* ---------- MASTHEAD ---------- */
  .od-bar {
    width: 100%;
    background: var(--od-ink);
    color: var(--od-fg);
    border-bottom: 2px solid var(--od-bronze);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  :global([data-theme="light"]) .od-bar { background: #1a2c33; color: #f1e7d2; }
  .od-bar-inner {
    max-width: 1500px; margin: 0 auto; padding: 0.5rem 2rem;
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; font-size: 0.66rem;
  }
  .od-bar-brand {
    font-family: 'Cormorant Garamond', serif; font-weight: 700;
    letter-spacing: 0.04em; font-size: 1.3rem; color: var(--od-bronze);
  }
  .od-bar-meta { white-space: nowrap; }
  .od-bar-center { flex: 1; text-align: center; letter-spacing: 0.24em; opacity: 0.92; }
  .od-bar-end { text-align: right; opacity: 0.75; }
  @media (max-width: 820px) {
    .od-bar-inner { padding: 0.5rem 1rem; gap: 0.6rem; font-size: 0.5rem; }
    .od-bar-end { display: none; }
    .od-bar-center { letter-spacing: 0.14em; }
  }

  /* ---------- HERO ---------- */
  .hero-section {
    position: relative; background: var(--od-bg); color: var(--od-fg);
    padding: 5.5rem 2rem 6rem; overflow: hidden;
  }
  :global([data-theme="dark"]) .hero-section {
    background:
      radial-gradient(circle at 82% 22%, rgba(213,86,58,0.16) 0%, transparent 46%),
      radial-gradient(circle at 12% 88%, rgba(47,125,146,0.20) 0%, transparent 52%),
      linear-gradient(168deg, #06121a 0%, #0b1a24 52%, #0f2733 100%);
  }
  :global([data-theme="light"]) .hero-section {
    background:
