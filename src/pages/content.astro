---
import BaseLayout from '../layouts/BaseLayout.astro';
import TabNav from '../components/TabNav.astro';
import { getCollection } from 'astro:content';
import { readFileSync, existsSync } from 'fs';

interface Episode {
  title: string;
  description: string;
  pubDate: string;
  link: string;
  duration: string;
  episodeNumber?: number;
}

interface YouTubeVideo {
  title: string;
  videoId: string;
  published: string;
  description: string;
  thumbnail: string;
  category: string;
}

interface ExternalVideo {
  title: string;
  url: string;
  published: string;
  source: string;
  description: string;
  category: string;
}

let episodes: Episode[] = [];
const dataPath = 'src/data/podcast-episodes.json';
if (existsSync(dataPath)) {
  try { episodes = JSON.parse(readFileSync(dataPath, 'utf-8')); } catch {}
}

let youtubeVideos: YouTubeVideo[] = [];
const ytPath = 'src/data/youtube-videos.json';
if (existsSync(ytPath)) {
  try { youtubeVideos = JSON.parse(readFileSync(ytPath, 'utf-8')); } catch {}
}

let externalVideos: ExternalVideo[] = [];
const extPath = 'src/data/external-videos.json';
if (existsSync(extPath)) {
  try { externalVideos = JSON.parse(readFileSync(extPath, 'utf-8')); } catch {}
}

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const VISIBLE = 8;

function formatDuration(seconds: string): string {
  const s = parseInt(seconds);
  if (isNaN(s)) return '';
  const m = Math.floor(s / 60);
  return `${m} min`;
}

function formatDate(dateStr: string): string {
  try {
    return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch { return dateStr; }
}
---

<BaseLayout title="Content | Edward Roske" description="Podcast, videos, and blog. Everything Edward Roske creates, in one place.">

  <div class="ch">

    <!-- ============ MASTHEAD ============ -->
    <header class="ch-masthead">
      <div class="ch-grain" aria-hidden="true"></div>
      <div class="ch-wrap">
        <p class="ch-kicker ch-rise">Content</p>
        <h1 class="ch-h1 ch-rise ch-rise-2">Everything I Make</h1>
        <p class="ch-lede ch-rise ch-rise-3">
          Video briefs, blog posts, and podcast episodes. Less formal than a book. More useful than a tweet.
        </p>
        <nav class="ch-toc ch-rise ch-rise-4" aria-label="On this page">
          <a href="#videos"><span>01</span>Videos</a>
          <a href="#blog"><span>02</span>Blog</a>
          <a href="#podcast"><span>03</span>Podcast</a>
          <a href="#interviews"><span>04</span>Interviews</a>
          <a href="#publications"><span>05</span>Publications</a>
        </nav>
      </div>
    </header>

    <!-- Sticky Tab Nav -->
    <TabNav tabs={[
      { label: "Videos", href: "#videos" },
      { label: "Blog", href: "#blog" },
      { label: "Podcast", href: "#podcast" },
      { label: "Interviews", href: "#interviews" },
      { label: "Publications", href: "#publications" },
    ]} />

    <!-- ============================================
         VIDEOS SECTION
         ============================================ -->
    <section id="videos" class="ch-section">
      <div class="ch-wrap">
        <header class="ch-head animate-on-scroll">
          <div class="ch-head-meta">
            <span class="ch-head-num">01</span>
            <span class="ch-head-rule" aria-hidden="true"></span>
          </div>
          <div class="ch-head-grid">
            <h2 class="ch-h2">Videos</h2>
            <p class="ch-deck">Monthly AI news briefs, plus a back catalog of Essbase and EPM how-tos (the Look Smarter Than You Are series, for the calc-script crowd).</p>
          </div>
        </header>

        {youtubeVideos.length > 0 ? (
          <div class="ch-videos">
            {youtubeVideos.map((video, idx) => (
              <a href={`https://www.youtube.com/watch?v=${video.videoId}`} target="_blank" rel="noopener noreferrer"
                class:list={["ch-video animate-on-scroll", idx === 0 && "ch-video-feature", idx >= VISIBLE && "js-more hidden"]}>
                <div class="ch-thumb">
                  <img src={video.thumbnail} alt={video.title} loading="lazy" decoding="async" />
                  <span class="ch-play" aria-hidden="true">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
                  </span>
                </div>
                <div class="ch-video-body">
                  <h3 class="ch-video-title">{video.title}</h3>
                  <p class="ch-video-desc ch-clamp2">{video.description}</p>
                  <span class="ch-mono-meta">{formatDate(video.published)}</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="ch-empty">
            <p>Videos will be populated from the YouTube feed during the next site rebuild.</p>
          </div>
        )}

        {youtubeVideos.length > VISIBLE && (
          <div class="ch-more">
            <button type="button" aria-expanded="false" data-show-all
              data-label-more={`Show all ${youtubeVideos.length - VISIBLE} more`}
              class="show-all-btn ch-showall">
              <span class="show-all-label">{`Show all ${youtubeVideos.length - VISIBLE} more`}</span>
              <svg class="show-all-chevron w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>
        )}

        <div class="ch-actions">
          <a href="https://www.youtube.com/@Roske-AI" target="_blank" rel="noopener noreferrer" class="ch-btn">
            Subscribe on YouTube
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================
         BLOG SECTION
         ============================================ -->
    <section id="blog" class="ch-section ch-section-alt">
      <div class="ch-wrap">
        <header class="ch-head animate-on-scroll">
          <div class="ch-head-meta">
            <span class="ch-head-num">02</span>
            <span class="ch-head-rule" aria-hidden="true"></span>
          </div>
          <div class="ch-head-grid">
            <h2 class="ch-h2">Blog</h2>
            <p class="ch-deck">Thoughts on AI, finance, MCP servers, and whatever else is worth the keystrokes.</p>
          </div>
        </header>

        {posts.length > 0 ? (
          <>
            <div class="ch-list">
              {posts.slice(0, VISIBLE).map(post => (
                <a href={`/blog/${post.id}/`} class="ch-row animate-on-scroll">
                  <time datetime={post.data.date.toISOString()} class="ch-row-when">
                    {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
                  </time>
                  <div class="ch-row-main">
                    <h3 class="ch-row-title">{post.data.title}</h3>
                    <p class="ch-row-desc">{post.data.description}</p>
                    {post.data.tags.length > 0 && (
                      <div class="ch-chips">
                        {post.data.tags.slice(0, 3).map(tag => (
                          <span class="ch-chip">{tag}</span>
                        ))}
                      </div>
                    )}
                  </div>
                  <svg class="ch-row-arrow w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
                </a>
              ))}
            </div>
            <div class="ch-actions">
              <a href="/blog/" class="ch-btn">
                View All Posts
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </a>
            </div>
          </>
        ) : (
          <div class="ch-empty animate-on-scroll">
            <div class="ch-empty-badge">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
              </svg>
            </div>
            <h3>Posts coming soon</h3>
            <p>I'm working on a few things. Check back shortly.</p>
          </div>
        )}
      </div>
    </section>

    <!-- ============================================
         PODCAST SECTION
         ============================================ -->
    <section id="podcast" class="ch-section">
      <div class="ch-wrap">
        <header class="ch-head animate-on-scroll">
          <div class="ch-head-meta">
            <span class="ch-head-num">03</span>
            <span class="ch-head-rule" aria-hidden="true"></span>
          </div>
          <div class="ch-head-grid">
            <h2 class="ch-h2">Asking Good Questions</h2>
            <p class="ch-deck">A podcast exploring how AI and technology are transforming the CFO's office.</p>
          </div>
        </header>

        <!-- Platform Links -->
        <div class="ch-platforms">
          {[
            { name: "Apple Podcasts", url: "https://podcasts.apple.com/podcast/id1783616142", icon: "apple" },
            { name: "Spotify", url: "https://open.spotify.com/show/2MJqqgiNbQGysS6i0MAihh", icon: "spotify" },
            { name: "Amazon Music", url: "https://music.amazon.com/podcasts/f5a5f18a-4c16-4f89-8735-079d49f49e49", icon: "amazon" },
            { name: "Buzzsprout", url: "https://askinggoodquestions.buzzsprout.com/", icon: "rss" },
          ].map(platform => (
            <a href={platform.url} target="_blank" rel="noopener noreferrer" class="ch-platform animate-on-scroll">
              <span class="ch-platform-icon">
                {platform.icon === "apple" && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                )}
                {platform.icon === "spotify" && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
                )}
                {platform.icon === "amazon" && (
                  <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M.045 18.02c.072-.116.187-.124.348-.064 2.729 1.353 5.706 2.008 8.876 2.008 2.17 0 4.406-.41 6.672-1.18.168-.056.3-.024.396.096.096.12.072.252-.072.396-1.692 1.296-4.11 2.028-6.996 2.028-3.366 0-6.378-1.044-8.988-3.096-.12-.096-.156-.2-.108-.312.024-.048.048-.048.072-.048l-.2.172zM22.92 16.32c.2.24.156.516-.132.756-.96.792-2.004 1.2-3.132 1.2-.648 0-1.212-.144-1.692-.432-.168-.108-.18-.252-.036-.432.12-.144.264-.168.432-.072.576.264 1.128.396 1.656.396.804 0 1.536-.3 2.196-.888.168-.156.348-.192.54-.108.072.024.12.072.168.144v-.564zM14.004 13.896c-.24 0-.48-.036-.672-.108-.384-.132-.576-.36-.576-.684 0-.384.228-.684.684-.888.384-.168.876-.252 1.476-.252.624 0 1.14.048 1.548.144v.288c0 .456-.168.852-.504 1.188-.336.336-.804.504-1.404.504l-.552-.192zm3.228-3.18c-.648-.6-1.536-.9-2.664-.9-1.128 0-2.304.3-3.528.9-.168.084-.3.06-.396-.072-.096-.132-.06-.264.108-.396 1.296-.744 2.58-1.116 3.852-1.116 1.32 0 2.352.384 3.096 1.152.264.288.264.456 0 .504-.12.024-.252-.012-.396-.108l-.072.036zM12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0z"/></svg>
                )}
                {platform.icon === "rss" && (
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 5c7.18 0 13 5.82 13 13M6 11a7 7 0 017 7m-6 0a1 1 0 11-2 0 1 1 0 012 0z"/></svg>
                )}
              </span>
              <span class="ch-platform-text">
                <span class="ch-platform-name">{platform.name}</span>
                <span class="ch-platform-sub">Listen now</span>
              </span>
              <svg class="ch-platform-arrow w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          ))}
        </div>

        <!-- About the Show -->
        <div class="ch-about animate-on-scroll">
          <p>
            <strong>Asking Good Questions</strong> started because I noticed that the best finance leaders I've worked with across 25+ years all had one thing in common: they asked better questions than everyone else in the room.
          </p>
          <p>
            Every episode explores how <strong>AI, data science, and technology</strong> are reshaping the Office of the CFO. Not to sell you software, but to figure out what's actually working and what's still hype.
          </p>
        </div>

        <!-- Recent Episodes -->
        {episodes.length > 0 ? (
          <div class="ch-list">
            {episodes.map((ep, idx) => (
              <a href={ep.link || 'https://askinggoodquestions.buzzsprout.com/'} target="_blank" rel="noopener noreferrer"
                class:list={["ch-row animate-on-scroll", idx >= VISIBLE && "js-more hidden"]}>
                <span class="ch-row-when">
                  <span>{formatDate(ep.pubDate)}</span>
                  {ep.duration && <span>{formatDuration(ep.duration)}</span>}
                </span>
                <div class="ch-row-main">
                  <h3 class="ch-row-title">{ep.title}</h3>
                  <p class="ch-row-desc ch-clamp2">{ep.description}</p>
                </div>
                <span class="ch-row-play" aria-hidden="true">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </span>
              </a>
            ))}
          </div>
        ) : (
          <div class="ch-empty animate-on-scroll">
            <p>Episodes will be populated from the RSS feed during the next site rebuild.</p>
            <a href="https://askinggoodquestions.buzzsprout.com/" target="_blank" rel="noopener noreferrer" class="ch-btn">
              Browse All Episodes
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        )}

        {episodes.length > VISIBLE && (
          <div class="ch-more">
            <button type="button" aria-expanded="false" data-show-all
              data-label-more={`Show all ${episodes.length - VISIBLE} more`}
              class="show-all-btn ch-showall">
              <span class="show-all-label">{`Show all ${episodes.length - VISIBLE} more`}</span>
              <svg class="show-all-chevron w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>
        )}

        <!-- Guest CTA -->
        <div class="ch-guest">
          <p>Want to be a guest? Have a topic you'd like covered?</p>
          <a href="/contact/">Get in touch &rarr;</a>
        </div>
      </div>
    </section>

    <!-- ============================================
         INTERVIEWS SECTION
         ============================================ -->
    <section id="interviews" class="ch-section ch-section-alt">
      <div class="ch-wrap">
        <header class="ch-head animate-on-scroll">
          <div class="ch-head-meta">
            <span class="ch-head-num">04</span>
            <span class="ch-head-rule" aria-hidden="true"></span>
          </div>
          <div class="ch-head-grid">
            <h2 class="ch-h2">Interviews</h2>
            <p class="ch-deck">Interviews (sometimes I'm asking, sometimes answering), conference talks, and a few webinars from across the web.</p>
          </div>
        </header>

        {externalVideos.length > 0 && (
          <div class="ch-list">
            {externalVideos.map((video, idx) => (
              <a href={video.url} target="_blank" rel="noopener noreferrer"
                class:list={["ch-row animate-on-scroll", idx >= VISIBLE && "js-more hidden"]}>
                <span class="ch-row-when">
                  <span>{formatDate(video.published)}</span>
                </span>
                <div class="ch-row-main">
                  <h3 class="ch-row-title">{video.title}</h3>
                  <p class="ch-row-desc">{video.description}</p>
                  <div class="ch-chips">
                    <span class="ch-chip">{video.source}</span>
                  </div>
                </div>
                <svg class="ch-row-arrow w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            ))}
          </div>
        )}
        {externalVideos.length > VISIBLE && (
          <div class="ch-more">
            <button type="button" aria-expanded="false" data-show-all
              data-label-more={`Show all ${externalVideos.length - VISIBLE} more`}
              class="show-all-btn ch-showall">
              <span class="show-all-label">{`Show all ${externalVideos.length - VISIBLE} more`}</span>
              <svg class="show-all-chevron w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </div>
        )}
      </div>
    </section>

    <!-- ============================================
         PUBLICATIONS SECTION
         ============================================ -->
    <section id="publications" class="ch-section">
      <div class="ch-wrap">
        <header class="ch-head animate-on-scroll">
          <div class="ch-head-meta">
            <span class="ch-head-num">05</span>
            <span class="ch-head-rule" aria-hidden="true"></span>
            <span class="ch-head-count">01 of 01</span>
          </div>
          <div class="ch-head-grid">
            <h2 class="ch-h2">Academic Publications</h2>
            <p class="ch-deck">Research from my Master of Data Science at SMU (4.0 GPA, Outstanding Graduate).</p>
          </div>
        </header>

        <div class="ch-list">
          <a href="https://scholar.smu.edu/datasciencereview/vol5/iss3/9/" target="_blank" rel="noopener noreferrer"
            class="ch-row animate-on-scroll">
            <span class="ch-row-when"><span>2021</span></span>
            <div class="ch-row-main">
              <h3 class="ch-row-title">Spotify: You have a Hit!</h3>
              <p class="ch-row-desc">
                Predicting hit songs using Spotify API data on 400,000+ tracks. Models built with LASSO and XGBOOST classification achieved 60%+ accuracy identifying songs that would reach 90%+ popularity.
              </p>
              <div class="ch-chips">
                <span class="ch-chip">SMU Data Science Review</span>
                <span class="ch-row-note">Co-authored with C. Dawson Jr., S. Mann, G. Vasseur</span>
              </div>
            </div>
            <svg class="ch-row-arrow w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        </div>
      </div>
    </section>

  </div>

  <script is:inline>
    (function () {
      function initShowAll() {
        document.querySelectorAll('[data-show-all]').forEach(function (btn) {
          if (btn.dataset.bound) return;
          btn.dataset.bound = '1';
          btn.addEventListener('click', function () {
            var scope = btn.closest('section');
            if (!scope) return;
            var items = scope.querySelectorAll('.js-more');
            var expanded = btn.getAttribute('aria-expanded') === 'true';
            items.forEach(function (el) {
              el.classList.toggle('hidden', expanded);
              if (!expanded) el.classList.add('visible');
            });
            btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            var label = btn.querySelector('.show-all-label');
            if (label) label.textContent = expanded ? (btn.getAttribute('data-label-more') || 'Show all') : 'Show fewer';
            var chevron = btn.querySelector('.show-all-chevron');
            if (chevron) chevron.style.transform = expanded ? '' : 'rotate(180deg)';
          });
        });
      }
      if (document.readyState !== 'loading') initShowAll();
      document.addEventListener('DOMContentLoaded', initShowAll);
      document.addEventListener('astro:page-load', initShowAll);
    })();
  </script>

</BaseLayout>

<style>
  /* ==========================================================
     CONTENT HUB: editorial catalog system.
     Every color and font routes through the weekly theme vars,
     aliased once per mode into local --ch-* custom properties.
     ========================================================== */
  .ch {
    --ch-line: var(--color-border);
    --ch-ink: var(--color-text);
    --ch-muted: var(--color-text-muted);
    --ch-meta: color-mix(in srgb, var(--color-text-muted) 80%, transparent);
    --ch-alt-bg: var(--color-surface);
    --ch-accent-line: color-mix(in srgb, var(--color-accent) 45%, transparent);
