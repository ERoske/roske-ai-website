---
/**
 * WeeklyAnimation.astro
 *
 * This component is OVERWRITTEN every week during the Saturday redesign.
 * It contains a themed animation that matches the current week's theme.
 *
 * IMPORTANT: Do NOT use Astro scoped <style> for dynamically created elements.
 * Astro adds data-astro-cid attributes to scoped CSS selectors, but elements
 * created via document.createElement won't have those attributes. Apply all
 * styles directly in JavaScript instead.
 *
 * Current theme: Stranger Things: Tales from '85 (April 18, 2026)
 * Animation: Flickering Christmas-lights alphabet wall (Joyce Byers' living room homage).
 * Lights spell short phrases one letter at a time: ROSKE AI, ASK GOOD QUESTIONS, RUN,
 * HELLO EDWARD, ROLL FOR INITIATIVE. Anchored to bottom-left on desktop, hidden on mobile.
 */
---

<div id="weekly-animation" style="position:fixed;left:0;right:0;bottom:0;top:0;pointer-events:none;z-index:5;overflow:hidden;" aria-hidden="true"></div>

<script is:inline>
  (function() {
    function initStrangerLights() {
      var container = document.getElementById('weekly-animation');
      if (!container) return function(){};
      container.innerHTML = '';

      // Hide on small screens — the alphabet strip needs horizontal room
      if (window.innerWidth < 768) {
        return function(){};
      }

      var isLight = document.documentElement.getAttribute('data-theme') === 'light';

      // Wall strip container — anchored to bottom of viewport, full width
      var strip = document.createElement('div');
      strip.style.cssText = [
        'position:absolute',
        'left:0',
        'right:0',
        'bottom:0',
        'height:7.5rem',
        'display:flex',
        'align-items:flex-end',
        'justify-content:center',
        'padding:0 2rem 1rem',
        'opacity:' + (isLight ? '0.45' : '0.6'),
        'pointer-events:none'
      ].join(';');
      container.appendChild(strip);

      // The wall-painted alphabet: A-Z in a single row
      var wall = document.createElement('div');
      wall.style.cssText = [
        'display:flex',
        'gap:0.25rem',
        'align-items:flex-end',
        'justify-content:center',
        'flex-wrap:nowrap',
        'max-width:100%'
      ].join(';');
      strip.appendChild(wall);

      // Classic Christmas-light colors, assigned to each letter in a rotating pattern
      var bulbColors = [
        '#ff2a2a', // red
        '#ffb020', // amber
        '#2ecc40', // green
        '#3090ff', // blue
        '#c040ff', // purple
      ];

      var letters = [];
      for (var i = 0; i < 26; i++) {
        var letterChar = String.fromCharCode(65 + i);
        var color = bulbColors[i % bulbColors.length];

        // Wrapper cell: letter on top, bulb on bottom
        var cell = document.createElement('div');
        cell.style.cssText = [
          'display:flex',
          'flex-direction:column',
          'align-items:center',
          'justify-content:flex-end',
          'width:clamp(1.5rem, 3.2vw, 2.4rem)',
          'gap:0.25rem'
        ].join(';');

        // Hand-painted letter on the "wall"
        var letter = document.createElement('div');
        letter.textContent = letterChar;
        letter.style.cssText = [
          'font-family:"Metamorphous", serif',
          'font-size:clamp(1.2rem, 2.2vw, 1.75rem)',
          'font-weight:400',
          'color:' + (isLight ? 'rgba(60, 20, 20, 0.75)' : 'rgba(240, 220, 210, 0.7)'),
          'letter-spacing:0',
          'line-height:1',
          'text-align:center',
          'user-select:none'
        ].join(';');
        cell.appendChild(letter);

        // The wire going down into the bulb
        var wire = document.createElement('div');
        wire.style.cssText = [
          'width:1px',
          'height:0.25rem',
          'background:' + (isLight ? 'rgba(60, 40, 30, 0.55)' : 'rgba(180, 160, 140, 0.5)')
        ].join(';');
        cell.appendChild(wire);

        // The bulb itself — dim by default, glows when "on"
        var bulb = document.createElement('div');
        bulb.style.cssText = [
          'width:clamp(0.9rem, 1.6vw, 1.25rem)',
          'height:clamp(1.1rem, 2vw, 1.5rem)',
          'border-radius:50% 50% 45% 45% / 55% 55% 45% 45%',
          'background:' + (isLight ? 'rgba(40, 30, 30, 0.25)' : 'rgba(60, 40, 40, 0.55)'),
          'box-shadow:none',
          'transition:background 0.18s ease-out, box-shadow 0.25s ease-out',
          'position:relative'
        ].join(';');
        cell.appendChild(bulb);

        wall.appendChild(cell);
        letters.push({ bulb: bulb, color: color, letter: letterChar, lit: false, fadeTimer: null });
      }

      function lightOn(entry, brightness) {
        brightness = brightness || 1;
        entry.lit = true;
        if (entry.fadeTimer) {
          clearTimeout(entry.fadeTimer);
          entry.fadeTimer = null;
        }
        var c = entry.color;
        entry.bulb.style.background = c;
        entry.bulb.style.boxShadow = [
          '0 0 ' + (10 * brightness) + 'px ' + c,
          '0 0 ' + (22 * brightness) + 'px ' + c,
          '0 -0.2rem 0.5rem rgba(255,255,255,0.15) inset'
        ].join(', ');
      }

      function lightOff(entry, fadeMs) {
        fadeMs = fadeMs || 400;
        entry.lit = false;
        entry.bulb.style.background = isLight ? 'rgba(40, 30, 30, 0.25)' : 'rgba(60, 40, 40, 0.55)';
        entry.bulb.style.boxShadow = 'none';
      }

      function flicker(entry, times, then) {
        var count = 0;
        function step() {
          if (count >= times * 2) {
            if (then) then();
            return;
          }
          if (count % 2 === 0) {
            lightOn(entry, 0.5 + Math.random() * 0.6);
          } else {
            lightOff(entry);
          }
          count++;
          setTimeout(step, 60 + Math.random() * 100);
        }
        step();
      }

      // Phrases to spell, one letter at a time, with flicker
      var phrases = [
        'ROSKE AI',
        'ASK GOOD QUESTIONS',
        'HELLO EDWARD',
        'ROLL FOR INITIATIVE',
        'RUN',
        'YOUR PRINCESS IS IN ANOTHER CASTLE', // leftover Edward-ism, a blink to last week
        'THIS IS FINE'
      ];

      var running = true;
      var phraseIdx = 0;

      function turnAllOff() {
        for (var i = 0; i < letters.length; i++) {
          lightOff(letters[i]);
        }
      }

      function playPhrase(phrase, done) {
        turnAllOff();
        var chars = phrase.split('');
        var i = 0;
        function next() {
          if (!running) return;
          if (i >= chars.length) {
            // Hold the full phrase a moment, then fade all off
            setTimeout(function() {
              if (!running) return;
              turnAllOff();
              setTimeout(done, 700);
            }, 1400);
            return;
          }
          var ch = chars[i];
          i++;
          if (ch === ' ') {
            setTimeout(next, 120);
            return;
          }
          var idx = ch.charCodeAt(0) - 65;
          if (idx >= 0 && idx < 26) {
            var entry = letters[idx];
            flicker(entry, 1 + Math.floor(Math.random() * 2), function() {
              lightOn(entry, 0.9 + Math.random() * 0.3);
              setTimeout(next, 160 + Math.random() * 120);
            });
          } else {
            setTimeout(next, 120);
          }
        }
        next();
      }

      // Idle twinkle: every so often, a random letter flickers briefly in the background
      var idleTimer = null;
      function idleTwinkle() {
        if (!running) return;
        var entry = letters[Math.floor(Math.random() * 26)];
        if (!entry.lit) {
          flicker(entry, 1, function() {
            lightOff(entry);
          });
        }
        idleTimer = setTimeout(idleTwinkle, 800 + Math.random() * 1800);
      }
      idleTimer = setTimeout(idleTwinkle, 1500);

      function loop() {
        if (!running) return;
        var phrase = phrases[phraseIdx % phrases.length];
        phraseIdx++;
        playPhrase(phrase, function() {
          setTimeout(loop, 1200 + Math.random() * 1800);
        });
      }

      // Kick off after a brief pause so the page settles
      setTimeout(loop, 800);

      function onResize() {
        // If screen shrinks below breakpoint, teardown; if grows, re-init
        if (window.innerWidth < 768) {
          running = false;
          if (idleTimer) clearTimeout(idleTimer);
          container.innerHTML = '';
        }
      }
      window.addEventListener('resize', onResize);

      return function cleanup() {
        running = false;
        if (idleTimer) clearTimeout(idleTimer);
        window.removeEventListener('resize', onResize);
        container.innerHTML = '';
      };
    }

    var cleanup = initStrangerLights();

    var observer = new MutationObserver(function() {
      if (cleanup) cleanup();
      cleanup = initStrangerLights();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // Re-init on viewport cross of the 768 breakpoint
    var wasDesktop = window.innerWidth >= 768;
    window.addEventListener('resize', function() {
      var isDesktop = window.innerWidth >= 768;
      if (isDesktop !== wasDesktop) {
        wasDesktop = isDesktop;
        if (cleanup) cleanup();
        cleanup = initStrangerLights();
      }
    });
  })();
</script>
