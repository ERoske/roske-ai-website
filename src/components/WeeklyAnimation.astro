---
/**
 * WeeklyAnimation.astro
 *
 * This component is OVERWRITTEN every week during the Saturday redesign.
 * It contains a themed animation that matches the current week's theme.
 *
 * IMPORTANT: Do NOT use Astro scoped <style> for dynamically created elements.
 * Astro adds data-astro-cid attributes to scoped CSS selectors, but elements
 * created via document.createElement won't have those attributes. Apply all
 * styles directly in JavaScript instead.
 *
 * Current theme: March Madness 2026
 * Animation: Small basketballs bouncing along the bottom of the screen
 */
---

<div id="weekly-animation" style="position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;z-index:5;overflow:hidden;" aria-hidden="true"></div>

<script is:inline>
  (function() {
    function initBouncingBalls() {
      var container = document.getElementById('weekly-animation');
      if (!container) return;
      container.innerHTML = '';

      var isLight = document.documentElement.getAttribute('data-theme') === 'light';
      var count = 7;
      var balls = [];
      var gravity = 0.15;
      var bounceDamping = 0.7;
      var floorOffset = 8;

      for (var i = 0; i < count; i++) {
        var el = document.createElement('span');
        el.textContent = '\u{1F3C0}';
        var size = 2.5 + Math.random() * 2;
        // Apply all styles inline (no CSS classes - Astro scoping breaks them)
        el.style.cssText = 'position:absolute;font-size:' + size + 'rem;opacity:1;pointer-events:none;user-select:none;background:orange;border-radius:50%;padding:10px;border:3px solid red;';
        container.appendChild(el);

        balls.push({
          el: el,
          x: Math.random() * window.innerWidth,
          vx: (Math.random() - 0.5) * 1.5,
          y: Math.random() * window.innerHeight * 0.5,
          vy: 0,
          size: size * 16,
          rotation: Math.random() * 360,
          spin: (Math.random() - 0.5) * 4
        });
      }

      var animId;
      function tick() {
        var w = window.innerWidth;
        var h = window.innerHeight;

        for (var j = 0; j < balls.length; j++) {
          var b = balls[j];
          b.vy += gravity;
          b.x += b.vx;
          b.y += b.vy;
          b.rotation += b.spin;

          var floor = h - floorOffset - b.size;
          if (b.y >= floor) {
            b.y = floor;
            b.vy = -Math.abs(b.vy) * bounceDamping;
            if (Math.abs(b.vy) < 0.5) {
              b.vy = -(2 + Math.random() * 3);
            }
            b.spin = (Math.random() - 0.5) * 6;
          }

          if (b.x < -b.size) b.x = w + b.size;
          if (b.x > w + b.size) b.x = -b.size;

          b.el.style.transform = 'translate(' + b.x + 'px, ' + b.y + 'px) rotate(' + b.rotation + 'deg)';
        }

        animId = requestAnimationFrame(tick);
      }

      animId = requestAnimationFrame(tick);
      return function() { cancelAnimationFrame(animId); };
    }

    var cleanup = initBouncingBalls();

    var observer = new MutationObserver(function() {
      if (cleanup) cleanup();
      cleanup = initBouncingBalls();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  })();
</script>
