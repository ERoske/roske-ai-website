---
/**
 * WeeklyAnimation.astro — Toy Story 5 week (2026-06-20).
 *
 * Andy's-room cloud wallpaper, brought gently to life. The cloud wallpaper is
 * the single most recognizable image in the franchise, so this is the rare
 * week that earns ambient motion (the snow/holiday exception). A handful of
 * large, soft, slow-drifting clouds. Not falling particles.
 *
 * Rules followed: inline styles only (no Astro scoped CSS on created nodes),
 * <script is:inline>, opacity tuned per mode, resets on data-theme toggle,
 * and honors prefers-reduced-motion.
 */
---

<div id="ts-clouds" style="position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;z-index:5;overflow:hidden;"></div>

<script is:inline>
  (function () {
    var CLOUD_SVG =
      "<svg viewBox='0 0 120 70' xmlns='http://www.w3.org/2000/svg' style='width:100%;height:100%;display:block;'>" +
      "<g fill='#ffffff'><circle cx='35' cy='42' r='22'/><circle cx='60' cy='30' r='27'/>" +
      "<circle cx='86' cy='43' r='20'/><rect x='30' y='42' width='62' height='24' rx='12'/></g></svg>";

    // width(rem), top(vh), duration(s), negative delay(s) for staggered start
    var CLOUDS = [
      { w: 11, top: 7,  dur: 80,  delay: 0 },
      { w: 7,  top: 21, dur: 98,  delay: -34 },
      { w: 14, top: 37, dur: 72,  delay: -56 },
      { w: 8,  top: 57, dur: 106, delay: -20 },
      { w: 10, top: 72, dur: 88,  delay: -70 },
      { w: 6,  top: 87, dur: 114, delay: -44 }
    ];

    function injectKeyframes() {
      if (document.getElementById("ts-cloud-kf")) return;
      var s = document.createElement("style");
      s.id = "ts-cloud-kf";
      s.textContent =
        "@keyframes tsDrift{from{transform:translateX(-28vw)}to{transform:translateX(124vw)}}" +
        "@media (prefers-reduced-motion: reduce){.ts-cloud{animation:none !important;transform:translateX(40vw)}}";
      document.head.appendChild(s);
    }

    function buildClouds() {
      var root = document.getElementById("ts-clouds");
      if (!root || root.dataset.ready === "1") return;
      root.dataset.ready = "1";
      CLOUDS.forEach(function (c) {
        var el = document.createElement("div");
        el.className = "ts-cloud";
        el.innerHTML = CLOUD_SVG;
        el.style.cssText =
          "position:absolute;top:" + c.top + "vh;left:0;" +
          "width:" + c.w + "rem;height:" + (c.w * 0.58) + "rem;" +
          "filter:drop-shadow(0 5px 7px rgba(15,30,70,0.14));" +
          "will-change:transform;" +
          "animation:tsDrift " + c.dur + "s linear " + c.delay + "s infinite;";
        root.appendChild(el);
      });
    }

    function applyOpacity() {
      var root = document.getElementById("ts-clouds");
      if (!root) return;
      var light = document.documentElement.getAttribute("data-theme") === "light";
      root.style.opacity = light ? "0.24" : "0.14";
    }

    function boot() {
      injectKeyframes();
      buildClouds();
      applyOpacity();
      if (!window.__tsCloudObs) {
        window.__tsCloudObs = new MutationObserver(applyOpacity);
        window.__tsCloudObs.observe(document.documentElement, {
          attributes: true,
          attributeFilter: ["data-theme"]
        });
      }
    }

    if (!window.__tsCloudListener) {
      window.__tsCloudListener = true;
      document.addEventListener("astro:page-load", boot);
    }
    boot();
  })();
</script>
