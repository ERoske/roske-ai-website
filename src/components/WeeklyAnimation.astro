---
/**
 * WeeklyAnimation.astro
 *
 * This component is OVERWRITTEN every week during the Saturday redesign.
 * It contains a themed animation that matches the current week's theme.
 *
 * IMPORTANT: Do NOT use Astro scoped <style> for dynamically created elements.
 * Astro adds data-astro-cid attributes to scoped CSS selectors, but elements
 * created via document.createElement won't have those attributes. Apply all
 * styles directly in JavaScript instead.
 *
 * Current theme: Roske International: Final Season (April 25, 2026)
 * Animation: Slow drifting Vought-style propaganda stars and the occasional
 * glinting "approved" stamp arc, plus rare horizontal lightning streaks
 * that read as a speedster zooming across the lower viewport.
 */
---

<div id="weekly-animation" style="position:fixed;left:0;right:0;bottom:0;top:0;pointer-events:none;z-index:5;overflow:hidden;" aria-hidden="true"></div>

<script is:inline>
  (function() {
    function init() {
      var container = document.getElementById('weekly-animation');
      if (!container) return function(){};
      container.innerHTML = '';

      var isLight = document.documentElement.getAttribute('data-theme') === 'light';
      var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      var STAR_OPACITY = isLight ? 0.32 : 0.55;
      var BOLT_OPACITY = isLight ? 0.28 : 0.45;
      var redColor = '#c8102e';
      var blueColor = '#1b2c5f';
      var creamColor = '#f7f1e3';

      // Five-pointed star SVG path (centered at 0,0, radius ~10)
      function starSVG(fill, stroke, sizePx) {
        var s = sizePx || 22;
        return '<svg width="' + s + '" height="' + s + '" viewBox="-12 -12 24 24" xmlns="http://www.w3.org/2000/svg">' +
          '<polygon points="0,-10 2.94,-4.05 9.51,-3.09 4.76,1.55 5.88,8.09 0,5 -5.88,8.09 -4.76,1.55 -9.51,-3.09 -2.94,-4.05" ' +
          'fill="' + fill + '" stroke="' + stroke + '" stroke-width="0.6" stroke-linejoin="round" />' +
          '</svg>';
      }

      // Lightning bolt SVG (horizontal-ish jagged streak)
      function boltSVG(color, sizePx) {
        var s = sizePx || 100;
        return '<svg width="' + s + '" height="' + (s * 0.25) + '" viewBox="0 0 200 50" xmlns="http://www.w3.org/2000/svg">' +
          '<polyline points="0,28 30,22 55,32 90,18 130,30 165,16 200,26" ' +
          'fill="none" stroke="' + color + '" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" ' +
          'stroke-dasharray="6 4" />' +
          '</svg>';
      }

      var running = true;
      var timers = [];

      // Drift a star slowly upward across the screen, then remove
      function spawnStar() {
        if (!running) return;

        var color = Math.random() < 0.55 ? redColor : (Math.random() < 0.5 ? blueColor : creamColor);
        var size = 14 + Math.random() * 28; // 14-42px
        var startX = Math.random() * window.innerWidth;
        var startY = window.innerHeight + size;
        var driftX = (Math.random() - 0.5) * 200; // sideways wander
        var duration = 12000 + Math.random() * 10000; // 12-22s — slow, propaganda-poster cadence
        var rotateAmt = (Math.random() - 0.5) * 360;

        var el = document.createElement('div');
        el.style.cssText = [
          'position:absolute',
          'left:' + startX + 'px',
          'top:' + startY + 'px',
          'width:' + size + 'px',
          'height:' + size + 'px',
          'opacity:0',
          'pointer-events:none',
          'will-change:transform,opacity',
          'filter:drop-shadow(0 0 ' + (size * 0.25) + 'px ' + color + ')',
          'transition:opacity 1.2s ease-out'
        ].join(';');
        el.innerHTML = starSVG(color, isLight ? 'rgba(20,30,60,0.4)' : 'rgba(247,241,227,0.4)', size);
        container.appendChild(el);

        // Fade in
        requestAnimationFrame(function() {
          el.style.opacity = String(STAR_OPACITY);
        });

        // Animate via Web Animations API for smooth GPU-accelerated motion
        var anim = el.animate(
          [
            { transform: 'translate(0px, 0px) rotate(0deg)' },
            { transform: 'translate(' + driftX + 'px, -' + (window.innerHeight + size * 2) + 'px) rotate(' + rotateAmt + 'deg)' }
          ],
          { duration: duration, easing: 'linear', fill: 'forwards' }
        );

        anim.onfinish = function() {
          if (el.parentNode) el.parentNode.removeChild(el);
        };

        // Fade out near the end
        var fadeT = setTimeout(function() {
          el.style.opacity = '0';
        }, duration - 1200);
        timers.push(fadeT);
      }

      // A horizontal lightning streak that flashes across the screen briefly
      function spawnBolt() {
        if (!running) return;

        var width = 220 + Math.random() * 220;
        var startY = window.innerHeight * (0.55 + Math.random() * 0.35); // lower half
        var goLeftToRight = Math.random() < 0.5;
        var startX = goLeftToRight ? -width : window.innerWidth + width;
        var endX = goLeftToRight ? window.innerWidth + width : -width;
        var color = Math.random() < 0.5 ? redColor : creamColor;

        var el = document.createElement('div');
        el.style.cssText = [
          'position:absolute',
          'left:' + startX + 'px',
          'top:' + startY + 'px',
          'width:' + width + 'px',
          'opacity:0',
          'pointer-events:none',
          'will-change:transform,opacity',
          'filter:drop-shadow(0 0 6px ' + color + ')',
          'transform-origin:center'
        ].join(';');
        el.innerHTML = boltSVG(color, width);
        container.appendChild(el);

        var duration = 700 + Math.random() * 500;

        // Fade in / out via Web Animations so removal is reliable
        el.animate(
          [
            { opacity: 0, transform: 'translateX(0px)' },
            { opacity: BOLT_OPACITY, transform: 'translateX(' + ((endX - startX) * 0.4) + 'px)' },
            { opacity: 0, transform: 'translateX(' + (endX - startX) + 'px)' }
          ],
          { duration: duration, easing: 'ease-out', fill: 'forwards' }
        ).onfinish = function() {
          if (el.parentNode) el.parentNode.removeChild(el);
        };
      }

      // Star spawn cadence: one every 1.4-2.6s
      function starLoop() {
        if (!running) return;
        spawnStar();
        timers.push(setTimeout(starLoop, 1400 + Math.random() * 1200));
      }

      // Bolt spawn cadence: one every 7-14s, less frequent than stars
      function boltLoop() {
        if (!running) return;
        spawnBolt();
        timers.push(setTimeout(boltLoop, 7000 + Math.random() * 7000));
      }

      if (!prefersReduced) {
        // Pre-populate a few stars so the screen isn't empty on load
        for (var i = 0; i < 3; i++) {
          timers.push(setTimeout(spawnStar, i * 600));
        }
        timers.push(setTimeout(starLoop, 1500));
        timers.push(setTimeout(boltLoop, 4500));
      }

      return function cleanup() {
        running = false;
        for (var i = 0; i < timers.length; i++) clearTimeout(timers[i]);
        timers = [];
        container.innerHTML = '';
      };
    }

    var cleanup = init();

    var observer = new MutationObserver(function() {
      if (cleanup) cleanup();
      cleanup = init();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  })();
</script>
