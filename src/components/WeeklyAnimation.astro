---
/**
 * WeeklyAnimation.astro - July 4, 2026: fireworks.
 *
 * Holiday carve-out (same as New Year's): fireworks fit America's 250th.
 * A rocket streaks up, then bursts into red / white / blue / gold particles
 * that arc out and fade. Low frequency, upper portion of the screen, behind
 * all content, pointer-events off. Honors prefers-reduced-motion and dims in
 * light mode. All styles are inline (Tailwind purges component classes and
 * Astro scopes <style>, neither of which reaches createElement nodes).
 */
---

<div id="wa-fireworks" style="position:fixed;top:0;left:0;right:0;bottom:0;pointer-events:none;z-index:1;overflow:hidden;" aria-hidden="true"></div>

<script is:inline>
  (function () {
    function initFireworks() {
      const root = document.getElementById('wa-fireworks');
      if (!root || root.dataset.waBound) return;
      root.dataset.waBound = '1';

      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      const COLORS = ['#e5484d', '#f4ecd8', '#5a8be0', '#e0b447', '#ffffff'];
      let timer = null;
      let running = false;

      function isLight() {
        return document.documentElement.getAttribute('data-theme') === 'light';
      }

      function burst(x, y) {
        const n = 20 + Math.floor((x + y) % 8); // 20-27 particles
        const color = COLORS[(Math.floor(x) + Math.floor(y)) % COLORS.length];
        for (let i = 0; i < n; i++) {
          const p = document.createElement('div');
          const angle = (Math.PI * 2 * i) / n + (x % 1);
          const dist = 60 + ((i * 37) % 70); // 60-130px spread
          const dx = Math.cos(angle) * dist;
          const dy = Math.sin(angle) * dist + 30; // slight gravity bias
          p.style.cssText =
            'position:absolute;left:' + x + 'px;top:' + y + 'px;width:9px;height:9px;' +
            'border-radius:50%;background:' + color + ';box-shadow:0 0 8px ' + color + ';' +
            'opacity:' + (isLight() ? 0.5 : 0.72) + ';transform:translate(-50%,-50%);' +
            'transition:transform 1.25s cubic-bezier(0.15,0.7,0.3,1),opacity 1.25s ease-out;will-change:transform,opacity;';
          root.appendChild(p);
          void p.offsetWidth; // reflow before animating
          p.style.transform = 'translate(calc(-50% + ' + dx + 'px), calc(-50% + ' + dy + 'px)) scale(0.4)';
          p.style.opacity = '0';
          setTimeout(function () { p.remove(); }, 1350);
        }
      }

      function rocket() {
        const w = window.innerWidth;
        const h = window.innerHeight;
        const x = w * (0.12 + Math.random() * 0.76);
        const targetY = h * (0.12 + Math.random() * 0.3);
        const startY = h * 0.66;
        const trail = document.createElement('div');
        const gold = '#e0b447';
        trail.style.cssText =
          'position:absolute;left:' + x + 'px;top:' + startY + 'px;width:4px;height:12px;' +
          'border-radius:3px;background:' + gold + ';box-shadow:0 0 8px ' + gold + ';' +
          'opacity:' + (isLight() ? 0.45 : 0.7) + ';transform:translate(-50%,-50%);' +
          'transition:top 0.6s ease-out,opacity 0.6s ease-out;will-change:top,opacity;';
        root.appendChild(trail);
        void trail.offsetWidth;
        trail.style.top = targetY + 'px';
        setTimeout(function () {
          trail.style.opacity = '0';
          trail.remove();
          burst(x, targetY);
        }, 600);
      }

      function schedule() {
        if (!running) return;
        rocket();
        if (Math.random() < 0.35) setTimeout(rocket, 350); // occasional double
        timer = setTimeout(schedule, 2200 + Math.random() * 2600);
      }

      function start() {
        if (running || reduce.matches) return;
        running = true;
        timer = setTimeout(schedule, 900);
      }
      function stop() {
        running = false;
        if (timer) clearTimeout(timer);
        while (root.firstChild) root.firstChild.remove();
      }

      start();

      document.addEventListener('visibilitychange', function () {
        if (document.hidden) stop();
        else start();
      });
      if (reduce.addEventListener) {
        reduce.addEventListener('change', function () { if (reduce.matches) stop(); else start(); });
      }
    }

    if (document.readyState !== 'loading') initFireworks();
    document.addEventListener('DOMContentLoaded', initFireworks);
    document.addEventListener('astro:page-load', initFireworks);
  })();
</script>
