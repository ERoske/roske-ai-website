---
// Theme toggle component: switches between dark and light mode
// Persists choice in localStorage, defaults to system preference
---

<button
  class="js-theme-toggle p-2 rounded-lg dark:text-[var(--color-text-muted)] text-[var(--color-text-dark-muted)] hover:text-[var(--color-accent)] dark:hover:bg-white/5 hover:bg-black/5 transition-all duration-200"
  aria-label="Toggle dark/light mode"
  title="Toggle dark/light mode"
>
  <!-- Sun icon (shown in dark mode, click to go light) -->
  <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
  </svg>
  <!-- Moon icon (shown in light mode, click to go dark) -->
  <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
  </svg>
</button>

<script is:inline>
  // ThemeToggle renders twice per page (desktop + mobile nav). is:inline
  // scripts are NOT deduplicated, so this block is emitted twice. Wrap in an
  // IIFE and bind by class (never a top-level const, never a duplicate id) so
  // the two copies can't collide, and re-bind after client-side navigation.
  (function () {
    function bindThemeToggles() {
      document.querySelectorAll('.js-theme-toggle').forEach(function (btn) {
        if (btn.dataset.themeBound) return;
        btn.dataset.themeBound = '1';
        btn.addEventListener('click', function () {
          const html = document.documentElement;
          const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('theme', next);
        });
      });
    }
    if (document.readyState !== 'loading') bindThemeToggles();
    document.addEventListener('DOMContentLoaded', bindThemeToggles);
    document.addEventListener('astro:page-load', bindThemeToggles);
  })();
</script>
