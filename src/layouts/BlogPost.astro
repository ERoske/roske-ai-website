---
import BaseLayout from './BaseLayout.astro';

interface Coauthor {
  name: string;
  image?: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  updatedDate?: Date;
  tags?: string[];
  slug?: string;
  coauthors?: Coauthor[];
}

const { title, description, date, updatedDate, tags = [], slug = '', coauthors = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;
const showUpdated = updatedDate && updatedDate.getTime() !== date.getTime();
---

<BaseLayout title={`${title} | Roske.AI`} description={description} ogType="article" articleDate={date} articleTags={tags}>

  <!-- NewsArticle JSON-LD for Google News -->
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "NewsArticle",
    "headline": title,
    "description": description,
    "datePublished": date.toISOString(),
    "dateModified": (updatedDate ?? date).toISOString(),
    "author": [
      {
        "@type": "Person",
        "name": "Edward Roske",
        "url": "https://roske.ai",
        "sameAs": [
          "https://www.linkedin.com/in/interrel/",
          "https://x.com/eroske"
        ]
      },
      ...coauthors.map(ca => ({
        "@type": ca.url?.includes('anthropic') ? "Organization" : "Person",
        "name": ca.name,
        ...(ca.url ? { "url": ca.url } : {})
      }))
    ],
    "publisher": {
      "@type": "Organization",
      "name": "Roske.AI",
      "url": "https://roske.ai",
      "logo": {
        "@type": "ImageObject",
        "url": "https://roske.ai/icon-512.png"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": `https://roske.ai/blog/${slug}/`
    },
    "image": "https://roske.ai/images/Edward_Roske_Headshot.png"
  })} />

  <!-- BreadcrumbList JSON-LD -->
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://roske.ai"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://roske.ai/blog/"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": title
      }
    ]
  })} />

  <article class="relative py-20 md:py-28 px-6">
    <div class="post-bg absolute inset-0" aria-hidden="true"></div>

    <div class="relative max-w-3xl mx-auto">
      <!-- Header -->
      <header class="mb-14">
        <a href="/blog/" class="post-backlink mb-8">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          Back to Blog
        </a>

        <!-- Tags above title -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-6"
            style="animation: fadeInUp 0.6s ease-out forwards;">
            {tags.map(tag => (
              <a href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}/`} class="post-tag">
                {tag}
              </a>
            ))}
          </div>
        )}

        <h1 class="post-title mb-8"
          style="animation: fadeInUp 0.6s ease-out 0.05s forwards; opacity: 0;">
          {title}
        </h1>

        <div class="flex items-center gap-4 flex-wrap"
          style="animation: fadeInUp 0.6s ease-out 0.1s forwards; opacity: 0;">
          <!-- Author info -->
          <div class="flex items-center gap-3">
            <img src="/images/Edward_Roske_Headshot.png" alt="Edward Roske" class="post-avatar" />
            <div>
              <a href="/about/" class="post-author">Edward Roske</a>
              <time datetime={date.toISOString()} class="post-meta block">
                {formattedDate}
              </time>
              {showUpdated && (
                <time datetime={updatedDate!.toISOString()} class="post-meta block">
                  Updated {formattedUpdatedDate}
                </time>
              )}
            </div>
          </div>
          {coauthors.length > 0 && coauthors.map(coauthor => (
            <div class="flex items-center gap-3">
              <span class="post-meta">&amp;</span>
              {coauthor.image && (
                <img src={coauthor.image} alt={coauthor.name} class="post-avatar" />
              )}
              <div>
                {coauthor.url ? (
                  <a href={coauthor.url} class="post-author">{coauthor.name}</a>
                ) : (
                  <span class="post-author">{coauthor.name}</span>
                )}
                <span class="post-meta block">Co-author</span>
              </div>
            </div>
          ))}
        </div>
      </header>

      <!-- Divider -->
      <div class="post-rule mb-12"
        style="animation: fadeInUp 0.6s ease-out 0.15s forwards; opacity: 0;"></div>

      <!-- Content -->
      <div class="blog-content"
        style="animation: fadeInUp 0.6s ease-out 0.2s forwards; opacity: 0;">
        <slot />
      </div>

      <!-- Footer -->
      <footer class="post-footer mt-20 pt-8">
        <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
          <a href="/blog/" class="post-backlink">
            <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            All Posts
          </a>
          <p class="post-signature">
            Asking good questions,<br/>Edward
          </p>
        </div>
      </footer>
    </div>
  </article>

</BaseLayout>

<style>
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    @keyframes fadeInUp {
      from { opacity: 1; transform: none; }
      to { opacity: 1; transform: none; }
    }
  }

  /* ---------- page chrome (theme-variable driven) ---------- */
  :global([data-theme="dark"]) .post-bg {
    background: linear-gradient(to bottom, var(--color-bg), var(--color-surface));
  }
  :global([data-theme="light"]) .post-bg {
    background: linear-gradient(to bottom, var(--color-bg-light), var(--color-surface-light));
  }

  .post-backlink {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .post-backlink:hover { color: var(--color-accent-hover); }
  .post-backlink svg {
    width: 0.85em;
    height: 0.85em;
    transition: transform 0.2s ease;
  }
  .post-backlink:hover svg { transform: translateX(-3px); }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.35rem 0.7rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 35%, transparent);
    border-radius: 2px;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .post-tag:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .post-title {
    font-family: var(--font-heading);
    font-size: clamp(2.1rem, 1.4rem + 3.4vw, 3.3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.08;
    text-wrap: balance;
  }
  :global([data-theme="dark"]) .post-title { color: var(--color-text); }
  :global([data-theme="light"]) .post-title { color: var(--color-text-dark); }

  .post-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid color-mix(in srgb, var(--color-accent) 40%, transparent);
  }

  .post-author {
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s ease;
  }
  :global([data-theme="dark"]) .post-author { color: var(--color-text); }
  :global([data-theme="light"]) .post-author { color: var(--color-text-dark); }
  a.post-author:hover { color: var(--color-accent); }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
  }
  :global([data-theme="dark"]) .post-meta { color: var(--color-text-muted); }
  :global([data-theme="light"]) .post-meta { color: var(--color-text-dark-muted); }

  .post-rule {
    width: 4rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-accent) 45%, transparent);
  }

  .post-footer {
    border-top: 1px solid;
  }
  :global([data-theme="dark"]) .post-footer { border-top-color: var(--color-border); }
  :global([data-theme="light"]) .post-footer { border-top-color: var(--color-border-light); }

  .post-signature {
    font-style: italic;
    font-size: 0.9rem;
    line-height: 1.6;
  }
  :global([data-theme="dark"]) .post-signature { color: var(--color-text-muted); }
  :global([data-theme="light"]) .post-signature { color: var(--color-text-dark-muted); }

  /* ---------- article typography ---------- */
  .blog-content {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.75;
    max-width: 70ch;
  }

  /* Paragraphs */
  .blog-content :global(p) {
    margin-bottom: 1.6rem;
    text-wrap: pretty;
    color: var(--color-text-dark-muted);
  }
  :global([data-theme="dark"]) .blog-content :global(p) {
    color: var(--color-text-muted);
  }

  /* Lede: the opening paragraph runs larger and in full ink */
  .blog-content > :global(p:first-of-type) {
    font-size: 1.28rem;
    line-height: 1.65;
    color: var(--color-text-dark);
  }
  :global([data-theme="dark"]) .blog-content > :global(p:first-of-type) {
    color: var(--color-text);
  }

  /* Headings: each h2 opens with a short accent rule, matching the header divider */
  .blog-content :global(h2) {
    font-family: var(--font-heading);
    font-size: clamp(1.55rem, 1.25rem + 1.2vw, 1.9rem);
    font-weight: 700;
    letter-spacing: -0.015em;
    line-height: 1.2;
    text-wrap: balance;
    margin-top: 4rem;
    margin-bottom: 1.1rem;
    scroll-margin-top: 6rem;
    color: var(--color-text-dark);
  }
  .blog-content :global(h2::before) {
    content: '';
    display: block;
    width: 2.5rem;
    height: 1px;
    margin-bottom: 1.2rem;
    background: color-mix(in srgb, var(--color-accent) 55%, transparent);
  }
  :global([data-theme="dark"]) .blog-content :global(h2) {
    color: var(--color-text);
  }
  .blog-content > :global(h2:first-child) {
    margin-top: 0;
  }

  .blog-content :global(h3) {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 1.1rem + 0.6vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.3;
    text-wrap: balance;
    margin-top: 2.75rem;
    margin-bottom: 0.8rem;
    scroll-margin-top: 6rem;
    color: var(--color-text-dark);
  }
  :global([data-theme="dark"]) .blog-content :global(h3) {
    color: var(--color-text);
  }

  /* h4 as a mono eyebrow, for posts that go that deep */
  .blog-content :global(h4) {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-top: 2.25rem;
    margin-bottom: 0.7rem;
    color: var(--color-accent);
  }

  /* Strong text */
  .blog-content :global(strong) {
    color: var(--color-text-dark);
    font-weight: 700;
  }
  :global([data-theme="dark"]) .blog-content :global(strong) {
    color: var(--color-text);
  }

  /* Links: real underlines, offset, quiet until hover */
  .blog-content :global(a) {
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    transition: text-decoration-color 0.2s ease;
  }
  .blog-content :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  /* Lists */
  .blog-content :global(ul),
  .blog-content :global(ol) {
    margin-bottom: 1.6rem;
    padding-left: 1.5rem;
  }
  .blog-content :global(li) {
    margin-bottom: 0.55rem;
    color: var(--color-text-dark-muted);
  }
  :global([data-theme="dark"]) .blog-content :global(li) {
    color: var(--color-text-muted);
  }
  .blog-content :global(ul > li) {
    list-style-type: disc;
  }
  .blog-content :global(ol > li) {
    list-style-type: decimal;
  }
  .blog-content :global(li::marker) {
    color: var(--color-accent);
  }
  .blog-content :global(ol > li::marker) {
    font-family: var(--font-mono);
    font-size: 0.85em;
  }

  /* Blockquotes: hairline pull-quote, full ink, no card background */
  .blog-content :global(blockquote) {
    margin: 2.6rem 0;
    padding: 0.35rem 0 0.35rem 1.6rem;
    border-left: 2px solid var(--color-accent);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.6;
    color: var(--color-text-dark);
  }
  :global([data-theme="dark"]) .blog-content :global(blockquote) {
    color: var(--color-text);
  }
  .blog-content :global(blockquote p) {
    margin-bottom: 1rem;
    color: inherit;
    font-size: inherit;
    line-height: inherit;
  }
  .blog-content :global(blockquote p:last-of-type) {
    margin-bottom: 0;
  }

  /* Code */
  .blog-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    padding: 0.15em 0.4em;
    border-radius: 3px;
    background: color-mix(in srgb, var(--color-text-dark) 7%, transparent);
    color: var(--color-accent);
  }
  :global([data-theme="dark"]) .blog-content :global(code) {
    background: color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .blog-content :global(pre) {
    margin: 2rem 0;
    padding: 1.4rem 1.5rem;
    border-radius: 4px;
    border: 1px solid var(--color-border-light);
    overflow-x: auto;
    font-size: 0.875rem;
    line-height: 1.65;
    background: var(--color-surface-light);
  }
  :global([data-theme="dark"]) .blog-content :global(pre) {
    background: var(--color-surface);
    border-color: var(--color-border);
  }
  .blog-content :global(pre code) {
    padding: 0;
    background: none;
    color: inherit;
    font-size: inherit;
  }

  /* Tables: hairline rows, mono column heads */
  .blog-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2.25rem 0;
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .blog-content :global(th) {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: left;
    padding: 0.6rem 1rem 0.6rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 45%, transparent);
    color: var(--color-text-dark-muted);
  }
  :global([data-theme="dark"]) .blog-content :global(th) {
    color: var(--color-text-muted);
  }
  .blog-content :global(td) {
    padding: 0.7rem 1rem 0.7rem 0;
    vertical-align: top;
    border-bottom: 1px solid var(--color-border-light);
    color: var(--color-text-dark-muted);
  }
  :global([data-theme="dark"]) .blog-content :global(td) {
    border-bottom-color: var(--color-border);
    color: var(--color-text-muted);
  }

  /* Horizontal rule: short accent hairline, same motif as headings */
  .blog-content :global(hr) {
    margin: 3.25rem 0;
    border: none;
    width: 2.5rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-accent) 45%, transparent);
  }

  /* Images */
  .blog-content :global(img) {
    border-radius: 4px;
    margin: 2.25rem 0;
    border: 1px solid var(--color-border-light);
  }
  :global([data-theme="dark"]) .blog-content :global(img) {
    border-color: var(--color-border);
  }

  /* Emphasis / italics */
  .blog-content :global(em) {
    font-style: italic;
  }

  /* Scroll-driven reveal on article images (progressive enhancement) */
  @supports (animation-timeline: view()) {
    @media (prefers-reduced-motion: no-preference) {
      .blog-content :global(img) {
        animation: imgReveal linear both;
        animation-timeline: view();
        animation-range: entry 5% entry 45%;
      }
    }
  }
  @keyframes imgReveal {
    from { opacity: 0.25; transform: translateY(14px); }
    to { opacity: 1; transform: none; }
  }

  /* Claude commentary blocks (Claude's tan is his identity color, deliberately theme-independent) */
  .blog-content :global(.claude-commentary) {
    position: relative;
    margin: 2rem 0;
    padding: 1.25rem 1.5rem 1.25rem 1.5rem;
    border-left: 3px solid #D4A574;
    border-radius: 0 4px 4px 0;
    background: linear-gradient(135deg, rgba(212, 165, 116, 0.06), rgba(196, 149, 106, 0.02));
    font-style: italic;
  }
  :global([data-theme="dark"]) .blog-content :global(.claude-commentary) {
    background: linear-gradient(135deg, rgba(212, 165, 116, 0.1), rgba(196, 149, 106, 0.04));
  }

  .blog-content :global(.claude-commentary-label) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-style: normal;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #D4A574;
    font-family: var(--font-mono);
  }

  .blog-content :global(.claude-commentary-label img) {
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    margin: 0;
    border: none;
    animation: none;
  }

  .blog-content :global(.claude-commentary p) {
    margin-bottom: 0.75rem;
  }
  .blog-content :global(.claude-commentary p:last-of-type) {
    margin-bottom: 0;
  }

  /* Override lede sizing if the first paragraph lands inside claude commentary */
  .blog-content :global(.claude-commentary p:first-of-type) {
    font-size: inherit;
    line-height: inherit;
    color: inherit;
  }
</style>
